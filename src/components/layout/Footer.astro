---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../config/site.config";

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <p>&copy; {year} {siteConfig.name}</p>
    <nav aria-label="Footer navigation">
      <a href="/rss.xml">RSS</a>
      <a href={siteConfig.socialLinks[0]?.url} target="_blank" rel="noreferrer">
        <Icon name="lucide:github" aria-hidden="true" />
        GitHub
      </a>
    </nav>
  </div>
</footer>

<style>
  .footer { margin-top: auto; border-top: 1px solid var(--color-border); }
  .footer__inner { display: flex; align-items: center; justify-content: space-between; gap: var(--space-lg); padding-block: var(--space-lg); color: var(--color-text-secondary); }
  .footer p { margin: 0; }
  .footer nav, .footer a { display: flex; align-items: center; gap: var(--space-sm); }
  .footer a { color: inherit; text-decoration: none; }
  .footer a:hover { color: var(--color-text-primary); }
  @media (max-width: 36rem) { .footer__inner { align-items: flex-start; flex-direction: column; } }
</style>
