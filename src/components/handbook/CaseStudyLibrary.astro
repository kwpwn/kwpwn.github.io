---
import {
  curatedCaseStudies,
  kernelSightCaseStudies,
} from "../../data/windows-security-case-studies";
import Badge from "../ui/data-display/Badge/Badge.astro";
import Card from "../ui/data-display/Card/Card.astro";
import Icon from "../ui/primitives/Icon/Icon.astro";

const years = Array.from(
  new Set(kernelSightCaseStudies.map((item) => item.year).filter(Boolean)),
).sort((left, right) => Number(right) - Number(left));
---

<div class="case-library" data-case-library>
  <nav class="case-library__breadcrumb" aria-label="Breadcrumb">
    <a href="/">Blogs</a>
    <span aria-hidden="true">/</span>
    <a href="/windows-security-concepts/">Windows Security Handbook</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">Case studies</span>
  </nav>

  <header class="case-library__hero">
    <div>
      <Badge variant="outline" size="sm">Coverage + curated reading</Badge>
      <p class="case-library__eyebrow">Case-study library</p>
      <h1>Study the conversion, not only the CVE.</h1>
      <p>
        Start with a small set of case studies that make every chain step
        explicit, then use the complete KernelSight coverage ledger to find
        driver-, subsystem-, and year-specific examples.
      </p>
    </div>
    <aside>
      <strong>{kernelSightCaseStudies.length}</strong>
      <span>KernelSight case-study links preserved</span>
      <p>
        Titles and links are indexed here; explanatory theory lives in this
        handbook, while the original case-study content remains with its
        authors.
      </p>
    </aside>
  </header>

  <section class="case-library__curated" aria-labelledby="curated-heading">
    <header class="case-library__section-head">
      <div>
        <p class="case-library__eyebrow">Read these first</p>
        <h2 id="curated-heading">Six reusable chains</h2>
      </div>
      <p>
        These are selected for clear primitives, reproducible reasoning, and
        useful conversion steps—not merely because the final impact is dramatic.
      </p>
    </header>
    <div class="case-library__curated-grid">
      {
        curatedCaseStudies.map((item) => (
          <Card hover class="curated-case">
            <p>{item.source}</p>
            <h3>{item.title}</h3>
            <code>{item.chain}</code>
            <p>{item.reason}</p>
            <a href={item.href} target="_blank" rel="noreferrer">
              Read original <Icon name="lucide:arrow-up-right" size={17} />
            </a>
          </Card>
        ))
      }
    </div>
  </section>

  <section class="case-library__ledger" aria-labelledby="ledger-heading">
    <header class="case-library__section-head">
      <div>
        <p class="case-library__eyebrow">Upstream coverage ledger</p>
        <h2 id="ledger-heading">Every KernelSight case study</h2>
      </div>
      <p>
        Filter the index without loading a wall of articles. Each result opens
        the original KernelSight page in a new tab.
      </p>
    </header>

    <div class="case-toolbar">
      <label for="case-query">Search CVE, driver, subsystem, or year</label>
      <div>
        <Icon name="lucide:search" size={18} />
        <input
          id="case-query"
          type="search"
          placeholder="Try CVE-2024, CLFS, Capcom…"
          autocomplete="off"
          data-case-query
        />
      </div>
      <select aria-label="Filter by case-study type" data-case-kind>
        <option value="all">All types</option>
        <option value="CVE">CVE</option>
        <option value="Driver">Driver</option>
        <option value="Subsystem">Subsystem</option>
      </select>
      <select aria-label="Filter by publication year" data-case-year>
        <option value="all">All years</option>
        {years.map((year) => <option value={String(year)}>{year}</option>)}
        <option value="undated">No CVE year</option>
      </select>
      <p aria-live="polite" data-case-count>
        {kernelSightCaseStudies.length} references
      </p>
    </div>

    <ul class="case-library__results">
      {
        kernelSightCaseStudies.map((item) => (
          <li
            data-case-item
            data-kind={item.kind}
            data-year={item.year ? String(item.year) : "undated"}
            data-search-text={`${item.title} ${item.slug} ${item.kind} ${item.year ?? ""}`.toLocaleLowerCase()}
          >
            <a href={item.href} target="_blank" rel="noreferrer">
              <span>
                <small>
                  {item.kind} · {item.year ?? "Reference"}
                </small>
                <strong>{item.title}</strong>
              </span>
              <Icon name="lucide:arrow-up-right" size={17} />
            </a>
          </li>
        ))
      }
    </ul>

    <div class="case-library__empty" data-case-empty hidden>
      <Icon name="lucide:search-x" size={24} />
      <p>No case study matches the current filters.</p>
    </div>
  </section>
</div>

<script>
  const root = document.querySelector<HTMLElement>("[data-case-library]");
  const input = root?.querySelector<HTMLInputElement>("[data-case-query]");
  const kind = root?.querySelector<HTMLSelectElement>("[data-case-kind]");
  const year = root?.querySelector<HTMLSelectElement>("[data-case-year]");
  const count = root?.querySelector<HTMLElement>("[data-case-count]");
  const empty = root?.querySelector<HTMLElement>("[data-case-empty]");
  const items = Array.from(
    root?.querySelectorAll<HTMLElement>("[data-case-item]") ?? [],
  );

  const filter = () => {
    const query = input?.value.trim().toLocaleLowerCase() ?? "";
    const selectedKind = kind?.value ?? "all";
    const selectedYear = year?.value ?? "all";
    let visible = 0;
    items.forEach((item) => {
      const matches =
        (!query || (item.dataset.searchText?.includes(query) ?? false)) &&
        (selectedKind === "all" || item.dataset.kind === selectedKind) &&
        (selectedYear === "all" || item.dataset.year === selectedYear);
      item.hidden = !matches;
      if (matches) visible += 1;
    });
    if (count)
      count.textContent =
        visible === 1 ? "1 reference" : `${visible} references`;
    if (empty) empty.hidden = visible !== 0;
  };

  input?.addEventListener("input", filter);
  kind?.addEventListener("change", filter);
  year?.addEventListener("change", filter);
</script>

<style>
  .case-library {
    display: grid;
    gap: var(--space-3xl);
  }

  .case-library a {
    text-underline-offset: var(--spacing-1);
  }

  .case-library a:focus-visible,
  .case-library input:focus-visible,
  .case-library select:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .case-library__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .case-library__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.65fr);
    gap: var(--space-2xl);
    align-items: end;
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
  }

  .case-library__hero > div {
    display: grid;
    justify-items: start;
    gap: var(--space-md);
  }

  .case-library__eyebrow,
  .curated-case > p:first-child,
  .case-library__results small {
    margin: 0;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .case-library__hero h1,
  .case-library__hero > div > p:last-child {
    margin: 0;
  }

  .case-library__hero h1 {
    max-width: var(--container-wide);
    font-size: var(--text-5xl);
    letter-spacing: var(--tracking-tight);
  }

  .case-library__hero > div > p:last-child {
    max-width: var(--container-wide);
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .case-library__hero aside {
    display: grid;
    gap: var(--space-xs);
    padding: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-secondary);
  }

  .case-library__hero aside strong {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
  }

  .case-library__hero aside span {
    font-weight: var(--font-weight-semibold);
  }

  .case-library__hero aside p {
    margin: var(--space-md) 0 0;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .case-library__curated,
  .case-library__ledger {
    display: grid;
    gap: var(--space-xl);
  }

  .case-library__section-head {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-xl);
    align-items: end;
  }

  .case-library__section-head h2,
  .case-library__section-head > p {
    margin: 0;
  }

  .case-library__section-head h2 {
    margin-top: var(--space-xs);
  }

  .case-library__section-head > p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .case-library__curated-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .curated-case :global(.ui-card__body) {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    height: 100%;
  }

  .curated-case h3,
  .curated-case p {
    margin: 0;
  }

  .curated-case code {
    padding: var(--space-sm);
    border-radius: var(--radius-md);
    background: var(--color-bg-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .curated-case > p:not(:first-child) {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .curated-case > a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: auto;
    font-weight: var(--font-weight-semibold);
  }

  .case-toolbar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto auto;
    gap: var(--space-sm);
    align-items: center;
  }

  .case-toolbar > label {
    grid-column: 1 / -1;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
  }

  .case-toolbar > div {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-inline: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
  }

  .case-toolbar input,
  .case-toolbar select {
    min-height: var(--space-2xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
    color: var(--color-text-primary);
    font: inherit;
  }

  .case-toolbar input {
    width: 100%;
    border: 0;
    background: transparent;
  }

  .case-toolbar input:focus {
    outline: 0;
  }

  .case-toolbar select {
    padding-inline: var(--space-sm);
  }

  .case-toolbar > p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .case-library__results {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .case-library__results li[hidden] {
    display: none;
  }

  .case-library__results a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    min-height: 100%;
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
    text-decoration: none;
  }

  .case-library__results a:hover {
    background: var(--color-bg-secondary);
  }

  .case-library__results a > span {
    display: grid;
    gap: var(--space-xs);
    min-width: 0;
  }

  .case-library__results strong {
    overflow-wrap: anywhere;
  }

  .case-library__empty {
    justify-items: center;
    gap: var(--space-sm);
    padding: var(--space-2xl);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-xl);
    text-align: center;
  }

  .case-library__empty:not([hidden]) {
    display: grid;
  }

  .case-library__empty p {
    margin: 0;
    color: var(--color-text-secondary);
  }

  @media (max-width: 64rem) {
    .case-library__hero,
    .case-library__section-head {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .case-library__curated-grid,
    .case-library__results {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .case-toolbar {
      grid-template-columns: 1fr 1fr;
    }

    .case-toolbar > div {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 40rem) {
    .case-library__curated-grid,
    .case-library__results,
    .case-toolbar {
      grid-template-columns: 1fr;
    }

    .case-toolbar > div {
      grid-column: 1;
    }
  }
</style>
