---

<div class="research-index" data-research-index>
  <div class="research-index__search">
    <label for="research-search">Search the index</label>
    <input
      id="research-search"
      type="search"
      placeholder="Try: KASLR, service ACL, prefetch, driver, Yarden..."
      autocomplete="off"
      data-research-search
    />
    <p data-research-status aria-live="polite">
      {researchers.length} researchers, {resources.length} resources, and {references.length} references
    </p>
  </div>

  <section aria-labelledby="researchers-heading">
    <div class="research-index__heading">
      <div>
        <p class="research-index__kicker">People to follow</p>
        <h2 id="researchers-heading">Researchers &amp; blogs</h2>
      </div>
      <span>{researchers.length} entries</span>
    </div>
    <div class="research-index__table-wrap">
      <table>
        <thead><tr><th>Researcher</th><th>Blog</th><th>Primary focus</th></tr></thead>
        <tbody data-researcher-body>
          {researchers.map((item) => (
            <tr data-index-row data-searchable={`${item.name} ${item.site} ${item.focus}`}>
              <td><a href={item.profile} target="_blank" rel="noreferrer">{item.name}</a></td>
              <td><a href={item.url} target="_blank" rel="noreferrer">{item.site}</a></td>
              <td>{item.focus}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="research-index__none" data-researcher-empty hidden>No matching researchers.</p>
  </section>

  <section aria-labelledby="resources-heading">
    <div class="research-index__heading">
      <div>
        <p class="research-index__kicker">Reading queue</p>
        <h2 id="resources-heading">Techniques, evasion &amp; references</h2>
      </div>
      <span>{resources.length} entries</span>
    </div>
    <div class="research-index__table-wrap">
      <table>
        <thead><tr><th>Resource</th><th>Type</th><th>Why it matters</th></tr></thead>
        <tbody data-resource-body>
          {resources.map((item) => (
            <tr data-index-row data-searchable={`${item.title} ${item.source} ${item.category} ${item.tags} ${item.note}`}>
              <td>
                <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
                <small>{item.source}</small>
              </td>
              <td><span class="research-index__badge">{item.category}</span></td>
              <td>{item.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="research-index__none" data-resource-empty hidden>No matching resources.</p>
  </section>

  <section aria-labelledby="references-heading">
    <div class="research-index__heading">
      <div>
        <p class="research-index__kicker">Keep open while researching</p>
        <h2 id="references-heading">Technical references</h2>
      </div>
      <span>{references.length} entries</span>
    </div>
    <div class="research-index__table-wrap">
      <table>
        <thead><tr><th>Reference</th><th>Area</th><th>How to use it</th></tr></thead>
        <tbody data-reference-body>
          {references.map((item) => (
            <tr data-index-row data-searchable={`${item.title} ${item.source} ${item.category} ${item.tags} ${item.note}`}>
              <td>
                <a href={item.url} target="_blank" rel="noreferrer">{item.title}</a>
                <small>{item.source}</small>
              </td>
              <td><span class="research-index__badge">{item.category}</span></td>
              <td>{item.note}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="research-index__none" data-reference-empty hidden>No matching references.</p>
  </section>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-research-index]").forEach((root) => {
    const input = root.querySelector<HTMLInputElement>("[data-research-search]");
    const status = root.querySelector<HTMLElement>("[data-research-status]");
    const researcherRows = [...root.querySelectorAll<HTMLElement>("[data-researcher-body] [data-index-row]")];
    const resourceRows = [...root.querySelectorAll<HTMLElement>("[data-resource-body] [data-index-row]")];
    const referenceRows = [...root.querySelectorAll<HTMLElement>("[data-reference-body] [data-index-row]")];
    const researcherEmpty = root.querySelector<HTMLElement>("[data-researcher-empty]");
    const resourceEmpty = root.querySelector<HTMLElement>("[data-resource-empty]");
    const referenceEmpty = root.querySelector<HTMLElement>("[data-reference-empty]");

    const filterRows = (rows: HTMLElement[], query: string) => {
      let visible = 0;
      rows.forEach((row) => {
        const matches = (row.dataset.searchable ?? "").toLowerCase().includes(query);
        row.hidden = !matches;
        if (matches) visible += 1;
      });
      return visible;
    };

    input?.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      const researcherCount = filterRows(researcherRows, query);
      const resourceCount = filterRows(resourceRows, query);
      const referenceCount = filterRows(referenceRows, query);
      if (researcherEmpty) researcherEmpty.hidden = researcherCount !== 0;
      if (resourceEmpty) resourceEmpty.hidden = resourceCount !== 0;
      if (referenceEmpty) referenceEmpty.hidden = referenceCount !== 0;
      if (status) status.textContent = `${researcherCount} researchers, ${resourceCount} resources, and ${referenceCount} references`;
    });
  });
</script>

<style>
  .research-index { display: grid; gap: var(--space-2xl); margin-top: var(--space-xl); }
  .research-index__search { position: sticky; top: 4.75rem; z-index: 5; display: grid; grid-template-columns: auto minmax(16rem, 1fr) auto; align-items: center; gap: var(--space-md); padding: var(--space-md); border: 1px solid var(--color-border); border-radius: var(--radius-xl); background: color-mix(in srgb, var(--color-bg-primary) 94%, transparent); box-shadow: var(--shadow-md); backdrop-filter: blur(12px); }
  .research-index__search label { font-weight: 700; }
  .research-index__search input { width: 100%; min-height: 2.75rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); background: var(--color-bg-primary); color: var(--color-text-primary); padding: 0.65rem 0.85rem; font: inherit; }
  .research-index__search p { margin: 0; color: var(--color-text-secondary); font-size: 0.8125rem; white-space: nowrap; }
  .research-index section { display: grid; gap: var(--space-md); }
  .research-index__heading { display: flex; align-items: end; justify-content: space-between; gap: var(--space-md); }
  .research-index__heading h2, .research-index__kicker { margin: 0; }
  .research-index__kicker { color: var(--color-text-secondary); font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; }
  .research-index__heading > span { color: var(--color-text-secondary); font-size: 0.8125rem; }
  .research-index__table-wrap { overflow-x: auto; border: 1px solid var(--color-border); border-radius: var(--radius-xl); }
  .research-index table { width: 100%; min-width: 52rem; border-collapse: collapse; font-size: 0.9rem; }
  .research-index th, .research-index td { padding: 0.9rem 1rem; border-bottom: 1px solid var(--color-border); text-align: left; vertical-align: top; }
  .research-index th { background: var(--color-bg-secondary); color: var(--color-text-secondary); font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; }
  .research-index tbody tr:last-child td { border-bottom: 0; }
  .research-index tbody tr:hover { background: var(--color-bg-secondary); }
  .research-index td:first-child { width: 28%; font-weight: 650; }
  .research-index td:nth-child(2) { width: 16%; }
  .research-index a { color: var(--color-text-primary); text-underline-offset: 0.2rem; }
  .research-index small { display: block; margin-top: 0.25rem; color: var(--color-text-secondary); font-weight: 400; }
  .research-index__badge { display: inline-flex; border: 1px solid var(--color-border); border-radius: var(--radius-full); background: var(--color-bg-secondary); padding: 0.2rem 0.55rem; font-size: 0.72rem; font-weight: 650; white-space: nowrap; }
  .research-index__none { margin: 0; padding: var(--space-lg); border: 1px dashed var(--color-border); border-radius: var(--radius-lg); color: var(--color-text-secondary); text-align: center; }
  [data-index-row][hidden] { display: none; }
  @media (max-width: 48rem) { .research-index__search { position: static; grid-template-columns: 1fr; } .research-index__search p { white-space: normal; } }
</style>
