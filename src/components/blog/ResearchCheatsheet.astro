const groups = [
  { id: "pwn", kicker: "Build the primitive", title: "Exploit Development & Pwn", items: [
    ["Windows Exploitation Tricks: Abusing the User-Mode Debugger", "https://projectzero.google/2019/04/windows-exploitation-tricks-abusing.html", "James Forshaw / Project Zero", "2019", 5, "Windows user mode debugger handle access upgrade kernel exploitation primitive", "Shows that attaching through the native debugger path with only process suspend/resume rights can yield full-access process and thread handles in debug events, then develops a second primitive for reclaiming dangling kernel handles. It is a model exploitation-tricks article because it turns subtle access-mode mismatches into reusable building blocks without mislabeling them as standalone vulnerabilities."],
    ["Trapping Virtual Memory Access on Windows 11 24H2", "https://projectzero.google/2025/01/windows-exploitation-tricks-trapping.html", "James Forshaw / Project Zero", "2025", 5, "Windows 11 24H2 TOCTOU virtual memory trap SMB custom port", "Updates the virtual-memory trapping technique for Windows 11 24H2 by using the SMB client's configurable destination port to host a delaying server locally. The change removes the earlier remote-host dependency and creates a practical primitive for widening TOCTOU races and testing false-file-immutability assumptions on current systems."],
    ["NetMan DLL Hijacking: Administrator to SYSTEM", "https://itm4n.github.io/windows-server-netman-dll-hijacking/", "itm4n", "2020", 5, "Network Connections NetMan service DLL hijacking SYSTEM Windows Server", "Investigates the Network Connections service on Windows Server and turns its privileged DLL-loading behavior into an Administrator-to-SYSTEM escalation. The writeup is particularly useful for its careful treatment of service activation, module resolution, writable locations, and the operational conditions required to make a DLL-hijacking observation exploitable."],
    ["Windows DLL Hijacking Clarified", "https://itm4n.github.io/windows-dll-hijacking-clarified/", "itm4n", "2020", 5, "Windows DLL hijacking search order phantom DLL proxying methodology", "Separates several techniques that are often collapsed under the DLL-hijacking label, including search-order abuse, phantom DLLs, replacement, and proxying. It supplies a precise vocabulary and a repeatable validation workflow, helping researchers distinguish a Process Monitor lead from a privilege boundary that can actually be crossed."],
    ["Chimichurri Reloaded", "https://itm4n.github.io/chimichurri-reloaded/", "itm4n", "2020", 5, "Chimichurri Task Scheduler token impersonation Windows privilege escalation", "Revisits the classic Chimichurri technique on modern Windows and reconstructs the underlying Task Scheduler and token behavior instead of merely updating an old exploit. The analysis shows which assumptions survived, which platform changes broke the original chain, and how a historical service-abuse primitive can be methodically re-evaluated."],
    ["Windows Privilege Escalation with DLL Proxying", "https://itm4n.github.io/dll-proxying/", "itm4n", "2019", 5, "DLL proxying hijacking exports Windows privilege escalation", "Explains how to preserve a legitimate DLL's exported behavior while interposing malicious initialization code, including export forwarding, dependency analysis, proxy construction, and deployment constraints. The technique is developed as a reliable Windows privilege-escalation building block rather than confused with ordinary missing-DLL search-order hijacking."],
    ["Weaponizing Privileged File Writes with USO, Part 1", "https://itm4n.github.io/usodllloader-part1/", "itm4n", "2019", 5, "Update Session Orchestrator USO privileged file write DLL LPE", "Investigates the Update Session Orchestrator as a way to convert a privileged arbitrary file write into code execution, mapping the service, filesystem targets, and DLL-loading opportunity. The post carefully develops prerequisites and constraints before the follow-up turns the primitive into a working loader."],
    ["Weaponizing Privileged File Writes with USO, Part 2", "https://itm4n.github.io/usodllloader-part2/", "itm4n", "2019", 5, "UsoDllLoader Windows Update service DLL hijack SYSTEM exploit", "Completes the USO research with the practical exploit chain and UsoDllLoader implementation, showing how to place the payload, trigger the privileged service, and obtain SYSTEM while respecting update-service behavior. Reading both parts provides a reusable method for evaluating other privileged file-write bugs."],
    ["Recovering LOCAL SERVICE Privileges", "https://itm4n.github.io/localservice-privileges/", "itm4n", "2019", 5, "LOCAL SERVICE token privileges SeImpersonate Windows service LPE", "Examines why expected token privileges may be absent from a LOCAL SERVICE process and how Windows service configuration and token construction affect them. The investigation matters for exploit chains that depend on impersonation privileges and demonstrates how to verify the effective token instead of trusting the account name."],
    ["CDPSvc DLL Hijacking: LOCAL SERVICE to SYSTEM", "https://itm4n.github.io/cdpsvc-dll-hijacking/", "itm4n", "2019", 5, "CDPSvc DLL hijacking LOCAL SERVICE SYSTEM privilege escalation", "Builds a service-to-SYSTEM escalation through Connected Devices Platform Service DLL loading, combining service context, writable locations, module resolution, and trigger behavior. The article records the complete chain and the boundary crossed, making it more instructive than a generic DLL-hijacking checklist."],
    ["PrintSpoofer", "https://itm4n.github.io/printspoofer-abusing-impersonate-privileges/", "itm4n", "2020", 5, "PrintSpoofer SeImpersonate named pipe spooler token SYSTEM", "Develops the PrintSpoofer technique from named-pipe impersonation and Print Spooler coercion through token duplication and SYSTEM process creation on modern Windows 10 and Server. It explains why older Potato approaches fail in some environments and provides implementation-level detail for the replacement primitive."],
    ["Windows .NET Core SDK Elevation of Privilege", "https://itm4n.github.io/dotnet-sdk-eop/", "itm4n", "2020", 5, ".NET Core SDK Windows service writable path DLL hijack EoP", "Analyzes a local elevation path introduced by the Windows .NET Core SDK installation and develops it from filesystem and service behavior to privileged code execution. The writeup is useful for learning how developer tooling changes system attack surface and how to validate an apparent writable-path finding operationally."],
    ["An Unconventional RpcEptMapper Exploit", "https://itm4n.github.io/windows-registry-rpceptmapper-exploit/", "itm4n", "2021", 5, "RpcEptMapper registry service DLL load Windows SYSTEM exploit", "Turns insecure RpcEptMapper registry permissions into execution using an unconventional service and registry path after obvious approaches prove unreliable. The article documents failed ideas, service hosting constraints, and the final trigger, offering a strong example of refining a configuration primitive into a dependable exploit."],
    ["MareBackup Scheduled Task Privilege Escalation", "https://itm4n.github.io/hijacking-the-windows-marebackup-scheduled-task-for-privilege-escalation/", "itm4n", "2025", 5, "MareBackup scheduled task DLL hijack SYSTEM Windows LPE", "Reverse engineers the built-in MareBackup scheduled task and its execution environment to identify a hijack path that elevates a local user. The analysis covers task definition, trigger conditions, privileged process behavior, load resolution, and practical exploitation, making it a current service-and-task escalation case study."],
    ["Arbitrary Object Directory Creation to LPE", "https://googleprojectzero.blogspot.com/2018/08/windows-exploitation-tricks-exploiting.html", "James Forshaw / Project Zero", "2018", 5, "object manager directory creation CSRSS AppContainer LPE Windows", "Turns an arbitrary object-manager directory creation bug into local privilege escalation by combining CSRSS behavior, namespace shadowing, symbolic links, and AppContainer-specific directories. The article is exemplary non-memory-corruption exploitation: each object and access check is developed explicitly until a constrained namespace primitive crosses a privilege boundary."],
    ["Symbolic Hooks Part 2: Getting the Target Name", "https://windows-internals.com/symhooks-part-two/", "Alex Ionescu", "2020", 5, "object manager symbolic link hook target name Windows exploitation", "Continues the Symbolic Hooks research by recovering the target of object-manager symbolic links and working through the internal name-resolution machinery required for a reliable hook. The series is valuable exploit-development material because it builds a primitive from namespace semantics and kernel objects rather than relying on code patching."],
    ["Symbolic Hooks Part 3: The Remainder Theorem", "https://windows-internals.com/symhooks-part-three/", "Alex Ionescu", "2020", 5, "symbolic hooks object manager parse procedure kernel redirection", "Develops the symbolic-link interception mechanism further by addressing unresolved parsing and redirection cases inside the object manager. It documents the constraints that emerge when a proof of concept meets real namespace behavior, making this installment essential for understanding the technique as a robust primitive rather than a novelty."],
    ["Symbolic Hooks Part 4: The App Container Traverse-ty", "https://windows-internals.com/symhooks-part-four/", "Alex Ionescu", "2020", 5, "symbolic hooks AppContainer object manager path traversal sandbox", "Applies the symbolic-hook model to AppContainer namespace traversal and shows how sandbox-specific path handling changes the reachable objects and redirection behavior. The article connects a low-level object-manager technique to an actual security boundary, while carefully examining the access checks and namespace layout that determine exploitability."],
    ["Exploiting a Simple Vulnerability in 35 Steps", "https://windows-internals.com/exploiting-a-simple-vulnerability-in-35-easy-steps-or-less/", "Yarden Shafir", "2020", 5, "Windows kernel exploitation arbitrary increment token privileges PreviousMode", "Begins with an intentionally modest kernel corruption primitive and develops it through the many constraints that real exploitation imposes, including address discovery, object selection, and privilege manipulation. The article is valuable precisely because it refuses to collapse the chain into token stealing and instead records the engineering decisions between trigger and reliable elevation."],
    ["Exploiting a Simple Vulnerability, Part 1.5: The Info Leak", "https://windows-internals.com/exploiting-a-simple-vulnerability-part-1-5-the-info-leak/", "Yarden Shafir", "2021", 5, "Windows kernel exploitation information leak KASLR object addresses", "Extends the simple-vulnerability series by constructing the information disclosure needed to make the later exploit deterministic. It separates the leak from the corruption primitive and demonstrates why modern kernel exploitation should account explicitly for object addresses and KASLR instead of assuming a convenient legacy disclosure API."],
    ["Exploiting a Simple Vulnerability, Part 2", "https://windows-internals.com/exploiting-a-simple-vulnerability-part-2-what-if-we-made-exploitation-harder/", "Yarden Shafir", "2021", 5, "Windows kernel exploitation mitigation bypass constrained primitive", "Revisits the same laboratory after deliberately removing convenient assumptions and adding exploitation constraints. Comparing the revised chain with the earlier solution shows how a primitive must be redesigned around mitigations, build behavior, and side effects, making the series useful practice for adapting rather than memorizing a single exploit."],
    ["One I/O Ring to Rule Them All", "https://windows-internals.com/one-i-o-ring-to-rule-them-all-a-full-read-write-exploit-primitive-on-windows-11/", "Yarden Shafir", "2022", 5, "Windows 11 I/O rings kernel arbitrary read write primitive", "Shows how corruption of I/O ring bookkeeping can transform a limited kernel write into a full kernel read/write primitive using legitimate asynchronous I/O machinery. The post documents the relevant user and kernel objects, registered-buffer path, and operational sequence in enough detail to understand both the exploit technique and its patch surface."],
    ["Windows Exploitation Tricks: Arbitrary File Writes", "https://googleprojectzero.blogspot.com/2018/04/windows-exploitation-tricks-exploiting.html", "James Forshaw / Project Zero", "2018", 5, "Windows LPE arbitrary file write oplock mount point hard link", "A foundational treatment of turning a constrained file-write vulnerability into local privilege escalation on modern Windows after earlier mount-point techniques were hardened. It carefully develops the object-manager and filesystem primitives, the race window, and the security boundary being crossed, so it remains a model for reasoning about non-memory-corruption exploits."],
    ["Windows Drivers Reverse Engineering Methodology", "https://voidsec.com/windows-drivers-reverse-engineering-methodology/", "VoidSec", "2022", 5, "WDM driver reversing IOCTL MSR MmMapIoSpace methodology", "A repeatable end-to-end methodology for lab setup, driver entry-point recovery, dispatch and IOCTL mapping, dangerous primitive discovery, and exploitability analysis. It includes a deliberately constrained target and exercises that force the reader to validate data flow rather than pattern-match vulnerable APIs."],
    ["Exploiting the System Mechanic driver", "https://voidsec.com/exploiting-system-mechanic-driver/", "VoidSec", "2021", 5, "driver reversing fuzzing token privileges LPE CTF", "Turns an initially unknown commercial driver into a complete exploitation exercise: interface recovery, fuzzing, root-cause analysis, primitive constraints, and SYSTEM escalation. It is especially valuable as a CTF-style Windows pwn writeup against a realistic third-party target."],
    ["CVE-2026-40369: Twelve Bytes to Escape the Browser Sandbox", "https://voidsec.com/cve-2026-40369-browser-sandbox-escape/", "VoidSec", "2026", 5, "Windows kernel arbitrary write sandbox escape NtCreateToken KASLR", "Develops a twelve-byte kernel write reachable from a browser renderer into SYSTEM without relying on classical token stealing. The chain disables the kernel-address-leak gate, locates the token, acquires token-creation privileges, and forges a SYSTEM primary token with unusually clear primitive accounting."],
    ["Crucial MOD Utility LPE (CVE-2021-41285)", "https://voidsec.com/crucial-mod-utility-lpe-cve-2021-41285/", "VoidSec", "2021", 5, "WinRing0 physical memory mapping driver LPE CVE-2021-41285", "Shows how a vendor utility inherited WinRing0's dangerous MSR and physical-memory functionality verbatim. The article combines binary comparison, IOCTL recovery, physical mapping, page-table reasoning, and a published exploit, making it a model driver-reuse case study."],
    ["Swimming in the (Kernel) Pool, Part 1", "https://connormcgarr.github.io/swimming-in-the-kernel-pool-part-1/", "Connor McGarr", "2021", 5, "HEVD pool exploitation, kLFH behavior, and low-integrity pool attacks", "Builds a Windows kernel pool exploit from allocator behavior upward, including an out-of-bounds read used for KASLR defeat. The careful treatment of kLFH makes it a strong foundation for understanding why heap shaping works rather than merely copying a spray."],
    ["ROP Gadget Hunting on Windows", "https://core-jmp.org/2026/06/rop-scanner-windows-rop-gadget-hunting-exploit-chain/", "core-jmp", "2026", 5, "ROP JOP gadgets CFG DEP VirtualProtect stack pivot", "Walks from instruction-pointer control to a bad-byte-clean VirtualProtect chain using ROP, JOP, syscall, and stack-pivot gadgets. It also considers CFG-aware gadget selection, making the article useful for designing a repeatable modern gadget-hunting workflow."],
    ["Exploiting the NT Kernel in 24H2", "https://exploits.forsale/24h2-nt-exploit/", "exploits.forsale", "2024", 5, "Windows 11 24H2 double fetch KASLR prefetch", "Covers bug discovery and exploit development against Windows 11 24H2, including double-fetch flaws introduced by user-memory handling changes. Its KASLR section connects prefetch timing with the reliability differences seen across Intel, AMD, native, and virtualized targets."],
    ["Physical-memory KASLR bypass on Windows 11 24H2", "https://xacone.github.io/kaslr_leak_24h2.html", "xacone", "2024", 5, "physical memory CR3 page tables HVCI KASLR", "Turns driver-assisted physical-memory access into a kernel-base disclosure after legacy pointer leaks were restricted. The post is an excellent practical reference for CR3 discovery, page-table traversal, and physical-to-virtual translation under HVCI."],
    ["From arbitrary pointer dereference to kernel R/W", "https://hnsecurity.it/blog/from-arbitrary-pointer-dereference-to-arbitrary-read-write-in-latest-windows-11/", "Hacking Notes", "2024", 5, "Windows 11 arbitrary pointer dereference SMEP kernel read write", "Develops a constrained arbitrary-pointer dereference into an arbitrary kernel read/write capability on a current Windows 11 target. The value lies in the intermediate reasoning: primitive refinement, SMEP constraints, and the choices needed to reach reliable privilege escalation."],
    ["Non-Paged Pool Overflow Exploitation", "https://github.com/vp777/Windows-Non-Paged-Pool-Overflow-Exploitation", "vp777", "2021", 4, "CVE-2020-17087 pool overflow off by one named pipe", "A hands-on collection for exploiting named-pipe non-paged-pool corruption, including CVE-2020-17087 and an off-by-one variant. It is useful for comparing allocator manipulation and exploitation techniques across older and newer Windows releases."],
    ["Shadow SSDT hijacking via R/W primitives", "https://www.exploitpack.com/blogs/news/shadow-ssdt-hijacking-to-achieve-kernel-code-execution-via-rw-primitives", "Exploit Pack", "2026", 4, "Shadow SSDT VBS HVCI kCET kernel execution", "Explores converting kernel read/write into code execution by targeting the Shadow SSDT while VBS, HVCI, and kernel CET are active. Treat it as a specialized chain-design study and validate assumptions against the exact Windows build you target."],
    ["HEVD SMEP bypass", "https://fluidattacks.com/blog/hevd-smep-bypass", "Fluid Attacks", "2020", 4, "HEVD SMEP bypass ROP kernel exploitation", "Introduces SMEP's effect on classic kernel shellcode execution and adapts an HEVD exploit to bypass it. The tutorial is especially useful as a bridge from older token-stealing exercises to ROP-based kernel exploitation."],
    ["Windows Exploitation Tricks: Trapping Virtual Memory Access", "https://projectzero.google/2021/01/windows-exploitation-tricks-trapping.html", "James Forshaw / Project Zero", "2021", 5, "Windows kernel TOCTOU double fetch memory trap SMB Cloud Filter", "Develops a reusable way to stall a kernel read or write of attacker-controlled virtual memory, giving exploit code both a timing signal and an arbitrarily widened race window. The research compares remote SMB-backed mappings with Cloud Filter placeholders, works through ProbeForWrite behavior, and states which double-fetch and false-immutability patterns can consume the primitive."],
    ["Exploiting Arbitrary File Writes for Local Elevation", "https://projectzero.google/2018/04/windows-exploitation-tricks-exploiting.html", "James Forshaw / Project Zero", "2018", 5, "Windows arbitrary file write LPE oplock mount point LPAC exploit primitive", "Turns a constrained privileged file-write vulnerability into local elevation on Windows 10 by combining filesystem redirection, opportunistic locks, object-manager links, and a privileged execution sink. The article is especially valuable because it explains the post-RS4 constraints and demonstrates that the chain can begin inside an Edge Low Privilege AppContainer."],
    ["Windows Exploitation Techniques: Winning Path-Lookup Races", "https://projectzero.google/2025/12/windows-exploitation-techniques.html", "James Forshaw / Project Zero", "2025", 5, "Windows path lookup race condition oplock object manager TOCTOU", "Revisits a practical technique for winning extremely narrow named-resource lookup races and retests the original PoC||GTFO method on modern Windows 11. It breaks the check-use sequence into observable filesystem and namespace operations, explains how to hold intermediate lookups, and distinguishes deterministic synchronization from blind retry loops."],
    ["Trying to Exploit a Windows Kernel Arbitrary Read", "https://starlabs.sg/blog/2022/06-trying-to-exploit-a-windows-kernel-arbitrary-read-vulnerability/", "Phan Thanh Duy / STAR Labs", "2022", 5, "Windows kernel arbitrary read registry process SAM bounce buffer race", "Explores the real limitations of a kernel arbitrary-read bug instead of assuming it immediately yields SYSTEM. After prototype-PTE and Registry-process address-space dead ends, the article derives a race against CmpBounceBufferLookaside while LSASS reads SAM data, providing a rare study of converting a narrow read into sensitive cross-context disclosure."],
    ["CVE-2023-21674: Windows Kernel ALPC UAF", "https://theori.io/blog/chaining-n-days-to-compromise-all-part-2-windows-kernel-lpe-a-k-a-chrome-sandbox-escape", "Frontier Squad / Theori", "2024", 5, "CVE-2023-21674 ALPC use after free Chrome sandbox escape worker factory", "Reconstructs an in-the-wild ALPC use-after-free reached through deferred worker-factory work, where a synchronous request leaves a dangling WaitingThread pointer after thread termination. Patch diffing, message lifecycle analysis, trigger construction, pool reclamation, and privilege escalation show how the Windows kernel stage escaped a compromised Chrome renderer."],
    ["CVE-2023-29360: Windows Driver LPE", "https://theori.io/blog/chaining-n-days-to-compromise-all-part-3-windows-driver-lpe-medium-to-system", "Frontier Squad / Theori", "2024", 5, "CVE-2023-29360 mskssrv MDL MmProbeAndLockPages KernelMode arbitrary kernel mapping", "Analyzes the Pwn2Own mskssrv logic flaw in which attacker-controlled addresses are placed in MDLs and passed to MmProbeAndLockPages with KernelMode, bypassing user-address validation. The writeup follows device discovery, IOCTL reachability, MDL construction, patch diffing, and exploitation from medium integrity to SYSTEM rather than stopping at the one-line AccessMode fix."],
    ["CVE-2023-36802: mskssrv Type Confusion to SYSTEM", "https://theori.io/blog/chaining-n-days-to-compromise-all-part-6-windows-kernel-lpe-get-system", "Frontier Squad / Theori", "2024", 5, "CVE-2023-36802 mskssrv type confusion pool grooming arbitrary decrement PreviousMode", "Develops the Streaming Service type confusion used as the final host-privilege stage of a multi-product chain. It recovers the rendezvous object mismatch through patch comparison, controls out-of-bounds FSStreamReg fields with ThreadName pool allocations, obtains an arbitrary reference-count decrement, and targets KTHREAD PreviousMode to reach kernel read/write and SYSTEM."],
    ["CVE-2023-28218: Windows Kernel Wild Copy", "https://theori.io/blog/exploiting-windows-kernel-wild-copy-with-user-fault-handling-cve-2023-28218", "Frontier Squad / Theori", "2023", 5, "CVE-2023-28218 afd.sys heap overflow wild copy user fault IO completion context", "Turns an apparently uncontrollable AFD heap overflow into a bounded corruption by placing an unmapped guard immediately after the user source buffer and using the resulting page fault to stop the copy. The chain then selects a sprayable IO_COMPLETION_CONTEXT, converts corruption into an arbitrary decrement, and manipulates PreviousMode, demonstrating a reusable user-fault technique for wild-copy bugs."],
    ["Patch Analysis of MS16-063: jscript9 TypedArray UAF", "https://theori.io/blog/patch-analysis-of-ms16-063-jscript9-dll", "Theori", "2016", 5, "MS16-063 jscript9 TypedArray DataView use after free LFH ROP", "Patch-diffs the Internet Explorer scripting fix, reconstructs the TypedArray and DataView lifetime bug, and shapes the LFH so a freed object can be replaced with controlled metadata. The exploit progresses through address disclosure, arbitrary read/write, a forged vtable, stack pivot, and VirtualProtect ROP, with source code available to audit the full low-integrity code-execution chain."],
    ["Chakra JIT CFG Bypass", "https://theori.io/blog/chakra-jit-cfg-bypass", "Theori", "2016", 5, "Chakra JIT Control Flow Guard bypass IE Edge arbitrary read write", "Starts from the read/write primitive built in the companion jscript9 research and explains why ordinary vtable hijacking fails under Control Flow Guard. By studying Chakra's JIT allocation and executable-code lifecycle, the researchers place attacker-controlled native code in a legitimate executable region and redirect execution without choosing an invalid CFG target, then relate the technique to Microsoft's mitigation fix."],
    ["CVE-2025-29824: Reconstructing the CLFS UAF", "https://starlabs.sg/blog/2025/07-my-blind-date-with-cve-2025-29824/", "Ong How Chong / STAR Labs", "2025", 5, "CVE-2025-29824 CLFS use after free FsContext2 cleanup close race patch diff", "Reconstructs an in-the-wild CLFS vulnerability without a public exploit sample by diffing the patched lifetime logic around CClfsLogCcb and FILE_OBJECT.FsContext2. The article distinguishes IRP_MJ_CLEANUP from IRP_MJ_CLOSE, identifies three IOCTL-reachable consumers of the stale context, and builds a reliable two-thread race and crash PoC from the recovered reference-count error."],
    ["CVE-2024-30088: From Chrome Sandbox to SYSTEM", "https://starlabs.sg/blog/2025/07-fooling-the-sandbox-a-chrome-atic-escape/", "Vincent Yeo / STAR Labs", "2025", 5, "CVE-2024-30088 Windows kernel double fetch Chrome sandbox partial write SepMediumDaclSd", "Adapts a Windows kernel double-fetch exploit from medium integrity to an untrusted Chrome renderer and works through the restrictions that break the public elevation chain. A controlled overwrite changes SepMediumDaclSd to bypass integrity enforcement, token privileges are repaired from the sandbox, and injection into winlogon escapes the job object, with careful accounting for the primitive's destructive 32-byte write."],
    ["CNG Key Isolation Sandbox Escape", "https://whereisk0shl.top/post/Isolate%20me%20from%20sandbox%20-%20Explore%20elevation%20of%20privilege%20of%20CNG%20Key%20Isolation/", "k0shl / Cyber Kunlun", "2023", 5, "CVE-2023-28229 CVE-2023-36906 KeyIso RPC UAF OOB read LSASS XFG sandbox escape", "Chains six race-driven use-after-frees in the CNG Key Isolation RPC service with a provider-property out-of-bounds read reachable from AppContainer. Predictable object handles, process-heap grooming, a leaked provider address, and a forged property object turn the stale virtual call into XFG-compatible LoadLibraryW execution inside LSASS, documenting both the discovery model and complete sandbox escape."],
    ["Windows Dirty Pipe: CVE-2022-22715", "https://whereisk0shl.top/post/Break%20me%20out%20of%20sandbox%20in%20old%20pipe%20-%20CVE-2022-22715%20Windows%20Dirty%20Pipe/", "k0shl / Cyber Kunlun", "2022", 5, "CVE-2022-22715 NPFS named pipe AppContainer integer overflow pool sandbox escape", "Reverse engineers a decade-old NPFS bug in AppContainer-local named-pipe alias translation, where 16-bit length arithmetic wraps through zero and produces a tiny allocation followed by an almost 64-kilobyte formatted write. The long-form exploit study develops the precise pipe name, paged-pool corruption, grooming and recovery strategy used to escape the Adobe Reader sandbox at Tianfu Cup."],
    ["The Story of CVE-2021-1648", "https://whereisk0shl.top/post/The_story_of_CVE_2021_1648/", "k0shl / Cyber Kunlun", "2021", 5, "CVE-2021-1648 Microsoft Defender MpEngine token swap race sandbox escape", "Analyzes a Microsoft Defender engine race in which asynchronous scanning retains a caller token while the underlying slot can be cleared and replaced, letting a low-privilege request inherit a more privileged client's security context. The write-up reconstructs MpEngine's token table, synchronization failure, race orchestration, and privileged file-operation path into an uncommon service-side sandbox escape primitive."],
    ["CVE-2019-1362: Exploiting Indexed Color Palettes", "https://www.thezdi.com/blog/2019/12/16/local-privilege-escalation-in-win32ksys-through-indexed-color-palettes", "Marcin Wiązowski / ZDI", "2019", 5, "CVE-2019-1362 win32k CreateSurfacePal indexed palette printer driver kernel LPE", "Develops a full Windows 7 kernel exploit from insufficient validation in win32k's CreateSurfacePal path, reached by intercepting a user-mode printer driver callback. The study explains the mismatched surface and palette state, controlled kernel memory effects, exploit object preparation, and the route from an unprivileged process to kernel execution and SYSTEM."],
    ["Turning Arbitrary File Deletes into SYSTEM", "https://www.thezdi.com/blog/2022/3/16/abusing-arbitrary-file-deletes-to-escalate-privilege-and-other-great-tricks", "Abdelhamid Naceri and Simon Zuckerbraun / ZDI", "2022", 5, "Windows Installer Config.Msi rollback RBS RBF arbitrary file folder delete SYSTEM LPE", "Turns apparently weak privileged file, folder, and recursive-delete primitives into reliable SYSTEM escalation by corrupting Windows Installer rollback state under C:\\Config.Msi. The updated technique removes its original race, preserves the installer's trust marker, forges RBS and RBF data, and shows how INDEX_ALLOCATION plus junctions and oplocks widen the usable primitive."],
    ["Breaking Windows LPE Assumptions, Part 1", "https://www.thezdi.com/blog/2024/7/29/breaking-barriers-and-assumptions-techniques-for-privilege-escalation-on-windows-part-1", "Michael DePlante and Nicholas Zubrisky / ZDI", "2024", 5, "Windows link following TOCTOU junction device map impersonation arbitrary directory delete LPE", "Builds a systematic methodology for finding privileged link-following bugs with Procmon, then tests common defenses such as reparse-point checks, impersonation, protected files, and Redirection Guard. Multi-race Avast and AVG cases demonstrate how directory reconstruction and cleanup can be redirected into arbitrary creation or deletion despite checks made on different handles."],
    ["Breaking Windows LPE Assumptions, Part 2", "https://www.thezdi.com/blog/2024/7/30/breaking-barriers-and-assumptions-techniques-for-privilege-escalation-on-windows-part-2", "Michael DePlante and Nicholas Zubrisky / ZDI", "2024", 5, "Windows NTFS alternate data streams junction ESET antivirus arbitrary delete SYSTEM LPE", "Uses an NTFS alternate data stream attached to a directory to satisfy a product's file checks while keeping the directory logically empty and therefore replaceable with a junction. The CVE-2024-0353 ESET case turns that subtle namespace property into a privileged arbitrary delete and then chains the primitive through the Config.Msi technique to SYSTEM."],
    ["Breaking Windows LPE Assumptions, Part 3", "https://www.thezdi.com/blog/2024/7/31/breaking-barriers-and-assumptions-techniques-for-privilege-escalation-on-windows-part-3", "Michael DePlante and Nicholas Zubrisky / ZDI", "2024", 5, "Windows Task Scheduler legacy jobs on boot delete junction Config.Msi PaperCut protected process debugging", "Converts an inconvenient boot-time deletion into an on-demand primitive by removing the legacy Task Scheduler SA.DAT guard, replacing the writable jobs directory with a junction, and redirecting task deletion into Config.Msi. A PaperCut chain and protected-process debugging technique make this a practical continuation rather than a catalog of related CVEs."],
    ["Patch Diff to SYSTEM: Exploiting a DWM Use-After-Free", "https://www.elastic.co/security-labs/patch-diff-to-system", "Joe Desimone / Elastic Security Labs", "2026", 5, "Windows DWM DirectComposition use after free heap spray CFG gadget SYSTEM exploit", "Patch-diffs January 2026 dwmcore.dll builds to recover a lifetime error in CSynchronousSuperWetInk, constructs the raw DirectComposition command sequence that leaves a dangling manager entry, and reclaims the object with a fully controlled RECT spray. The exploit then chains CFG-valid user32 and combase dispatch gadgets into VirtualProtect and shellcode, defuses repeat iteration, repairs the stack, and documents a separate DWM-to-SYSTEM step, making the path from feature-gated fix to reliable privilege escalation independently auditable."],
    ["Bypassing Windows Administrator Protection", "https://projectzero.google/2026/26/windows-administrator-protection.html", "James Forshaw / Google Project Zero", "2026", 5, "Windows 11 25H2 Administrator Protection shadow administrator token device map symbolic link LPE", "Analyzes Windows 11 Administrator Protection as a newly defended replacement for UAC and develops one of nine pre-release bypasses from an interaction between linked tokens, logon sessions, and per-session DOS-device maps. Identification-level impersonation of the shadow administrator causes the kernel to create a device directory with attacker-owned inherited permissions because ZwCreateDirectoryObject bypasses access checks; a C: symbolic-link override then redirects privileged file and DLL access, with the final fix precisely scoped to shadow-token device-map creation."],
    ["Bypassing Administrator Protection by Abusing UI Access", "https://projectzero.google/2026/02/windows-administrator-protection.html", "James Forshaw / Google Project Zero", "2026", 5, "Windows Administrator Protection UIAccess UIPI RAiLaunchAdminProcess DLL injection privilege escalation", "Unifies five Administrator Protection bypasses around the legacy UIAccess model, showing how AppInfo silently creates High-integrity accessibility processes whose shared profile, environment, and desktop undermine the new shadow-admin separation. The article evaluates secure-directory and MSIX gaps, On-Screen Keyboard and Quick Assist DLL loading, unsanitized debug flags, a path TOCTOU in RAiLaunchAdminProcess, window hooks, token ratcheting, and the policy changes required to turn long-tolerated UAC behavior into serviceable vulnerabilities."],
    ["A Deep Dive into GetProcessHandleFromHwnd", "https://projectzero.google/2026/02/gphfh-deep-dive.html", "James Forshaw / Google Project Zero", "2026", 5, "GetProcessHandleFromHwnd UIAccess win32k process handle Windows hook injection access check", "Reverse engineers an obscure API used by Quick Assist to obtain the process behind a window and separates its historical UIAccess hook-based implementation from the current Windows 11 win32k syscall path. By tracing handle rights, UIPI, process ownership, integrity checks, cross-user behavior, message-only windows, and the conditions that turn a UI primitive into code injection, the article supplies both an exploitation building block and a methodology for testing undocumented broker-like APIs against their real kernel enforcement."],
    ["Activation Context Cache Poisoning: Exploiting CSRSS", "https://www.thezdi.com/blog/2023/1/23/activation-context-cache-poisoning-exploiting-csrss-for-privilege-escalation", "Simon Zuckerbraun / Zero Day Initiative", "2023", 5, "Windows CSRSS activation context cache poisoning manifest section object privilege escalation", "Defines a Windows bug class in which CSRSS caches activation contexts derived from attacker-controlled manifests and later reuses them across process or privilege boundaries under an unsafe identity key. The research connects several in-the-wild and reported escalations to shared section objects, process creation, manifest parsing, cache lifetime, and DWM or privileged consumers, then evaluates Microsoft's general mitigation and the remaining corner cases instead of treating each CVE as an unrelated parser flaw."],
    ["CVE-2023-21822: Exploiting User-mode Printer Bitmap Handling", "https://www.thezdi.com/blog/2023/8/1/exploiting-a-flaw-in-bitmap-handling-in-windows-user-mode-printer-drivers", "Marcin Wiązowski / Zero Day Initiative", "2023", 5, "CVE-2023-21822 win32kfull printer driver bitmap UAF SURFOBJ reference count LPE", "Reverse engineers the split user/kernel representation created when a user-mode printer driver locks a win32k bitmap and finds a lifetime mismatch that leaves a user-mode SURFOBJ copy referencing freed kernel state. The writeup develops the reference-count sequence, callback and bitmap operations needed to trigger the use-after-free, controlled reclamation, privilege-escalation path, and Microsoft's patch, preserving both the unusual printer-driver boundary and exploit reasoning."],
    ["Windows 11 24H2 Nonpaged Pool Overflow, Part 1", "https://insideyourkernel.com/2025-03-22-windows-11-x64-kernel-exploitation-nonpaged-pool-overflow-using-hevd-part-1-arbitrary-read.html", "Acebond / Inside Your Kernel", "2025", 5, "Windows 11 24H2 HEVD kLFH nonpaged pool overflow named pipe DQE arbitrary read", "Builds a modern Windows 11 24H2 pool exploit from HEVD's 0x1f0-byte overflow, first activating and grooming the kernel LFH bucket with thousands of named-pipe data queue entries. Precise corruption of an adjacent buffered NP_DATA_QUEUE_ENTRY expands an out-of-bounds read, identifies the affected pipe, and redirects a forged unbuffered entry through a user-controlled IRP into an arbitrary kernel read, with allocator diagrams and full code for every transition."],
    ["HEVD Double-fetch Race to Kernel Execution", "https://insideyourkernel.com/2025-02-06-windows-10-x64-kernel-exploitation-time-of-check-time-of-use-toctou-race-condition-using-hevd.html", "Acebond / Inside Your Kernel", "2025", 5, "Windows 10 HEVD double fetch TOCTOU race stack overflow ROP SMEP SYSTEM", "Turns HEVD's short size-check/use window into a reliable double-fetch race using coordinated DeviceIoControl and mutation threads, then converts the resulting stack overflow into kernel execution through a build-specific ROP chain and token-stealing payload. The article improves one-shot synchronization by feeding success back through the original user buffer, documents register and stack recovery in WinDbg, and includes the complete exploit rather than treating race success as the endpoint."],
    ["HEVD Write-What-Where Exploitation on Windows x64", "https://insideyourkernel.com/2025-02-01-windows-10-x64-kernel-exploitation-arbitrary-write-write-what-where-using-hevd.html", "Acebond / Inside Your Kernel", "2025", 5, "Windows 10 HEVD arbitrary write read primitive token swap HalDispatchTable ROP SMEP", "Starts from HEVD's pointer-dereference write-what-where and demonstrates that reversing the source and destination yields a practical arbitrary kernel read into user memory. It then compares data-only EPROCESS token replacement with control-flow routes through HalDispatchTable, handles SMEP through ROP and shellcode placement, locates kernel symbols and process-list offsets, and explains restoration and reference-bit details that determine whether a nominal write primitive survives use."],
    ["HEVD Stack Buffer Overflow Exploitation on Windows x64", "https://insideyourkernel.com/2025-01-23-windows-kernel-stack-buffer-overflow-exploitation-using-hevd.html", "Acebond / Inside Your Kernel", "2025", 4, "Windows 10 HEVD kernel stack overflow WinDbg cyclic pattern ROP SMEP token stealing", "Provides a complete x64 kernel stack-overflow workflow from reversing the vulnerable IOCTL and calculating the saved return-address offset with a cyclic pattern through kernel-base discovery, gadget selection, SMEP control, executable payload locking, and SYSTEM token theft. Although the target is intentionally vulnerable, the explicit calling convention, trap and stack state, crash triage, and full exploit make it a solid baseline for understanding the harder race and pool chains built afterward."],
    ["Exploit Writing Tutorial 10: Chaining DEP with ROP", "https://www.corelan.be/index.php/2010/06/16/exploit-writing-tutorial-part-10-chaining-dep-with-rop-the-rubikstm-cube/", "Peter Van Eeckhoutte / Corelan", "2010", 5, "Windows exploit development ROP DEP ASLR stack pivot VirtualProtect WriteProcessMemory mona", "A foundational, experiment-driven guide to turning instruction-pointer control into a working Windows exploit when hardware DEP prevents stack execution. It develops gadgets, stack pivots, calling conventions, ROP NOPs, and chains for VirtualProtect, WriteProcessMemory, NtSetInformationProcess, and related APIs, then examines SEH delivery, bad characters, Unicode constraints, ASLR portability, and debugger-assisted gadget selection instead of presenting a single opaque payload."],
    ["Exploit Writing Tutorial 11: Heap Spraying Demystified", "https://www.corelan.be/index.php/2011/12/31/exploit-writing-tutorial-part-11-heap-spraying-demystified/", "Peter Van Eeckhoutte / Corelan", "2011", 5, "Windows heap spraying Internet Explorer precision spray DEP ROP ASLR WinDbg exploit development", "Builds heap spraying from allocator behavior rather than treating repeated strings as a magic reliability trick. The tutorial instruments allocations in WinDbg, compares browser and document runtimes, explains chunk sizing, fragmentation, alignment and predictable addresses, then develops precision sprays suitable for DEP-bypass chains on IE8 and IE9 while documenting the assumptions that fail across engines and Windows versions."],
    ["Windows Kernel Exploitation: Stack Overflow and Debugging", "https://connormcgarr.github.io/Kernel-Exploitation-1/", "Connor McGarr", "2019", 5, "Windows kernel exploitation HEVD stack overflow WinDbg IOCTL token stealing SMEP x64", "Walks from constructing a two-machine WinDbg lab and reversing the HEVD device interface to controlling the kernel stack through a vulnerable buffered IOCTL. The exploit is assembled incrementally with Python ctypes, x64 calling and structure details, crash analysis, EPROCESS traversal, and token replacement, making the transition from user-mode request to SYSTEM shell observable at every stage rather than hiding it behind a framework module."],
    ["Windows Kernel Exploitation: Arbitrary Overwrites", "https://connormcgarr.github.io/Kernel-Exploitation-2/", "Connor McGarr", "2019", 5, "Windows kernel exploitation HEVD arbitrary overwrite write what where PTE U S bit SMEP", "Turns HEVD's write-what-where bug into a modern x64 privilege-escalation chain and uses the exercise to explain why an arbitrary kernel write is only an intermediate primitive. The article traces IOCTL handling and pointer validation, constructs the user-mode request, locates page-table entries, clears the supervisor restriction needed to survive SMEP-era execution, redirects a kernel callback, performs token stealing, and restores state for a stable return."],
    ["One Font Vulnerability to Rule Them All, Part 4", "https://projectzero.google/2015/08/one-font-vulnerability-to-rule-them-all_21.html", "Mateusz Jurczyk / Google Project Zero", "2015", 5, "Windows 8.1 x64 ATMFD CVE-2015-0090 kernel pool spray arbitrary read write KASLR SMEP sandbox escape", "Completes a cross-architecture font exploit by converting an uninitialized Registry Object in ATMFD into an x64 kernel read/write primitive. The writeup derives a reliable session-pool spray, obtains kernel addresses from architectural tables despite restricted information APIs, finds a nearby executable trampoline, programs a CharString payload to modify the IDT, crosses SMEP and ASLR, and returns cleanly from a Windows 8.1 sandbox escape."],
    ["In-Console-Able: Escaping Restricted Job Objects", "https://projectzero.google/2015/05/in-console-able.html", "James Forshaw / Google Project Zero", "2015", 5, "Windows sandbox escape console host job object breakaway conhost process creation token", "Investigates an unfixed Windows 8.1 behavior that lets a sandboxed process escape the containment assumptions of restrictive job objects through console process management. The research reconstructs how conhost and CSRSS create and associate processes, identifies the security-context mismatch, develops the practical breakaway sequence, and explains how a modest operating-system inconsistency becomes a valuable link in a browser sandbox-escape chain."],
    ["Blackswan: Seven Windows Kernel Zero-Days", "https://fieldeffect.com/hubfs/Blackswan/Blackswan_Technical_Write%20Up_Field_Effect.pdf", "Erik Egsgard / Field Effect", "2021", 5, "Windows Blackswan ALPC AFD HTTP sys TOCTOU kernel pool arbitrary read write CVE-2021", "Presents the technical work behind seven related Windows zero-days discovered while reverse engineering ALPC, kernel I/O and socket behavior. The paper develops TOCTOU and state-confusion conditions across ALPC, AFD and HTTP.sys, turns paged-pool corruption into controlled read and write primitives, explains the process and pipe objects selected for exploitation, and documents reliability considerations for six privilege escalations plus an information leak rather than merely listing their assigned CVEs."],
    ["Porting a Data-Only Kernel Exploit to Windows 11 24H2", "https://blog.vmcall.io/blog/2025-04-05-porting-to-24H2/", "Nicola / VMCALL.IO", "2025", 5, "Windows 11 24H2 kernel exploit WNF token BnoIsolationHandlesEntry arbitrary increment PreviousMode", "Ports a paged-pool data-only chain to Windows 11 24H2 after Microsoft removed the familiar PreviousMode shortcut. The writeup converts an overflow into overlapping WNF state objects, performs pool feng shui with variable-size tokens, derives arbitrary read through BNO isolation metadata, locates EPROCESS without restricted address queries, and abuses a token reference counter as a reversible byte-precision increment that enables SeDebugPrivilege."],
    ["CVE-2023-36802: Exploiting Microsoft Kernel Streaming", "https://www.ibm.com/think/x-force/critically-close-to-zero-day-exploiting-microsoft-kernel-streaming-service", "Valentina Palmiotti / IBM X-Force", "2023", 5, "CVE-2023-36802 mskssrv kernel streaming type confusion rendezvous object pool exploit SYSTEM", "Takes an unfamiliar PnP kernel component from device-interface discovery through a stable SYSTEM exploit. The researcher maps mskssrv's camera-stream rendezvous protocol, handles demand loading during debugging, identifies a registration-object type confusion, constructs controlled stream and context state, grooms the relevant pool allocations and converts the confused lifetime into useful corruption, providing a complete example of learning a compact Windows attack surface rather than starting from a known PoC."],
    ["CVE-2024-30089: The Little Race That Could", "https://www.ibm.com/think/x-force/little-bug-that-could", "Valentina Palmiotti / IBM X-Force", "2024", 5, "CVE-2024-30089 mskssrv race use after free Pwn2Own Windows 11 VBS kernel exploit", "Explains the Pwn2Own-winning mskssrv use-after-free that remained exploitable on a fully updated Windows 11 target with VBS and hardware mitigations enabled. The analysis compares state-machine paths around FSContextReg reference counting, exposes a missing lock and deterministic race window, traces object destruction and reuse, and examines both the vulnerability's lineage and Microsoft's patch, demonstrating how concurrency review can uncover variants after an attack surface appears exhausted."],
    ["One Bit to Rule Them All", "https://www.fortinet.com/blog/threat-research/one-bit-to-rule-them-all-bypassing-windows-10-protections-using-a-single-bit", "enSilo Research / Fortinet", "2015", 5, "CVE-2015-0057 win32k single bit overwrite kernel exploitation SMEP KASLR sandbox escape", "Studies how CVE-2015-0057 reduces Windows kernel exploitation to corruption of a single strategically selected bit rather than a broad write-what-where primitive. The researchers follow the win32k state mistake, reason about which protected structure and flag can collapse multiple security assumptions, and connect the minimal modification to sandbox escape, kernel segregation and randomization bypass, making it a durable lesson in choosing high-leverage data targets even though weaponization details are intentionally constrained."],
    ["Windows Registry Adventure #7: Attack-Surface Analysis", "https://projectzero.google/2025/05/the-windows-registry-adventure-7-attack-surface.html", "Mateusz Jurczyk / Google Project Zero", "2025", 5, "Windows registry kernel attack surface hive corruption callbacks predefined handles LPE", "Turns a complete architectural model of the Configuration Manager into a vulnerability-research plan. The article classifies kernel pool and hive-local corruption, malformed regf state, symbolic and predefined-key confusion, memory-mapping edge cases, registry callbacks and privileged clients, then relates more than fifty fixed bugs to the primitive each exposes and the boundary it crosses; this makes it a reusable guide for choosing targets and evaluating exploitability rather than a retrospective CVE list."],
    ["Windows Registry Adventure #8: Exploiting Hive Corruption", "https://projectzero.google/2025/05/the-windows-registry-adventure-8-exploitation.html", "Mateusz Jurczyk / Google Project Zero", "2025", 5, "Windows 11 registry hive UAF CVE-2023-23420 cell index kernel read write token exploit", "Develops a modern Windows 11 SYSTEM exploit from the registry's deterministic cell allocator and a transacted-key-rename use-after-free. Carefully arranged volatile keys reclaim the freed node as attacker-controlled value metadata, out-of-bounds cell indexes escape the hive mapping into its CMHIVE pool object, and two Registry values become arbitrary kernel read/write; the exploit then locates EPROCESS objects and applies a SYSTEM token through ordinary registry tools while discussing why current mitigations do not disturb the layout."],
    ["Leveraging Page-Table Entries for Windows Kernel Exploitation", "https://connormcgarr.github.io/pte-overwrites/", "Connor McGarr", "2020", 5, "Windows kernel PTE arbitrary read write SMEP NX page table randomization HEVD exploit", "Builds an end-to-end Windows 10 x64 chain around a one-QWORD HEVD read/write primitive and uses page-table control rather than a CR4 ROP gadget to defeat execution protections. The writeup derives virtual-address translation and PTE bit fields, locates the randomized self-reference entry with a disclosure, distinguishes clearing NX from making user pages supervisor-owned for SMEP, stages shellcode and restores modified state, providing a concrete bridge from paging theory to a reliable exploit."],
    ["Windows x64 Token Payloads and SMEP Bypass", "https://connormcgarr.github.io/x64-Kernel-Shellcode-Revisited-and-SMEP-Bypass/", "Connor McGarr", "2020", 5, "Windows 10 x64 kernel token stealing SMEP CR4 ROP HEVD stack overflow exploit", "Revisits the canonical token-stealing payload on x64 by deriving every GS, KTHREAD, EPROCESS and token-list transition instead of copying opaque shellcode with stale offsets. The article then places that payload behind HEVD's stack overflow, identifies a kernel ROP sequence that changes CR4 to permit user-page execution, accounts for the Windows x64 ABI and stack repair, and validates the full SYSTEM escalation under SMEP, making both the data target and mitigation bypass auditable."],
    ["Exploiting a CLFS Use-After-Free", "https://blog.exodusintel.com/2022/03/10/exploiting-a-use-after-free-in-windows-common-logging-file-system-clfs/", "Arav Garg / Exodus Intelligence", "2022", 5, "CVE-2021-36955 Windows CLFS use after free pool grooming arbitrary write token LPE", "Reverse engineers a Common Logging File System use-after-free from public symbols and patched binaries, reconstructing the base-log and client-context lifetimes that let a stale pointer survive container removal. The exploit shapes the relevant kernel pool, replaces the freed object with controlled state, converts the resulting callbacks and fields into useful memory effects, and reaches local privilege escalation while explaining the CLFS APIs and on-disk artifacts required to reproduce the trigger rather than assuming prior subsystem knowledge."],
    ["Windows Kernel Logic Bug Class: Access Mode Mismatch", "https://projectzero.google/2019/03/windows-kernel-logic-bug-class-access.html?m=0", "James Forshaw / Google Project Zero", "2019", 5, "Windows kernel IO Manager PreviousMode access mode mismatch IRP device object LPE", "Derives a recurring driver vulnerability class from the boundary between user-originated I/O and kernel-mode forwarding. The analysis follows requestor mode through IRP construction, IoCreateFile and Zw versus Nt call paths, shows how a kernel component can accidentally convert an untrusted request into KernelMode authority, and connects the mismatch to device access, extended attributes, TOCTOU exploitation and a platform-level hardening response."],
    ["Hunting for Bugs in Windows Mini-Filter Drivers", "https://projectzero.google/2021/01/hunting-for-bugs-in-windows-mini-filter.html?m=1&version=published", "James Forshaw / Google Project Zero", "2021", 5, "Windows minifilter Filter Manager IRP altitude communication port fuzzing vulnerability research", "Provides a research methodology for an unusually subtle kernel attack surface rather than cataloguing isolated driver bugs. It maps Filter Manager registration, callback ordering and altitudes, pre/post-operation state, reparse and completion behavior, user communication ports and METHOD_NEITHER buffers, then derives bug patterns from four Cloud Filter and WOF vulnerabilities with PowerShell and header tooling for reproducing the analysis."],
    ["Attacking the Windows NVIDIA Driver", "https://projectzero.google/2017/02/attacking-windows-nvidia-driver.html", "Oliver Chang / Google Project Zero", "2017", 5, "Windows NVIDIA WDDM display miniport driver IOCTL fuzzing sandbox escape kernel exploit", "Maps the Windows NVIDIA graphics stack from user-mode entry points through dxgkrnl callbacks into the display miniport, then turns that architecture into a targeted vulnerability-research workflow. The post covers exposed WDDM interfaces, reverse engineering, coverage and mutation strategies, and representative memory-corruption findings from a sixteen-vulnerability audit, making it a durable guide for attacking complex vendor drivers reachable from browser sandboxes."],
    ["The Windows Registry Adventure #6: Kernel-mode Objects", "https://projectzero.google/2025/04/the-windows-registry-adventure-6-kernel.html", "Mateusz Jurczyk / Google Project Zero", "2025", 5, "Windows registry kernel CMHIVE HHIVE KCB cells transactions pool exploitation", "Reconstructs the runtime object graph behind active registry hives, including reverse-engineered CMHIVE and HHIVE layouts, view maps, cell translation callbacks, key bodies, KCBs, security caches and transaction objects. WinDbg enumeration and field-by-field lifetime analysis expose the pool objects and cross-references that turn regf corruption into reliable kernel primitives, bridging the series' on-disk format work with its later Windows 11 exploitation chain."],
    ["In-the-Wild Windows Exploits: Four 0-day Chains", "https://projectzero.google/2021/01/in-wild-series-windows-exploits.html", "Maddie Stone / Google Project Zero", "2021", 5, "Windows in the wild exploit chains CVE-2020-1027 CSRSS win32k UAF CFG sandbox escape", "Compares four captured Windows privilege-escalation exploits at implementation level rather than summarizing their CVEs. The analysis reconstructs a CSRSS ALPC capture-buffer overflow and multiple Win32k memory-corruption chains, then follows shared-memory grooming, information leaks, object reuse, arbitrary writes and CFG-aware control transfer to show how attackers converted distinct bugs into stable primitives across supported builds."],
  ]},
  { id: "ctf", kicker: "Practice the full chain", title: "Windows CTF Pwn", items: [
    ["Cache Cache — Insomni'hack 2024", "https://itm4n.github.io/insomnihack-2024-cache-cache/", "itm4n", "2024", 5, "Windows CTF cache service RPC authentication privilege escalation", "A full solution to a Windows-native Insomni'hack challenge that begins with an unfamiliar privileged service and works through its exposed interface, state model, and security assumptions to a reliable exploit. The post preserves the investigative branches and verification steps, making it useful practice in service-oriented Windows pwn rather than only a flag-recovery recipe."],
    ["Easier — DEF CON CTF Quals 2016", "https://github.com/legitbs/quals-2016/tree/master/easier", "LegitBS", "2016", 5, "Windows CTF pwn DEF CON source binary exploitation", "An official DEF CON Quals challenge repository preserving the target source and deployment material for a Windows pwnable. The artifact supports a full audit of the intended vulnerability and lets researchers compare independent solutions against the organizer's exact build rather than a reconstructed binary."],
    ["Divided — DEF CON CTF Quals 2017", "https://github.com/securifera/Defcon-Quals-2017-Divided", "Securifera", "2017", 5, "Windows CTF DEP CFG ROP process exploitation writeup", "A dedicated solution repository for DEF CON's Windows challenge with exploit code and an accompanying technical narrative. It is strong practice for analyzing an unfamiliar PE service, recovering its corruption primitive, and working through platform mitigations to a stable payload."],
    ["VBS — 0CTF 2015", "https://github.com/ctfs/write-ups-2015/tree/master/0ctf-2015/exploit/vbs", "0CTF community archive", "2015", 4, "Windows VBScript engine CTF exploitation challenge writeup", "A preserved challenge package and solution material targeting Windows scripting behavior rather than a conventional ELF service. It offers historical but still useful practice in recovering a language runtime's object and memory model before converting a script-level bug into native control."],
    ["Drunk — BCTF 2015", "https://github.com/pwning/public-writeup/tree/master/bctf2015/pwn300-drunk", "PPP", "2015", 5, "Windows CTF usermode exploit public writeup code", "A public solution from a top CTF team for a Windows pwnable, retaining both the reasoning and exploit artifacts. The repository is useful for studying how experienced solvers identify Windows-specific attack surface, obtain the necessary disclosures, and assemble a reliable chain under competition constraints."],
    ["Thing2 — DEF CON CTF Quals 2015", "https://github.com/ctfs/write-ups-2015/tree/master/defcon-qualifier-ctf-2015/pwnable/thing2", "DEF CON CTF community archive", "2015", 4, "Windows CTF pwn Thing2 source exploit writeup", "A mirrored set of original materials and writeups for an uncommon Windows challenge from DEF CON Quals. Its age makes it best treated as historical exploitation practice, but the retained binary and solution still support reproducible work with PE layout, Windows APIs, and native memory corruption."],
    ["Memory — CONFidence CTF 2014", "https://github.com/j00ru/ctf-tasks/tree/master/CONFidence%20CTF%202014/Main%20event/Memory", "j00ru", "2014", 5, "Windows CTF memory corruption challenge source j00ru", "An official Windows challenge authored and archived by j00ru with sufficient material to reconstruct both design and intended vulnerability. It is a useful historical benchmark for the Windows exploitation techniques emphasized in high-level CTFs before modern pool and control-flow mitigations changed common chains."],
    ["Entree — CONFidence CTF 2016", "https://github.com/j00ru/ctf-tasks/tree/master/CONFidence%20CTF%202016/Main%20event/Entree", "j00ru", "2016", 5, "Windows CTF exploitation challenge PE source binary", "A Windows-native exploitation task preserved by its author with challenge files and documentation. The clean provenance and complete artifacts make it suitable for methodical reverse engineering, debugging, and exploit reproduction instead of relying on a potentially modified mirror."],
    ["Bubblegum — CONFidence CTF 2016 Teaser", "https://github.com/j00ru/ctf-tasks/tree/master/CONFidence%20CTF%202016/Teaser/Bubblegum", "j00ru", "2016", 5, "Windows CTF Bubblegum binary exploitation source", "A compact Windows pwnable from the CONFidence teaser series, released by the challenge author. It provides a controlled environment for practicing PE triage, input-path recovery, and native exploit development with authoritative artifacts and known challenge intent."],
    ["Fastcalc — CONFidence CTF 2017 Teaser", "https://github.com/j00ru/ctf-tasks/tree/master/CONFidence%20CTF%202017/Teaser/Fastcalc", "j00ru", "2017", 5, "Windows CTF calculator floating point exploitation challenge", "An organizer-authored Windows challenge centered on a calculator-style target and distributed with the original files. Its unusual data processing rewards careful semantic analysis before memory-corruption work, and the hardened companion makes it possible to compare the primitive as mitigations change."],
    ["Fastcalc Hardened — CONFidence CTF 2017", "https://github.com/j00ru/ctf-tasks/tree/master/CONFidence%20CTF%202017/Main%20event/Fastcalc-hardened", "j00ru", "2017", 5, "Windows CTF hardened Fastcalc mitigation bypass exploit", "The main-event evolution of Fastcalc deliberately strengthens the original target, creating a useful before-and-after exploitation exercise. Researchers can compare what the teaser solution depended on, identify which assumptions were removed, and redesign the chain against the hardened Windows binary."],
    ["Globetrotter — CSAW CTF 2018 Finals", "https://github.com/osirislab/CSAW-CTF-2018-Finals/tree/master/pwn/globetrotter", "OSIRIS Lab", "2018", 5, "Windows CTF Globetrotter pwn source notes exploit", "An official CSAW Finals repository containing the Windows challenge and author notes. The retained design material makes this more than a binary archive: it allows readers to trace the intended attack surface, constraints, and exploitation decisions directly from the organizer's implementation."],
    ["Greenhornd — CSAW CTF 2014", "https://github.com/trailofbits/ctf-challenges/tree/master/csaw-2014/greenhornd", "Trail of Bits", "2014", 4, "Windows CTF beginner PE buffer overflow exploit source", "A deliberately approachable Windows exploitation challenge preserved by its authors with source and supporting files. It is a good bridge from basic stack corruption to PE tooling and Windows calling conventions, with enough provenance to reproduce the original exercise reliably."],
    ["PE Analysis — Pwn2Win CTF 2021", "https://github.com/epicleet/write-ups/tree/master/2021/Pwn2Win/pwn-pe_analysis/solution", "Epic Leet Team", "2021", 5, "Windows PE analysis CTF exploitation solution source", "A complete solution directory for a Windows PE-focused pwnable with the code needed to reproduce the solve. It combines file-format reasoning and native exploitation, making it useful to analysts who want practice translating static PE observations into an operational attack rather than stopping at reverse engineering."],
    ["PwnME — INTENT CTF 2022", "https://github.com/nobodyisnobody/write-ups/tree/main/INTENT.CTF.2022/pwn/PwnME", "nobodyisnobody", "2022", 4, "Windows CTF PwnME PE exploitation writeup exploit", "A code-backed writeup for a Windows pwn challenge that records the target analysis and final exploit in a reproducible repository. Its value lies in the complete solver path and explicit Windows environment assumptions, which allow readers to validate each stage locally."],
    ["StrikeBack — Insomni'hack 2018", "https://github.com/Insomnihack/Insomnihack-2018/tree/master/StrikeBack", "Insomni'hack", "2018", 5, "Windows VBA CTF exploitation Office macro challenge source", "An official challenge archive for a Windows and VBA-oriented exploitation task, retaining the files necessary to examine its Office execution and memory model. It broadens the CTF table beyond conventional native services while still demanding low-level reasoning and a concrete exploit path."],
    ["Fullchain LPE — CODEGATE 2025 Finals", "https://github.com/enki-kr/codegate2025-final-fullchain/tree/main/Fullchain-LPE/prob", "ENKI", "2025", 5, "Windows fullchain CTF browser sandbox kernel LPE source", "A purpose-built Windows full-chain challenge distributed with its target components and environment rather than only a remote endpoint. The preserved source makes it possible to study how the stages and security boundaries were designed, reproduce the intended escalation path, and compare a solution against the exact vulnerable implementation."],
    ["BabyKernel — Dragon CTF 2019", "https://github.com/j00ru/ctf-tasks/tree/master/Dragon%20CTF%202019/Main%20event/BabyKernel", "j00ru", "2019", 5, "Windows kernel CTF driver pool memory corruption source exploit", "A Windows kernel pwnable authored by a specialist in Windows vulnerability research and preserved with challenge materials and documentation. It offers a compact but realistic driver interface for practicing reverse engineering, kernel debugging, memory-corruption triage, and exploit construction against a known build."],
    ["Winsanity — CODEGATE 2020 Finals", "https://github.com/leesh3288/CTF/tree/master/2020/CODEGATE_2020_Finals/winsanity", "leesh3288", "2020", 5, "Windows usermode CTF heap exploitation source exploit writeup", "A difficult Windows user-mode pwn challenge preserved with exploit and writeup material from CODEGATE Finals. The artifact is particularly useful for reconstructing the allocator state and mitigation assumptions from code, then comparing that reasoning with a complete solver instead of relying on a short event recap."],
    ["Winterpreter — CODEGATE 2020 Quals", "https://github.com/leesh3288/CTF/tree/master/2020/CODEGATE_2020_Preliminary/winterpreter", "leesh3288", "2020", 5, "Windows CTF interpreter VM exploitation arbitrary code execution", "A Windows pwnable built around a custom interpreter, with the target and exploit writeup retained together. It exercises the transition from recovering bytecode and object semantics to identifying a memory-safety primitive and escaping the virtualized execution model under Windows-specific calling and memory constraints."],
    ["LowFunHeap — Hack.lu CTF 2020", "https://github.com/leesh3288/CTF/tree/master/2020/Hacklu_2020/LowFunHeap", "leesh3288", "2020", 5, "Windows Low Fragmentation Heap CTF LFH exploitation", "A rare Windows heap challenge centered on Low Fragmentation Heap behavior, accompanied by exploit material from an experienced Windows CTF solver. It is valuable for practicing subsegment and bucket reasoning, heap shaping, and corruption under an allocator whose behavior differs substantially from the glibc heap assumed by most pwn curricula."],
    ["Breath of Shadow — HITCON CTF 2019", "https://github.com/scwuaptx/CTF/blob/master/2019-writeup/hitcon/breathofshadow.c", "AngelBoy", "2019", 5, "Windows kernel CTF driver stack pivot kernel shellcode exploit", "A complete exploit artifact for a Windows kernel challenge whose constrained execution environment forces careful use of kernel APIs and control-flow state. Reading the source alongside the challenge writeups exposes the practical decisions around stack integrity, payload execution, and returning a stable system after ring-0 code runs."],
    ["dadadb — HITCON CTF 2019", "https://github.com/scwuaptx/CTF/blob/master/2019-writeup/hitcon/dadadb.py", "AngelBoy", "2019", 5, "Windows CTF usermode heap database exploit Python", "A solver artifact for HITCON's Windows database pwnable from a researcher known for advanced Windows heap challenges. The exploit provides a concrete route through protocol interaction, memory disclosure, heap manipulation, and final control flow, making it suitable for line-by-line reconstruction in a debugger."],
    ["LazyFragmentationHeap", "https://github.com/scwuaptx/LazyFragmentationHeap", "AngelBoy", "2020", 5, "Windows LFH heap exploitation training challenge slides", "A dedicated Windows heap exploitation challenge and research package with slides explaining the relevant allocator behavior. It bridges theory and practice by pairing the target with material on LFH internals and the grooming strategy needed to make a corruption primitive reliable."],
    ["BFS Windows Exploitation Challenge 2022", "https://voidsec.com/windows-exploitation-challenge-blue-frost-security-2022/", "VoidSec", "2022", 5, "Windows CTF integer overflow stack overflow IRETD GDT shellcode", "An end-to-end solution to Blue Frost Security's Windows challenge, moving from protocol recovery through a signedness bug and stack corruption to mitigation-aware code execution. The unusual IRETD and GDT work, bad-byte constraints, commented exploit, database, and target binary make it a particularly reproducible user-mode case study."],
    ["BFS Ekoparty Exploitation Challenge 2019", "https://connormcgarr.github.io/eko2019-exe/", "Connor McGarr", "2019", 5, "Windows 10 x64 CTF ASLR DEP ROP information leak", "A detailed Windows 10 x64 solution to a network service challenge requiring full ASLR and DEP bypass. It develops the vulnerability, leak, module recovery, stack pivot, and ROP chain in a debugger, providing the intermediate reasoning normally omitted from final exploit scripts."],
    ["GTF — WCTF 2019", "https://github.com/icchy/wctf2019-gtf", "icchy", "2019", 5, "Windows CTF kernel GDI exploitation challenge slides", "A preserved Windows exploitation challenge repository with accompanying slides from WCTF 2019. The combination of target artifacts, presentation, and implementation details supports independent reconstruction of the Windows-specific primitive and provides stronger evidence than an isolated solve script."],
    ["PigDriver — WCTF Kernel Driver Challenge", "https://github.com/FlappyPig/WCTF-pigdriver/blob/master/Windows%2BKernel%2BDriver%2BChallenge-r3kapig.pdf", "r3kapig", "2018", 4, "Windows kernel driver CTF PDF reverse engineering exploit", "A substantial writeup for a Windows kernel driver challenge that walks through interface recovery, bug analysis, and exploit construction. Although delivered as a PDF, it preserves the technical narrative and code needed to understand the intended ring-0 path rather than merely recording the flag or final payload."],
    ["DoroboH — SECCON CTF 2022", "https://github.com/0xcpu/ctf/blob/main/writeups/seccon_2022/DoroboH.md", "0xcpu", "2022", 5, "Windows CTF reversing heap exploitation DoroboH writeup", "A source-backed writeup for a difficult Windows challenge from SECCON, documenting the recovered program model and the exploitation path with supporting code. It is useful for studying how Windows runtime and allocator details surface in a competition target when conventional Linux tooling and assumptions do not apply."],
    ["SSTIC 2021 Stage 2", "https://github.com/nneonneo/sstic-2021/tree/main/files/stage2", "nneonneo", "2021", 5, "Windows SSTIC challenge reverse engineering emulator exploit artifacts", "The second-stage artifact set from Robert Xiao's complete SSTIC 2021 solution, preserving files and tooling for a highly layered systems challenge. It rewards careful reconstruction of undocumented formats and Windows behavior, and the repository allows the analysis to be repeated instead of consumed only as prose."],
    ["EasyWin — Insomni'hack 2017", "https://github.com/Insomnihack/Insomnihack-2017/tree/master/pwn/easywin", "Insomni'hack", "2017", 4, "Windows PE CTF beginner exploitation source binary", "An approachable Windows pwn challenge released by the organizers with source and deployment artifacts. It is a useful entry point for adapting stack-corruption and PE analysis fundamentals to Windows calling conventions, APIs, and debugger workflow before moving to the event's more advanced targets."],
    ["Winworld — Insomni'hack Teaser 2017", "https://github.com/Insomnihack/Teaser-2017/tree/master/winworld", "Insomni'hack", "2017", 4, "Windows CTF pwn PE challenge source exploit practice", "An organizer-preserved Windows challenge with the original binary and supporting material, suitable for reproducing the intended vulnerability and mitigation analysis. Its compact scope makes it valuable practice for identifying Windows-specific execution details without the environmental uncertainty of an unavailable remote service."],
    ["winhttpd — Insomni'hack Teaser 2019", "https://github.com/Insomnihack/Teaser-2019/tree/master/winhttpd", "Insomni'hack", "2019", 5, "Windows HTTP server CTF network pwn heap exploitation", "A Windows network-service pwnable released with its original challenge artifacts by the organizers. It combines protocol-facing input processing with native memory corruption, making it good practice for moving from packet structure and request lifecycle to a reliable exploit under Windows mitigations."],
    ["Firewall — CSAW CTF 2017", "https://github.com/osirislab/CSAW-CTF-2017-Quals/tree/master/pwn/firewall", "OSIRIS Lab", "2017", 5, "Windows CTF firewall driver pwn source solution", "An organizer repository containing the Windows-oriented Firewall pwnable and its solution artifacts. Keeping construction and solution side by side makes it possible to audit the intended vulnerability, reproduce the service, and understand the exploit's assumptions without depending on third-party mirrors."],
    ["STAR Labs Windows Exploitation Challenge 2025", "https://starlabs.sg/blog/2025/03-star-labs-windows-exploitation-challenge-2025-writeup/", "STAR Labs / Võ Văn Tiến Dũng", "2025", 5, "Windows kernel CTF race condition UAF pool DQE arbitrary read write", "A complete solution to a purpose-built Windows kernel challenge centered on racing message buckets into a non-paged-pool use-after-free. It develops the corrupted object through buffered DQE reclamation and fake-object spraying into arbitrary kernel read/write, with enough structure recovery and timing detail to reproduce the reasoning."],
    ["HFSAntiCheat — Midnight Sun CTF Finals", "https://clubby789.me/hfsanticheat/", "clubby789", "2023", 5, "Windows kernel CTF KMDF anti-cheat IOCTL physical memory shellcode", "Reverses a KMDF anti-cheat driver, reconstructs its IOCTL surface, and works through a deliberately unusual kernel exploitation environment. The writeup is strong because it documents failed assumptions, WDF structure recovery, physical-memory constraints, and the final kernel payload rather than presenting only a solve script."],
    ["OpenDoor — HTB Business CTF 2022", "https://www.hackthebox.com/blog/open-door-business-ctf", "Hack The Box", "2022", 4, "Windows kernel CTF arbitrary read write EPROCESS token WinDbg", "An accessible Windows kernel challenge built around an intentionally backdoored driver exposing arbitrary read/write. It provides a clean laboratory for locating kernel modules and EPROCESS objects, walking ActiveProcessLinks, and replacing a token while learning the relevant WinDbg workflow."],
    ["Secure Storage Driver — CCCamp 2023", "https://ctftime.org/writeup/37751", "h4x0r-dz / CTFtime", "2023", 4, "Windows kernel CTF pool overflow IOCTL kernel read write", "A ring-0 Windows challenge writeup that begins with the supplied user-mode client and reverses the driver's IOCTL contract before exploiting a kernel pool corruption primitive. Its value is the concrete transition from interface reconnaissance to controlled kernel memory operations and a working exploit."],
    ["WkNote — SECCON CTF 2023 Finals", "https://ctftime.org/writeup/38357", "mephi42 / CTFtime", "2023", 4, "Windows kernel CTF note driver heap pool exploit", "A compact but code-backed solution to a Windows kernel note-driver pwnable from SECCON Finals. The linked exploit is the important artifact: it demonstrates kernel heap manipulation and the exact user-mode interactions needed to turn the challenge bug into privilege escalation."],
    ["FileUtility — Pflanzen CTF 2026", "https://unvariant.pages.dev/writeups/plfanzenctf-2026/die-braucht-viel-licht/", "unvariant", "2026", 5, "Windows kernel CTF file object handle driver exploitation", "A modern Windows kernel challenge whose driver consumes a user-supplied file handle and returns file metadata under subtle lifetime and object-manager constraints. The solution is valuable for its detailed exploration of Windows file objects, kernel handles, exploitation dead ends, and the stronger primitive ultimately constructed."],
    ["Reverse Engineering a Kernel Driver Challenge", "https://pwner.gg/blog/2024-09-22-kernel-driver-pwn", "pwner.gg", "2024", 4, "Windows driver challenge reversing bug PoC exploitation series", "A staged driver-pwn laboratory presented as a reversing and exploitation series: recover the interface, locate the vulnerability, build a trigger, then strengthen the primitive toward LPE. The article serves as the durable index while the accompanying videos preserve the live analysis process and mistakes."],
    ["Pwn2Own 2013 Windows kernel exploit", "https://labs.reversec.com/posts/2013/09/mwr-labs-pwn2own-2013-write-up-kernel-exploit", "MWR Labs", "2013", 5, "Pwn2Own Windows win32k pool overflow kernel fuzzer sandbox escape", "A classic but still instructive account of the win32k kernel stage used to escape Chrome's sandbox at Pwn2Own. It covers fuzzer discovery, root-cause analysis, pool layout control, exploit construction, and the mitigations of its era, making it useful historical context for how Windows kernel pwn matured."],
    ["ProcessFlipper — SekaiCTF 2024", "https://github.com/project-sekai-ctf/sekaictf-2024/tree/main/pwn/process-flipper", "Project Sekai CTF", "2024", 5, "Windows 11 kernel CTF anti-cheat driver LPE solution", "An expert Windows 11 kernel challenge inspired by commercial anti-cheat behavior and distributed with the driver, environment, and official solution. The repository preserves both challenge construction and exploit source, making it substantially more useful than a narrative writeup without artifacts."],
    ["InsoBug — Insomni'hack 2023", "https://itm4n.github.io/insomnihack-2023-insobug/", "itm4n", "2023", 5, "Windows RPC CTF impersonation WebClient NTLM relay service", "A meticulously documented Windows RPC challenge built around a realistic authentication and impersonation logic bug. The writeup reconstructs the service interface, RPC transport, WebClient behavior, token state, and exploit path while explaining why several obvious approaches fail."],
    ["Hexacon 2022 Hyper-V Challenge", "https://github.com/nneonneo/hexacon-2022", "nneonneo", "2022", 5, "Hyper-V CTF VM escape VMBus reverse engineering exploit", "A complete solution artifact for Hexacon's Windows Hyper-V escape challenge, including tooling and exploit code. It is high-value practice for reverse engineering host/guest communication, reconstructing undocumented protocols, and chaining a virtual-device bug across the VM trust boundary."],
    ["Archangel Michael's Storage — HITCON CTF 2020", "https://github.com/scwuaptx/CTF/tree/master/2020-writeup/hitcon/MichaelStorage", "AngelBoy", "2020", 5, "Windows usermode CTF segment heap exploitation", "An advanced Windows user-mode heap challenge and solution focused on the segment heap rather than the classic NT heap. The source-backed writeup is useful for allocator state reconstruction, heap grooming, and studying exploitation techniques that are underrepresented in general pwn material."],
    ["Lucifer — HITCON CTF 2020", "https://github.com/scwuaptx/CTF/tree/master/2020-writeup/hitcon/lucifer", "AngelBoy", "2020", 5, "Windows kernel CTF segment heap driver exploitation", "A Windows kernel challenge designed around the kernel segment heap, with challenge and exploit artifacts preserved together. It provides rare hands-on material for understanding allocator metadata and grooming on builds where older pool exploitation recipes no longer describe reality."],
    ["BitmapManager — Dragon CTF 2020", "https://github.com/j00ru/ctf-tasks/tree/master/Dragon%20CTF%202020/BitmapManager", "j00ru / Dragon Sector", "2020", 5, "Windows kernel CTF bitmap manager driver challenge solution", "A professionally authored Windows kernel pwnable distributed with source, binaries, deployment material, and solution artifacts. It is a strong target for practicing driver attack-surface recovery and exploit construction against a challenge designed by an experienced Windows vulnerability researcher."],
    ["LOKALTAL — Hack.lu CTF 2025", "https://ctf.gg/blog/lokaltal", "unvariant and cope", "2026", 5, "Windows 11 kernel CTF CVE-2023-21688 ALPC UAF LPAC IO ring", "Ports the AlpcpCreateView use-after-free to Windows 11 25H2 and begins exploitation inside a Low-Privilege AppContainer. The writeup develops a difficult race, pool reclamation with several object families, an arbitrary decrement, failed modern PreviousMode paths, and two final read/write strategies including I/O rings, with challenge files and debugging notes attached."],
    ["Address Book — ECW CTF 2024", "https://blog.randorisec.fr/fr/ctf-ecw-2024/", "RandoriSec", "2024", 5, "Windows pwn CTF address book heap LFH ROP ECW", "A one-solve Windows user-mode pwn challenge documented from protocol and PE triage through heap corruption and final exploitation. The article includes the solver scripts and enough allocator and mitigation reasoning to reproduce the chain, making it a useful modern complement to older Windows 7 heap exercises."],
    ["Baby Heap but Windows — justCTF 2024 Finals", "https://eternal.red/2024/baby-heap-but-windows/", "sajjadium / justCTF", "2024", 5, "Windows usermode CTF segment heap UAF LFH note service", "An author writeup for a one-solve Windows heap challenge distributed with source, solver, VM instructions, and a remotely hosted note service. It follows a dangling note object through Windows heap behavior, disclosures, grooming, and control-flow recovery, providing a rare competition-grade user-mode allocator case with authoritative artifacts."],
    ["BadType — Dragon CTF 2019 Teaser", "https://github.com/j00ru/ctf-tasks/tree/master/Dragon%20CTF%202019/Teaser/BadType", "j00ru / Dragon Sector", "2019", 5, "Windows CTF OpenType CharStrings font engine reverse engineering maze", "An official Windows x64 challenge that hides its verifier inside OpenType CharStrings interpreted by the platform font engine. The repository includes the PE, embedded-font workflow, maze reconstruction, solution summary, and solver, making it high-quality practice in tracing an unusual Windows parser and virtual machine rather than recognizing a conventional flag check."],
    ["Easier: Refreshing the Main Process Heap", "https://j00ru.vexillium.org/2016/07/windows-user-mode-exploitation-trick-refreshing-the-main-process-heap/", "Mateusz Jurczyk / Dragon Sector", "2016", 5, "DEF CON CTF Easier Windows heap refresh ROP DEP ASLR AppJailLauncher", "Explains Dragon Sector's solution to the five-solve DEF CON Quals Easier service, where heap corruption yields read/write but subsequent Windows API calls destabilize the already-damaged allocator. The key technique builds a replacement process heap, repairs PEB state, and then runs a CreateFile/ReadFile/WriteFile ROP chain under DEP and ASLR, turning a challenge-specific obstacle into a reusable exploitation pattern."],
    ["Divided: Windows Pwn and WinDbg Automation", "https://www.securifera.com/blog/2017/06/18/defcon-ctf-2017-divided-writeup/", "Securifera", "2017", 5, "DEF CON CTF Divided Windows OOB write WinDbg pwntools ROP CFG", "Develops an independent solution to DEF CON Quals Divided while documenting the missing Windows exploit-development automation around it. The writeup builds WinDbg process and breakpoint control for pwntools, models the challenge's airline state machine, isolates an out-of-bounds ticket write, and carries the corruption through debugger-assisted address recovery and payload construction rather than presenting only the final script."],
    ["Eko 2019: BFS Windows Pwn", "https://www.danbrodsky.me/writeups/bfsctf2019-ekko/", "Daniel Brodsky", "2019", 5, "BFS Ekoparty Windows pwn PE TIB PEB WinExec socket exploit", "Provides a second, independently reasoned solution to the BFS Ekoparty Windows x64 service, beginning with its socket loop and annotated IDA decompilation. It traces the memory corruption, uses TIB and PEB relationships to recover process state and imported APIs, constructs a network-delivered exploit, and records the Windows-specific debugging lessons that complement Connor McGarr's separate ROP-oriented treatment."],
    ["Firewall: CSAW Windows POSIX Subsystem Pwn", "https://ctftime.org/writeup/7591", "shocktop / Shell Collecting Club", "2017", 5, "CSAW CTF Firewall Windows POSIX subsystem PSXDLL token exploit PE", "Solves an unusual PE executable targeting Windows Services for UNIX rather than ordinary Win32, first rebuilding the abandoned Windows 7 POSIX environment and identifying PSXDLL behavior. The writeup reverses the service-token gate, analyzes the reachable memory corruption with GDB, and develops the exploit within a subsystem whose ABI and loader assumptions differ from both ELF Linux pwn and conventional Windows binaries."],
    ["EasyWinHeap: Introductory Windows Heap Pwn", "https://xuanxuanblingbling.github.io/ctf/pwn/2020/07/09/winpwn/", "xuanxuanblingbling", "2020", 5, "SCTF EasyWinHeap Windows 7 UAF unlink WinDbg IDA ucrt system", "Uses SCTF EasyWinHeap to teach Windows exploitation by explicit comparison with familiar Linux tooling and allocator concepts. It configures symbols for WinDbg and IDA, reconstructs NT heap entries and free lists, turns a dangling pointer into heap and image leaks, applies Windows unlink to rewrite the note index, recovers ucrtbase, and redirects a function pointer to system, with enough debugger output to reproduce every transition."],
    ["BabyPwn — WCTF 2019", "https://ctftime.org/writeup/15951", "Andrea Fioraldi and Matteo Rizzo / mhackeroni", "2019", 5, "WCTF BabyPwn Windows PE32 Diffie Hellman integer overflow ROP ASLR DEP", "Documents the first-blood and only solve of a hybrid Windows pwn and cryptography challenge whose PE32 service implements a flawed Diffie–Hellman exchange before processing attacker-controlled encrypted data. The solution reverses the unrecognized entry flow, exploits an integer truncation to reach memory corruption, derives usable protocol keys, leaks kernel32 across a first connection, relies on Windows' boot-scoped module layout for a second connection, and constructs a DEP-compatible ROP chain rather than ignoring the cryptographic state machine."],
    ["Process Flipper — SekaiCTF 2024", "https://nu1lptr0.github.io/2024/10/10/windows-kernel-challenge-process-flipper.html", "Abhishek Kumar Singh / nu1lptr", "2024", 5, "SekaiCTF Process Flipper Windows 11 24H2 kernel EPROCESS DiskCounters token read write", "Provides a beginner-friendly reconstruction of a rare Windows 11 24H2 kernel challenge whose runner accepts compiled exploits and returns screenshots from a real target. Starting with a constrained EPROCESS field-flip primitive, the writeup explains how DiskCounters.BytesWritten can be observed and influenced through NtQuerySystemInformation, converts that behavior into token disclosure and modification, handles current structure offsets and target-process discovery, and reaches SYSTEM without assuming legacy unrestricted kernel-pointer queries."],
    ["Phrack 40th Anniversary Windows Kernel Challenge", "https://github.com/xforcered/PhrackCTF", "Chompie / X-Force Red", "2025", 5, "Phrack CTF AVeryNormalDriver Windows kernel LPE challenge source exploit pool memory", "Preserves the complete Windows half of Phrack's 40th-anniversary binary-exploitation challenge: the signed AVeryNormalDriver target, reproducible virtual-machine environment, original binaries, source released after the event, and example exploits. Multiple intended vulnerabilities and solution paths make the repository useful for practicing driver reversal, IOCTL recovery, kernel memory corruption, mitigation-aware privilege escalation, and exploit comparison rather than following a single preordained token-swap recipe."],
    ["Lokaltal — Hack.lu CTF 2025", "https://unvariant.pages.dev/writeups/hackluctf-2025/lokaltal/", "unvariant, kroot, and cope", "2025", 5, "Hack.lu Lokaltal CVE-2023-21688 ALPC use after free Windows 11 25H2 kernel exploit", "Ports CVE-2023-21688's AlpcpCreateView use-after-free into a contemporary Windows kernel challenge and then carries the exploit to Windows 11 25H2 under stricter assumptions than the original public analysis. The team reconstructs ALPC section-view lifetime, orchestrates the race, grooms the relevant pool allocations, builds disclosure and corruption stages, and adapts the final privilege path around modern pointer-leak and PreviousMode restrictions, with code and failure analysis retained throughout."],
    ["Searchme — WCTF 2018 Paged-Pool Off-by-One", "https://j00ru.vexillium.org/2018/07/exploiting-a-windows-10-pagedpool-off-by-one/", "Mateusz Jurczyk / Google Project Zero", "2018", 5, "WCTF Searchme Windows 10 kernel paged pool off by one bitmap GDI token exploit", "Develops WCTF's searchme.sys challenge from four recovered buffered-I/O commands into a reliable Windows 10 kernel exploit for a single-byte paged-pool overflow. The article studies controllable allocation sizes and adjacency, shapes pool layout, selects corruption targets whose low byte has useful semantics, builds kernel information disclosure and arbitrary memory effects, and completes SYSTEM elevation while carefully explaining allocator behavior, reliability problems, and why the same bug class is substantially harder than its size suggests."],
    ["ProcessFlipper — Author Solution and Runner Design", "https://sekai.team/blog/sekaictf-2024/flipper", "nyancat0131 / Project SEKAI", "2024", 5, "SekaiCTF ProcessFlipper Windows 11 24H2 EPROCESS DiskCounters exploit runner kernel", "Gives the challenge author's complete account of ProcessFlipper, including the nested Windows 11 24H2 infrastructure that compiled and executed player submissions as well as the intended kernel solution. Starting from a constrained primitive that can flip an attacker-selected EPROCESS field, it derives observable read and write behavior through process accounting, evaluates safer targets than blindly replacing Token, and records alternate solver strategies discovered during the event."],
    ["BabyKernel — Midnight Sun CTF 2024 Quals", "https://cbsctf.ru/media/tpost/gobec8zn41-reshenie-zadaniya-babykernel-s-midnight", "Georgy 'ker' Kiguradze / C4T BuT S4D", "2024", 5, "Midnight Sun CTF BabyKernel Windows driver ProbeForRead ProbeForWrite PreviousMode token", "Builds an approachable but technically complete solution to Midnight Sun's Windows kernel task from driver loading and IOCTL recovery through its flawed use of ProbeForRead and ProbeForWrite. The writeup explains the caller-mode assumption behind the checks, turns the resulting access into practical kernel memory primitives, locates the relevant process and token state, and includes the debugger and exploit details needed to reproduce SYSTEM escalation rather than treating the driver as a black box."],
    ["BFS Ekoparty 2022 Windows Exploitation Challenge", "https://vulndev.io/2022/11/03/ekoparty-2022-bfs-windows-challenge/", "xct", "2022", 5, "Ekoparty BFS Windows x64 signed length stack overflow IRET GDT mode switch shellcode", "Solves a Windows network pwnable whose signed length check expands into a stack overflow but whose initialized executable heap and bad-byte filter demand an unusual control-flow plan. The writeup reconstructs the packet state machine, lands on an IRET sequence, selects usable GDT descriptors to enter 32-bit user mode, performs a far jump back to 64-bit execution, restores the stack, and publishes staged proof-of-concept code for every transition."],
    ["Windowsland — HITCON CTF 2018", "https://github.com/wmliang/windowsland", "wmliang", "2018", 5, "HITCON Windowsland CTF kernel driver exploit challenge source WinDbg", "Preserves a solver's full working directory for HITCON's Windows-native pwn challenge, including exploit source, debugger automation, recovered structures, and supporting binaries rather than only a retrospective summary. The repository is particularly useful for reconstructing the exact user-to-kernel interaction and comparing intermediate crash-state assumptions with a finished exploit, while its focused artifacts make it practical to reproduce in an isolated Windows VM."],
    ["BabyStack — HITB GSEC 2017 Windows Pwn", "https://whereisk0shl.top/post/hitb_gsec_ctf_babystack_writeup", "k0shl / Tencent Security", "2017", 5, "HITB GSEC BabyStack Windows CTF PE stack overflow ASLR DEP ROP WinDbg", "Documents an end-to-end Win32 exploitation workflow for HITB's BabyStack challenge, beginning with PE mitigation inspection and debugger-assisted stack reconstruction before converting the corruption into a mitigation-aware chain. The article retains annotated disassembly, register and stack states, leak reasoning, gadget selection, payload construction, and the final exploit, making it a useful historical baseline for Windows calling conventions and ROP rather than a flag-only competition note."],
    ["Breath of Shadow — HITCON CTF 2019", "https://ctftime.org/writeup/16782", "mephi42 / LC↯BC", "2019", 5, "HITCON Breath of Shadow Windows 10 kernel driver direct IO stack overflow ROP ZwOpenFile", "Takes a low-integrity command shell and a supplied Windows 10 driver through full remote kernel exploitation under unusually restrictive conditions. The solver reconstructs the buffer contract, triggers an output-length stack overflow, develops and debugs a kernel ROP chain with x64 alignment and interrupt-safe stack placement, discovers why kernel handles cannot solve the task directly, and ultimately redirects file access so the protected flag can be recovered without relying on token stealing."],
    ["Trumpervisor — Hack the Vote 2016", "https://ctftime.org/writeup/5269", "diogomonica / CTFtime", "2016", 5, "Trumpervisor Windows 10 x64 driver VT-x hypervisor VM exit MSR bitmap kernel CTF", "Reverse engineers a Windows 10 x64 driver that installs a Blue-Pill-style VT-x hypervisor, making the challenge a study of both kernel initialization and virtual-machine control state. The writeup maps VMXON and VMCS setup, EPT and intercept configuration, hypercall and VM-exit dispatch, then turns an unsafe guest-to-hypervisor interface into controlled host execution, preserving debugger observations and exploit code for a rare Windows-native virtualization pwnable."],
    ["BabyKernel — Dragon CTF 2019", "https://blog.null2root.org/blog/2020/01/11/BabyKernel-Dragon2019-writeup.html", "y0ny0ns0n / NULL@ROOT", "2020", 5, "Dragon CTF BabyKernel Windows 10 SecureDrv ProbeForWrite integer overflow CFG SMEP kernel exploit", "Builds a complete solution for SecureDrv.sys from reproducible Windows 10 and kernel-debugger setup through reversing its three IOCTL operations and global callback state. A zero-length integer edge case defeats ProbeForWrite's user-address validation, exposing memory and an executable pool callback; the article then navigates SMEP, kernel CFG, structure offsets, shellcode placement, token replacement and stable triggering with annotated WinDbg state and a working exploit."],
    ["calc.exe — snakeCTF 2024 Quals", "https://snakectf.org/writeups/2024-quals/pwn/calc", "snakeCTF", "2024", 5, "snakeCTF calc.exe Windows x86 pwn stack overflow SEH DEP ASLR ROP calculator", "Presents an official solution to a purpose-built 32-bit Windows calculator whose fixed result array can be driven out of bounds through ordinary arithmetic operations. The writeup reconstructs the object and stack layout, identifies the corruption and available disclosures, accounts for PE mitigations and Windows calling conventions, and develops the values, stack pivot and return-oriented chain needed for reliable code execution rather than treating the executable as a generic ret2win exercise."],
    ["Return to Mania — SunshineCTF 2019", "https://github.com/Cryptogenic/Exploit-Writeups/blob/master/CTF/SunshineCTF-2019/Return%20To%20Mania.md", "Cryptogenic", "2019", 5, "SunshineCTF Return to Mania Windows x86 pwn stack overflow DEP ROP VirtualProtect PE", "Documents a Windows PE pwnable where a constrained stack overflow must be converted into execution with a mitigation-aware ROP chain. The solver establishes the overwrite and bad-character boundaries, inventories usable modules and imported APIs, constructs the calling frame and stack transition required for VirtualProtect, and supplies a complete pwntools exploit, making the challenge a compact but auditable exercise in Windows x86 ABI and DEP bypass."],
    ["Madame Mercy — Hexacon 2023 Challenge", "https://challenge.hexacon.fr/writeups/2023/writeup-madame_mercy.pdf", "Hexacon Challenge Solvers", "2023", 5, "Hexacon Madame Mercy Windows driver SQLPAL CapnProto key value store secstore exploit reverse engineering", "Solves a deliberately cross-platform challenge that hosts a Windows storage driver as a library inside a Linux SQLPAL process and exposes it through a Cap'n Proto service. The 29-page writeup reconstructs container artifacts and schemas, reverses the driver's IRP and IOCTL dispatch plus its in-memory tree, connects integer keys to the public string API, and develops the corruption and protocol interactions needed to recover the protected data."],
    ["Kernel Crackme — X-MAS CTF 2019", "https://ctf.harrison.green/2019/x-mas-ctf/kernel_crackme/", "Harrison Green", "2019", 4, "X-MAS CTF Windows kernel crackme driver IRP WinDbg obfuscation return address mangling license key", "Provides a complete beginner-friendly Windows kernel reversing path from a two-VM WinDbg setup to the user/client and driver communication contract. The solver identifies the Crackme device and read/write IRP handlers, follows ProbeForRead and ProbeForWrite boundaries into a block transform, removes deterministic preprocessing and return-address-mangled control flow, then inverts the resulting byte operations to recover the license key instead of brute forcing the user-mode comparison."],
    ["HFSAntiCheat — TokyoWesterns Solution", "https://ptr-yudai.hatenablog.com/entry/2023/08/26/201508", "ptr-yudai / TokyoWesterns", "2023", 5, "Midnight Sun CTF HFSAntiCheat Windows kernel physical memory read write page table NtQueryIntervalProfile", "Offers an independent solution to HFSAntiCheat that is valuable precisely because the first elegant exploit failed under the distributed Vagrant target. After reversing the driver's physical-memory IOCTLs, the author documents a broken virtual-to-physical approach, adapts under the five-second limit by scanning physical memory for the NtQueryIntervalProfile implementation, overwrites it with token-stealing shellcode and triggers the modified path, preserving the reliability tradeoff and complete C client."],
    ["Vision — VolgaCTF 2026 Qualifier", "https://blog.sdark.me/vision-volgactf-2026", "SD4RK", "2026", 5, "VolgaCTF Vision Windows kernel reverse VMProtect kdmapper driver callback encrypted registry flag", "The author solution to a zero-solve Windows kernel reversing challenge that combines a nonstandard driver, a VMProtect-packed client and kdmapper-based loading. The writeup recovers hashed kernel imports, initialization and callback logic without ordinary IOCTL handlers, unpacks and debugs the user component, reconstructs the shared state and cryptographic transformations, and shows how user/kernel behavior must be analyzed together to extract the intended flag."],
    ["Winworld — Insomni'hack Teaser 2017 Solution", "https://blog.scrt.ch/2017/01/27/exploiting-a-misused-c-shared-pointer-on-windows-10/", "Nicolas Collignon / SCRT", "2017", 5, "Windows usermode CTF x64 C++ shared_ptr use after free CFG AppContainer WinHTTP ROP", "Presents the challenge author's detailed solution for a hardened Windows 10 C++ service running with ASLR, DEP, Control Flow Guard, and AppContainer isolation. It traces a misused shared pointer into a reliable use-after-free, explains object and heap manipulation needed for control, and develops the mitigation-aware code-reuse and WinHTTP exfiltration path while preserving the Windows-specific constraints that make the chain educational."],
    ["Greenhornd — CSAW CTF 2014", "https://oviche.github.io/2020/09/CSAW-CTF-2014-greenhornd-Writeup/", "Ovi Che", "2020", 5, "CSAW greenhornd Windows x86 pwn OpenProcess ReadFile WriteFile ROP DEP AppJailLauncher", "Reconstructs a classic 32-bit Windows pwnable inside a reproducible AppJailLauncher service rather than translating it into a Linux surrogate. The solution recovers the stack overwrite, inventories PE imports and usable gadgets under DEP, respects stdcall argument layout, and builds an OpenFile, ReadFile and WriteFile ROP chain that returns the protected key across the socket, offering a compact exercise in Windows handles, calling conventions and file-oriented code reuse."],
    ["Pwn2Win 2021: PE Analysis and Accessing the Truth", "https://ptr-yudai.hatenablog.com/entry/2021/05/31/232507", "ptr-yudai / uuunderflow", "2021", 5, "Pwn2Win Windows PE parser OOB write ROP UEFI SMM bootloader shellcode CTF", "Documents two rare Windows-platform pwn tasks with complete solvers. For PE Analysis, cross-platform AFL fuzzing finds a libpe export-table indexing bug; a malicious PE controls repeated stack writes and constructs an x64 Windows ROP chain using only the fixed analyzer image. Accessing the Truth then extracts a UEFI firmware image, triggers a boot-service memory bug, writes position-independent bootloader shellcode, locates EFI protocols and reads the flag before the operating system starts."],
    ["Accessing the Truth — Official Pwn2Win Solver", "https://github.com/epicleet/write-ups/blob/master/2021/Pwn2Win/pwn-Accessing_the_Truth/solve.py", "Pedro Barbosa / Epic Leet Team", "2021", 5, "Pwn2Win Accessing the Truth UEFI pwn firmware shellcode PEI DXE filesystem protocol", "Preserves the organizer's authoritative exploit generator for Pwn2Win's UEFI challenge, complementing the independent narrative with exact byte-level construction. The Python source parses and patches the supplied firmware artifacts, assembles the payload and lays out the protocol-facing shellcode used to recover the protected file, allowing researchers to compare intended offsets and EFI calling assumptions against the alternate solution instead of relying on screenshots or a dead remote service."],
    ["Archangel Michael's Storage — HITCON CTF 2020", "https://pwnfirstsear.ch/2020/12/09/hitconctf2020-archangel", "papa / pwn first search", "2020", 5, "HITCON Archangel Windows Server 20H2 Segment Heap OOB write LFH ROP CTF", "Works through a Windows Server 20H2 menu heap challenge while retaining unsuccessful hypotheses that reveal why older NT heap techniques do not transfer directly to the Segment Heap. An eight-byte out-of-bounds write is combined with backend and LFH allocation behavior to overlap typed storage, manufacture an address disclosure, recover ntdll and process mappings through Windows structures, and assemble the final ROP path, making the allocator reasoning more valuable than a flag-only solution."],
    ["PwnME — INTENT CTF 2022 Independent Solution", "https://pwner.gg/ctf-writeups/2022-12-17-intent-ctf-pwnme", "pwner.gg", "2022", 4, "INTENT CTF PwnME Windows x64 stack overflow information leak VirtualProtect ROP shellcode", "Provides a narrative companion to the preserved PwnME solver by rebuilding the exploit against a local Windows target before contacting the competition service. The writeup validates the disclosed gadget, stack and VirtualProtect addresses, lays out Microsoft x64 register arguments and writable output storage, aligns the protected stack region, and constructs the complete ROP-to-shellcode transition with executable code, making each Windows-specific assumption independently auditable."],
    ["Trustworthy — N1CTF 2018", "https://ctftime.org/writeup/9130", "shiki7 / Nu1L", "2018", 5, "Windows CTF S4U impersonation token IdentificationLevel AccessCheck thread token", "Builds a Windows pwnable around a security-logic error instead of memory corruption: a server enumerates client threads and evaluates their impersonation or primary tokens against a protected file's security descriptor. The intended solution creates an S4U logon token at Identification impersonation level and exploits the distinction between identity usable for AccessCheck and authority usable for impersonation, with the challenge source and solution preserving the exact token APIs and assumptions."],
    ["Weapon Safety — Cyber League 2022", "https://archive.elmo.sg/posts/ctfs/2022/cyberleague-weapon-safety/", "Elma / Social Engineering Experts", "2022", 5, "Windows pwn CTF x64 heap buffer overflow ROP VirtualProtect socket shellcode", "Walks through a native Windows x64 service from protocol and object-lifetime reconstruction to a working remote exploit. A size-management flaw turns a heap-backed weapon buffer into an overflow; the solution recovers module state, builds a Windows calling-convention-aware ROP chain, changes memory protection and transfers into staged shellcode over the existing socket, documenting the debugger and payload adjustments that distinguish the chain from a conventional Linux pwnable."],
  ]},
  { id: "mitigations", kicker: "Understand the boundary", title: "Mitigations & Windows Internals", items: [
    ["The Internals of AppLocker, Part 1", "https://www.tiraniddo.dev/2019/11/the-internals-of-applocker-part-1.html", "James Forshaw", "2019", 5, "AppLocker Windows application control policy internals setup enforcement", "Establishes an instrumented AppLocker laboratory and maps policy storage, rule collections, services, event channels, and the high-level enforcement architecture. The post is the correct foundation for the series because it distinguishes user-facing policy behavior from the kernel and user-mode mechanisms examined in the later installments."],
    ["The Internals of AppLocker, Part 2", "https://www.tiraniddo.dev/2019/11/the-internals-of-applocker-part-2.html", "James Forshaw", "2019", 5, "AppLocker process creation enforcement CI policy SaferIdentifyLevel", "Traces executable enforcement through process creation, application identity, code-integrity decisions, policy queries, and the access checks that ultimately allow or block an image. Debugger and API experiments show where AppLocker obtains identity and why enforcement cannot be reduced to a simple path or hash comparison."],
    ["The Internals of AppLocker, Part 3", "https://www.tiraniddo.dev/2019/11/the-internals-of-applocker-part-3.html", "James Forshaw", "2019", 5, "AppLocker access tokens security attributes conditional ACE access check", "Explains how AppLocker materializes policy decisions as token security attributes and how conditional ACEs consume those attributes during access checks. The analysis connects application identity to the general Windows authorization model, which is essential for understanding packaged-app ACLs, policy inheritance, and why copied tokens can produce surprising results."],
    ["The Internals of AppLocker, Part 4", "https://www.tiraniddo.dev/2019/11/the-internals-of-applocker-part-4.html", "James Forshaw", "2019", 5, "AppLocker DLL enforcement loader code integrity policy Windows", "Completes the series by following DLL enforcement through the Windows loader and code-integrity interfaces, including differences from primary executable checks and the performance and compatibility tradeoffs involved. It clarifies exactly when a module load is evaluated and which process state carries the effective AppLocker policy."],
    ["Empirically Assessing Windows Service Hardening", "https://www.tiraniddo.dev/2020/01/empirically-assessing-windows-service.html", "James Forshaw", "2020", 5, "Windows service hardening restricted SID privileges network firewall empirical", "Builds an automated, measurement-driven view of service hardening by collecting service SIDs, privileges, restricted tokens, network permissions, process mitigations, and accessible resources across Windows services. The resulting comparisons expose where similarly privileged services have materially different attack surfaces and demonstrate how to validate hardening rather than trust configuration labels."],
    ["Don't Use SYSTEM Tokens for Sandboxing", "https://www.tiraniddo.dev/2020/01/dont-use-system-tokens-for-sandboxing.html", "James Forshaw", "2020", 5, "Windows sandbox restricted SYSTEM token access checks privileges security boundary", "Demonstrates why deriving a restricted sandbox token from SYSTEM can preserve dangerous access through identity, ownership, default DACLs, service objects, and authorization assumptions even after privileges and groups are removed. Concrete token comparisons and resource tests turn a subtle design warning into a reusable sandbox-review methodology."],
    ["LowBox Token Permissive Learning Mode", "https://www.tiraniddo.dev/2021/09/lowbox-token-permissive-learning-mode.html", "James Forshaw", "2021", 5, "AppContainer LowBox token permissive learning mode access logging sandbox", "Reverse engineers an obscure LowBox token mode that records resources an AppContainer would have been denied while allowing execution to continue. The post identifies token flags, access-check integration, event collection, and practical creation through NtObjectManager, making the feature useful for designing and testing sandbox capability policies."],
    ["Enabling Adminless Mode on Windows 10 S Mode", "https://www.tiraniddo.dev/2019/01/enabling-adminless-mode-on-windows-10.html", "James Forshaw", "2019", 5, "Windows 10 S Mode adminless WDAC UAC policy security model", "Investigates the supported but poorly documented adminless configuration of Windows 10 S Mode, tracing account creation, policy state, application restrictions, recovery paths, and the resulting privilege model. The experiment provides concrete evidence for how application control and removal of persistent local administrators change the assumptions behind UAC-era hardening."],
    ["Inside Microsoft's Plan to Kill PPLFault", "https://www.elastic.co/security-labs/inside-microsofts-plan-to-kill-pplfault", "Gabriel Landau / Elastic", "2023", 5, "PPLFault Code Integrity page hashes SEC_IMAGE Cloud Filter mitigation", "Patch-diffs Windows Insider builds to identify the memory-manager and Code Integrity change that blocks PPLFault by enforcing page hashes for network-backed images. Kernel debugging compares vulnerable and fixed behavior, connects the change to SEC_IMAGE immutability assumptions, and evaluates both Microsoft's fix and Elastic's NoFault mitigation."],
    ["Dismantling Smart App Control", "https://www.elastic.co/security-labs/dismantling-smart-app-control", "Joe Desimone / Elastic", "2024", 5, "Smart App Control SmartScreen reputation Mark of the Web LNK bypass", "Maps Smart App Control and SmartScreen trust decisions, then tests signed malware, reputation hijacking and seeding, interpreter abuse, and a Mark-of-the-Web-removing LNK canonicalization bug. Public utilities, samples, call stacks, in-the-wild evidence, and compensating detections make this both a mitigation study and a rigorous bypass assessment."],
    ["A Windows Authorization Guide", "https://csandker.io/2018/06/14/A-Windows-Authorization-Guide.html", "Christoph Sandker", "2018", 5, "Windows authorization access tokens SIDs privileges ACL security descriptors", "Builds Windows authorization from access tokens, SIDs, groups, privileges, integrity levels, security descriptors, DACLs, and the access-check algorithm. The article is valuable mitigation context for every IPC and service exploit in the catalog because it supplies the vocabulary needed to explain exactly why an operation is permitted instead of reducing findings to 'bad permissions.'"],
    ["DUT Processes in Windows 10", "https://windows-internals.com/dut-processes-in-windows-10/", "Alex Ionescu and Yarden Shafir", "2020", 5, "DUT process Windows protection level secure process trust model", "Investigates the undocumented DUT process category and places it within Windows' evolving protected-process and trust model. By recovering creation policy, flags, and kernel checks, the post illustrates how security-sensitive process classes differ from ordinary PPL labels and why precise terminology matters when evaluating process protection boundaries."],
    ["Random Windows Things: PreviousMode Mitigation", "https://windows-internals.com/random-windows-things-part-1-previousmode-mitigation/", "Yarden Shafir", "2026", 5, "PreviousMode Windows kernel mitigation KTHREAD exploit primitive hardening", "Examines Microsoft's newer hardening around the KTHREAD PreviousMode field, a long-standing target for turning kernel writes into trusted kernel-mode system-call behavior. It traces the implementation changes and their consequences for exploit chains, providing current context for why older PreviousMode recipes no longer transfer unchanged to recent builds."],
    ["Goodbye Secure Pool, Hello KDP Pool", "https://windows-internals.com/goodbye-secure-pool-hello-kdp-pool/", "Yarden Shafir", "2026", 5, "KDP pool secure kernel VTL1 memory integrity mitigation", "Documents the evolution from the original Secure Pool design to a KDP-backed pool mechanism for protecting sensitive kernel allocations. The analysis connects allocator behavior, VTL boundaries, access policy, and compatibility tradeoffs, making it a useful current reference for researchers evaluating which kernel data can still be modified from VTL0."],
    ["Module Tampering Protection", "https://windows-internals.com/understanding-a-new-mitigation-module-tampering-protection/", "Yarden Shafir", "2022", 5, "module tampering protection MTP Windows kernel image integrity", "Reverse engineers Module Tampering Protection as introduced in Windows, explaining the policy, loader integration, protected regions, and enforcement path rather than relying on the feature name. The post is particularly useful for distinguishing this mechanism from PatchGuard, HVCI, and ordinary image-signature checks when modeling kernel code-integrity boundaries."],
    ["HyperGuard Part 1: SKPG Initialization", "https://windows-internals.com/hyperguard-secure-kernel-patch-guard-part-1-skpg-initialization/", "Yarden Shafir", "2022", 5, "HyperGuard SKPG secure kernel PatchGuard VTL1 initialization", "The first part of a detailed HyperGuard reconstruction, following Secure Kernel Patch Guard initialization and the handoff of protected state into VTL1. It provides the vocabulary and lifecycle needed to reason about later extents and checks, while clearly separating hypervisor-enforced protection from traditional PatchGuard behavior in the normal kernel."],
    ["HyperGuard Part 2: SKPG Extents", "https://windows-internals.com/hyperguard-secure-kernel-patch-guard-part-2-skpg-extents/", "Yarden Shafir", "2022", 5, "HyperGuard SKPG extents secure kernel protected memory", "Continues the HyperGuard analysis by decoding SKPG extents, the descriptors that identify memory and state subject to secure-kernel validation. The article ties recovered structures to initialization and checking code, enabling researchers to verify precisely what is covered rather than treating HyperGuard as an undocumented monolithic integrity feature."],
    ["HyperGuard Part 3: More SKPG Extents", "https://windows-internals.com/hyperguard-part-3-more-skpg-extents/", "Yarden Shafir", "2022", 5, "HyperGuard SKPG extents callbacks MSR control registers", "Expands the extent taxonomy with additional protected targets and validation forms, including state that cannot be described as a simple immutable memory range. Read with the first two parts, it becomes an unusually complete public model of how Windows delegates sensitive kernel integrity checks across the VTL boundary."],
    ["Secure Pool Internals: Dynamic KDP", "https://windows-internals.com/secure-pool/", "Yarden Shafir", "2020", 5, "Secure Pool dynamic KDP VBS VTL1 kernel data protection", "Reverse engineers Secure Pool and Dynamic Kernel Data Protection from allocation request through secure-kernel enforcement. It explains how selected kernel data becomes read-only to ordinary VTL0 code while remaining manageable through controlled interfaces, giving exploit developers and defenders a concrete model of data protection under VBS."],
    ["R.I.P ROP: CET Internals in Windows", "https://windows-internals.com/cet-on-windows/", "Yarden Shafir", "2020", 5, "CET shadow stack Windows kernel user mode ROP mitigation", "A foundational implementation-level analysis of Intel CET support in Windows, covering shadow stacks, process policy, context switching, exception handling, and kernel participation. It goes well beyond a mitigation overview and explains the structures and transitions that determine whether return-address corruption is actually prevented."],
    ["CET Updates: CET on Xanax", "https://windows-internals.com/cet-updates-cet-on-xanax/", "Yarden Shafir", "2020", 5, "CET relaxed mode compatibility shadow stack Windows", "Examines Windows' compatibility mechanisms for applications that cannot immediately obey strict shadow-stack semantics, including relaxed handling and policy transitions. The details are important for security analysis because they reveal where deployment compatibility changes the effective protection promised by CET on paper."],
    ["CET Updates: Dynamic Address Ranges", "https://windows-internals.com/cet-updates-dynamic-address-ranges/", "Yarden Shafir", "2021", 5, "CET dynamic code JIT shadow stack address ranges mitigation", "Explains how Windows accommodates JIT engines and other dynamic-code producers under CET using managed address ranges and explicit policy. The article maps the supporting APIs and kernel bookkeeping, helping researchers distinguish legitimate dynamically generated call targets from gaps or abuse opportunities in shadow-stack enforcement."],
    ["The KASLR graveyard: leaking ntoskrnl on Windows 11 25H2", "https://afflicted.sh/blog/posts/kaslr-graveyard.html", "afflicted.sh", "2026", 5, "Windows 11 25H2 KASLR leaks GDT IDT desktop heap prefetch", "Tests a wide catalog of kernel-base disclosure paths against a concrete Windows 11 25H2 target and explains why each succeeds or fails. The result works like a modern KASLR decision tree spanning restricted queries, descriptor tables, desktop heaps, physical memory, CPU differences, and prefetch behavior."],
    ["Bypassing Windows Kernel Mitigations: Part 0", "https://hackyboiz.github.io/2025/04/13/l0ch/bypassing-kernel-mitigation-part0/en/", "Hackyboiz / L0ch", "2025", 5, "Windows 11 24H2 KASLR prefetch EntryBleed KVA shadow", "Explains the Windows 11 24H2 KASLR restriction from an exploit developer's perspective, then adapts an EntryBleed-style prefetch timing side channel. It connects page tables, KVA shadowing, TLB state, and CPU-specific timing behavior to practical ntoskrnl-base recovery."],
    ["Windows Exploit Mitigations", "https://github.com/nccgroup/exploit_mitigations/blob/main/windows_mitigations.md", "NCC Group", "Living", 5, "Windows mitigations DEP ASLR CFG CET reference", "A maintained knowledge base that maps Windows exploit mitigations to their purpose, scope, and implementation context. Use it as a high-level map before diving into a single bypass or comparing protections across platform generations."],
    ["KASLR Leaks Restriction", "https://windows-internals.com/kaslr-leaks-restriction/", "Windows Internals", "2024", 5, "ExIsRestrictedCaller NtQuerySystemInformation KASLR", "Explains the Windows changes that remove many kernel-address disclosures from unprivileged callers. It is the best starting point for understanding ExIsRestrictedCaller, affected system-information classes, and why older disclosure assumptions no longer hold."],
    ["An End to KASLR Bypasses?", "https://windows-internals.com/an-end-to-kaslr-bypasses/", "Windows Internals", "2024", 4, "kernel pointers restricted caller integrity level", "Provides the broader design context behind Microsoft's restriction of kernel pointer disclosures. It helps connect integrity levels and sandbox boundaries to the mitigation and identifies assumptions embedded in older Windows kernel exploits."],
    ["Windows Kernel Shadow Stack Mitigation", "https://www.synacktiv.com/sites/default/files/2025-06/sstic_windows_kernel_shadow_stack_mitigation.pdf", "Synacktiv / SSTIC", "2025", 5, "kernel shadow stack CET mitigation PDF", "A deep technical treatment of Windows kernel shadow stacks and their consequences for control-flow hijacking. The slides are dense but valuable when evaluating which exploitation paths kernel CET removes and what remains available."],
    ["The new Windows Component Filter mitigation", "https://big5-sec.github.io/posts/component-filter-mitigation/", "BIG5", "2024", 5, "Windows Component Filter kernel mitigation KASLR", "Reverse engineers the Component Filter mitigation and explains how Windows restricts sensitive system information by caller context. Read it alongside the KASLR restriction posts to understand both policy and implementation details."],
    ["Intel VT-rp, Part 1", "https://tandasat.github.io/blog/2023/07/05/intel-vt-rp-part-1.html", "Tandasat", "2023", 5, "Intel VT remapping HLAT KDP g_CiOptions", "Introduces a virtualization-based remapping attack and the role of Hypervisor-managed Linear Address Translation. It demonstrates how page-remapping ideas interact with KDP and g_CiOptions, connecting hardware virtualization to Windows kernel protection research."],
    ["Windows Internals archive", "https://windows-internals.com/category/windows-internals/", "Winsider", "Living", 5, "Windows internals kernel secure kernel VBS", "A concentrated archive of original Windows internals research spanning the kernel, secure kernel, mitigations, and low-level APIs. Use it as a topic index and favor the individual articles when recording a technique or claim."],
    ["ZeroHVCI", "https://github.com/zer0condition/ZeroHVCI", "zer0condition", "2024", 5, "HVCI bypass CVE-2024-26229 CVE-2024-35250 KernelForge kernel ROP", "Chains kernel read/write primitives from csc.sys and ks.sys vulnerabilities with KernelForge's HVCI-compatible function-calling technique. The source demonstrates data access and constructed kernel calls without loading an unsigned driver, making it a concrete study of what memory integrity blocks, what it still permits, and how separate primitives compose."],
    ["Introducing Kernel Data Protection", "https://www.microsoft.com/en-us/security/blog/2020/07/08/introducing-kernel-data-protection-a-new-platform-security-technology-for-preventing-data-corruption/", "Microsoft Security Team", "2020", 5, "Kernel Data Protection KDP VBS SLAT secure pool driver data", "The primary implementation overview of static and dynamic KDP, explaining how VTL1 and hypervisor-controlled second-level page tables make selected driver data read-only even after VTL0 kernel compromise. It documents MmProtectDriverSection, ExAllocatePool3 secure-pool parameters, tags and cookies, unload semantics, GVA-to-GPA-to-SPA translation, and the trust boundary enforced by EPT or NPT."],
    ["KVA Shadow: Mitigating Meltdown on Windows", "https://www.microsoft.com/en-us/msrc/blog/2018/03/kva-shadow-mitigating-meltdown-on-windows", "Microsoft Security Response Center", "2018", 5, "KVA Shadow Meltdown page tables PCID TLB Windows kernel mitigation", "Describes the extensive Windows kernel redesign used to isolate kernel mappings from user-mode page tables against Meltdown. The article covers separate address spaces, user/kernel transition costs, PCID_KERNEL and PCID_USER tagging, translation-buffer preservation and invalidation, driver compatibility assumptions, and why performance varies by processor capability and workload."],
    ["Understanding Hardware-enforced Stack Protection", "https://techcommunity.microsoft.com/blog/windowsosplatform/understanding-hardware-enforced-stack-protection/1247815", "Microsoft Windows Kernel Protection", "2020", 5, "Intel CET shadow stack ROP control protection exception Windows", "Introduces Windows' hardware-backed backward-edge control-flow integrity from the processor contract upward: shadow-stack pages, SSP state, CALL and RET comparison, #CP delivery, new CET management instructions, context switching, PE opt-in metadata, and the relationship with CFG, DEP, ASLR, CIG, and ACG. It provides the architectural baseline needed before studying compatibility exceptions or bypasses."],
    ["Developer Guidance for Hardware-enforced Stack Protection", "https://techcommunity.microsoft.com/blog/windowsosplatform/developer-guidance-for-hardware-enforced-stack-protection/2163340/", "Microsoft Windows Kernel Protection", "2021", 5, "CET compatibility strict mode EH continuation dynamic code Windows", "Details the deployed user-mode CET policies that the introductory article leaves open: compatibility versus strict enforcement, /CETCOMPAT modules, dynamic-code ranges, instruction-pointer validation for exception handling, process mitigation controls, audit surfaces, and unsupported WoW64 or guest scenarios. The compatibility rules are especially important when assessing the mitigation's effective rather than advertised coverage."],
    ["Kernel-mode Hardware-enforced Stack Protection", "https://learn.microsoft.com/en-us/windows-server/security/kernel-mode-hardware-stack-protection", "Microsoft", "Living", 4, "kernel CET shadow stacks VBS HVCI driver blocklist Windows 11", "Documents the production kernel-mode form of hardware shadow-stack enforcement, including its VBS and HVCI prerequisites, supported Intel and AMD generations, CFG interaction, return-address mismatch behavior, enablement policy, and incompatible-driver blocklist. It complements reverse-engineering research with the current platform support and deployment contract administrators and driver authors must satisfy."],
    ["Driver Compatibility with Hypervisor-Protected Code Integrity", "https://learn.microsoft.com/en-us/windows-hardware/test/hlk/testref/driver-compatibility-with-device-guard", "Microsoft", "Living", 4, "HVCI memory integrity W XOR X driver compatibility HLK Windows", "Provides the authoritative driver-development constraints imposed by HVCI: executable memory cannot be writable, executable pool and dynamic code patterns must be removed, section alignment and relocations must be valid, and HLK checks can identify incompatible images. This is a practical complement to offensive HVCI research because it defines which driver behaviors the isolated code-integrity boundary is designed to reject."],
    ["Software Defense: Mitigating Heap Corruption Vulnerabilities", "https://www.microsoft.com/en-us/msrc/blog/2013/10/software-defense-mitigating-heap-corruption-vulnerabilities/", "Matt Miller / Microsoft", "2013", 5, "Windows 8 heap hardening LFH metadata guard pages allocation randomization", "Explains the Windows 8 and 8.1 heap changes from the engineering team that built them: fatal metadata checks, global pointer encoding, extended-header validation, guard-page placement, and randomized LFH allocation order. The threat-oriented discussion is particularly useful because it connects each implementation change to the exploitation assumption it was intended to invalidate and states the residual limitations."],
    ["Windows 10 Segment Heap Internals", "https://www.blackhat.com/docs/us-16/materials/us-16-Yason-Windows-10-Segment-Heap-Internals-wp.pdf", "Steven Yason / IBM X-Force", "2016", 5, "Windows 10 Segment Heap LFH VS allocator backend metadata", "Reconstructs the Segment Heap introduced for modern Windows applications, covering its variable-size and low-fragmentation front ends, backend page ranges, allocation metadata, data structures, and debugger-assisted experiments. It remains the foundational implementation reference for researchers who need to reason about heap grooming or corruption on processes that no longer use the classic NT heap."],
    ["Exploring Control Flow Guard in Windows 10", "https://documents.trendmicro.com/assets/wp/exploring-control-flow-guard-in-windows10.pdf", "Trend Micro Research", "2015", 5, "Control Flow Guard CFG bitmap indirect calls compiler loader bypass", "Reverse engineers the first deployed Windows CFG design across compiler instrumentation, PE metadata, loader processing, the global call-target bitmap, and runtime dispatch. It also tests practical limitations and bypass surfaces, providing the low-level baseline needed to understand why later Windows releases changed bitmap ownership and why XFG attempted a finer-grained policy."],
    ["Control Flow Guard for Platform Security", "https://learn.microsoft.com/en-us/windows/win32/secbp/control-flow-guard", "Microsoft", "Living", 4, "Control Flow Guard CFG compiler linker valid call targets API", "Documents the supported CFG contract for native applications: compiler and linker opt-in, indirect-call validation, module compatibility, valid-call-target registration, executable-memory behavior, and verification through PE headers. Read beside reverse-engineering work, it distinguishes stable platform guarantees and developer controls from build-specific loader internals."],
    ["Leveraging XFG to Help with Reverse Engineering", "https://m417z.com/Leveraging-XFG-to-help-with-reverse-engineering/", "Michael Maltsev", "2023", 5, "eXtended Flow Guard XFG function hashes x64dbg reverse engineering", "Turns XFG's compiler-generated type hashes into useful reverse-engineering metadata, precisely locating the eight-byte signatures before indirect-call targets and automating their recognition in x64dbg. Although the focus is analysis rather than bypass, the implementation evidence clarifies what XFG records in binaries, how dispatch checks consume it, and how tooling should avoid decoding hashes as instructions."],
    ["CFG in Windows 11 24H2", "https://ynwarcs.github.io/Win11-24H2-CFG", "Yarden Shafir", "2024", 5, "Windows 11 24H2 CFG SCPCFG hotpatch kernel user mode bitmap", "Reverse engineers the substantial CFG redesign in Windows 11 24H2 across both user and kernel mode, including SCPCFG structures, hotpatch coupling, bitmap management, dispatch paths, and altered initialization. Its build-specific debugging and recovered layouts make it the natural modern counterpart to the original Windows 10 CFG research and expose which legacy assumptions no longer hold."],
    ["Windows Defender System Guard Runtime Attestation", "https://www.microsoft.com/security/blog/2018/04/19/introducing-windows-defender-system-guard-runtime-attestation/", "Microsoft Defender Research and Windows Platform Security", "2018", 5, "System Guard runtime attestation VBS enclave TPM session certificate kernel tampering", "Designs an attestation path that can report security-state violations even after an attacker gains ordinary kernel privileges. The article places measurement and signing inside a VBS enclave, binds boot properties and a per-session public key to a Microsoft-signed certificate, keeps the corresponding private key outside VTL0 reach, defines report security levels for different hardware configurations, and explains how relying parties verify runtime claims rather than trusting telemetry generated in the compromised domain."],
    ["VBS Memory Enclaves: Data Protection Through Isolation", "https://www.microsoft.com/en-us/security/blog/2018/06/05/virtualization-based-security-vbs-memory-enclaves-data-protection-through-isolation/", "Microsoft Defender Security Research", "2018", 5, "VBS memory enclave VTL1 secure kernel Vertdll attestation sealing isolated execution", "Introduces the Windows VBS enclave programming and trust model for isolating sensitive user-mode code and data from both normal processes and a compromised VTL0 kernel. It covers enclave image signing, Vertdll imports, secure allocation, host-call restrictions, local and remote attestation, key sealing, debugging constraints, and the HVCI and virtualization prerequisites, providing the platform contract behind later offensive enclave and runtime-attestation research."],
    ["Kernel DMA Protection", "https://learn.microsoft.com/en-us/windows/security/hardware-security/kernel-dma-protection-for-thunderbolt", "Microsoft", "Living", 4, "Kernel DMA Protection IOMMU DMA remapping Thunderbolt USB4 PCIe lock screen", "Defines the production Windows boundary against drive-by DMA attacks from hot-plug PCIe, Thunderbolt, USB4, and CFexpress peripherals. The documentation explains how the IOMMU blocks devices until their drivers support DMA remapping, confines compatible devices to assigned memory regions, defers incompatible hardware until an authorized unlock, exposes policy and verification state, and distinguishes this runtime protection from older BitLocker-only countermeasures."],
    ["Windows Exploit Protection Mitigation Reference", "https://learn.microsoft.com/en-us/defender-endpoint/exploit-protection-reference", "Microsoft", "Living", 4, "Exploit Protection ACG CIG ASLR DEP SEHOP EAF IAF Win32k mitigation reference", "Provides the authoritative behavior and compatibility contract for Windows' configurable process mitigations rather than only listing their names. It specifies enforcement and failure semantics for Arbitrary Code Guard, Code Integrity Guard, image-load restrictions, Win32k lockdown, child-process blocking, DEP, ASLR, SEHOP, heap and handle validation, and legacy ROP checks, including audit modes, thread opt-outs, JIT constraints, and the MitigationOptions policy surface needed to reproduce tests consistently."],
    ["Introducing Kernel Sanitizers on Microsoft Platforms", "https://www.microsoft.com/en-us/security/blog/2023/01/26/introducing-kernel-sanitizers-on-microsoft-platforms/", "Microsoft Security Response Center", "2023", 5, "KASAN KCSAN kernel sanitizers shadow memory compiler instrumentation Windows Xbox", "Describes Microsoft's production adaptation of compiler-assisted kernel sanitizers for finding memory-safety and concurrency defects before release. The technical walkthrough covers the one-to-eight shadow-memory layout, poisoned redzones, allocation and free instrumentation, compiler-inserted checks, crash reporting, driver enablement, performance constraints, and deployment across Windows and Xbox, connecting bug-class prevention directly to the flaws exploit mitigations otherwise must contain at runtime."],
    ["Solving Uninitialized Kernel Pool Memory", "https://www.microsoft.com/en-us/msrc/blog/2020/07/solving-uninitialized-kernel-pool-memory-on-windows", "Joe Bialek / Microsoft MSRC", "2020", 5, "Windows kernel pool zero initialization ExAllocatePool2 ExAllocatePool3 memory disclosure mitigation", "Explains Microsoft's engineering path toward eliminating uninitialized kernel-pool disclosures by construction, from performance experiments and rejected allocator designs to new zero-by-default pool APIs and migration of the memory manager. It quantifies the bug class, cache and allocation costs, compiler limitations, opt-out semantics, deployment stages, and optimization work behind a mitigation that changes the default security contract for driver allocations."],
    ["Solving Uninitialized Stack Memory with InitAll", "https://www.microsoft.com/en-us/msrc/blog/2020/05/solving-uninitialized-stack-memory-on-windows", "Joe Bialek / Microsoft MSRC", "2020", 5, "Windows InitAll compiler uninitialized stack variables zero initialization MSVC mitigation", "Documents the design and deployment of InitAll, Microsoft's compiler transformation that initializes eligible stack variables before use and deterministically removes an entire disclosure and control-flow bug class from protected Windows code. The article compares zero and pattern initialization, code-size and runtime effects, redundant-store elimination, telemetry compatibility, build rollout, and concrete vulnerabilities neutralized before their source defects were serviced."],
    ["Safe Unlinking and Reference-Count Hardening", "https://www.microsoft.com/en-us/msrc/blog/2013/11/software-defense-safe-unlinking-and-reference-count-hardening", "Ken Johnson / Microsoft MSRC", "2013", 5, "Windows fast fail LIST_ENTRY safe unlink reference count wrap kernel hardening", "Connects Windows 8 and 8.1 lifetime-safety defenses to the exploitation primitives they interrupt: fail-fast termination, doubly linked-list consistency checks, object-manager reference-count wrap prevention, pointer-sized counters, and shared inline instrumentation. Its CVE-2013-1280 case study and precise discussion of over-reference versus under-reference limitations make the residual boundary as useful as the protections themselves."],
    ["Safe Unlinking in the Kernel Pool", "https://www.microsoft.com/en-us/msrc/blog/2009/05/safe-unlinking-in-the-kernel-pool", "Microsoft Security Research & Defense", "2009", 5, "Windows 7 kernel pool safe unlink LIST_ENTRY arbitrary write mitigation", "Presents the original Windows 7 kernel-pool safe-unlinking change from the team that shipped it, first deriving the classic free-list corruption and arbitrary-write primitive and then adding forward and backward link-consistency validation before removal. The discussion covers bugcheck behavior, performance cost, compatibility, threat-model limits, and why corrupting adjacent application data remains possible even after allocator metadata is protected."],
    ["Hardening the Hyper-V VM Worker Process", "https://www.microsoft.com/en-us/msrc/blog/2019/09/attacking-the-vm-worker-process/", "Saar Amar / Microsoft MSRC", "2019", 5, "Hyper-V VMWP sandbox CFG export suppression ACG CIG SeImpersonate hardening", "Uses a guest-to-host Hyper-V exploit study to explain why the VM worker process is a valuable boundary and how Microsoft reduced its usable attack surface. Beyond reconstructing the device and worker architecture, it evaluates strong exploitation primitives against CFG export suppression, forced CFG, Arbitrary Code Guard, Code Integrity Guard, and removal of SeImpersonatePrivilege, including which demonstrated chain each policy breaks and what residual options remain."],
    ["Eternal Synergy Exploit Analysis", "https://www.microsoft.com/en-us/msrc/blog/2017/07/eternal-synergy-exploit-analysis", "Georgios Baltas / Microsoft MSRC", "2017", 5, "EternalSynergy CVE-2017-0143 SMB Windows kernel HVCI CFG exploit mitigation", "Reconstructs EternalSynergy's Windows SMB exploit chain from pool grooming and an out-of-bounds write through function-pointer corruption and kernel execution, then tests its assumptions against newer platform defenses. The case study is especially valuable because it shows concretely how HVCI blocks copied unsigned kernel code even in RWX memory while CFG rejects the corrupted indirect-call target, rather than describing either mitigation in isolation."],
    ["Control Flow Guard for Clang, LLVM, and Rust", "https://www.microsoft.com/en-us/msrc/blog/2020/08/control-flow-guard-for-clang-llvm-and-rust/", "Andrew Paverd / Microsoft Research", "2020", 5, "Windows CFG Clang LLVM Rust control-flow integrity compiler instrumentation PE COFF", "Explains Microsoft's implementation of Windows CFG support outside MSVC, covering compiler-generated indirect-call checks, linker-produced address-taken function tables, PE and COFF metadata, operating-system enforcement, and the upstream LLVM and Rust integration path. It is a useful bridge between platform internals and toolchain engineering because it identifies which protection guarantees come from compilation, linking, loading, and runtime dispatch respectively."],
    ["Why Microsoft Changed the Mitigation Bypass Bounty", "https://www.microsoft.com/en-us/msrc/blog/2018/06/announcing-changes-to-microsofts-mitigation-bypass-bounty", "Joe Bialek / Microsoft MSRC", "2018", 4, "CFG bypass threat model fine-grained CFI ACG CIG MemGC mitigation research", "Records Microsoft's post-deployment assessment of CFG after years of mitigation-bypass submissions and explains why the coarse-grained design was removed from bounty scope while remaining a supported defense. The article captures the evolved threat model—finer-grained target validation, read-only policy data, and safe unwind and exception handling—and places CFG beside ACG, CIG, and MemGC when judging the economic impact and residual limits of layered mitigations."],
    ["Windows Defender Application Control: May 2019 Engineering Update", "https://www.microsoft.com/en-us/security/blog/2019/07/01/delivering-major-enhancements-in-windows-defender-application-control-with-the-windows-10-may-2019-update/", "Windows Platform Security Team / Microsoft", "2019", 5, "WDAC code integrity path rules multiple policies COM script enforcement Application Control CSP", "Documents the Windows 10 1903 WDAC redesign around real deployment constraints: runtime administrator-write checks for otherwise weak path rules, composable base and supplemental policies, COM registration controls, optional script enforcement, rebootless policy updates, and a dedicated management CSP. The security discussion makes clear which policy combinations can only expand trust, where deny rules are honored, and how runtime path protection preserves the intended application-control boundary."],
    ["Introducing Windows Defender Application Control", "https://www.microsoft.com/en-us/security/blog/2017/10/23/introducing-windows-defender-application-control/", "Windows Platform Security Team / Microsoft", "2017", 4, "WDAC Device Guard configurable code integrity HVCI Intelligent Security Graph trust policy", "Separates configurable Code Integrity from the broader Device Guard label and explains the actual deployment and hardware boundaries between WDAC, HVCI, VBS, firmware protections, and the fully locked-down Device Guard state. It also introduces Intelligent Security Graph authorization as a reputation-backed alternative to enumerating every allowed binary, exposing the central application-control tradeoff between deterministic signer rules, operational coverage, and cloud-derived trust."],
    ["Randomizing KUSER_SHARED_DATA on Windows", "https://www.microsoft.com/en-us/msrc/blog/2022/04/randomizing-the-kuser_shared_data-structure-on-windows", "Ken Johnson / Microsoft MSRC", "2022", 5, "KUSER_SHARED_DATA KASLR blind write kernel exploit mitigation Windows 11", "Explains how a fixed writable KUSER_SHARED_DATA mapping survived earlier KASLR improvements as a dependable target for blind kernel writes, including remote exploits that could not first disclose an address. Microsoft preserves the documented user mapping while moving writable kernel state to a randomized allocation and leaving the legacy kernel address read-only, closing a generic exploit target without breaking applications that legitimately read shared system data."],
    ["Enabling Hardware-enforced Stack Protection in Chrome", "https://security.googleblog.com/2021/05/enabling-hardware-enforced-stack.html", "Alex Gough / Google Chrome Security", "2021", 5, "Chrome Windows CET shadow stack CETCOMPAT renderer exploit mitigation compatibility", "Documents a large real-world deployment of Windows user-mode CET in Chrome rather than discussing the instruction set only in theory. The engineering account covers CETCOMPAT marking, processor and Windows prerequisites, renderer and browser rollout, compatibility failures, crash telemetry, third-party module concerns, and the residual forward-edge attack surface, showing how hardware shadow stacks alter practical exploit chains while still requiring complementary control-flow defenses."],
    ["Mitigating Speculative-execution Side Channels on Windows", "https://www.microsoft.com/en-us/msrc/blog/2018/03/mitigating-speculative-execution-side-channel-hardware-vulnerabilities", "Matt Miller / Microsoft MSRC", "2018", 5, "Spectre Meltdown Windows KVA Shadow retpoline IBRS speculation side channel mitigation", "Builds a threat taxonomy for speculative-execution attacks and maps Windows mitigations to three distinct goals: preventing speculation primitives, removing secrets from reachable address spaces, and closing observation channels. It then relates firmware controls, compiler transformations, kernel changes, browser isolation, KVA Shadow, and operational compatibility costs to specific Spectre and Meltdown variants, preventing the common mistake of treating one toggle as universal coverage."],
    ["Mitigating Vulnerabilities in Endpoint Network Stacks", "https://www.microsoft.com/security/blog/2020/05/04/mitigating-vulnerabilities-endpoint-network-stacks/", "Microsoft Security Response Center", "2020", 5, "Windows TCP IP network stack RCE ASLR CFG InitAll HVCI Secured-core mitigation", "Uses remotely reachable network-stack vulnerabilities to show how layered Windows defenses change exploit reliability before a patch is available. The analysis connects ASLR and information-disclosure requirements, CFG-constrained indirect control flow, InitAll's removal of uninitialized state, HVCI's executable-memory restrictions, and Secured-core hardware isolation to attacker prerequisites, while distinguishing exploit prevention from detection and rapid servicing."],
    ["User Shadow Stack Policy Reference", "https://learn.microsoft.com/en-us/windows/win32/api/winnt/ns-winnt-process_mitigation_user_shadow_stack_policy", "Microsoft", "Living", 4, "PROCESS_MITIGATION_USER_SHADOW_STACK_POLICY CET strict mode audit dynamic EH continuation", "Defines the authoritative per-process policy bits behind Windows user-mode hardware shadow stacks, including compatibility and strict modes, audit behavior, dynamic-code exceptions, context and instruction-pointer validation, and CET-compatible exception continuation. It is a compact but essential reference for reproducing experiments because it identifies which controls are immutable after process creation and which apparent bypasses are expected compatibility behavior rather than failures of CET itself."],
    ["Investigating Windows Kernel-Mode Shadow Stacks", "https://connormcgarr.github.io/km-shadow-stacks/", "Connor McGarr", "2025", 5, "Windows kernel CET shadow stack HVCI VTL1 secure kernel VMCS context restore", "Reverse engineers kernel CET from both NT and Secure Kernel perspectives instead of extrapolating from user-mode shadow stacks. The investigation follows boot-policy decisions, kernel-stack allocation, secure calls, CONTEXT_EX and KERNEL_CET_CONTEXT restoration, supervisor SSP registers, and VTL0 guest state in the VMCS, then demonstrates why HVCI is a prerequisite for protecting shadow-stack pages and configuration against an attacker who already has kernel read/write."],
    ["Living with VBS, HVCI, and Kernel CFG", "https://connormcgarr.github.io/hvci/", "Connor McGarr", "2022", 5, "Windows VBS HVCI kCFG MBEC data only kernel exploit ROP CET", "Uses a real Dell driver arbitrary read/write primitive to test what HVCI and kernel CFG actually prevent. The article derives executable-page and CFG-bitmap protection from EPT and MBEC, shows why unsigned kernel shellcode and arbitrary indirect calls fail, then constructs a data-assisted return-address chain that remains policy-compliant while kernel CET is absent. Its conclusion carefully treats HVCI, kCFG, and kCET as complementary controls rather than calling a code-reuse path an HVCI bypass."],
    ["Mitigating Spectre Variant 2 with Retpoline on Windows", "https://techcommunity.microsoft.com/blog/windowsosplatform/mitigating-spectre-variant-2-with-retpoline-on-windows/295618", "Mehmet Iyigun / Microsoft", "2018", 5, "Windows Spectre variant 2 retpoline dynamic boot patching import optimization kernel", "Explains how Windows adopted retpoline without shipping separate kernels for processors that require different speculative-execution defenses. The compiler rewrites indirect branches through kernel stubs, while boot-time dynamic patching selects retpoline or the appropriate hardware-assisted sequence and import optimization preserves performance. The article documents CPU compatibility limits, branch-prediction reasoning, deployment gates, and the measurements behind replacing broadly expensive IBRS on supported systems."],
    ["Hardware-Based System Integrity for Defender", "https://www.microsoft.com/security/blog/2019/07/31/how-windows-defender-antivirus-integrates-hardware-based-system-integrity-for-informed-extensive-endpoint-protection//", "Microsoft Defender Research", "2019", 5, "Windows Defender System Guard runtime attestation VBS HVCI TPM assertions kernel integrity", "Describes how Defender combines ordinary endpoint telemetry with System Guard runtime attestation so security decisions can depend on properties measured from a hardware-isolated trust boundary. The technical case study follows assertion generation, VBS-protected validation, TPM-backed reporting, HVCI and kernel Code Integrity state, and cloud interpretation, showing how a defender can detect or constrain tampering even when the normal Windows kernel is considered potentially compromised."],
    ["RedirectionGuard: Blocking Unsafe Junction Traversal", "https://www.microsoft.com/en-us/msrc/blog/2025/06/redirectionguard-mitigating-unsafe-junction-traversal-in-windows", "Microsoft MSRC", "2025", 5, "Windows RedirectionGuard NTFS junction reparse point privileged file operation TOCTOU mitigation", "Introduces a Windows 11 mitigation designed to eliminate a recurring local-elevation bug class in which a privileged component follows attacker-controlled junctions or other reparse points during filesystem work. The article defines the unsafe traversal pattern, explains why ad hoc path validation and developer discipline repeatedly fail, outlines the operating-system enforcement and compatibility model, and shows how applications opt in or are protected centrally so one platform change can cover many privileged file-operation paths."],
    ["Demystifying Attack Surface Reduction Rules", "https://techcommunity.microsoft.com/blog/microsoftdefenderatpblog/demystifying-attack-surface-reduction-rules---part-1/1306420", "António Vasconcelos and Rob Mead / Microsoft", "2020", 4, "Microsoft Defender attack surface reduction ASR rules audit warn block exclusions deployment", "Explains the design and operational model of Microsoft Defender Attack Surface Reduction rules, separating the broad ASR security family from the individual behavior-based controls. The authors cover block, audit and warn modes, rule dependencies, exclusions, policy delivery and staged rollout, giving researchers the context needed to evaluate whether a technique defeats a mitigation, falls outside its intended scope, or only succeeds because the control was never safely deployed."],
    ["Windows Defender System Guard Platform Integrity", "https://www.microsoft.com/en-us/security/blog/2017/10/23/hardening-the-system-and-maintaining-integrity-with-windows-defender-system-guard/", "Microsoft", "2017", 5, "Windows Defender System Guard secure boot VBS runtime attestation platform integrity TPM", "Introduces System Guard as a chain of platform-integrity controls spanning hardware-rooted boot, virtualization-based isolation of critical services and post-boot runtime attestation. The article explains why gaining SYSTEM or even compromising the normal kernel should not automatically invalidate every security decision, then connects measured boot, VBS-protected state, assertions and remote verification into a layered trust model useful for assessing low-level persistence claims."],
    ["SMM Isolation and Platform Hardening", "https://www.microsoft.com/en-us/security/blog/2020/11/12/system-management-mode-deep-dive-how-smm-isolation-hardens-the-platform/", "Microsoft Enterprise and OS Security", "2020", 5, "Windows System Management Mode SMM isolation VBS HVCI firmware secure launch DMA protection", "Examines why System Management Mode sits above the hypervisor in the practical trust hierarchy and how compromised firmware handlers could undermine HVCI, Credential Guard and other VBS protections. The deep dive follows memory and device isolation, paging and validation requirements, platform firmware cooperation and Secured-core enforcement, extending Windows mitigation study below the NT kernel to the privileged execution environment that must be constrained for hardware-backed guarantees to remain meaningful."],
    ["Administrator Protection for Windows Applications", "https://blogs.windows.com/windowsdeveloper/2025/05/19/enhance-your-application-security-with-administrator-protection/", "Windows Developer Team", "2025", 4, "Windows administrator protection just in time elevation isolated admin token UAC application compatibility", "Describes Windows Administrator Protection's shift from a reusable split admin token to just-in-time elevation under an isolated identity, reducing the value of token theft and silent reuse by unelevated malware. The developer-focused guidance details process identity, file and registry separation, elevation flows, application compatibility and testing expectations, making it a useful architectural reference for distinguishing this newer boundary from conventional UAC consent behavior."],
    ["Software Defense: Exploit Mitigation and Vulnerability Detection", "https://www.microsoft.com/en-us/msrc/blog/2013/09/software-defense-series-exploit-mitigation-and-vulnerability-detection", "Microsoft Security Engineering Center", "2013", 5, "Windows software defense exploit mitigation vulnerability detection ASLR DEP CFG compiler SDL", "Frames exploit mitigation and proactive vulnerability detection as complementary engineering controls rather than substitutes for fixing bugs. Microsoft relates operating-system and Visual Studio defenses to exploit reliability, attacker economics and scalable bug discovery, providing historical design context for DEP, ASLR and later control-flow protections while offering a durable method for evaluating a mitigation by the primitive it removes, the assumptions it adds and the residual paths it leaves."],
    ["Windows Security Tools: Kernel Integration Best Practices", "https://www.microsoft.com/en-us/security/blog/2024/07/27/windows-security-best-practices-for-integrating-and-managing-security-tools/", "David Weston / Microsoft", "2024", 5, "Windows security sensor kernel mode PPL VBS enclave HVCI WDAC attestation Rust reliability", "Responds to the CrowdStrike outage with an architectural account of how security products can reduce both kernel attack surface and system-wide failure risk. Microsoft separates capabilities that genuinely require kernel execution from collection and analysis that can move into protected user mode, then connects PPL, VBS enclaves, HVCI, WDAC, runtime attestation, safer deployment rings and Rust support into a defense-in-depth engineering model rather than prescribing a single product fix."],
    ["An Armful of CHERIs", "https://msrc.microsoft.com/blog/2022/01/an_armful_of_cheris/", "David Chisnall / Microsoft MSRC", "2022", 5, "CHERI Morello Windows memory safety capabilities compartmentalization C C++ exploit mitigation", "Explains Microsoft’s investigation of CHERI and Arm Morello as a hardware-software route beyond probabilistic memory-corruption mitigations. The article shows how capabilities attach bounds, permissions and provenance to pointers, distinguishes deterministic spatial safety from compartmentalization, and relates those properties to existing C and C++ code, operating-system abstractions and the Verona research language, making clear which exploit primitives CHERI removes and which temporal or logic problems remain."],
    ["Recall Security and Privacy Architecture", "https://blogs.windows.com/windowsexperience/2024/09/27/update-on-recall-security-and-privacy-architecture/", "David Weston / Microsoft", "2024", 5, "Windows Recall VBS enclave TPM Windows Hello ESS encryption security architecture", "Documents the redesigned Recall trust model from data capture through storage, indexing and user-authorized retrieval. Sensitive operations and keys are isolated in VBS enclaves, identity is bound to Windows Hello Enhanced Sign-in Security and the TPM, snapshots are encrypted with per-user controls, and authorization gates resist ordinary administrator or kernel access; the post is useful for evaluating the boundary and residual assumptions of a prominent Windows feature rather than relying on marketing-level privacy claims."],
    ["Hardening the Trust Boundary of VBS Enclaves", "https://techcommunity.microsoft.com/blog/microsoft-security-blog/everything-old-is-new-again-hardening-the-trust-boundary-of-vbs-enclaves/4386961", "James Forshaw / Microsoft", "2025", 5, "Windows VBS enclave VTL0 VTL1 pointer validation strict memory policy trusted execution", "Uses concrete vulnerable enclave code to show that VTL isolation does not make an unsafe interface trustworthy: a hostile host can alias attacker-chosen offsets with enclave pointers and corrupt secret state across the boundary. The analysis derives robust pointer-validation rules from enclave address ranges and documents the later strict-memory policy, EnclaveRestrictContainingProcessAccess and copy APIs that prevent direct VTL0 dereferences, turning a subtle confused-deputy pattern into actionable secure-enclave guidance."],
    ["Windows 11 Security Architecture: New Platform Defenses", "https://www.microsoft.com/en-us/security/blog/2024/05/20/new-windows-11-features-strengthen-security-to-address-evolving-cyberthreat-landscape/", "Microsoft Security", "2024", 4, "Windows 11 VBS enclave Win32 app isolation administrator protection Pluton key protection", "Surveys the security boundaries being added or strengthened across current Windows 11 hardware, identity, applications and administration. The technically important connections are between Pluton and measured platform trust, VBS-backed credential and key isolation, AppContainer-based Win32 app isolation, protected printing, stronger signing defaults and just-in-time administrator access; together they provide a roadmap for locating the deeper implementation references behind each modern mitigation."],
    ["Hypervisor-enforced Paging Translation", "https://techcommunity.microsoft.com/blog/windowsosplatform/protecting-linear-address-translations-with-hypervisor-enforced-paging-translati/4399739", "Hilal Asmat / Microsoft", "2025", 5, "Windows HVPT HLAT page tables aliasing remapping SLAT VBS HVCI", "Explains how Windows 11 24H2 and Server 2025 use Intel HLAT and second-level translation controls to protect selected guest-virtual-to-physical mappings from kernel arbitrary writes. Secure-kernel-managed paging structures, Paging Write and Guest Paging Verification bits, the HLAT prefix and restart path are tied directly to remapping and aliasing attacks against KDP, CFG and shadow-stack state, with hardware and VBS prerequisites made explicit."],
    ["CHERI-Lite for Memory Safety", "https://www.microsoft.com/en-us/research/wp-content/uploads/2025/11/CHERI-Lite-for-Memory-Safety.pdf", "Microsoft Research", "2025", 5, "CHERI-Lite memory safety pointer provenance bounds C C++ hardware mitigation", "Presents a reduced-capability architecture aimed at bringing deterministic pointer integrity and spatial memory safety to large C and C++ systems with a smaller compatibility and hardware cost than full CHERI. The paper defines which pointer-forgery and out-of-bounds primitives the model prevents, how metadata and instructions enforce provenance and bounds, and where temporal safety, deployment, and legacy interoperability still require complementary controls."],
    ["Windows Kernel Security", "https://www.synacktiv.com/sites/default/files/2023-10/windows_kernel_security_hitb_slides.pdf", "Fabien Perigaud and colleagues / Synacktiv", "2023", 5, "Windows kernel mitigations CastGuard HVCI KCFG CET KDP exploit development", "Builds a mitigation-oriented map of the modern Windows kernel from an exploit developer's perspective, connecting KASLR, SMEP and SMAP, HVCI, kernel CFG, CET shadow stacks, KDP and CastGuard to the primitives each control removes. Concrete exploitation constraints and bypass history make the deck especially useful for understanding why a data-only chain may survive one layer while code injection, forged indirect calls, or C++ type confusion fail at another."],
    ["Mitigating Arbitrary Native Code Execution with MemGC", "https://blogs.windows.com/msedgedev/2015/06/17/mitigating-arbitrary-native-code-execution/", "Microsoft Edge Team", "2015", 5, "Microsoft Edge MemGC use after free memory safety garbage collection mitigation", "Describes MemGC as a browser exploit mitigation for use-after-free vulnerabilities rather than a generic garbage collector. The design tracks references from protected heap objects, delays reclamation while conservative scanning finds live pointers, and integrates with EdgeHTML and MSHTML allocation paths; the article discusses performance, compatibility and residual corruption classes so researchers can judge exactly when the defense breaks a native-code execution chain."],
    ["Hotpatching on Windows", "https://techcommunity.microsoft.com/t5/windows-os-platform-blog/hotpatching-on-windows/ba-p/2959541", "Windows Kernel Team / Microsoft", "2021", 5, "Windows hotpatch Secure Kernel PE image validation retpoline atomic security update", "Reverse engineers the operating-system path used to apply security fixes without rebooting, from PE hotpatch metadata and base-image validation through Secure Kernel participation and atomic code redirection. It explains how the engine handles user, NT kernel, Secure Kernel and hypervisor images, why patch entry stubs use retpoline-aware dispatch, and how compatibility and rollback constraints shape a mitigation that shortens exposure without weakening code integrity."],
    ["Finding Truth in the Shadows", "https://www.elastic.co/security-labs/finding-truth-in-the-shadows/", "Gabriel Landau / Elastic", "2023", 5, "Windows hardware stack protection CET shadow stack WinDbg stack spoofing detection ShadowStackWalk", "Examines user-mode Hardware Stack Protection beyond its intended ROP threat model, showing how the hardware-maintained return-address history can recover a corrupted or unwind-less call stack, reduce the cost of kernel telemetry walks, and expose deliberately forged frames. The published ShadowStackWalk proof of concept compares ordinary and shadow traces against ThreadStackSpoofer and CallStackSpoofer, while the article documents adoption limits—modern CPU requirements, partial process coverage, no WOW64 support—and why thread-context syscalls remain a future tampering surface."],
    ["Windows Defender Antivirus in a Sandbox", "https://www.microsoft.com/en-us/security/blog/?p=86257", "Microsoft Defender Research", "2018", 5, "Windows Defender antivirus sandbox MsMpEngCP AppContainer low privilege CFG DEP ASLR CIG Win32k lockdown", "Describes the engineering boundary that moves untrusted file parsing out of the privileged MsMpEng service and into low-privilege MsMpEngCP content processes. The design combines AppContainer isolation with DEP, ASLR and CFG locked against runtime changes, signed-code-only loading, disabled Win32k and extension points, capability minimization, process recycling, and a brokered coordination model. Compatibility, performance, remediation, and telemetry considerations show why sandboxing an antivirus parser is a system redesign rather than a single restricted token."],
    ["Clarifying Mandatory ASLR on Windows", "https://www.microsoft.com/en-us/msrc/blog/2017/11/clarifying-the-behavior-of-mandatory-aslr", "Matt Miller / Microsoft MSRC", "2017", 5, "Windows mandatory ASLR bottom up randomization WDEG EMET MitigationOptions DYNAMICBASE", "Separates forced image rebasing from entropy after a CERT/CC report exposed a confusing Windows Defender Exploit Guard and EMET configuration. Non-DYNAMICBASE modules can be displaced by mandatory ASLR, but their replacement address is predictable unless bottom-up randomization is also enabled; the article derives both controls, explains why opted-in images are unaffected, supplies system-wide and per-program workarounds, decodes the relevant MitigationOptions bytes, and warns that overriding the registry value may discard other exploit policies."],
    ["On the Effectiveness of DEP and ASLR", "https://www.microsoft.com/en-us/msrc/blog/2010/12/on-the-effectiveness-of-dep-and-aslr/", "Matt Miller / Microsoft Security Research & Defense", "2010", 5, "Windows DEP ASLR exploit mitigation ROP JIT spraying predictable DLL information disclosure", "Evaluates DEP and ASLR as a combined exploit-cost mechanism using observed browser and application exploits rather than treating either feature as absolute prevention. The analysis classifies real bypasses through predictable third-party mappings, address disclosures, JIT spraying and return-oriented programming, explains why DEP's value is dominated by layout secrecy once reusable code is available, and contrasts sophisticated chains with the much larger set of exploits that simply fail on protected targets. Its limitations and proposed mandatory-ASLR and JIT-hardening directions remain a useful model for measuring mitigation value."],
    ["When ASLR Makes the Difference", "https://www.microsoft.com/en-us/msrc/blog/2014/03/when-aslr-makes-the-difference/", "Elia Florio / Microsoft MSRC", "2014", 4, "Windows ASLR exploit reliability Internet Explorer Office third party DLL predictable mapping", "Compares two exploit samples targeting the same Internet Explorer vulnerability to isolate the practical effect of address randomization: one chain assumes fixed module locations and fails when the expected mapping moves, while the more capable chain obtains the information needed to adapt. The case study also demonstrates how a non-ASLR third-party DLL can weaken an otherwise randomized Microsoft process, making mitigation coverage an ecosystem property rather than an executable checkbox and giving defenders a concrete reason to inventory every loaded module."],
  ]},
  { id: "evasion", kicker: "Observe and evade", title: "Evasion & EDR", items: [
    ["Working Your Way Around an ACL", "https://www.tiraniddo.dev/2024/06/working-your-way-around-acl.html", "James Forshaw", "2024", 5, "WindowsApps conditional ACL token security attributes impersonation Explorer", "Dissects the conditional ACL protecting the WindowsApps directory and shows how an unelevated process can borrow an existing packaged-app token carrying WIN://SYSAPPID, then preserve it through Explorer process creation. The post is a precise example of satisfying an access policy through legitimate token state instead of modifying or bypassing the ACL itself."],
    ["Bypassing SACL Auditing on LSASS", "https://www.tiraniddo.dev/2017/10/bypassing-sacl-auditing-on-lsass.html", "James Forshaw", "2017", 5, "LSASS SACL auditing process handle access token duplicate evasion", "Examines Windows object auditing around LSASS and develops access paths whose effective operations are not represented by the expected SACL events. Native handle, token, and access-check behavior explain the telemetry gap, making the article valuable for defenders who might otherwise treat one process-access audit as complete credential-access coverage."],
    ["Sandboxing Antimalware Products", "https://www.elastic.co/security-labs/sandboxing-antimalware-products", "Gabriel Landau / Elastic", "2023", 5, "PPL antimalware token sandbox trust label SYSTEM integrity EDR bypass", "Shows that an administrator can open and modify a protected antimalware service's token, remove privileges, lower integrity, and quietly incapacitate the product without terminating its PPL process. The research traces token security descriptors and trust labels, releases PPLGuard mitigation code, and records Microsoft disclosure, giving both attack and defensive implementation evidence."],
    ["Effective Parenting: Detecting LRPC PPID Spoofing", "https://www.elastic.co/security-labs/effective-parenting-detecting-lrpc-based-parent-pid-spoofing/", "John Uhlmann / Elastic", "2023", 5, "LRPC COM WMI PPID spoofing process creation ETW correlation", "Studies process creation proxied through COM, WMI, and other LRPC servers as a parentage-evasion problem, then develops a generic detector by correlating RPC client and server activity with kernel process events. The article tests common heuristics, documents their blind spots, and proposes telemetry that recovers the initiating process rather than trusting the visible parent."],
    ["Detecting In-Memory Threats with Kernel ETW Call Stacks", "https://www.elastic.co/security-labs/doubling-down-etw-callstacks", "Elastic Security Labs", "2024", 5, "kernel ETW Threat Intelligence call stacks direct syscalls injection evasion", "Explains how kernel ETW call stacks expose direct and indirect syscalls, proxied calls, ROP-like transitions, unbacked executable memory, hollowing, and AMSI or ETW patching that bypass user-mode hooks. Concrete behavior fields and production detection rules make it an unusually transparent reference for both designing and evaluating modern in-memory evasion."],
    ["A Taxonomy of Endpoint Detection Bypasses", "https://www.elastic.co/blog/edr-bypass-taxonomy", "Gabriel Landau / Elastic", "2023", 5, "EDR bypass taxonomy kernel callbacks ETW minifilters user mode hooks", "Builds an architectural taxonomy of Windows endpoint sensors—kernel callbacks, minifilters, WFP, ETW, AMSI, event logs, and user-mode hooks—and maps bypass classes to the trust layer they defeat. The explicit distinction between asynchronous detection, synchronous prevention, tampering, and semantic evasion provides a durable framework for judging individual bypass claims."],
    ["Forget Vulnerable Drivers: Admin Is All You Need", "https://www.elastic.co/security-labs/forget-vulnerable-drivers-admin-is-all-you-need", "Gabriel Landau / Elastic", "2023", 5, "PPLFault GodFault PPL kernel exploit EDRSandblast driverless admin kernel", "Demonstrates an admin-to-PPL chain followed by a PPL-to-kernel trust violation, then uses the resulting access to reproduce vulnerable-driver-style EDR tampering without loading a driver. The report includes PPLFault, GodFault, NoFault, kernel consequences, mitigation guidance, and a careful discussion of the contested admin-to-kernel security boundary."],
    ["Do You Really Know LSA Protection?", "https://itm4n.github.io/lsass-runasppl/", "itm4n", "2021", 5, "LSASS RunAsPPL LSA protection protected process light Windows internals", "Builds the threat model for LSA protection from the actual RunAsPPL configuration, process-protection levels, signer requirements, and boot behavior. It is the necessary foundation for judging credential-dumping claims because it distinguishes what PPL prevents, what remains observable, and which trust boundaries later bypass research must cross."],
    ["Bypassing LSA Protection in Userland", "https://itm4n.github.io/bypassing-lsa-protection-userland/", "itm4n", "2021", 5, "LSA protection PPL bypass user mode DLL loading credential dumping", "Develops a user-mode route around LSA protection by studying how LSASS loads code and how protected-process signing policy is enforced. The article accounts for prerequisites, target state, payload constraints, and detection surface, making it a strong example of converting a platform-internals observation into a bounded credential-access technique."],
    ["Revisiting a Credential Guard Bypass", "https://itm4n.github.io/credential-guard-bypass/", "itm4n", "2022", 5, "Credential Guard VBS LSASS authentication package bypass secrets", "Re-examines a published Credential Guard bypass against current Windows behavior and traces credentials across LSASS, authentication packages, and the isolated security boundary. It is valuable because it tests the scope of the protection empirically and states which material remains obtainable rather than treating Credential Guard as an all-or-nothing control."],
    ["The End of PPLdump", "https://itm4n.github.io/the-end-of-ppldump/", "itm4n", "2022", 5, "PPLdump protected process LSASS patch bypass remediation", "Analyzes the Windows changes that broke PPLdump and uses the failure to explain the exact implementation weakness the tool depended on. By comparing the original primitive with the patched object and access behavior, the post teaches both PPL bypass mechanics and the importance of revalidating offensive tools after platform servicing."],
    ["Bypassing PPL in Userland Again", "https://itm4n.github.io/bypassing-ppl-in-userland-again/", "itm4n", "2023", 5, "protected process light PPL userland bypass LSASS code execution", "Returns to user-mode PPL bypass after earlier paths were hardened and develops a new chain from Windows loading and trust behavior. The research clearly separates discovery, required privileges, protected-process constraints, and practical execution, which makes it useful for both offensive study and evaluating whether a defensive PPL deployment closes the intended path."],
    ["The Ghost in the PPL, Part 1", "https://itm4n.github.io/ghost-in-the-ppl-part-1/", "itm4n", "2024", 5, "PPL protected process code injection section mapping Windows internals", "Opens a three-part investigation into executing code inside a protected process by establishing the protection model, available handles, memory objects, and loader constraints. The installment is intentionally primitive-focused, giving readers enough internals to understand why ordinary injection fails before the later stages assemble a workable chain."],
    ["The Ghost in the PPL, Part 2", "https://itm4n.github.io/ghost-in-the-ppl-part-2/", "itm4n", "2024", 5, "PPL bypass KnownDll section object namespace injection Windows", "Extends the Ghost in the PPL research through object-manager and image-loading behavior, refining the initial capabilities into a route that can influence protected execution. It records the dead ends and security checks encountered along the way, which is especially useful for reasoning about the difference between writable state and executable influence."],
    ["The Ghost in the PPL, Part 3", "https://itm4n.github.io/ghost-in-the-ppl-part-3/", "itm4n", "2024", 5, "PPL bypass exploit chain LSASS protected process code execution", "Completes the series by joining the discovered namespace, image, and execution primitives into a practical protected-process compromise and then examining limitations and remediation. Read with the first two parts, it is one of the clearest end-to-end studies of modern user-mode PPL attack surface and exploit-chain engineering."],
    ["Direct System Calls for Red Teams", "https://www.mdsec.co.uk/2020/12/bypassing-user-mode-hooks-and-direct-invocation-of-system-calls-for-red-teams/", "MDSec", "2020", 5, "direct syscalls Windows ntdll user mode hooks process injection", "A careful treatment of resolving and invoking Windows system calls without relying on potentially hooked ntdll stubs. It discusses the motivation, implementation choices, version-dependent service numbers, and injection use case, giving readers enough context to evaluate both the bypass and the telemetry that remains below user mode."],
    ["FireWalker: Generic User-Space Hook Bypass", "https://www.mdsec.co.uk/2020/08/firewalker-a-new-approach-to-generically-bypass-user-space-edr-hooking/", "MDSec", "2020", 5, "FireWalker EDR hook bypass hardware breakpoints exception handler", "Introduces a generic approach to stepping through and bypassing user-space EDR hooks using exception-driven control rather than restoring library bytes or hard-coding syscall identifiers. The writeup develops the mechanism and limitations in detail, making it a valuable study of what hooks observe and how alternative control flow interacts with them."],
    ["Silencing Cylance", "https://www.mdsec.co.uk/2019/03/silencing-cylance-a-case-study-in-modern-edrs/", "MDSec", "2019", 5, "Cylance EDR self protection service driver bypass case study", "A product-specific investigation of Cylance's user and kernel components, self-protection, and enforcement behavior that proceeds from reverse engineering to a tested bypass. It is valuable as methodology: the researchers map the product architecture and validate assumptions instead of presenting a generic AV-disable command."],
    ["Cisco AMP Self-Protection Bypass", "https://www.mdsec.co.uk/2018/10/cisco-amp-bypassing-self-protection/", "MDSec", "2018", 4, "Cisco AMP EDR self protection bypass Windows service", "A concise real-world case study in analyzing and bypassing an endpoint product's self-protection during an engagement. The article records the service and process behavior, the control weakness, and operational result, providing historical evidence of why protection claims must be checked against the complete component architecture."],
    ["Chaos Rootkit", "https://github.com/ZeroMemoryEx/Chaos-Rootkit", "ZeroMemoryEx", "2023", 5, "Windows rootkit DKOM process driver file hiding callbacks networking", "A substantial open-source Windows rootkit research project implementing multiple hiding and tampering capabilities rather than a single proof of concept. The code offers a concrete basis for studying DKOM, callbacks, object discovery, and cross-view detection assumptions, and it is frequently referenced from vulnerable-driver research graphs."],
    ["AvastHV", "https://github.com/tanduRE/AvastHV", "tanduRE", "2020", 5, "Avast hypervisor SSDT hook nested virtualization Windows kernel", "A research project that repurposes Avast's virtualization components to intercept Windows system calls from the hypervisor rather than patching the ordinary kernel. It provides rare code-level material for understanding how security-product virtualization can become an execution and monitoring primitive below PatchGuard's usual view."],
    ["Qilin EDR Killer Infection Chain", "https://blog.talosintelligence.com/qilin-edr-killer/", "Cisco Talos", "2026", 5, "Qilin EDR killer ETW syscalls kernel object manipulation hooks", "A code-level analysis of an EDR-killing DLL deployed with Qilin ransomware, covering its PE loader, SEH and VEH control-flow obfuscation, syscall and API resolution, user-mode hook removal, ETW suppression, and kernel-object manipulation. The report is especially useful because it follows the whole execution chain and relates each evasion layer to observable behavior."],
    ["DKOM, Now with Symbolic Links", "https://windows-internals.com/dkom-now-with-symbolic-links/", "Yarden Shafir", "2020", 5, "DKOM object manager symbolic links kernel hiding manipulation", "Demonstrates Direct Kernel Object Manipulation against object-manager symbolic links and uses the exercise to expose the structures and lookup behavior behind familiar DOS-device paths. Beyond the hiding effect, the post is a strong example of deriving a manipulation from object lifetime and namespace internals rather than copying offsets."],
    ["Kernel Data Discovery Through Lookaside Lists", "https://windows-internals.com/lookaside-list-forensics/", "Yarden Shafir", "2020", 5, "kernel data discovery lookaside lists forensics rootkit signature scanning", "Proposes lookaside-list metadata as a more structural way to discover kernel allocations than fragile byte signatures. The approach is relevant to both stealth tooling and memory forensics because it reasons from allocator ownership and cached object types, while also documenting the version and lifecycle assumptions a detector must validate."],
    ["RedEdr", "https://github.com/dobin/RedEdr", "dobin", "Living", 5, "EDR introspection ETW ETW-TI Defender telemetry hooks callbacks", "An open-source laboratory for observing the same Windows telemetry surfaces that endpoint products consume, including ETW, ETW Threat Intelligence, user-mode hooks, kernel callbacks, and Defender-specific providers. It earns a place here because it supports measurement and validation: researchers can see which behavior generated which signal instead of assuming that a bypass worked because a payload executed."],
    ["EDR-Introspection", "https://github.com/yo-yo-yo-jbo/EDR-Introspection", "John Barak", "Living", 5, "EDR internals minifilter callbacks ETW WFP telemetry enumeration", "A research tool for enumerating the operating-system integrations used by endpoint products, including process and object callbacks, minifilters, ETW providers, WFP filters, and related kernel registrations. It is especially useful for building a product-specific attack-surface map before testing evasion claims, and for comparing what remains visible after a technique changes one telemetry path."],
    ["libelevate: handle elevation against ObRegisterCallbacks", "https://github.com/notscimmy/libelevate", "notscimmy", "2017", 4, "ObRegisterCallbacks DKOM handle table access elevation anti-cheat EDR", "A compact kernel research project that bypasses access stripping by modifying a target handle-table entry after callbacks have run, rather than removing the callback registration itself. The accompanying explanation is valuable for studying ExEnumHandleTable, encoded handle entries, and the distinction between disabling an enforcement mechanism and repairing the rights it removed."],
    ["About Hiding on Windows", "https://kernullist.github.io/kernullist-blog/posts/hiding-on-windows/", "Kernullist", "2026", 5, "DKOM injection BYOVD hiding cross-view detection", "Surveys hiding processes, threads, DLLs, drivers, callbacks, and executable regions using DKOM, injection, and BYOVD techniques. Its cross-view detection discussion is particularly useful because it pairs offensive manipulation with the defender's competing sources of truth."],
    ["Attacking EDRs Part 1: EDR Drivers", "https://labs.infoguard.ch/posts/edr_part1_intro_-_security_analysis_of_edr_drivers/", "InfoGuard Labs", "2025", 5, "EDR driver callbacks attack surface reverse engineering", "Establishes a methodology for analyzing the kernel drivers that give EDR products visibility and enforcement power. It maps callbacks, exposed interfaces, and attack surface so later bypass work is grounded in how the product actually collects telemetry."],
    ["Attacking EDRs Part 2: Driver Analysis Results", "https://labs.infoguard.ch/posts/edr_part2_driver_analysis_results/", "Manuel Feifel / InfoGuard Labs", "2025", 5, "Cortex XDR Sophos EDR driver IOCTL minifilter snapshot fuzzing", "Applies the first installment's methodology to real Cortex XDR and Sophos drivers, tracing open device interfaces, IOCTL authorization, process tables, minifilter communication ports, and a startup race fixed as CVE-2024-5905. The WinDbg, IDA, ret-sync, and WTF workflow makes both successful findings and unproductive paths reproducible instead of reducing the result to a vendor advisory."],
    ["Attacking EDRs Part 3: One Bug to Stop Them All", "https://labs.infoguard.ch/posts/edr_part3_one_bug_to_stop_them_all/", "Manuel Feifel / InfoGuard Labs", "2025", 5, "EDR denial of service ALPC object squatting Cortex Defender CrowdStrike", "Generalizes an Object Manager namespace and ALPC startup weakness across a wide set of Windows EDR agents: a low-privileged process creates the expected object first, causing the protected service to fail after reboot. The article verifies product-specific impact, documents CVE and vendor responses, and shows why preexisting-object handling is a cross-vendor design problem rather than one isolated crash."],
    ["Attacking EDRs Part 4: Fuzzing Defender's Engine", "https://labs.infoguard.ch/posts/attacking_edr_part4_fuzzing_defender_scanning_and_emulation_engine/", "Manuel Feifel / InfoGuard Labs", "2025", 5, "Microsoft Defender mpengine snapshot fuzzing WTF kAFL NYX emulator", "Builds snapshot-fuzzing harnesses for Defender's privileged mpengine.dll scanning and emulation surface with WTF and kAFL/NYX, including module loading, state capture, input replacement, coverage, and crash triage. The discovered out-of-bounds reads and null dereferences are assessed conservatively as denial-of-service candidates, making the post a useful model for evidence-based EDR parser research."],
    ["Stopping Vulnerable Driver Attacks", "https://www.elastic.co/security-labs/stopping-vulnerable-driver-attacks/", "Joe Desimone / Elastic", "2023", 5, "BYOVD driver blocklist YARA WDAC HVCI Process Explorer physical memory", "Connects vulnerable-driver primitives to EDR tampering, including a Process Explorer handle-duplication path that yields physical-memory access and kernel read/write under HVCI. It then explains how Elastic derived and released 65 driver YARA rules, contrasts blocklisting with allowlisting and behavioral controls, and states the operational gaps of every approach."],
    ["Detecting and Blocking Unknown KnownDlls", "https://www.elastic.co/blog/detect-block-unknown-knowndlls-windows-acl-hardening-attacks-cache-poisoning-escalation", "Gabriel Landau / Elastic", "2021", 5, "KnownDlls PPL code integrity CI Spotter PPLDump section object detection", "Investigates the observable Code Integrity violations left by KnownDll and section-object manipulation used to place unsigned code inside Protected Process Light. The accompanying CI Spotter driver demonstrates an enforcement path, while Elastic telemetry examples distinguish the technique from Phantom DLL hollowing and turn a PPL bypass primitive into concrete defensive signals."],
    ["awesome-edr-bypass", "https://github.com/tkmru/awesome-edr-bypass", "tkmru", "Living", 4, "EDR bypass curated research tools", "A curated directory of EDR bypass research, techniques, presentations, and tooling. It is best used as a discovery index; verify individual techniques against modern product versions before treating them as operationally current."],
    ["KernelCallbackTable Injection PoC", "https://github.com/0xHossam/KernelCallbackTable-Injection-PoC#introduction", "0xHossam", "2024", 4, "process injection PEB KernelCallbackTable execution hijack", "Demonstrates process injection by replacing a callback pointer in the target's PEB-backed KernelCallbackTable. The compact PoC makes the execution flow easy to trace and provides a useful basis for studying telemetry and defensive detection."],
    ["kurasagi: runtime PatchGuard bypass", "https://github.com/NeoMaster831/kurasagi", "NeoMaster831", "2025", 4, "Windows 11 PatchGuard bypass 24H2 25H2", "A research implementation targeting runtime PatchGuard bypass on Windows 11 24H2 and 25H2. Because it depends strongly on undocumented and build-specific behavior, use it as an advanced study target rather than a portable technique."],
    ["BYOVD and legitimate certificates", "https://blog.ghostwolflab.com/apt/737/", "Ghost Wolf Lab", "2026", 3, "BYOVD APT certificates vulnerable drivers", "Discusses how BYOVD tradecraft is shifting from obviously vulnerable drivers toward trust inherited from legitimate certificates. It is a useful threat-research perspective for connecting driver abuse, signing policy, and the limits of blocklist-only defenses."],
    ["EDRPrison: borrow a legitimate driver to mute EDR", "https://www.3nailsinfosec.com/post/edrprison-borrow-a-legitimate-driver-to-mute-edr-agent", "Ziyi Shen", "2024", 5, "EDR evasion WinDivert WFP callout network telemetry", "Builds an EDR network-isolation technique around the legitimate WinDivert callout driver and Windows Filtering Platform metadata. The article explains why firewall, proxy, and persistent-filter approaches are weaker, then traces how process-associated packets can be selectively dropped without opening the protected EDR process."],
    ["Nirvana v2: detecting raw and gadgeted direct syscalls", "https://cameronbabcock.net/blog/direct-syscall-detection-instrumentation-callbacks/", "Cameron Babcock", "2026", 5, "direct syscall detection instrumentation callback ThreadLastSystemCall provenance", "Builds a kernel-grounded detector that catalogs live ntdll and win32u syscall stubs, captures the previous user PC through ProcessInstrumentationCallback, obtains the serviced ID from ThreadLastSystemCall, and verifies that syscall ownership matches return-address ownership. The source and WinDbg notes demonstrate clean, raw, and borrowed-gadget cases without relying on entry-point hooks."],
    ["ETW Internals: architecture, tampering, and detection", "https://kernullist.github.io/kernullist-blog/posts/etw-internals-deep-dive/", "Kernullist", "2026", 5, "ETW ETWTI provider session consumer DKOM AutoLogger detection", "Maps ETW as a routing fabric across provider registration, enable slots, logger contexts, buffers, filters, real-time consumers, AutoLoggers, silos, and security-qualified ETWTI access. It analyzes user-mode patching versus kernel DKOM, byte-level provider silencing and delivery-path corruption, then derives cross-view canaries and integrity checks so defenders can distinguish a quiet system from a blinded sensor."],
    ["Windows Instrumentation Callbacks, part 1", "https://cirosec.de/en/news/windows-instrumentation-callbacks/", "Lino Facco / cirosec", "2025", 5, "Windows instrumentation callback KiSetupForInstrumentationReturn syscall spoofing patchless hooks", "Reverse engineers the Windows 10 and 11 process instrumentation callback path from KPROCESS.InstrumentationCallback through KiSetupForInstrumentationReturn and the saved KTRAP_FRAME. The article documents NtSetInformationProcess setup, x64 register and stack restoration, recursion hazards, and practical syscall logging and spoofing, establishing the mechanics later used for patchless monitoring or evasion."],
    ["Using process creation properties to catch evasion", "https://www.microsoft.com/en-us/security/blog/2022/06/30/using-process-creation-properties-to-catch-evasion-techniques/", "Microsoft Defender Research", "2022", 5, "process tampering NtCreateProcessEx ECP image section TOCTOU antimalware", "Generalizes Doppelgänging, Ghosting, and related transient-file execution into one detection model. It contrasts NtCreateUserProcess with legacy section-based NtCreateProcessEx, follows process callbacks and GUID_ECP_CREATE_USER_PROCESS provenance, then combines the missing ECP with MmDoesFileHaveUserWritableReferences to identify pagefile-backed image sections whose malicious disk state vanished before scanning."],
    ["False File Immutability: Breaking Windows Code Integrity", "https://www.elastic.co/security-labs/false-file-immutability", "Gabriel Landau / Elastic", "2024", 5, "False File Immutability PPLFault Code Integrity security catalog page hashes kernel", "Defines False File Immutability as a Windows vulnerability class and demonstrates two distinct trust failures caused by treating attacker-controlled backing files as stable. The research explains PPLFault's network-redirector image mutation, then races Code Integrity between validation and parsing of a security catalog to load an unsigned driver, documenting page-hash policy, working-set eviction, mitigations, disclosure, and public exploit code."],
    ["The Immutable Illusion: Pwning the Kernel with Cloud Files", "https://www.elastic.co/security-labs/immutable-illusion", "Gabriel Landau / Elastic", "2026", 5, "Cloud Files cldflt PPLFault Redux GodFault Code Integrity PPL bypass", "Revisits False File Immutability after Microsoft's original PPLFault mitigation and removes the external SMB dependency by abusing the built-in Cloud Files stack. Reverse engineering cldflt.sys and CfExecute reveals how rehydration can overwrite an image without FILE_WRITE_DATA, leading to Redux and GodFault-Redux chains that reach WinTcb-Light and kernel memory on supported Windows Server releases, with a minifilter mitigation and version matrix."],
    ["Upping the Ante: Kernel Call-Stack Detection", "https://www.elastic.co/security-labs/upping-the-ante-detecting-in-memory-threats-with-kernel-call-stacks", "Joe Desimone, Samir Bousseaden, and Gabriel Landau / Elastic", "2023", 5, "kernel call stacks direct syscalls callback evasion module stomping unbacked memory", "Explains how endpoint telemetry captured inline from the Windows kernel can retain the call path behind process, file, registry, and image events even when user-mode hooks are bypassed. More than thirty concrete rules cover direct syscalls, callback-based execution, module stomping, unbacked callers, suspicious CLR loads, and Office macro provenance, while stack-aware exclusions show how defenders can reduce false positives without creating filename-based evasion gaps."],
    ["Bypassing Image Load Kernel Callbacks", "https://www.mdsec.co.uk/2021/06/bypassing-image-load-kernel-callbacks/", "MDSec", "2021", 5, "PsSetLoadImageNotifyRoutine SEC_IMAGE NtCreateSection NtMapViewOfSection telemetry spoofing", "Traces PsSetLoadImageNotifyRoutine notifications through the user-mode loader, SEC_IMAGE section creation, and NtMapViewOfSection to determine exactly when EDR image-load telemetry fires. The research shows that a low-privilege process cannot suppress the kernel callback but can create and map valid image sections without actually linking or executing them, producing convincing false module-load events and exposing the difference between a sensor observation and execution evidence."],
    ["TiEtwAgent: ETW-TI Injection Detection Lab", "https://github.com/xuanxuan0/TiEtwAgent", "xuanxuan0", "2021", 5, "ETW Threat Intelligence PPL ELAM process injection detection bypass laboratory", "Provides a buildable Windows research agent for consuming the protected Microsoft-Windows-Threat-Intelligence provider and testing memory-injection detections and bypasses against kernel-originated telemetry. Its C and C++ implementation covers ELAM-backed PPL setup, generic event-field parsing, pluggable detection logic, and reproducible lab configuration, making it a focused companion to broader EDR introspection tools rather than another unverified evasion collection."],
    ["Windows Malware Evasion Trends Across 100,000 Samples", "https://www.elastic.co/security-labs/unveiling-malware-behavior-trends", "Samir Bousseaden / Elastic Security Labs", "2024", 5, "Windows malware telemetry defense evasion injection DLL sideloading unhooking Defender tampering", "Measures defense-evasion behavior across more than one hundred thousand dynamically executed Windows malware samples instead of extrapolating from a few hand-picked families. The study separates tactics and sub-techniques, compares self- and remote injection, quantifies DLL side-loading and system-binary proxy abuse, identifies Defender tampering and ntdll unhooking trends, and publishes the behavioral-rule context used to produce the observations."],
    ["Misbehaving Modalities: Detecting Tools, Not Techniques", "https://www.elastic.co/security-labs/misbehaving-modalities", "John Uhlmann / Elastic Security Labs", "2025", 5, "Windows execution modality kernel ETW call stacks PowerShell RPC WMI detection evasion", "Develops execution modality as a way to distinguish how the same Windows behavior reaches the operating-system source of truth, contrasting utilities, PowerShell, RPC, WMI, managed runtimes, shellcode, and indirect syscalls. It uses service creation and call-stack evidence to score brittle versus kernel-grounded detections, then examines module stomping, proxied calls, synthetic frames, and hardware trace features that complicate stack spoofing."],
    ["Call Stacks: No More Free Passes for Malware", "https://www.elastic.co/security-labs/call-stacks-no-more-free-passes-for-malware", "John Uhlmann / Elastic Security Labs", "2025", 5, "Windows call stacks ETW provenance stack spoofing module stomping APC kernel callback detection", "Turns raw Windows stack addresses into security provenance by explaining stack walking, module and export enrichment, final-user-module attribution, expected syscall paths, and special transitions such as APCs and kernel callbacks. It then evaluates return-address spoofing against call-site bytes, private and overwritten mappings, protection provenance, start-address consistency, tail calls, and baselines, showing why a plausible-looking frame sequence can create additional detectable contradictions."],
    ["EDR Erase Data Remotely", "https://www.safebreach.com/blog/edr-erase-data-remotely-by-cooking-unforgettable-byte-signature-dish/", "Tomer Bar and Shmuel Cohen / SafeBreach Labs", "2023", 5, "EDR quarantine abuse remote file deletion Defender signature web logs databases denial service", "Explores an inversion of endpoint protection in which attacker-controlled content embeds a minimal malware signature into data owned by another service and lets privileged automatic remediation delete or corrupt the containing file. The research derives a compact Defender trigger, expands it across web logs, event logs, mail and database paths, tests multiple EDR products, and documents the remote and unauthenticated conditions that turn a scanning trust boundary into a destructive primitive."],
    ["Hunting Suspicious Windows Libraries for Execution and Evasion", "https://www.elastic.co/security-labs/Hunting-for-Suspicious-Windows-Libraries-for-Execution-and-Evasion", "Samir Bousseaden / Elastic Security Labs", "2023", 5, "Windows DLL load sideloading rundll32 regsvr32 ISO VHD archive MSIEXEC timestomp detection", "Builds a practical detection methodology for the extremely noisy Windows DLL-load surface using signer, path, device, file-age, original-name, process, and creation-event relationships. Published queries and protection rules cover Rundll32 and Regsvr32 proxies, renamed signed hosts, ISO and VHD delivery, archive and document extraction, MSI custom actions, search-order hijacking, oversized images, timestomping, removable media, and freshly dropped libraries beside established applications."],
    ["Turning Cortex XDR into an Offensive Tool", "https://www.safebreach.com/blog/dark-side-of-edr-offensive-tool/", "Shmuel Cohen / SafeBreach Labs", "2024", 5, "Cortex XDR ransomware honeypot whitelist LSASS dump minifilter hardlink rule tampering", "Reverse engineers Cortex XDR's readable Lua and Python content to turn its own assumptions into attack surface: allowlisted names hide ransomware from decoy files, alternate command spelling and process names defeat rules, and a hard-link primitive bypasses path-based minifilter protection. The chain proceeds from editing detection logic to executing attacker code persistently inside the privileged EDR process, with vendor fixes and limitations documented."],
    ["Aikido Wiper: Making EDR Delete Protected Files", "https://www.safebreach.com/blog/safebreach-labs-researcher-discovers-multiple-zero-day-vulnerabilities/", "Or Yair / SafeBreach Labs", "2022", 5, "Aikido Wiper EDR AV quarantine TOCTOU junction delayed delete reboot CVE-2022-37971", "Turns privileged antivirus quarantine into an unprivileged arbitrary-delete proxy by holding a detected file open until remediation is deferred, replacing its controlled parent with an NTFS junction, and letting reboot-time cleanup follow the redirected path. Cross-product testing, three coordinated CVEs, exact race staging, recovery destruction, and the distinction between immediate and PendingFileRenameOperations deletion make the trust-boundary failure reproducible."],
    ["ETW-TI Hardware Breakpoints Without SetContext Telemetry", "https://www.praetorian.com/blog/etw-threat-intelligence-and-hardware-breakpoints/", "Rad Kawar / Praetorian", "2025", 5, "ETW Threat Intelligence hardware breakpoint NtContinue SetThreadContext debug registers telemetry bypass", "Walks kernel symbols and WinDbg call stacks to identify which context-changing paths emit ETW Threat Intelligence events used to detect hardware-breakpoint hooks. It then shows that NtContinue restores the same debug-register state without reaching EtwTiLogSetContextThread, explains the trap-frame conversion, and provides both an evasion primitive and the evidence defenders need to close the specific telemetry gap."],
    ["LayeredSyscall: VEH-Assisted Indirect Syscalls", "https://whiteknightlabs.com/2024/07/31/layeredsyscall-abusing-veh-to-bypass-edrs/", "Adhithya Suresh Kumar / White Knight Labs", "2024", 5, "LayeredSyscall VEH hardware breakpoint indirect syscall legitimate call stack EDR hook bypass", "Uses vectored exception handling and hardware breakpoints to route sensitive operations through ordinary Win32 APIs, replace their execution at carefully selected return points, and issue indirect syscalls while preserving a plausible unwindable stack. The article and public implementation spell out stack construction, argument transfer, gadget selection, exception lifecycle, and defensive checks, making it stronger than a syscall-stub demonstration."],
    ["EDR-Freeze", "https://github.com/TwoSevenOneT/EDR-Freeze", "Itamar Hällström / TwoSevenOneT", "2025", 5, "EDR Freeze WerFaultSecure Windows Error Reporting MiniDumpWriteDump protected process suspend", "Abuses Windows Error Reporting's trusted dump workflow to place an endpoint agent into a sustained suspended or coma-like state without terminating its protected process or loading a vulnerable driver. The source exposes process selection, WerFaultSecure orchestration, MiniDumpWriteDump interaction, timeout handling, restoration, and practical constraints, providing a compact lab artifact for measuring whether an EDR detects loss of its own execution rather than only process death."],
    ["EDR Bypassing via Memory Manipulation", "https://labs.withsecure.com/publications/edr-bypassing-via-memory-manipulation-techniques", "Connor Morley / WithSecure Labs", "2023", 5, "Windows EDR memory manipulation process injection sleep obfuscation stack spoofing detection", "Organizes modern memory evasion around how endpoint products acquire and interpret telemetry rather than presenting a bag of injection recipes. The paper explains covert allocation and execution, sleep-time concealment, call-stack manipulation, and related native mechanisms, then pairs them with memory, thread, stack, and behavioral detection strategies and the engineering limitations defenders face when collecting those signals at scale."],
    ["Adventures in Dynamic Evasion", "https://specterops.io/blog/2020/12/07/adventures-in-dynamic-evasion/", "Adam Chester / SpecterOps", "2020", 5, "SHAPESHIFTER dynamic invocation EDR hooks ETW Threat Intelligence syscall telemetry", "Builds a capability-driven model of EDR visibility by tracing where user-mode hooks sit, dynamically recovering clean function implementations, and testing what changes when calls bypass that layer. Crucially, it follows execution below the apparent bypass into kernel callbacks, ETW Threat Intelligence, static scanning, managed-runtime telemetry, and network artifacts, demonstrating why successful payload execution is not proof that an endpoint sensor was blinded."],
    ["One WSL BOF to Rule Them All", "https://specterops.io/blog/2026/01/16/one-wsl-bof-to-rule-them-all/", "Daniel Mayer / SpecterOps", "2026", 5, "WSL2 COM interface Beacon Object File Windows EDR visibility Hyper-V execution", "Reverse engineers the changing undocumented COM interface used to control WSL across Windows releases and packages the recovered methods into a Beacon Object File for enumeration and execution without spawning wsl.exe. The article explains interface-version discovery, vtable and parameter reconstruction, cross-version dispatch, WSL1 versus WSL2 trust boundaries, host-visible artifacts, and the substantial monitoring gap created when execution moves into a separate Hyper-V guest."],
    ["Tool Graph: 900 Paths to the Same Injection Capability", "https://specterops.io/blog/2023/06/01/part-8-tool-graph/", "Jared Atkinson / SpecterOps", "2023", 5, "process injection function call graph Win32 Native API syscalls EDR detection abstraction", "Models classic remote-thread shellcode injection as a graph of equivalent Windows function chains instead of one canonical API sequence, deriving roughly nine hundred ways to reach the same underlying capability through Win32, Native API, and syscall layers. The graph makes brittle function-name detections and superficial API substitution measurable, while giving defenders a method to identify lower-level convergence points that survive implementation changes."],
    ["Proxy Windows Tooling via SOCKS", "https://specterops.io/blog/2021/06/10/proxy-windows-tooling-via-socks/", "Michael Rand and Lee Christensen / SpecterOps", "2021", 5, "Windows SOCKS proxied tooling LOGON_NETCREDENTIALS_ONLY domain authentication EDR off host", "Moves Windows-native tooling away from a monitored foothold by combining SOCKS proxying with a locally created net-only logon session that carries remote domain credentials without joining the operator machine to the domain. The writeup covers token and process creation, DNS and protocol constraints, tool compatibility, traffic and latency tradeoffs, and the residual host and network evidence, providing a rigorous alternative to endlessly patching AMSI, ETW, hooks, and injection behavior on the compromised endpoint."],
    ["Bypassing Windows Defender Runtime Scanning", "https://labs.withsecure.com/publications/bypassing-windows-defender-runtime-scanning", "Charalampos Billinis / WithSecure Labs", "2020", 5, "Windows Defender runtime memory scanner PAGE_NOACCESS API trigger Ninjasploit injection", "Reverse engineers when Defender's runtime scanner inspects a process rather than assuming that encryption alone defeats protection. Controlled tests identify API-triggered scanning and memory-region selection, then a Metasploit extension hooks those trigger calls, suspends the payload, temporarily marks its pages PAGE_NOACCESS, waits for inspection to finish, restores permissions, and resumes execution. The public Ninjasploit code and documented process exceptions make the historical result reproducible and its modern limitations testable."],
    ["Gargoyle Against Periodic Memory Scanners", "https://labs.withsecure.com/publications/experimenting-bypassing-memory-scanners-with-cobalt-strike-and-gargoyle", "WithSecure Labs", "2018", 5, "Gargoyle Cobalt Strike Beacon timer ROP memory scanner executable page evasion", "Adapts the Gargoyle timer-and-ROP concept from a message-box demonstration into a staged Cobalt Strike Beacon that spends most of its lifetime outside executable memory. The research explains the scanner assumptions being tested, shellcode and loader constraints, periodic permission transitions, timer callback execution, interaction with injected-thread and module-stomping detections, and the telemetry that still survives, providing an early but unusually explicit sleep-obfuscation experiment."],
    ["Evadere: Classifying What an Evasion Actually Bypasses", "https://specterops.io/blog/2021/06/01/evadere-classifications/", "Jonathan Johnson / SpecterOps", "2021", 5, "Evadere EDR evasion taxonomy telemetry collection detection configurational perceptual", "Defines a precise vocabulary for endpoint evasion by separating product visibility, collection configuration, built-in analytics, custom detections, and analyst interpretation. The model distinguishes perceptual gaps from data that exists but is not collected or acted upon, then maps responsibility between sensor developers and end users. It is a critical evaluation reference because it prevents a tool from claiming an EDR bypass when it only evades one default rule or unconfigured event source."],
    ["Telemetry Layering for Resilient Windows Detection", "https://specterops.io/blog/2023/02/10/telemetry-layering/", "Jonathan Johnson / SpecterOps", "2023", 5, "Windows telemetry layering AMSI ETW CLR kernel callbacks detection evasion data source", "Shows how the same behavior can be observed through multiple Windows layers and why detections should be designed around the reliability and tamper boundary of each source. Using managed assembly loading as a worked example, it compares AMSI content, .NET runtime ETW, lower-level operating-system activity, configuration requirements, performance cost, and likely evasion routes, turning abstract defense in depth into a method for selecting complementary evidence instead of stacking redundant alerts."],
    ["Uncovering the Source of Windows Security Events", "https://specterops.io/blog/2022/11/14/uncovering-window-security-events/", "Jonathan Johnson / SpecterOps", "2022", 5, "Windows Security Auditing ETW event generation TelemetrySource syscall kernel audit evasion", "Introduces TelemetrySource by tracing thirty-seven Microsoft-Windows-Security-Auditing events back toward the APIs, system calls, kernel routines, and policy gates that generate them. The work emphasizes verifying event provenance in code rather than trusting documentation or event names, exposes where configuration and alternate execution paths suppress evidence, and gives defenders and evasion researchers a shared map for deciding whether an action was invisible, unaudited, or merely absent from collection."],
    ["Taking SHELLTER: Commercial Evasion in the Wild", "https://www.elastic.co/security-labs/taking-shellter", "Daniel Stepanic and Elastic Security Labs", "2025", 5, "SHELLTER Windows evasion framework indirect syscall call stack truncation memory scanner PEB", "Reverse engineers malicious samples protected by the commercial SHELLTER framework and connects configuration claims to observable runtime mechanisms. The analysis reconstructs time-keyed decoding, page-permission cycling, PEB-backed temporary storage, trampoline-based indirect syscalls, return-driven stack truncation, user- and kernel-debugger checks, environmental gating and encrypted staging, then uses ETW Threat Intelligence call stacks and memory captures to show both the telemetry disrupted and the artifacts that remain."],
    ["Evading Elastic Call-Stack Signatures with Call Gadgets", "https://offsec.almond.consulting/evading-elastic-callstack-signatures.html", "SAERXCIT / Almond Offensive Security", "2025", 5, "Elastic EDR call stack evasion call gadgets proxy API unwind metadata ETW TI", "Tests Elastic's published call-stack detections against a deliberately constructed proxy chain rather than making a generic stack-spoofing claim. The research identifies signature assumptions, selects real CALL sites in image-backed code, preserves valid unwind behavior and argument state, executes sensitive APIs through those gadgets, and compares captured ETW-TI stacks before and after evasion, giving defenders concrete ideas for distinguishing semantically impossible call paths from merely well-formed image-backed frames."],
    ["HookChain: IAT-Driven Indirect Syscalls", "https://arxiv.org/abs/2404.16856", "Helvio Junior", "2024", 5, "HookChain Windows EDR bypass IAT hooking indirect syscall SSN ntdll kernelbase", "Combines dynamic system-service-number recovery, indirect syscall dispatch and Import Address Table rewriting so an existing Windows program can route selected API calls around user-mode EDR hooks without source changes. The paper describes PE import traversal, hook installation, syscall-stub discovery and compatibility testing across Windows builds and endpoint products, publishes the implementation, and makes the threat model explicit: it targets telemetry that depends on patched NTDLL paths rather than claiming to suppress kernel callbacks or ETW-TI."],
    ["Nighthawk 0.2.6: API Call-Stack Masking", "https://www.mdsec.co.uk/2023/09/nighthawk-0-2-6-three-wise-monkeys/", "MDSec Research", "2023", 5, "Nighthawk call stack masking ETW TI unbacked memory API proxy EDR evasion", "Explains the design pressure created by kernel-captured ETW-TI stacks and why direct or indirect syscalls still unwind into unbacked implant memory. Nighthawk's response proxies every Windows API call through a masking layer that constructs a fully image-backed unwind path during active beacon execution, not only sleep; the article demonstrates the result with Sealighter traces and thread inspection, contrasts it with instrumentation-callback patching and ordinary return-address spoofing, and records the remaining behavioral assumptions defenders can challenge."],
    ["Resolving System Service Numbers Through PE Metadata", "https://www.mdsec.co.uk/2022/04/resolving-system-service-numbers-using-the-exception-directory/", "MDSec Research", "2022", 5, "Windows syscall SSN exception directory runtime function table Guard CF export table EDR hook bypass", "Shows that NTDLL contains multiple independently sorted views of syscall entry points beyond the familiar export-address approach used by Hell's Gate and its descendants. The research derives service numbers from x64 RUNTIME_FUNCTION entries in the exception directory and from Guard CF function metadata, explains filtering and ordering requirements, compares the methods with reading disk or KnownDll images, and provides implementation detail useful to both resilient syscall dispatch and defensive detection of metadata-driven hook bypass."],
    ["Blindside: EDR Evasion with Hardware Breakpoints", "https://cymulate.com/blog/blindside-a-new-technique-for-edr-evasion-with-hardware-breakpoints/", "Ilan Kalendarov / Cymulate", "2022", 5, "Blindside Windows EDR hardware breakpoints debug registers NTDLL loader hooks injection evasion", "Generalizes hardware-breakpoint tampering beyond one AMSI or ETW function by controlling a newly created process before its defensive user-mode instrumentation is established. The research follows debug-register and exception behavior around DLL loading, redirects monitored paths without patching code bytes, tests the method against multiple endpoint products, and discusses the kernel-visible artifacts defenders can use to distinguish debugging from deliberate sensor blinding."],
    ["Windows Downdate: Taking Over the Update Process", "https://www.safebreach.com/blog/downgrade-attacks-using-windows-updates/", "Alon Leviev / SafeBreach Labs", "2024", 5, "Windows Downdate update stack downgrade TrustedInstaller integrity verification PPL Credential Guard VBS bypass", "Reverse engineers the Windows Update deployment path and turns an unprivileged control weakness into a custom downgrade flow that still appears fully patched to the operating system. By replacing verified manifests and staged components at the right boundary, the research revives fixed vulnerabilities in DLLs, drivers, the NT kernel, Secure Kernel, Hyper-V, Credential Guard and PPL while documenting why ordinary recovery and integrity checks do not expose the rollback."],
    ["Windows Downdate: Reviving a DSE Bypass", "https://www.safebreach.com/blog/update-on-windows-downdate-downgrade-attacks/", "Alon Leviev / SafeBreach Labs", "2024", 5, "Windows Downdate DSE ItsNotASecurityBoundary ci.dll kernel downgrade unsigned driver rootkit", "Extends the Windows Update takeover into a focused kernel-security case by downgrading the code-integrity component that closed the ItsNotASecurityBoundary Driver Signature Enforcement bypass. The follow-up demonstrates unsigned driver loading on an otherwise current Windows 11 host, separates the downgrade primitive from the revived DSE flaw, and identifies servicing and telemetry assumptions that defenders must monitor when version reporting remains deceptively healthy."],
    ["Bind-Link Abuse: Blinding EDR, AMSI, and AppLocker", "https://www.bitdefender.com/en-gb/blog/businessinsights/bind-link-abuses-windows-feature-edr-evasion-technique", "Bitdefender Labs", "2026", 5, "Windows bind links Filter Manager EDR sensor AMSI AppLocker path redirection telemetry bypass", "Examines bind links as a supported namespace-redirection feature and develops three administrator-level ways to separate security products' view of a path from the bytes a process actually loads or executes. The research traces how Filter Manager, AMSI, AppLocker and endpoint sensors resolve affected paths, supplies proof-of-concept behavior and detection guidance, and treats the shared semantic mismatch as a bug class rather than three unrelated product bypasses."],
    ["Hiding In-Memory .NET Execution from ETW", "https://www.mdsec.co.uk/2020/03/hiding-your-net-etw/", "Adam Chester / MDSec", "2020", 5, "Windows .NET CLR ETW assembly method telemetry execute assembly EtwEventWrite patch evasion", "Builds a minimal unmanaged CLR host and a corresponding ETW consumer to show exactly how assembly and method-load telemetry reveals execute-assembly tradecraft. It then traces event emission through clr.dll into ntdll, patches EtwEventWrite in native and managed contexts, measures what remains visible before and after tampering, and publishes the loader and consumer fragments so both evasion and defensive limitations can be reproduced."],
    ["Exploring Windows UAC Bypasses and Detection", "https://www.elastic.co/security-labs/exploring-windows-uac-bypasses-techniques-and-detection-strategies", "Samir Bousseaden / Elastic Security Labs", "2023", 5, "Windows UAC bypass auto elevation COM IFileOperation DLL hijack registry token security attributes detection", "Organizes UAC bypasses by the primitive that redirects trusted elevation—per-user class registration, environment variables, DLL search, privileged IFileOperation and auto-elevated COM—rather than by tool name. It then derives resilient detections from integrity transitions, token security attributes, module provenance and registry symbolic links, tests them against real malware and UACME variants, and documents where path-only correlations fail when an attacker renames or redirects the observed object."],
    ["Peeling Back Windows Events with Call Stacks", "https://www.elastic.co/security-labs/peeling-back-the-curtain-with-call-stacks", "Samir Bousseaden / Elastic Security Labs", "2023", 5, "Windows call stack detection Dirty Vanity process forking injection unbacked memory DLL sideloading telemetry", "Demonstrates how symbolized kernel call stacks distinguish identical high-level Windows events by their real execution path. Worked cases cover Dirty Vanity process forking, WMI consumers, injected ransomware, Office OLE writes, unsigned service DLLs and direct syscalls, with queries that reason about backed versus unbacked frames and expected API ancestry; the result is both an evasion map and a method for replacing brittle process-name allowlists with provenance-aware detection."],
    ["Bypassing EDRs with EDR-Preloading", "https://malwaretech.com/2024/02/bypassing-edrs-with-edr-preload.html", "Marcus Hutchins", "2024", 5, "Windows EDR preloading AvrfpAPILookupCallbackRoutine LdrInitializeThunk loader hooks process initialization", "Locates the narrow process-initialization interval before an endpoint product can safely load its user-mode sensor and turns an Application Verifier callback in ntdll into pre-entrypoint execution. The article reconstructs relevant loader state, enables and redirects AvrfpAPILookupCallbackRoutine in a suspended child, neutralizes the incoming monitoring module, handles version-dependent offsets and publishes a focused proof of concept, making the timing assumption behind injected EDR hooks concrete and testable."],
    ["An Introduction to Bypassing User-Mode EDR Hooks", "https://malwaretech.com/2023/12/an-introduction-to-bypassing-user-mode-edr-hooks.html", "Marcus Hutchins", "2023", 5, "Windows EDR user mode hooks direct syscall ntdll system service number Hell's Gate detection", "Builds the user-mode hooking threat model from first principles by comparing the documented Win32 path, ntdll syscall stubs and an EDR-patched entrypoint in a debugger. It shows why hard-coded service numbers are build-specific, how clean stubs can be parsed to recover them dynamically, and which kernel or behavioral telemetry remains after hooks are bypassed, giving readers a precise baseline for evaluating direct-syscall claims rather than treating them as universal invisibility."],
    ["PatchGuard Peekaboo: Process Hiding on Modern Windows", "https://www.outflank.nl/blog/2026/01/07/patchguard-peekaboo-hiding-processes-on-systems-with-patchguard-in-2026/", "Outflank Research", "2026", 5, "Windows PatchGuard process hiding DKOM EPROCESS ActiveProcessLinks HVCI CET callbacks hypervisor", "Re-evaluates classic EPROCESS unlinking against current PatchGuard, HVCI and control-flow protections instead of assuming a decades-old rootkit primitive still works. The research traces process deletion integrity checks, tests direct list manipulation and context-hijack ideas, explains why timing and shadow-stack constraints make them fragile, and contrasts them with documented process-notification interception, giving both attackers and defenders a concrete account of which process-hiding state remains monitored and where visibility can still diverge."],
    ["GrimResource: Microsoft Management Console Evasion", "https://www.elastic.co/security-labs/grimresource", "Joe Desimone and Samir Bousseaden / Elastic", "2024", 5, "GrimResource MSC mmc apds XSS DotNetToJScript PASTALOADER DirtyCLR indirect syscalls", "Reconstructs an in-the-wild MSC file that points a StringTable entry at an old apds.dll resource XSS, gaining JavaScript execution inside trusted mmc.exe with few user warnings. The chain hides VBScript through transformNode, stores a .NET loader in environment variables, invokes it through DotNetToJScript, and injects Cobalt Strike using DirtyCLR, unhooking, and indirect syscalls. Elastic then separates generic MMC-console signals from payload-specific behavior and publishes call-stack detections, cache-file forensics, YARA, and sample observables."],
    ["Defeating EDRs with Office Products", "https://www.optiv.com/insights/source-zero/blog/defeating-edrs-office-products", "Matthew Eidelberg / Optiv", "2022", 5, "Ivy Office VBA EDR unhooking fileless shellcode AccessVBOM ActiveX Excel COM", "Introduces Ivy by tracing how a script can enable AccessVBOM, instantiate a hidden Excel automation server, write encrypted VBA into its live project, and simulate the editor's Run action so the generated macro never exists in a document on disk. The article compares same-process thread execution with suspended-process injection, explains direct syscall and EDR-unhooking options, measures the remaining Office and registry artifacts, and gives defenders concrete policy and telemetry points rather than claiming the technique is universally fileless or invisible."],
    ["ScareCrow Payload Creation Framework", "https://www.optiv.com/insights/source-zero/tools/scarecrow-payload-creation-framework", "Matthew Eidelberg / Optiv", "2021", 4, "ScareCrow Windows EDR unhooking DLL side loading custom syscalls shellcode loader YARA", "Documents a Windows payload-builder architecture that favors DLL side-loading into legitimate processes over conventional remote injection, restores monitored system-library sections to remove inherited user-mode hooks, and uses custom syscall and API paths to stage encrypted shellcode. The project page links the full source and companion YARA repository, explains certificate and version-resource masquerading, and explicitly frames the signatures as a starting point because build-time malleability prevents a single disk rule from representing the complete behavior."],
    ["Mark-of-the-Web from a Red Team's Perspective", "https://www.outflank.nl/blog/2020/03/30/mark-of-the-web-from-a-red-teams-perspective/", "Stan Hegt / Outflank", "2020", 5, "Mark of the Web Zone.Identifier IAttachmentExecute ISO VHD 7-Zip Git SmartScreen Office Protected View", "Maps the Zone.Identifier alternate stream and IAttachmentExecute behavior to the Windows controls that actually consume it, including SmartScreen, Office Protected View, internet-macro blocking, Visual Studio warnings, and Application Guard. Controlled tests show where Git and 7-Zip fail to apply or propagate provenance and why ISO or VHD containers historically strip an NTFS-only stream at the mounted boundary. The post distinguishes delivery gaps from protection failures and turns those observations into mail, proxy, policy, and attack-surface guidance for defenders."],
    ["So You Think You Can Block Macros?", "https://www.outflank.nl/blog/2023/04/25/so-you-think-you-can-block-macros/", "Pieter Ceelen / Outflank", "2023", 5, "Microsoft Office macro security signed VBA XLAM XLL LOLdocs MotW trusted location bypass", "Audits Office macro defenses as interacting trust decisions rather than a single enable-or-disable switch, covering internet-origin blocking, signed VBA, trusted publishers and locations, add-ins, XLL loading, and administrative policy edge cases. The second half develops LOLdocs—legitimately signed documents whose existing control flow can be redirected—showing why signature validation does not imply that every reachable external component or mutable field is trusted. Configuration matrices and concrete bypass paths make the article useful for both red-team validation and hardened Office deployment review."],
  ]},
  { id: "byovd", kicker: "Cross the trust boundary", title: "BYOVD & Kernel Driver Abuse", items: [
    ["The (Almost) Forgotten Vulnerable Driver", "https://decoder.cloud/2025/01/09/the-almost-forgotten-vulnerable-driver/", "Decoder", "2025", 5, "StopZilla vulnerable driver increment primitive PPL PreviousMode BYOVD", "Revisits a signed StopZilla driver whose METHOD_NEITHER IOCTL exposes a constrained increment primitive, then applies it to token privileges, LSASS protection fields, and KTHREAD PreviousMode. The post is unusually useful because it records build-specific offsets and explains why the PreviousMode route behaves differently on Windows 11 24H2."],
    ["Exploiting Toshiba qiomem.sys", "https://valium007.github.io/posts/toshiba-vuln/", "Valium", "2026", 5, "Toshiba qiomem physical memory MmMapIoSpace PnP HVCI BYOVD", "Reverse engineers qiomem.sys IOCTLs that map attacker-chosen physical addresses, reconstructs the packed request format, and demonstrates round-trip physical reads and writes. It also solves the often-overlooked loading constraint by creating a matching software PnP device and tests the driver under HVCI and the Microsoft blocklist."],
    ["From Domain User to Kernel Memory", "https://expel.com/blog/well-that-escalated-quickly-how-a-red-team-went-from-domain-user-to-kernel-memory/", "Expel", "2025", 5, "red team BYOVD vulnerable driver kernel memory exploit chain", "Documents a real red-team path from domain-user access to control of Windows kernel memory, preserving the discovery, driver selection, exploit engineering, and defensive implications of each transition. It is valuable because BYOVD is presented as one link in a complete operation rather than as an isolated driver-loading demonstration."],
    ["Chasing the Silver Fox: Kernel Shadows", "https://research.checkpoint.com/2025/silver-fox-apt-vulnerable-drivers/", "Check Point Research", "2025", 5, "Silver Fox APT BYOVD vulnerable drivers EDR evasion kernel malware", "Tracks Silver Fox campaigns as they rotate vulnerable and malicious kernel drivers to disable security controls, with driver-level analysis, execution flow, infrastructure, and detection material. The research connects catalog hashes to an evolving adversary workflow and shows why defenders must reason about capabilities and signer lineage, not filenames alone."],
    ["Mimidrv In Depth", "https://posts.specterops.io/mimidrv-in-depth-4d273d19e148", "Matt Hand / SpecterOps", "2020", 5, "mimidrv Windows kernel driver IOCTL process protection token callbacks", "Reverse engineers Mimikatz's kernel driver and maps its user-mode commands to device IOCTLs, kernel structures, process protection manipulation, token operations, and callback removal. It is an important bridge between public offensive tooling and the exact privileged mechanisms that detections or driver policies must constrain."],
    ["Dellicious", "https://github.com/jbaines-r7/dellicious", "Jake Baines / Rapid7", "2021", 5, "BYOVD Dell DBUtilDrv2 LSA protection PPL process flags", "A focused implementation that installs vulnerable Dell DBUtilDrv2, locates a target EPROCESS, and modifies signature and protection fields to enable or disable LSA protection before removing the device. The README documents required driver hashes, build offsets, artifacts, influences, and exact CLI output, making the kernel-write path auditable rather than opaque."],
    ["GoodBaiii", "https://github.com/RainbowDynamix/GoodBaiii", "RainbowDynamix", "2024", 4, "BYOVD Baidu BdApiUtil low integrity process termination", "A small, source-available proof of concept showing that Baidu's BdApiUtil driver can terminate arbitrary processes even when invoked from low integrity, with an optional bring-your-own-driver path. It includes the vulnerable-driver hash and concrete driver-load telemetry, so the offensive primitive is paired with actionable detection guidance."],
    ["Blackout", "https://github.com/ZeroMemoryEx/Blackout", "ZeroMemoryEx", "2023", 4, "BYOVD anti malware protected process termination vulnerable driver", "A concise BYOVD implementation for terminating protected anti-malware processes through a signed vulnerable driver. Its value is the readable orchestration and kernel interaction, which can be compared with sibling projects to understand how different drivers expose similar process-kill outcomes and what artifacts each path produces."],
    ["Backstab", "https://github.com/Yaxser/Backstab", "Yaxser", "2023", 4, "BYOVD antimalware process killer vulnerable driver callbacks", "A source-level tool for killing protected security-product processes using a vulnerable signed driver, linked from LOLDrivers records and the author's broader BYOVD research. It is useful for tracing driver deployment, device communication, target selection, and teardown as one complete chain rather than treating the vulnerable IOCTL in isolation."],
    ["CYBERSEC 2023 BYOVD Demo", "https://github.com/zeze-zeze/CYBERSEC2023-BYOVD-Demo", "zeze-zeze", "2023", 4, "BYOVD conference demo Windows kernel vulnerable driver EDR", "The public demonstration artifact accompanying a CYBERSEC presentation on bringing vulnerable drivers into an attack chain. It preserves the code and operational setup needed to reproduce the technique and compare the driver's kernel capability with the user-mode actions it enables."],
    ["Exploring vulnerable Windows drivers", "https://blog.talosintelligence.com/exploring-vulnerable-windows-drivers/", "Cisco Talos", "2024", 5, "BYOVD arbitrary memory write MSR EDR ransomware driver blocklist", "One of the strongest modern surveys of how vulnerable drivers are converted into token theft, unsigned kernel-code loading, EDR termination, and destructive payloads. It joins vulnerability classes to real ransomware campaigns and explains where Microsoft's vulnerable-driver blocklist helps—and where it does not."],
    ["Signed kernel drivers: an unguarded gateway to Windows' core", "https://www.welivesecurity.com/2022/01/11/signed-kernel-drivers-unguarded-gateway-windows-core/", "ESET Research", "2022", 5, "BYOVD signed drivers DSE malware rootkit kernel", "A foundational study of signed-driver abuse across APT and commodity malware, supported by a large-scale survey of vulnerable drivers. It gives the historical and architectural context needed to understand why code signing alone cannot solve BYOVD."],
    ["LOLDrivers", "https://www.loldrivers.io/", "Community project", "Living", 5, "BYOVD hashes certificates vulnerable malicious drivers detection", "The canonical community-maintained catalog of Windows drivers abused to bypass security controls or execute kernel code. Each record connects hashes, signatures, known abuse, detections, and references, making it the first stop for triage—not a substitute for reversing the actual driver."],
    ["Shedding light on the ABYSSWORKER driver", "https://www.elastic.co/security-labs/abyssworker", "Elastic Security Labs", "2025", 5, "malicious driver EDR killer callbacks minifilter IOCTL ransomware", "A code-level analysis of the MEDUSA-linked ABYSSWORKER driver, including IOCTL handlers that terminate processes, remove callbacks, detach minifilters, and replace dispatch routines. RVAs, samples, YARA, and a client implementation make the research unusually reproducible."],
    ["Lazarus & BYOVD: evil to the Windows core", "https://www.welivesecurity.com/2022/09/30/amazon-themed-campaigns-lazarus-netherlands-belgium/", "ESET Research", "2022", 5, "Lazarus CVE-2021-21551 Dell driver rootkit EDR blinding", "Documents Lazarus weaponizing Dell's DBUtil vulnerability to obtain kernel read/write and disable monitoring components. It is a high-value bridge between exploit primitives and a real APT's operational rootkit and defense-evasion design."],
    ["Screwed Drivers", "https://github.com/eclypsium/Screwed-Drivers", "Eclypsium", "2019", 5, "signed drivers firmware access kernel primitives research corpus", "The research corpus behind Eclypsium's discovery of widespread signed drivers exposing privileged hardware and firmware access. It is useful both as a historic BYOVD turning point and as a concrete collection for comparing vulnerable interface patterns across vendors."],
    ["physmem_drivers", "https://github.com/namazso/physmem_drivers", "namazso", "Living", 5, "physical memory vulnerable signed drivers comparative library", "A compact comparative library for signed drivers that expose physical-memory primitives, with common abstractions and per-driver implementations. Reading the code side by side reveals how recurring IOCTL and mapping designs can be normalized into reusable kernel read/write capabilities."],
    ["KDU", "https://github.com/hfiref0x/KDU", "hfiref0x", "Living", 5, "kernel driver utility vulnerable driver providers DSE mapping", "A mature research utility with a provider model covering many vulnerable-driver families and multiple kernel-code loading strategies. Its breadth and careful build-specific handling make it executable documentation of the BYOVD ecosystem, though it belongs only in isolated research environments."],
    ["BYOVD Research", "https://github.com/KOSEC-LLC/BYOVD-Research", "KOSEC", "Living", 4, "BYOVD driver research exploit chains vendor analysis", "A focused repository collecting reproducible vulnerable-driver research and exploitation artifacts. It is valuable as a bridge from catalog records to code-level validation, with enough context to compare driver primitives rather than treating hashes as the research endpoint."],
    ["BlackSnufkin BYOVD", "https://github.com/BlackSnufkin/BYOVD", "BlackSnufkin", "Living", 4, "BYOVD EDR termination callbacks kernel driver PoC", "A practical implementation of vulnerable-driver-assisted security-product tampering with clear source and operational flow. Use it to study how user-mode orchestration, device IOCTLs, process discovery, and kernel capabilities are assembled into an EDR-kill chain."],
    ["RealBlindingEDR", "https://github.com/myzxcg/RealBlindingEDR", "myz", "2024", 5, "EDR callbacks minifilters ETW Ti vulnerable driver kernel tampering", "A source-level implementation of blinding EDR telemetry through kernel read/write, including callback, minifilter, and ETW-related targets. It is frequently referenced by threat research because it connects generic BYOVD primitives to the exact kernel structures defenders depend on."],
    ["Hunting Vulnerable Kernel Drivers", "https://blogs.vmware.com/security/2023/10/hunting-vulnerable-kernel-drivers.html", "Takahiro Haruyama / VMware TAU", "2023", 5, "WDM WDF vulnerable driver hunting IDAPython firmware kernel memory", "Builds an IDAPython-assisted pipeline for triaging both WDM and WDF drivers, then applies it to roughly 18,000 samples and validates 34 vulnerable driver families. The article explains device ACL filtering, firmware and MSR access, kernel read/write primitives, exploit development, reporting, and the limits of blocklist-based BYOVD defenses."],
    ["Driver-Based Attacks: Past and Present", "https://www.rapid7.com/blog/post/2021/12/13/driver-based-attacks-past-and-present/", "Jake Baines / Rapid7", "2021", 5, "BYOVD Dell DBUtil PPL LSA protection driver blocklist", "Connects historical in-the-wild driver abuse to a concrete exploitation of Dell DBUtilDrv2, using kernel writes to change process protection and expose LSASS. It also compares unsigned-driver loaders, explains why administrative-only access does not remove BYOVD value, and records practical detection and mitigation options."],
    ["Screwed Drivers: Signed, Sealed, Delivered", "https://eclypsium.com/blog/screwed-drivers-signed-sealed-delivered/", "Eclypsium", "2019", 5, "signed vulnerable drivers firmware physical memory port IO BYOVD", "The original long-form publication behind Eclypsium's cross-vendor driver corpus, showing how legitimate hardware utilities expose privileged physical-memory, model-specific register, port-I/O, and firmware capabilities. It frames the recurring design failure and explains why valid signatures can turn vendor maintenance components into reusable kernel-entry paths."],
    ["Mother of All Drivers", "https://eclypsium.com/research/mother-of-all-drivers-new-vulnerabilities-found-in-windows-drivers/", "Eclypsium", "2019", 4, "Windows drivers firmware update arbitrary kernel access vendor research", "Extends the Screwed Drivers investigation with additional affected vendors and driver families, tracing weak access control and hardware-facing interfaces into kernel compromise and firmware risk. The report is useful for comparing recurring vulnerable patterns across otherwise unrelated OEM update and diagnostic utilities."],
    ["Screwed Drivers Open ATMs to Attack", "https://eclypsium.com/research/screwed-drivers-open-atms-to-attack/", "Eclypsium", "2020", 4, "ATM POS vulnerable driver port IO PCI firmware persistence", "Applies vulnerable-driver analysis to Windows-based ATM and point-of-sale systems, identifying a signed driver that exposes arbitrary x86 port I/O and a path toward PCI and firmware manipulation. It adds operational context around legacy Windows fleets, vendor update constraints, physical access, and long-lived blocklist gaps."],
    ["facebook-media Driver Kernel LPE", "https://github.com/Haider303/facebook-media-driver-exploit", "Haider Mustafa", "2026", 4, "facebook-media driver virtual physical memory read write token steal", "A compact source exploit for a signed driver exposing kernel virtual reads and physical-memory reads and writes through three unvalidated IOCTLs. It walks active EPROCESS objects, translates the available primitives into a SYSTEM-token replacement, records build-dependent structure offsets, and keeps the driver contract visible for independent review."],
    ["WinNotify.sys Arbitrary Kernel Read/Write", "https://github.com/Haider303/winnotify-exp", "Haider Mustafa", "2026", 4, "WinNotify signed driver low privilege arbitrary kernel read write token LPE", "Demonstrates a Microsoft-signed driver's world-accessible interface yielding arbitrary kernel reads and writes from a standard-user process. The source resolves the kernel base, traverses EPROCESS state, and replaces the caller's token on Windows 10 22H2, while clearly identifying the build-specific offsets that must be revalidated elsewhere."],
    ["BYOVD to the next level, part 2: reflective driver loading", "https://blog.quarkslab.com/exploiting-lenovo-driver-cve-2025-8061_part2.html", "Luis Casvella / Quarkslab", "2025", 5, "Lenovo BYOVD reflective driver loading kernel mapper DSE bypass", "Carries the LnvMSRIO primitives into a complete unsigned-driver mapping chain: temporary NtAddAtom patching for PASSIVE_LEVEL kernel API calls, nonpaged-pool allocation, PE relocation and import resolution, physical-memory copying, and entry-point invocation. The article also explains IRQL and PatchGuard constraints that simplistic mapper descriptions omit."],
    ["gdrv3.sys: thirteen signed-driver hardware primitives", "https://zonifer.dev/posts/byovd-kernel-driver-hardware-primitives.html", "Zonifer", "2026", 5, "gdrv3 Gigabyte BYOVD physical memory MSR kernel memcpy port IO", "Reverse engineers a signed Gigabyte driver into a concrete map of thirteen IOCTLs rather than stopping after the first exploitable call. The recovered surface includes physical-memory mapping, arbitrary kernel copying, model-specific-register access, raw port I/O, PCI configuration, and related hardware operations, with request layouts and missing authorization checks tied directly to BYOVD outcomes."],
    ["ThrottleStop CVE-2025-7771: physical memory to process internals", "https://www.poh0.dev/windows/driver/vulnerability/2025/09/22/throttlestop-vulnerable-driver/", "poh0", "2025", 5, "CVE-2025-7771 ThrottleStop physical memory Superfetch PFN VAD BYOVD", "Reconstructs ThrottleStop.sys device naming and METHOD_BUFFERED IOCTLs 0x80006498 and 0x8000649C for attacker-selected MmMapIoSpace reads and writes. The source-backed PoC then uses Superfetch PFN information for virtual-to-physical translation, locates EPROCESS state, and walks a target's VAD tree, demonstrating how a raw hardware primitive becomes useful cross-process memory access."],
    ["Vulnerable Driver Manipulation", "https://git.back.engineering/IDontCode/VDM/raw/tag/v1.3/VDM.pdf", "IDontCode / back.engineering", "2020", 5, "VDM vulnerable drivers physical memory page tables kernel function calls", "Develops a reusable abstraction for signed drivers that expose physical-memory mapping, including device and IOCTL discovery, buffer contracts, page-table traversal, virtual-memory reads and writes, and invocation of exported kernel routines. By applying the same exploitation architecture across multiple providers, the paper shows which pieces belong to the driver and which can be normalized into a portable BYOVD layer."],
    ["Bring Your Own Backdoor: how vulnerable drivers let hackers in", "https://blogs.vmware.com/security/2023/04/bring-your-own-backdoor-how-vulnerable-drivers-let-hackers-in.html", "Dana Behling / VMware TAU", "2023", 4, "BYOVD MSR IOCTL PnP firmware UEFI driver vulnerability taxonomy", "Builds a Windows-driver abuse taxonomy around attacker-controlled MSRs, unprotected IOCTLs, plug-and-play trust, firmware update paths, and UEFI components. Each class is connected to concrete primitives such as LSTAR replacement or MmMapIoSpace writes, platform mitigations, and real campaign or CVE references, making the article a useful graph hub rather than a generic BYOVD definition."],
    ["Unveiling BYOVD Threats: a comprehensive analysis", "https://www.ndss-symposium.org/wp-content/uploads/2026-s1491-paper.pdf", "NDSS Symposium researchers", "2026", 5, "BYOVD empirical study vulnerable drivers IOCTL capabilities blocklists termdd", "Presents a large empirical study of vulnerable-driver abuse, validating which samples still load on modern Windows and classifying the privileged capabilities exposed through their interfaces. The paper connects driver provenance, IOCTL behavior, observed attacks, blocklist coverage, and detailed cases such as legacy termdd.sys abuse, providing evidence for ecosystem-level conclusions that individual reversals cannot support."],
    ["CVE-2021-21551: DBUtil Page-Table Exploitation", "https://connormcgarr.github.io/cve-2020-21551-sploit/", "Connor McGarr", "2021", 5, "CVE-2021-21551 DBUtil arbitrary read write PTE SMEP kCFG HalDispatchTable", "Takes Dell DBUtil's controllable memmove arguments beyond a data-only token edit and builds a full code-execution chain. The writeup derives one-QWORD kernel reads and writes, locates driver and kernel bases, stages shellcode in a writable image section, modifies its page-table entry to defeat NX and SMEP, and redirects HalDispatchTable while explaining where VBS, HVCI, and kernel CFG change the result."],
    ["RTCore64 BYOVD Read/Write Primitive Toolkit", "https://github.com/0xJs/BYOVD_read_write_primitive", "0xJs", "Living", 5, "RTCore64 BYOVD PPL callbacks ETW token DSE g_CiOptions symbols", "Provides separate source-level clients that normalize MSI RTCore64's kernel read/write IOCTLs into concrete security-control modifications. The projects change PPL state, remove process and thread callbacks, patch ETW providers, swap or downgrade tokens, resolve offsets from public symbols, toggle g_CiOptions when VBS is absent, load an unsigned demonstration driver, and restore or unload artifacts for comparison."],
    ["MmMapIoSpace Interception as a Driver Exploit Primitive", "https://www.microsoft.com/en-us/msrc/blog/2022/03/exploring-a-new-class-of-kernel-exploit-primitive/", "Microsoft Security Response Center", "2022", 5, "MmMapIoSpace interception vulnerable drivers physical memory race kernel exploit primitive", "Explains Microsoft's platform mitigation for drivers that map attacker-selected physical memory by intercepting MmMapIoSpace and MmMapIoSpaceEx calls and validating sensitive ranges. The post models the exploitable mapping window, page-table and kernel-code targets, race constraints, compatibility decisions, telemetry, and why preventing dangerous mappings centrally can shrink an entire cross-vendor BYOVD class rather than block individual hashes."],
    ["Realtek RtsPer Driver Vulnerabilities, Part 1", "https://zwclose.github.io/2024/10/14/rtsper1.html", "ZwClose", "2024", 5, "Realtek RtsPer DMA physical memory kernel write pool stack leak CVE", "Reverse engineers a widely deployed Realtek SD-card reader driver whose permissive device and control handlers expose pool and stack disclosures, arbitrary kernel writes, and hardware DMA programming from an unprivileged client. The article reconstructs several IOCTL formats, bypasses the driver's own signature checks, compares related CVEs, and shows how device-backed DMA reaches physical memory across many Dell and Lenovo systems."],
    ["IOMap64 Physical Memory Exposure: CVE-2024-41498", "https://reveng.ai/blog/physmem-e-when-kernel-drivers-peek-into-memory", "RevEng.AI Research", "2024", 5, "CVE-2024-41498 IOMap64 physical memory mapping IOCTL BYOVD PoC YARA", "Analyzes IOMap64.sys from device creation through its IOCTL dispatcher to the missing authorization and range validation that expose all physical RAM to user mode. The researchers verify the mapping and read/write contract with a public proof of concept, connect the primitive to kernel compromise, compare vulnerable versions, and publish hashes, YARA, and behavioral indicators suitable for validating blocklists and endpoint detections."],
    ["Exploiting WRMSR in Vulnerable Drivers", "https://idafchev.github.io/research/2023/10/31/wrmsr.html", "Iliya Dafchev", "2023", 5, "WRMSR LSTAR vulnerable driver KPTI SMEP SMAP PatchGuard kernel ROP", "Builds a stable privilege-escalation chain from a driver that accepts attacker-selected WRMSR arguments, rather than ending with an LSTAR crash. The article reconstructs Windows syscall entry and exit, KVA shadow, SMEP, SMAP, per-core affinity, ROP stack preparation, fast restoration for PatchGuard safety, token-stealing shellcode, and a clean return to user mode with accompanying source."],
    ["CVE-2020-28921: PC Analyser Arbitrary MSR Access", "https://github.com/eset/vulnerability-disclosures/blob/master/CVE-2020-28921/CVE-2020-28921.md", "Michal Poslušný / ESET", "2020", 5, "CVE-2020-28921 PCADRVX64 arbitrary RDMSR WRMSR LSTAR SYSENTER Ring 0", "The original coordinated disclosure for PCADRVX64.sys records the world-accessible IOCTLs that expose arbitrary RDMSR and WRMSR operations to an unprivileged process. It identifies the exact control codes and critical IA32_LSTAR and IA32_SYSENTER_EIP targets, evaluates modern SMEP and SMAP exploitability, and preserves the vendor response and fixed release timeline."],
    ["MSREXEC: Elevating Arbitrary WRMSR to Kernel Execution", "https://github.com/backengineering/msrexec", "backengineering", "2021", 5, "MSREXEC WRMSR LSTAR KVA shadow SMEP SMAP ROP vulnerable driver", "Provides a reusable source abstraction that accepts any driver-specific arbitrary-WRMSR callback and converts it into execution of a caller-supplied routine in the Windows kernel. Its assembly and documentation cover LSTAR redirection, KVA-shadow entry, SMEP gadgets, user-controlled AC state for SMAP, register and flag restoration, syscall restrictions inside the payload, and the important limitation that HVCI or security hypervisors break the method."],
    ["Not Very Gentlemanly: ktapi.sys Zero-Day EDR Killer", "https://expel.com/blog/not-very-gentlemanly-analyzing-a-zero-day-exploit-used-by-the-gentlemen-ransomware-to-disable-targets-edrs/", "Expel", "2026", 5, "ktapi.sys Gentlemen ransomware zero-day BYOVD SMAP SMEP EDR termination", "Reverse engineers a Gentlemen ransomware incident in which a decade-old signed Kontron ktapi.sys driver was weaponized before it appeared in public vulnerable-driver blocklists. The analysis follows the exploit from the exposed interface through mitigation bypasses for SMAP and SMEP to kernel execution and termination of protected Defender, ESET, Cortex XDR, and SentinelOne processes, then supplies incident artifacts and mitigations."],
    ["PhantomKiller: Weaponizing Lenovo BootRepair.sys", "https://github.com/redteamfortress/PhantomKiller", "j3h4ck / RedTeamFortress", "2026", 5, "Lenovo BootRepair.sys BYOVD ZwTerminateProcess PPL EDR killer IOCTL 0x222014", "Documents and implements abuse of Lenovo PC Manager's signed BootRepair.sys driver, whose unrestricted device accepts a four-byte PID through IOCTL 0x222014 and reaches PsLookupProcessByProcessId, ObOpenObjectByPointer, and ZwTerminateProcess without caller validation. Source, hashes, signer metadata, loading commands, and a compiled lab release make the PPL process-kill path independently auditable."],
    ["MSI Ambient Link Multiple Driver Vulnerabilities", "https://www.coresecurity.com/core-labs/advisories/msi-ambient-link-multiple-vulnerabilities", "Lucas Dominikow / CoreLabs", "2020", 5, "CVE-2020-17382 MsIo64 stack overflow IOCTL port IO low integrity SYSTEM", "The original CORE-2020-0012 disclosure shows that a world-accessible MsIo64 device exposes four IOCTL handlers with attacker-sized memmove operations and separate port-I/O primitives. It derives the 0x48-byte return-address overwrite, provides a Windows 7 SYSTEM exploit, explains the additional mitigation work required on Windows 10, and preserves the forced-disclosure timeline after MSI supplied no fix."],
    ["Viper RGB Driver Multiple Vulnerabilities", "https://www.coresecurity.com/core-labs/advisories/viper-rgb-driver-multiple-vulnerabilities", "Ricardo Narvaja and Lucas Dominikow / CoreLabs", "2020", 5, "CVE-2019-19452 CVE-2020-9756 Viper RGB MsIo stack overflow port IO", "Binary-diffs Patriot Viper RGB driver revisions to show that an attempted fix left the controllable memmove overflow intact, then turns IOCTL 0x80102040 into x64 kernel execution and SYSTEM. A second vulnerability exposes raw port reads and writes through 0x80102050 and 0x80102054; complete proof-of-concept code, device contracts, modern-mitigation caveats, and the vendor timeline make both primitives reproducible."],
    ["ASUS ATSZIO Physical-Memory Driver", "https://github.com/Chigusa0w0/AsusDriversPrivEscala/blob/master/ATSZIO.md", "LimiQS", "2018", 5, "ASUS ATSZIO WinFlash physical memory MSR PCI port IO DSE BYOVD", "Discloses that ASUS WinFlash installs a signed, world-accessible ATSZIO device with roughly twenty unauthenticated hardware-control IOCTLs. The report maps physical-memory reads and writes, 4K block access, MSRs, PCI configuration, port I/O, contiguous allocation, and CPU registers, then supplies a PoC that dumps and restores physical pages and explains the resulting DSE and privilege-escalation impact."],
    ["ASUS driver7.sys Physical-Memory Mapping", "https://github.com/Chigusa0w0/AsusDriversPrivEscala/blob/master/DRIVER7.md", "LimiQS", "2018", 5, "ASUS driver7 NKeyUpdate iteacc physical memory mapping MSR PCI SMI BYOVD", "Reverse engineers the second ASUS firmware utility driver in the same disclosure campaign, recovering about thirty IOCTLs behind the unprivileged iteacc device. The catalog includes arbitrary physical mapping, PCI and port access, CPU commands, MSRs, memory-space operations, and software SMI paths; signer hashes, hardware gating, disclosure history, and the absence of any unlock protocol make the risk independently auditable."],
    ["SliffDriver Multi-Provider SYSTEM Chain", "https://github.com/Haider303/sliff-driv-exploit", "Haider Mustafa", "2026", 5, "SliffDriver FoxKeDriver WinNotify physical memory VA PA arbitrary read token steal BYOVD", "Combines three signed vulnerable drivers whose individual capabilities are incomplete: SliffDriver maps attacker-selected physical memory, FoxKeDriver64 translates virtual addresses to physical ones, and WinNotify supplies kernel reads. The C exploit normalizes those interfaces, locates EPROCESS state, and performs SYSTEM token theft from a standard user on Windows 10 22H2, with binaries, source, offsets, and a demonstration retained together."],
    ["Dell SupportAssist Driver Local Privilege Escalation", "https://dronesec.net/blog/dell-supportassist-driver-local-privilege-escalation/", "Bryan Alexander / DroneSec", "2018", 5, "Dell SupportAssist PC Doctor driver physical memory MSR IOCTL token privileges LPE", "The original disclosure traces a Dell SupportAssist diagnostic driver from its permissive device object through a broad hardware-control IOCTL surface, including physical-memory, CMOS, PCI, port, and MSR operations. It turns the exposed primitive into a working local elevation, publishes exploit source and driver contracts, and provides the research lineage later ASUS physical-memory reports explicitly used as their comparison point."],
    ["VirtualBox VBoxDrv Arbitrary Kernel Write", "https://www.coresecurity.com/core-labs/advisories/virtualbox-privilege-escalation-vulnerability", "Anibal Sacco / CoreLabs", "2008", 5, "VirtualBox VBoxDrv METHOD_NEITHER arbitrary kernel write IOCTL ring0 privilege escalation", "A classic primary disclosure showing how a world-accessible VBoxDrv fast IOCTL returns through a METHOD_NEITHER UserBuffer without validating whether the pointer is user mode. The advisory follows the open-source dispatch path, derives the affected control codes, demonstrates an arbitrary kernel write with a minimal PoC, and explains how repeated controlled writes cross from an unprivileged VirtualBox client into ring-0 execution."],
    ["CVE-2018-19320: GIGABYTE GDrv Kernel Primitives", "https://seclists.org/fulldisclosure/2018/Dec/39", "Core Security", "2018", 5, "CVE-2018-19320 GIGABYTE GDrv ring0 memcpy physical memory MSR port IO BYOVD", "The original coordinated disclosure maps four vulnerabilities across GIGABYTE's signed GDrv family, including a ring-0 memcpy operation, physical-memory mapping, MSR access, and raw port I/O. It preserves affected versions, IOCTL contracts, proof-of-concept code, vendor correspondence, and the primitive later weaponized by RobbinHood to disable Driver Signature Enforcement."],
    ["CVE-2021-3437: HP OMEN HpPortIox64", "https://www.sentinelone.com/labs/cve-2021-3437-hp-omen-gaming-hub-privilege-escalation-bug-hits-millions-of-gaming-devices/", "Kasif Dekel / SentinelLabs", "2021", 5, "CVE-2021-3437 HP OMEN HpPortIox64 WinRing0 IOCTL kernel memory PCI MSR port IO", "Traces HP OMEN Gaming Hub's signed HpPortIox64.sys back to copied WinRing0 code and enumerates the low-privilege IOCTLs exposing kernel-memory, PCI configuration, model-specific-register, and port-I/O operations. The research connects each hardware primitive to realistic kernel escalation paths and documents the coordinated fix rather than stopping at a generic device-ACL finding."],
    ["Reverse Engineering Genshin Impact's mhyprot2", "https://research.meekolab.com/analyzing-genshin-impacts-anticheat-module", "meekochii / MeekoLabs", "2023", 5, "mhyprot2 Genshin Impact anti cheat BYOVD process termination callbacks DKOM ransomware", "Reverse engineers the mhyprot2 anti-cheat driver's callback registration, integrity validation, Windows-version handling, and process-termination interface after its use by spyware and ransomware. The analysis explains how its user-mode client passes protected targets, how kernel callbacks and DKOM resistance interact, and which design choices turn a legitimate game component into a portable defense-evasion dependency."],
    ["Argus: Abusing Defender's KslD Process Gate", "https://ckoi.dev/blog/argus-kernel-memory-disclosure-through-defenders-ksld-process-gate/", "koi", "2026", 5, "Microsoft Defender KslD IOCTL process path trust gate MmCopyMemory kernel physical memory read", "Finds a driver-abuse path in Microsoft Defender's own signed KslD.sys rather than importing a third-party BYOVD. By injecting into a suspended executable whose image path satisfies the driver's weak caller gate, Argus reaches symbol-resolution and MmCopyMemory commands, builds a kernel and physical-memory read primitive, and validates it through EPROCESS and VAD enumeration."],
    ["Analyzing WinPmem Driver Vulnerabilities", "https://static.ernw.de/whitepaper/ERNW_White_Paper_73-Analyzing_WinpMem_Driver_Vulnerabilities_1.0_signed.pdf", "ERNW Research", "2025", 5, "WinPmem METHOD_NEITHER TOCTOU arbitrary kernel read write zero where DSE SeCiCallbacks", "Audits the open forensic WinPmem driver as an attacker-accessible kernel interface, deriving a METHOD_NEITHER race and an output-pointer write-zero-where alongside its intended arbitrary-read capability. The paper evaluates historical gCiOptions tampering, HVCI and PatchGuard constraints, token-oriented alternatives, and SeCiCallbacks targets, clearly separating raw primitives from version-dependent exploitation."],
    ["Realtek RtsPer Driver Vulnerabilities, Part 2: DMA to Physical Memory", "https://zwclose.github.io/2026/07/08/rtsper2.html", "ZwClose", "2026", 5, "Realtek RtsPer RtsUer DMA SCSI physical memory IOMMU BYOVD CVE-2024-40431", "Completes the Realtek card-reader investigation by turning exposed control registers and vendor-specific SCSI commands into device-programmed DMA writes to arbitrary addresses in the first four gigabytes of physical memory. The article reconstructs the undocumented instruction format from open-source drivers, builds ADMA2 descriptors, solves virtual-to-physical discovery with self-corrupting descriptors, debugs on real hardware, and evaluates SD-card, shared-controller, DMA-remapping, OEM rollout, and multi-stage vendor-fix constraints."],
    ["CVE-2025-61156: ThreatFire System Monitor Driver", "https://github.com/D7EAD/CVE-2025-61156", "D7EAD", "2026", 4, "CVE-2025-61156 TfSysMon ThreatFire BYOVD PPL arbitrary process termination IOCTL", "Provides the original disclosure and source proof of concept for ThreatFire's still-signed TfSysMon.sys, whose permissive device security descriptor lets an unprivileged caller reach a kernel process-termination command. The repository identifies the affected release and driver hash, documents the device and IOCTL contract, demonstrates termination of PPL, EDR, and critical processes, records blocklist and certificate status at disclosure, and separates elevation impact from local denial of service."],
    ["Making Vulnerable Drivers Exploitable Without Hardware", "https://atos.net/wp-content/uploads/2026/04/atos-byovd-article.pdf", "Atos Cybersecurity Services", "2026", 5, "BYOVD hardware gating PnP IoCreateDevice AddDevice IOCTL reachability driver patching", "Develops a practical methodology for deciding whether a hardware-bound Windows driver can be repurposed as BYOVD on a machine that lacks its intended device. It traces DriverEntry, AddDevice, PnP dispatch, device-interface publication, and teardown gates; compares software-rooted device creation, registry and service state, runtime patching, and emulation approaches; and shows how to validate that the vulnerable IOCTL remains reachable rather than dismissing a strong primitive because normal installation never creates its device object."],
    ["Driver Reverse Engineering 101: Static Analysis", "https://eversinc33.com/2025/08/15/driver-reverse-engineering-101", "eversinc33", "2025", 5, "Windows driver reverse engineering WDM IOCTL IRP DriverEntry BYOVD triage", "Presents a disciplined static-analysis workflow developed while triaging a 47-gigabyte corpus of signed Windows drivers for BYOVD candidates. It moves from PE metadata, imports, device creation, symbolic links, and security descriptors through MajorFunction recovery, IRP stack locations, IOCTL decoding, transfer methods, buffer provenance, and dangerous API data flow, with enough IDA-oriented reasoning to distinguish a genuinely attacker-controlled primitive from an attractive but unreachable call site."],
    ["PoisonX: Reverse Engineering a BYOVD Zero-Day", "https://threatlabsnews.xcitium.com/blog/reverse-engineering-a-0-day-poisonx-byovd-driver-bypasses-crowdstrike-edr/", "Xcitium Threat Research", "2026", 5, "PoisonX ProcessMonitorDriver CVE-2026-0828 Safetica CrowdStrike EDR process termination BYOVD", "Reverse engineers PoisonX's use of Safetica ProcessMonitorDriver.sys as an unlisted process-kill primitive, following embedded-driver extraction, installation, device communication, request layout, protected-target selection, and cleanup inside the operational loader. The analysis connects the undocumented termination IOCTL to CVE-2026-0828, verifies impact against CrowdStrike Falcon, and supplies hashes, behavioral sequence, and detection ideas so defenders can recognize the capability independently of the malware's packaging."],
    ["PoisonX WindowsTelemetry: GLCKIo Callback Removal", "https://www.derp.ca/research/poisonx-windowstelemetry-byovd-rat/", "Derp Research", "2026", 5, "PoisonX WindowsTelemetry GLCKIo physical memory callback removal BYOVD RAT", "Dissects a second PoisonX component far enough to recover its complete GLCKIo driver protocol and post-load behavior. The analysis identifies the physical-memory map and unmap IOCTLs, follows kernel export and callback-array discovery, explains how matching EDR callbacks are erased, and preserves the driver properties, execution sequence, and configuration details needed to distinguish the BYOVD stage from the later RAT payload."],
    ["BootBypass: Atomic SeCiCallbacks Patching with RTCore64", "https://www.kvc.pl/repositories/bootbypass", "Marek Wesołowski", "2026", 5, "BootBypass RTCore64 SeCiCallbacks DSE unsigned driver atomic restore BYOVD", "Implements a narrowly scoped boot-time chain around RTCore64 rather than presenting an abstract kernel read/write demo. The loader resolves and patches the live SeCiCallbacks entry, starts a selected unsigned driver, restores the original pointer in the same sequence, and exposes configuration and cleanup behavior, making the repository useful for studying the operational boundary between a vulnerable-driver primitive and transient code-integrity bypass."],
    ["WinRing0 Vulnerable Driver Threat Description", "https://www.microsoft.com/en-us/wdsi/threats/malware-encyclopedia-description?Name=VulnerableDriver%3AWinNT%2FWinring0.B", "Microsoft Security Intelligence", "2025", 4, "WinRing0 CVE-2020-14979 vulnerable driver protected memory Microsoft Defender", "Documents Microsoft's detection and product-impact view of the widely redistributed WinRing0 driver behind CVE-2020-14979. It connects the unrestricted protected-memory capability to the many hardware-monitoring and tuning packages that bundle the same driver, giving defenders a vendor-maintained identity and remediation reference for a driver lineage whose filenames and parent applications vary substantially."],
    ["Kernel-Only WDAC Policy for BYOVD Protection", "https://github.com/HotCakeX/Harden-Windows-Security/wiki/WDAC-policy-for-BYOVD-Kernel-mode-only-protection", "Harden Windows Security", "2025", 4, "WDAC App Control kernel mode deny by default BYOVD policy driver allowlist", "Provides a deployable App Control design that removes implicit trust from third-party kernel drivers while leaving user-mode policy out of scope. The guide explains audit and enforcement modes, supplemental allow rules, signing implications, policy creation and rollout, and the operational tradeoff of treating every non-Microsoft driver as untrusted, offering a concrete defensive alternative to chasing an incomplete vulnerable-driver hash list."],
    ["Constraining High-Privilege Driver Behavior", "https://learn.microsoft.com/en-us/windows-hardware/drivers/driversecurity/driver-security-dev-best-practices", "Microsoft", "2024", 5, "Windows driver security IOCTL access control MmMapIoSpace ZwMapViewOfSection MSR port IO", "Defines Microsoft's secure-design expectations for the exact kernel capabilities most often converted into BYOVD primitives. The guidance pairs unsafe and constrained patterns for physical-memory mapping, model-specific registers, port I/O, arbitrary process and file operations, and IOCTL authorization, so researchers can compare a reversed dispatch path against platform-owner recommendations and developers can remove the primitive rather than merely block one binary hash."],
    ["CVE-2020-12138: Exploiting atillk64.sys", "https://h0mbre.github.io/atillk64_exploit/", "h0mbre", "2020", 5, "CVE-2020-12138 ATI atillk64 physical memory mapping page tables token stealing BYOVD", "Reverse engineers the signed atillk64.sys driver bundled with GIGABYTE RGB Fusion and recovers an IOCTL that maps attacker-selected physical memory into user space. The exploit then translates virtual addresses through live page tables, locates kernel process structures, replaces the current process token, and returns a SYSTEM shell, documenting request layouts, physical-address constraints, WinDbg validation, and complete proof-of-concept code."],
    ["Fast and Furious: Outrunning Kernel Notification Routines", "https://pmc.ncbi.nlm.nih.gov/articles/PMC7338165/", "Pierre Ciholas, Clémentine Maurice, Leyla Bilge, Gianluca Stringhini, Nuno Neves, and Jose Miguel Such", "2020", 5, "Windows kernel notification callback race protected process EDR anti-cheat handle inheritance", "Identifies a design-level race between process creation and the kernel notification callbacks used by endpoint and anti-cheat drivers to establish protection. The researchers systematically measure the window, preserve or transfer useful handles before enforcement arrives, and demonstrate impact against Symantec Endpoint Protection, VirtualBox, BattlEye, and EasyAntiCheat; published source, timing experiments, and proposed API and object-table defenses make the work reproducible beyond any one vulnerable driver."],
    ["Qihoo 360 Hypervisor Driver BYOVD Kill Switch", "https://cyberdagger.com/blog/qihoo-360-byovd-killswitch-loldrivers/", "CyberDagger Research", "2026", 5, "Qihoo 360 hypervisor driver BYOVD VMXOFF SVM disable virtualization IOCTL LOLDrivers", "Analyzes a signed Qihoo 360 hypervisor driver whose standalone device interface exposes a direct virtualization shutdown primitive to an administrator-controlled caller. The research traces driver initialization, device permissions and the relevant IOCTL to per-processor VMXOFF or AMD-V teardown, demonstrates how a trusted security component can disable VBS-backed defenses without a memory-corruption exploit, and records hashes and operational detection points incorporated into LOLDrivers."],
    ["Breaking Boundaries: Investigating Vulnerable Drivers and Mitigating Risks", "https://www.virusbulletin.com/uploads/pdf/conference/vb2024/papers/Breaking-boundaries-investigating-vulnerable-drivers-and-mitigating-risks.pdf", "Milan Stanojević and Vladan Milić / ESET", "2024", 5, "Windows vulnerable drivers BYOVD IOCTL permissions reverse engineering security checks blocklist Virus Bulletin", "Evaluates vulnerable-driver risk at the capability and access-control level rather than equating a signed hash with exploitability. Across real security and hardware drivers, the study classifies dangerous IOCTLs, reverses encoded request formats and privilege checks, shows how apparently read-only or hardware-dependent operations can still yield writes and kernel impact, and compares vendor hardening, Microsoft blocklisting, HVCI, and behavioral restrictions with concrete bypasses and deployment limitations."],
    ["What's Under the Hood? Root-Cause and Patch Analysis of Windows EoP", "https://www.dsta.gov.sg/staticfile/ydsp/projects/files/reports/Whats_under_the_Hood_Root_Caused_and_Patch_Analyses_of_Elevation_of_Privilege_Vulnerabilities_in_the_Windows_Operating_System.pdf", "DSTA Young Defence Scientists Programme", "2024", 5, "Windows EoP dbutil_2_3.sys DeviceIoControl physical memory AFD patch diff exploit development", "Applies a consistent root-cause and patch-diff workflow to Windows elevation-of-privilege targets, including Dell's dbutil_2_3.sys vulnerable driver. The report moves from device discovery and IOCTL recovery through static and dynamic validation, constructs the driver's arbitrary physical-memory access into an exploitation primitive, and contrasts that closed-source analysis with a patched Windows AFD flaw, providing concrete debugger, decompiler, symbol, and proof-of-concept methodology."],
    ["Terminator EDR Killer: Zemana Driver Abuse", "https://www.sentinelone.com/blog/terminator-edr-killer-spyboy-detecting-and-preventing-a-windows-byovd-attack/", "SentinelOne", "2023", 5, "Terminator Spyboy Zemana zam64 zamguard64 BYOVD EDR killer process termination IOCTL", "Analyzes the commercial Terminator EDR-killer offering and ties its claimed product coverage to vulnerable Zemana Anti-Logger and Anti-Malware drivers. The report follows staging and service creation, driver signing and device access, the user-mode controller's process targeting, observable artifacts and prevention results, giving defenders a concrete bridge between an underground tool advertisement, the signed kernel component it relies on and the behavior surrounding exploitation."],
    ["Terminator Variants Still Abusing Zemana Drivers", "https://www.sophos.com/en-us/blog/itll-be-back-attackers-still-abusing-terminator-tool-and-variants", "Andreas Klopsch and Matt Wixey / Sophos X-Ops", "2024", 5, "Terminator Zemana zam64 zamguard64 AuKill BlackByte BYOVD IOCTL allowlist process kill ransomware", "Extends the original Terminator disclosure with code comparison of the two Zemana drivers and the IOCTL sequence that first allowlists the attacker's process and then terminates a target. Sophos tracks C#, Nim and packed variants across Citrix intrusions, cryptomining and healthcare incidents, documents fallback from Zemana to AuKill, and shows why hash-only blocking loses coverage when criminals recompile, rename or substitute a functionally similar driver."],
    ["An In-Depth Look at Windows Kernel Threats", "https://documents.trendmicro.com/assets/white_papers/wp-an-in-depth-look-at-windows-kernel-threats.pdf", "Trend Micro Research", "2023", 5, "Windows kernel threats BYOVD malicious driver rootkit DSE callback tampering ransomware detection", "Builds a technical taxonomy of Windows kernel threats across exploitation of signed vulnerable drivers, abuse of intended driver capabilities and attacker-authored signed or unsigned implants. The paper maps representative malware and ransomware chains to DSE bypass, callback and process tampering, rootkit persistence and security-product disruption, then relates artifacts at service installation, image load, device interaction and kernel behavior to defensive coverage instead of reducing BYOVD to a list of hashes."],
    ["Monitoring and Preventing Vulnerable Driver Attacks", "https://techcommunity.microsoft.com/blog/microsoftsecurityexperts/strategies-to-monitor-and-prevent-vulnerable-driver-attacks/4103985", "Microsoft Security Experts", "2024", 4, "Windows BYOVD vulnerable driver monitoring Defender XDR WDAC App Control blocklist Sysmon event", "Presents Microsoft's operational model for detecting and constraining vulnerable-driver attacks across driver-load telemetry, code-signing identity, service creation, file provenance and post-load tampering. It distinguishes the Microsoft vulnerable-driver blocklist from allowlisting with App Control for Business, provides Defender hunting and policy guidance, and emphasizes validation of legitimate hardware dependencies so enforcement can be deployed without turning every old signed driver into either an automatic incident or an unmanaged exception."],
    ["Falcon Prevents Multiple Vulnerable Driver Attacks", "https://www.crowdstrike.com/en-us/blog/falcon-prevents-vulnerable-driver-attacks-real-world-intrusion/", "CrowdStrike", "2024", 5, "Windows BYOVD real world intrusion vulnerable driver DSE EDR tampering kernel memory CrowdStrike Falcon", "Reconstructs multiple vulnerable-driver attempts observed during a real intrusion, correlating driver staging and loading with the adversary's attempts to obtain kernel memory access, defeat endpoint controls and continue the operation. The report is useful beyond its product outcome because it preserves the sequence and attacker adaptation around blocked drivers, explains the relevant trust and code-integrity boundary, and identifies behavioral opportunities that survive filename and hash changes."],
    ["Making Hardware-Gated Drivers Exploitable Without Hardware", "https://bulletproofservers.hk/blog/making-vulnerable-drivers-exploitable-without-hardware-the-byovd-perspective/", "David Sasson / Bulletproof Servers", "2026", 5, "Windows BYOVD hardware gating PnP MMIO PCI BAR root enumerated device emulation", "Challenges the assumption that a vulnerable hardware driver is irrelevant when its physical device is absent. The research classifies initialization gates around PnP IDs, PCI configuration space, BAR-backed MMIO and chip-register checks, then demonstrates which state can be synthesized from administrator-controlled user mode through root-enumerated devices or software-visible configuration, giving analysts a disciplined way to distinguish truly unreachable IOCTLs from BYOVD candidates whose hardware dependency can be emulated."],
    ["Physmeme: Modular Unsigned Kernel Driver Mapping", "https://back.engineering/blog/19/04/2020/", "IDontCode / back.engineering", "2020", 5, "Physmeme Windows BYOVD physical memory unsigned driver mapper syscall hook kernel PE", "Converts an arbitrary physical read/write interface into a provider-independent unsigned-driver mapper. The implementation locates the physical page backing a selected ntoskrnl system-call stub, temporarily replaces it with a trampoline, invokes kernel allocation and copy routines through the ordinary user-mode syscall entry, resolves relocations and imports for the payload image, calls its entry point and restores the patched bytes, clearly separating reusable mapping logic from each vulnerable driver's four primitive adapters."],
    ["PTM: Page-Table Manipulation from User Mode", "https://git.back.engineering/IDontCode/PTM/raw/branch/master/PTM.pdf", "IDontCode / back.engineering", "2020", 5, "PTM Windows page tables BYOVD physical memory self reference PML4 user mode kernel", "Uses a vulnerable driver's physical-memory primitive only for bootstrap, then rewires page-table state so a user-mode library can inspect and modify arbitrary physical and virtual memory after the driver is removed. The paper covers PML4 through PTE translation, self-referential mappings, per-process address spaces, TLB implications and integrations with VDM, showing how a short-lived BYOVD foothold can create a longer-lived capability that no longer depends on repeated device IOCTLs."],
    ["RobbinHood and the GIGABYTE Driver DSE Bypass", "https://www.sophos.com/en-us/blog/the-realities-of-ransomware-the-evasion-arms-race", "Mark Loman / Sophos", "2020", 5, "RobbinHood ransomware GIGABYTE GDrv BYOVD DSE unsigned driver EDR termination", "Reconstructs how RobbinHood operationalized the old GIGABYTE GDrv vulnerability instead of merely shipping a generic process killer. The ransomware installs the still-signed hardware driver, uses its kernel memory capability to disable Driver Signature Enforcement, loads an attacker-controlled unsigned driver and issues commands that terminate security products before encryption; the wider incident context also shows why signer revocation and endpoint tamper protection must cover the entire staged chain."],
    ["Weaponizing gdrv.sys for a Complete BYOVD Chain", "https://mateustesser.github.io/posts/byovd/", "Mateus Tesser", "2025", 4, "GIGABYTE gdrv BYOVD IOCTL kernel memcpy g_CiOptions DSE rootkit mapping", "Provides a compact source-oriented lab that begins at gdrv.sys device creation and IOCTL recovery, reconstructs the request structure for its ring-0 memcpy operation, and turns the primitive into controlled kernel reads and writes. The worked chain locates and modifies g_CiOptions, handles the crash risk around invalid Code Integrity state, and loads a research rootkit, making the transitions from LOLDrivers sample to driver contract to privileged outcome explicit enough to reproduce and critique."],
    ["GGProtect64: Bypassing Weak Driver Authentication", "https://medium.com/%40haider303mustafa/bypassing-weak-driver-authentication-to-kill-ppl-protected-processes-ggprotect64-sys-analysis-d8f44c5837b4", "Haider Mustafa", "2026", 5, "GGProtect64 anticheat driver IOCTL authentication bypass PPL process termination BYOVD", "Reverse engineers a Microsoft-signed Chinese anti-cheat driver whose privileged IOCTL dispatcher is hidden behind nested control flow and a caller-registration scheme. Working backward from ZwTerminateProcess reveals IOCTL 0x223C04, while analysis of registration IOCTL 0x223C14 shows that any process can overwrite the trusted PID; the accompanying exploit registers itself, then terminates or suspends PPL-protected security processes from kernel context."],
    ["DsArk64: Authenticated Qihoo Driver with Kernel R/W", "https://www.loldrivers.io/drivers/399fb787-5b06-46f0-86cb-dff7374bb015/", "LOLDrivers contributors and Patrick Saif", "2026", 5, "DsArk64 Qihoo 360 driver Authenticode bypass AES IOCTL arbitrary kernel read write PPL", "Documents a WHQL-signed Qihoo anti-rootkit driver that combines PPL-capable process termination with bounded arbitrary kernel reads and writes. The entry preserves the exact kill IOCTL, AES-protected memory protocol, static-key requirement, initialization registry state and caller-signature gate, then explains how process hollowing into a freely available Qihoo-signed executable satisfies that gate and exposes the primitives to a BYOVD client."],
    ["Disabling PPL with a LOLDriver", "https://eljayright.dev/windows-driver-exploitation/loldriver_ppl/", "El Jay", "Living", 5, "Windows PPL EPROCESS Protection vulnerable driver arbitrary write offsets kernel debugging", "Turns a signed driver's arbitrary kernel write into a narrowly scoped data-only attack against Protected Process Light rather than loading unsigned kernel code. The walkthrough locates the target EPROCESS, resolves the version-dependent Protection field, validates offsets in WinDbg, and reuses the same IOCTL contract as a public EDR-blinding project to clear the protection byte, providing a compact bridge from driver reverse engineering to a modern post-exploitation objective."],
    ["Understanding Arbitrary Access Primitives in Windows Drivers", "https://whiteknightlabs.com/2025/06/17/understanding-arbitrary-access-primitives-in-windows-kernel/", "Jay Pandya / White Knight Labs", "2025", 5, "Windows vulnerable drivers arbitrary read write physical memory MSR IOCTL primitives", "Separates five commonly conflated driver bug capabilities—virtual arbitrary read, virtual arbitrary write, physical read, physical write and MSR access—and implements small vulnerable handlers to make their data flow explicit. Real driver examples such as DirectIO64 connect user buffers, MmMapIoSpace, physical mappings and rdmsr or wrmsr operations to concrete escalation options, helping researchers classify what an unfamiliar IOCTL actually grants before attempting weaponization."],
    ["Finding Vulnerable Drivers with Hooking and Result Verification", "https://link.springer.com/article/10.1186/s42400-025-00434-w", "Security and Communication Networks researchers", "2026", 5, "Windows driver vulnerability discovery API hooking reachability verification GPU-Z IOCTL BYOVD dataset", "Proposes a hybrid driver-hunting method that goes beyond flagging dangerous imports by verifying that attacker-controlled IOCTL paths actually reach sensitive instructions and return usable results. The evaluation covers more than eight hundred WDM drivers, instruments functions and privileged operations, filters hardware and initialization false positives, and uses GPU-Z's CVE-2019-7245 path as a detailed case study, making exploitability evidence—not a static keyword—the classification boundary."],
  ]},
  { id: "ipc", kicker: "Map privileged conversations", title: "COM, RPC & ALPC", items: [
    ["Relaying Kerberos from DCOM OXID Resolving", "https://www.tiraniddo.dev/2024/04/relaying-kerberos-authentication-from.html", "James Forshaw", "2024", 5, "DCOM OXID resolver Kerberos relay SPN target information ADCS", "Extends DCOM authentication research by showing how a marshaled target-information suffix can decouple the hostname used for OXID communication from the SPN authenticated by Kerberos. The post develops the OBJREF, DNS, RPCSS, integrity, and ADCS constraints explicitly and validates the primitive against contemporary SilverPotato research."],
    ["Finding Running RPC Servers with NtObjectManager", "https://www.tiraniddo.dev/2022/06/finding-running-rpc-server-information.html", "James Forshaw", "2022", 5, "Windows RPC endpoint enumeration NtObjectManager ALPC RpcView attack surface", "Compares four ways to identify live Windows RPC interfaces: endpoint-mapper queries, service and module correlation, process inspection, and asking an endpoint for its registered interface IDs. The article documents the blind spots of every method and combines them into a practical NtObjectManager workflow for mapping real attack surface rather than merely parsing binaries."],
    ["How the Windows Firewall RPC Filter Works", "https://www.tiraniddo.dev/2021/08/how-windows-firewall-rpc-filter-works.html", "James Forshaw", "2021", 5, "Windows firewall RPC filter interface UUID endpoint protocol security", "Reverse engineers the Windows Firewall RPC filtering layer, explaining how rules match interfaces, procedures, endpoints, protocol sequences, authentication, and network profiles before traffic reaches an RPC server. The implementation-focused analysis is crucial for understanding why an apparently reachable TCP endpoint may still be blocked and how interface-specific exposure should be tested."],
    ["How to Secure a Windows RPC Server—and How Not To", "https://www.tiraniddo.dev/2021/08/how-to-secure-windows-rpc-server-and.html", "James Forshaw", "2021", 5, "Windows RPC server security descriptors authentication callbacks multiplexed endpoints", "Builds a precise security model for Windows RPC across endpoint ACLs, interface security descriptors, authentication levels, registration flags, callbacks, impersonation, and ad-hoc checks. It also explains endpoint multiplexing and unauthenticated transports, showing why a server can be exposed through a weaker binding even when one endpoint appears correctly secured."],
    ["Finding Windows RPC Clients Through Brute Force", "https://www.tiraniddo.dev/2018/11/finding-windows-rpc-client.html", "James Forshaw", "2018", 5, "Windows RPC client discovery NDR format strings MIDL reverse engineering", "Presents a reverse-engineering technique for locating statically linked or otherwise hidden Windows RPC client stubs by searching candidate NDR format strings and validating their surrounding structures. The method fills an important tooling gap because client implementations reveal privileged callback and coercion paths that server-only enumeration cannot discover."],
    ["Finding Interactive-User COM Objects", "https://www.tiraniddo.dev/2018/09/finding-interactive-user-com-objects_9.html", "James Forshaw", "2018", 5, "COM interactive user activation session token OleViewDotNet PowerShell", "Uses OleView.NET and PowerShell to identify COM classes whose activation escapes a service or noninteractive session and reaches the logged-on user's context. The article maps registration, launch behavior, session selection, marshaling, and security assumptions, turning an obscure COM activation mode into an auditable cross-session attack surface."],
    ["Offensive Windows IPC Internals 1: Named Pipes", "https://csandker.io/2021/01/10/Offensive-Windows-IPC-1-NamedPipes.html", "Christoph Sandker", "2021", 5, "Windows named pipes impersonation SQOS race condition IPC attack surface", "Explains named-pipe modes, overlapped I/O, security descriptors, client impersonation, SQOS, local-versus-remote semantics, and instance-creation races from an offensive perspective. The included client/server examples and kernel call-path discussion make it the foundational first part of Sandker's Windows IPC series."],
    ["Windows Bug Class: Trapped COM Objects with IDispatch", "https://projectzero.google/2025/01/windows-bug-class-accessing-trapped-com.html", "James Forshaw / Project Zero", "2025", 5, "COM IDispatch ITypeInfo trapped object PPL code execution bug class", "Defines a cross-boundary bug class in which a remotely accessible object leaves dangerous helper objects trapped inside a privileged server, then demonstrates how IDispatch and type-library interfaces can instantiate in-process COM classes. The worked WaaSRemediation example reaches a PPL-Windows process and provides concrete hunting guidance rather than describing only one fixed CVE."],
    ["Insecure RpcEptMapper Registry Permissions", "https://itm4n.github.io/windows-registry-rpceptmapper-eop/", "itm4n", "2020", 5, "RpcEptMapper RPC endpoint mapper registry permissions service security", "Documents an unexpected permission weakness in the RpcEptMapper service configuration and methodically maps what a low-privilege user can alter. The post is an excellent IPC case study because it connects registry security descriptors, shared service hosting, RPC infrastructure, and restart behavior before a separate follow-up develops the exploit."],
    ["Fuzzing Windows RPC with RpcView", "https://itm4n.github.io/fuzzing-windows-rpc-rpcview/", "itm4n", "2021", 5, "Windows RPC fuzzing RpcView interface reconstruction NDR harness", "Presents a practical workflow for turning RpcView's recovered interface metadata into callable and fuzzable Windows RPC clients. It covers bindings, procedure formats, parameter reconstruction, harness design, and failure diagnosis, providing a concrete bridge between endpoint enumeration and systematic attack-surface testing."],
    ["From RpcView to PetitPotam", "https://itm4n.github.io/from-rpcview-to-petitpotam/", "itm4n", "2021", 5, "PetitPotam EFSRPC NTLM coercion RpcView Windows authentication", "Retraces the discovery path from RPC interface inspection to the PetitPotam authentication-coercion primitive, including EFSRPC procedures, bindings, authentication behavior, and reachable server variants. The narrative is especially valuable as a discovery methodology: it shows how tooling output becomes a security hypothesis and then a reproducible protocol-level result."],
    ["Process Injection via COM IRundown::DoCallback", "https://www.mdsec.co.uk/2022/04/process-injection-via-component-object-model-com-irundowndocallback/", "MDSec", "2022", 5, "COM IRundown DoCallback process injection RPC threadless", "Develops an injection technique around the undocumented IRundown::DoCallback interface, COM marshaling, and an existing target thread rather than a conventional remote-thread creation API. The article traces its inspiration to Project Zero work, explains the interface and call path, and publishes implementation details suitable for defensive reproduction."],
    ["Windows Lateral Movement with DCOM", "https://www.mdsec.co.uk/2020/09/i-like-to-move-it-windows-lateral-movement-part-2-dcom/", "MDSec", "2020", 4, "DCOM lateral movement activation remote execution Windows", "A practical examination of DCOM-based lateral movement that goes beyond listing well-known CLSIDs by explaining activation, remote object use, authentication assumptions, and observable behavior. It is useful context for COM security research because it shows how the same infrastructure is operated across hosts during a real red-team workflow."],
    ["External C2 Through Internet Explorer COM Objects", "https://www.mdsec.co.uk/2019/02/external-c2-ie-com-objects-and-how-to-use-them-for-command-and-control/", "MDSec", "2019", 4, "Internet Explorer COM External C2 IPC command control", "Builds a custom command-and-control transport through Internet Explorer COM automation and Cobalt Strike's External C2 interface. The writeup exposes the COM object interactions and data path, making it a useful case study in repurposing a trusted Windows component rather than merely naming a living-off-the-land binary."],
    ["Injecting Code into Windows Protected Processes Using COM, Part 1", "https://googleprojectzero.blogspot.com/2018/10/injecting-code-into-windows-protected.html", "James Forshaw / Project Zero", "2018", 5, "COM PPL protected process code integrity KnownDlls injection", "Builds the background and first half of a Protected Process Light injection chain from Windows code-integrity policy, KnownDll handling, COM activation, and trust-level behavior. Paired with the follow-up exploit, it is one of the clearest demonstrations of COM as a security-boundary mechanism rather than merely an application automation technology."],
    ["Investigating Filter Communication Ports", "https://windows-internals.com/investigating-filter-communication-ports/", "Yarden Shafir", "2023", 5, "minifilter communication ports Filter Manager IPC security descriptors", "Reverse engineers the communication mechanism between filesystem minifilters and user-mode services, including Filter Manager port objects, connection state, messages, and access control. It fills an important IPC gap left by COM/RPC/ALPC material and provides a practical basis for auditing privileged filter services and their trust assumptions."],
    ["Offensive Windows IPC Internals 3: ALPC", "https://csandker.io/2022/05/24/Offensive-Windows-IPC-3-ALPC.html", "Christoph Sandker", "2022", 5, "ALPC ports messages attributes impersonation mapped views heap spray", "A systematic explanation of ALPC port relationships, message flow, attributes, security descriptors, impersonation, and resource-lifetime attack surface. It includes a working client/server laboratory and concrete methods for finding accessible ports and vulnerable high-privilege servers."],
    ["Debugging and Reversing ALPC", "https://csandker.io/2022/05/29/Debugging-And-Reversing-ALPC.html", "Christoph Sandker", "2022", 5, "ALPC WinDbg kernel debugging port objects reversing", "A practical companion that traces ALPC from user-mode calls into kernel objects with WinDbg. Read it after the IPC overview to learn how to verify undocumented behavior rather than relying on diagrams or stale structure definitions."],
    ["Injecting code into Windows Protected Processes using COM", "https://googleprojectzero.blogspot.com/2018/11/injecting-code-into-windows-protected.html", "James Forshaw / Project Zero", "2018", 5, "COM PPL protected process IDispatch ALPC injection", "Shows how COM marshaling and exposed automation interfaces can become an injection path into Protected Process Light targets. The research is exemplary because it develops the object and transport mechanics, exploit constraints, and mitigations rather than presenting COM as a registry trick."],
    ["Windows Exploitation Tricks: Relaying DCOM Authentication", "https://googleprojectzero.blogspot.com/2021/10/windows-exploitation-tricks-relaying.html", "James Forshaw / Project Zero", "2021", 5, "DCOM Kerberos relay OXID resolver RPC ALPC authentication", "Dissects DCOM activation, OXID resolution, RPC bindings, and authentication to construct a local Kerberos relay primitive. It is required reading for understanding the protocol machinery behind coercion and relay families instead of treating them as opaque Potato variants."],
    ["OleView.NET", "https://github.com/tyranid/oleviewdotnet", "James Forshaw", "Living", 5, "COM RPC inspection activation marshaling security tooling", "A comprehensive .NET suite for enumerating, inspecting, activating, and security-testing COM and RPC infrastructure. Its parsers, viewers, scripting model, and database make it both a daily research tool and executable documentation of COM internals."],
    ["Offensive Windows IPC Internals 2: RPC", "https://csandker.io/2021/02/21/Offensive-Windows-IPC-2-RPC.html", "Christoph Sandker", "2021", 5, "RPC interfaces endpoints authentication impersonation attack surface", "Builds an offensive mental model of Windows RPC from interface definitions and bindings through authentication and impersonation. It is particularly useful before COM research because it exposes the transport and server assumptions that COM normally hides."],
    ["Named Pipe Secure Prefixes", "https://www.tiraniddo.dev/2017/11/named-pipe-secure-prefixes.html", "James Forshaw", "2017", 5, "NPFS named pipe squatting secure prefixes SeTcbPrivilege SDDL", "Reverse engineers the undocumented NPFS prefix objects that prevent low-privilege processes from squatting a privileged service's pipe name. The article follows NtCreateNamedPipeFile into the driver, identifies the SeTcbPrivilege gate and prefix DACL checks, documents SMSS-created protected namespaces, and shows how lifetime is tied to open handles."],
    ["Windows Tooling Updates: OleView.NET", "https://projectzero.google/2024/12/windows-tooling-updates-oleviewnet.html", "James Forshaw / Project Zero", "2024", 5, "OleView.NET COM proxy RPC ALPC OXID NDR tooling", "Documents major OleView.NET research improvements for reconstructing COM proxies, parsing type information, and invoking interfaces over RPC. The post explains ORPCTHIS/ORPCTHAT, ALPC-specific transport fields, OXID resolution, IRpcChannelBuffer reuse, activation, and the practical compromises required to make undocumented COM calls reliable."],
    ["Exploiting a Leaked Thread Handle", "https://projectzero.google/2016/03/exploiting-leaked-thread-handle.html", "James Forshaw / Project Zero", "2016", 5, "MS16-032 Secondary Logon RPC thread handle leak token SYSTEM", "Analyzes MS16-032 in the Secondary Logon service, where an RPC process-creation path leaks a highly privileged thread handle across the security boundary. The article then develops non-memory-corruption exploitation around thread context, impersonation, token state, and process creation, showing how a single object capability can be equivalent to code execution."],
    ["Calling Local Windows RPC Servers from .NET", "https://projectzero.google/2019/12/calling-local-windows-rpc-servers-from.html", "James Forshaw / Project Zero", "2019", 5, "Local RPC ALPC NDR managed client UAC NtApiDotNet", "Builds a pure managed path from extracting RPC metadata out of Windows binaries through NDR marshaling and direct ALPC transport, then applies it to a previously undocumented UAC bypass. The worked PowerShell flow shows interface selection, endpoint-mapper lookup, client generation, binding, and invocation without hiding the protocol behind a native proxy DLL."],
    ["Windows Exploitation Tricks: Spoofing Named Pipe Client PID", "https://projectzero.google/2019/09/windows-exploitation-tricks-spoofing.html", "James Forshaw / Project Zero", "2019", 5, "named pipe NPFS client PID spoofing SMB2 impersonation", "Reverse engineers how NPFS derives client PID and session metadata from extended attributes and demonstrates why a named-pipe server must not treat that identity as authoritative. It covers direct EA injection on older systems, local SMB's fixed ProcessId field, PID cycling, version boundaries, and the exact security-check patterns that become exploitable."],
    ["Internet Explorer EPM Sandbox Escape CVE-2014-6350", "https://projectzero.google/2014/12/internet-explorer-epm-sandbox-escape.html", "James Forshaw / Project Zero", "2014", 5, "DCOM COM marshaling EPM sandbox escape OBJREF memory disclosure", "Develops an unusual Enhanced Protected Mode escape through COM and DCOM rather than a conventional broker call. The write-up explains marshaled interface pointers, remote object references, activation across integrity boundaries, and how a companion memory disclosure supplies the address knowledge needed to convert the COM behavior into code execution."],
    ["Sharing a Logon Session a Little Too Much", "https://www.tiraniddo.dev/2020/04/sharing-logon-session-little-too-much.html", "James Forshaw", "2020", 5, "NETWORK SERVICE logon session SMB named pipe impersonation RPCSS token", "Shows that loopback SMB authentication by a NETWORK SERVICE process can yield an impersonation token carrying the service SID state of RPCSS, because LSASS associates the logon session with its first token. A named-pipe server and NtObjectManager experiments turn that subtle token-sharing behavior into full access to the otherwise protected RPCSS process, clearly exposing the boundary and its prerequisites."],
    ["Device Guard on Windows 10 S: Executing Arbitrary Code", "https://www.tiraniddo.dev/2017/07/dg-on-windows-10-s-executing-arbitrary.html", "James Forshaw", "2017", 5, "Windows 10 S Device Guard named pipe .NET Remoting BinaryFormatter code execution", "Breaks the Windows 10 S application policy by targeting AddInProcess.exe, whose named-pipe .NET Remoting channel accepts Full TypeFilterLevel BinaryFormatter messages. The article reconstructs the IPC URI and wire format, generates a serialized request offline, then finds an allowed scriptlet and FileSystemObject path to write raw exploit bytes into the pipe despite command and scripting restrictions."],
    ["Stupid Is as Stupid Does with .NET Remoting", "https://www.tiraniddo.dev/2014/11/stupid-is-as-stupid-does-when-it-comes.html", "James Forshaw", "2014", 5, ".NET Remoting IpcChannel named pipe BinaryFormatter TypeFilterLevel exploit", "Analyzes a privileged local .NET Remoting service whose IpcChannel is marked secure but exposes a Full TypeFilterLevel formatter over a predictable named pipe. The post separates transport authentication from object-deserialization safety, reconstructs the service URI and formatter sink chain, and develops the reusable exploitation approach that later Windows policy bypasses build upon."],
    ["An Overview of MS-RPC and Its Security Mechanisms", "https://www.akamai.com/blog/security-research/msrpc-security-mechanisms", "Oryan De Paz, Akamai", "2022", 5, "MS-RPC security endpoints interfaces callbacks authentication multiplexing impersonation", "Builds a security-focused model of MS-RPC from IDL and bindings through transport authentication, endpoint descriptors, interface registration flags, security callbacks, impersonation, and system-wide policy. Its treatment of endpoint and SSPI multiplexing explains why an interface can inherit a weaker transport or unexpected authentication state from another service hosted in the same process."],
    ["Fantastic RPC Interfaces and How to Find Them", "https://www.akamai.com/blog/security-research/rpc-toolkit-fantastic-interfaces-how-to-find", "Oryan De Paz, Akamai", "2023", 5, "RPC Toolkit PE Analyzer interface scraping security callback IDA radare", "Turns system-wide RPC attack-surface discovery into a repeatable workflow using Akamai's open-source PE scraper and Interface Analyzer. The article shows how to recover client and server UUIDs, registration flags, callback addresses, interface-level caching, and procedure names from dormant binaries, then query the JSON output for security-relevant patterns that live endpoint enumeration would miss."],
    ["Cold Hard Cache: Bypassing RPC Interface Security", "https://www.akamai.com/blog/security-research/cold-hard-cache-bypassing-rpc-with-cache-abuse", "Oryan De Paz and Stiv Kupchik, Akamai", "2022", 5, "CVE-2022-38034 CVE-2022-38045 RPC security callback cache SSPI multiplexing", "Discovers that RPC security-callback decisions can be cached too broadly and combines that behavior with process-wide SSPI registration to bypass procedure-specific restrictions. The research automates interface discovery and develops concrete srvsvc and WksSvc cases, showing how an allowed operation primes the cache before a restricted opnum is invoked for authentication coercion or cross-session share access."],
    ["CVE-2022-30216: Windows Server Service Authentication Coercion", "https://www.akamai.com/blog/security-research/authentication-coercion-windows-server-service", "Akamai Security Research", "2022", 5, "CVE-2022-30216 srvsvc MS-SRVS SMB over QUIC NTLM relay AD CS", "Reverse engineers new SMB-over-QUIC procedures added to the long-lived srvsvc RPC interface and finds that its callback's local-opnum range was not updated. By reaching LocalrServerCertificateMappingModify remotely with a UNC certificate-store path, the researchers force privileged WinReg RPC authentication to an attacker and relay it to AD CS, with a public proof of concept and precise patch analysis."],
    ["RPC Runtime, Take Two: CVE-2022-22019", "https://www.akamai.com/blog/security/rpc-runtime-patch-tuesday-take-two", "Ben Barnea, Akamai", "2022", 5, "CVE-2022-22019 rpcrt4 integer overflow heap buffer overflow patch diff", "Follows patch diffing of three critical rpcrt4 flaws to a missed integer-overflow variant in the same allocation path. The article explains how RPC fragment sizes and arithmetic produce an undersized heap buffer in both client and server code, why the April check did not cover the new path, and how systematic variant analysis led to a separately fixed remote-code-execution vulnerability."],
    ["RPC Visibility with Windows ETW", "https://www.akamai.com/blog/security-research/msrpc-defense-measures-in-windows-etw", "Stiv Kupchik, Akamai", "2023", 5, "MS-RPC ETW rpcrt4 TCP SMB named pipe opnum DCSync PetitPotam", "Reverse engineers the Microsoft-Windows-RPC provider and shows how to recover interface UUID, opnum, endpoint, authentication, and impersonation metadata from client and server call events. Because server events omit source addresses, the research correlates them with TCP and SMB ETW—including named-pipe opens and connection UUIDs—and publishes a visibility tool plus worked DCSync and PetitPotam detections."],
    ["Call and Register: Relay Attack on the WinReg RPC Client", "https://www.akamai.com/blog/security-research/winreg-relay-vulnerability", "Stiv Kupchik, Akamai", "2024", 5, "WinReg RPC client NTLM relay RegConnectRegistry endpoint mapper authentication", "Finds a legacy WinReg client path that accepts NTLM without integrity and turns it into a coercion-and-relay primitive after reconstructing the registry provider's outbound RPC flow. The report evaluates RPC-to-RPC and SMB relay targets, documents the practical authentication constraints, supplies ETW hunting guidance keyed to the WinReg UUID, and follows the issue through Microsoft's eventual patch."],
    ["PhantomRPC: Privilege Escalation Through Fake RPC Servers", "https://securelist.com/phantomrpc-rpc-vulnerability/119428/", "Haidar Kabibo, Kaspersky", "2026", 5, "PhantomRPC ALPC fake server endpoint squatting impersonation SYSTEM ETW", "Demonstrates an architectural local escalation in which a service account registers the endpoint of an unavailable legitimate RPC server, then coerces a privileged client that connects with SecurityImpersonation. The article develops five paths—including Group Policy to TermService—maps NtAlpcConnectPort and RequiredServerSid behavior, and provides an ETW methodology for finding high-privilege failed calls that can be captured by counterfeit servers."],
    ["Automating MS-RPC Vulnerability Research", "https://www.incendium.rocks/posts/Automating-MS-RPC-Vulnerability-Research/", "Remco van der Meer", "2025", 5, "MS-RPC fuzzing NtObjectManager dynamic client NDR Neo4j automation", "Designs a complete RPC research pipeline around NtObjectManager-generated managed clients: extract interfaces and endpoints from binaries, instantiate NDR parameter types, invoke procedures across available bindings, classify errors and successful calls, and load relationships into Neo4j. The long-form paper documents the protocol and engineering obstacles closely enough to reproduce the workflow instead of treating fuzzing as random integers."],
    ["Context-Aware MS-RPC Fuzzing", "https://www.incendium.rocks/posts/Revisiting-MS-RPC-Vulnerability-Research-automation/", "Remco van der Meer", "2025", 5, "MS-RPC fuzzer context handles procedure dependencies PrinterBug coercion", "Extends the initial fuzzer by sorting procedures according to output-to-input dependencies and reusing complex values such as NDR context handles, then tests the design against the Print Spooler and PrinterBug call sequence. The article compares default and context-aware mutation, records why semi-valid handles remain valuable, adds coercion and filesystem modes, and releases the implementation for independent testing."],
    ["Recursive MS-RPC Structure Fuzzing with ETW", "https://www.incendium.rocks/posts/Fuzzing-MS-RPC-structures-and-monitoring/", "Remco van der Meer", "2026", 5, "MS-RPC recursive structures unions ETW canary syscall monitoring RpcAddPrintProvidor", "Adds recursive embedded and pointer-backed structure generation, discriminated-union support, replayable crash detection, and an ETW monitor that follows canary input into privileged file and registry operations. A concrete spoolsv finding shows RpcAddPrintProvidor carrying a controlled DLL path to SYSTEM over TCP, demonstrating how semantic telemetry can surface dangerous behavior even when the call does not crash."],
    ["Automating COM and DCOM Vulnerability Research", "https://www.incendium.rocks/posts/Automating-COM-Vulnerability-Research/", "Remco van der Meer", "2025", 5, "COM DCOM fuzzing OleView.NET interfaces type libraries activation automation", "Transfers the RPC automation model to COM and DCOM using OleView.NET for class discovery, activation, proxy and type-library recovery, interface invocation, parameter construction, and result triage. The paper explicitly handles out-of-process boundaries and marshaling complications, then publishes a COM fuzzer and worked results, making it a practical bridge from COM enumeration to repeatable vulnerability hunting."],
    ["Remotely Crashing the Windows Spooler over RPC", "https://www.incendium.rocks/posts/Remotely-crashing-spooler/", "Remco van der Meer", "2025", 5, "Windows Spooler RPC remote denial service context handle fuzzing ALPC crash", "Documents a remotely reachable Spooler denial of service discovered by context-aware RPC fuzzing and reproducible by a low-privilege or enabled guest account. The writeup derives valid printer context handles, isolates the crashing procedures and parameter constraints, interprets the disappearing ALPC endpoint, studies service recovery limits, and records Microsoft's decision not to assign a CVE."],
    ["RPC-Racer: Winning RPC Endpoints Against Services", "https://www.safebreach.com/blog/you-snooze-you-lose-winning-rpc-endpoints/", "Ron Ben Yizhak / SafeBreach Labs", "2025", 5, "CVE-2025-49760 RPC endpoint mapper poisoning race PPL NTLM relay AD CS", "Develops EPM poisoning by racing delayed Windows services to register a trusted interface UUID first, causing high-integrity and PPL clients to bind to an attacker-controlled ALPC endpoint without server-identity verification. The CVE-2025-49760 case coerces a machine account through Delivery Optimization, relays NTLM to AD CS, obtains a certificate and TGT, and reaches domain secrets, with RPC-Racer tooling and ETW detection guidance."],
    ["EPM Poisoning from Low Integrity", "https://www.safebreach.com/blog/an-update-on-you-snooze-you-lose-winning-lpes-by-racing-services-for-rpc-endpoints/", "Ron Ben Yizhak / SafeBreach Labs", "2026", 5, "CVE-2025-59200 CVE-2025-59230 EPM poisoning low integrity DsSvc toast XML injection", "Extends RPC-Racer from ordinary user contexts into a sandbox escape: a low-integrity process registers the Data Sharing Service interface first, bypasses UIPI through an obscure diagnostic hotkey, and controls the scheduled task's RPC response. The resulting XML injection into a toast notification reaches medium integrity, while the RasMan variant and Microsoft's server-SID fix clarify how EPM clients should authenticate servers."],
    ["Win-DoS: Abusing RPC at Scale", "https://www.safebreach.com/blog/win-dos-epidemic-abusing-rpc-for-dos-and-ddos/", "Or Yair and Shahak Morag / SafeBreach Labs", "2025", 5, "Windows RPC TorpeDoS stateless bind Netlogon Spooler LDAP referrals denial service", "Builds stateless RPC and TorpeDoS techniques that pre-bind thousands of connections, pre-sign authenticated calls, and sharply increase procedure-call throughput. Reverse engineering Netlogon and Spooler allocation paths turns those primitives into remotely triggered resource exhaustion, while manipulated LDAP referrals show how public domain controllers can be recruited into a reflected Win-DDoS chain."],
    ["CVE-2025-29969: MS-EVEN Remote File Write", "https://www.safebreach.com/blog/safebreach_labs_discovers_cve-2025-29969/", "Shmuel Cohen and Tomer Bar / SafeBreach Labs", "2026", 5, "CVE-2025-29969 MS-EVEN EventLog RPC EVTX SMB TOCTOU arbitrary file write", "Reconstructs the Event Log service's legacy MS-EVEN methods and turns low-privilege remote access into both a file-existence oracle and an arbitrary file write. By serving an EVTX file over SMB, retaining its handle, and changing its contents after validation, the researchers win a cross-machine TOCTOU and redirect ElfrBackupELFW into user-writable execution paths on the victim."],
    ["Bypassing VirtualBox Process Hardening with COM", "https://projectzero.google/2017/08/bypassing-virtualbox-process-hardening.html", "James Forshaw / Google Project Zero", "2017", 5, "VirtualBox process hardening COM hijack scriptlet scrobj signed DLL trust boundary", "Tests VirtualBox's signed-image process hardening as a chain-of-trust problem and finds that per-user COM registration still influences the protected process. A Microsoft-signed scriptlet runtime and the signed .NET framework then transform trusted components into arbitrary in-memory code execution, illustrating why validating each loaded image does not secure the behavior composed through COM."],
    ["LDAPNightmare: CVE-2024-49113", "https://www.safebreach.com/blog/ldapnightmare-safebreach-labs-publishes-first-proof-of-concept-exploit-for-CVE-2024-49113/", "Or Yair / SafeBreach Labs", "2025", 5, "CVE-2024-49113 LDAPNightmare Netlogon RPC CLDAP referral LSASS denial service", "Reverse engineers an unauthenticated Netlogon RPC path that makes LSASS act as a CLDAP client, then shows how a malicious referral response reaches the vulnerable LDAP parsing path and crashes an unpatched Windows Server. The write-up develops packet construction, DNS and referral requirements, crash analysis, and a reproducible proof of concept rather than stopping at Microsoft's sparse advisory."],
    ["RemotePotato0: Relaying DCOM Authentication Across Sessions", "https://www.sentinelone.com/labs/relaying-potatoes-another-unexpected-privilege-escalation-vulnerability-in-windows-rpc-protocol/", "Antonio Cocomazzi and Andrea Pierini / SentinelLabs", "2021", 5, "RemotePotato0 DCOM OXID resolver NTLM relay session hijack RPC impersonation", "Extends Potato-style abuse beyond service accounts by combining DCOM activation, a forged OXID resolver, RPC authentication forwarding, and session selection to capture an interactive user's NTLM exchange and relay it to HTTP, LDAP, or SMB targets. The report reconstructs OBJREF and IRemUnknown2 traffic, explains identification-level and Message Integrity Check constraints, tests relay destinations, publishes the proof of concept and YARA rule, and records why server-side relay hardening remains necessary."],
    ["LocalPotato: NTLM Context Swapping to SYSTEM", "https://www.localpotato.com/localpotato_html/LocalPotato.html", "Andrea Pierini and Antonio Cocomazzi", "2023", 5, "CVE-2023-21746 LocalPotato NTLM local authentication context swap SMB arbitrary file write", "Discovers that two concurrent local NTLM authentications can have their context identifiers exchanged, causing an attacker-controlled SMB request to be authorized with a privileged COM client's credentials. The research traces SSPI hooks, challenge reserved fields, OXID triggering, local reflection behavior, and SMB signing assumptions, then converts arbitrary file read/write into SYSTEM through printconfig.dll loading while documenting affected builds and Microsoft's fix."],
    ["RoguePotato: Rebuilding the OXID Resolver Chain", "https://decoder.cloud/2020/05/11/no-more-juicypotato-old-story-welcome-roguepotato/", "Antonio Cocomazzi and Andrea Pierini", "2020", 5, "RoguePotato DCOM fake OXID resolver ResolveOxid2 named pipe epmapper token kidnapping", "Rebuilds Potato exploitation after Windows restricted custom OXID ports by implementing a remote ResolveOxid2 server, returning a crafted ncacn_np binding, and using named-pipe path normalization to redirect RPCSS from the reserved epmapper endpoint into an attacker-controlled pipe. The resulting NETWORK SERVICE impersonation token carries RPCSS logon-session access, enabling duplication of a SYSTEM token; packet layouts, DUALSTRINGARRAY construction, prerequisites, and source are all preserved."],
    ["From NETWORK SERVICE to SYSTEM", "https://decoder.cloud/2020/05/04/from-network-service-to-system/", "Antonio Cocomazzi", "2020", 5, "NETWORK SERVICE RPCSS logon session named pipe impersonation token duplication SYSTEM", "Turns the subtle RPCSS logon-session sharing behavior into a minimal standalone experiment: a NETWORK SERVICE process connects to an attacker-created pipe through loopback, the server impersonates that client, and the acquired token grants access to token handles stored inside RPCSS. The post explains authentication IDs, the NT SERVICE\\RpcSs group relationship, process-token enumeration, SYSTEM-token duplication, desktop permissions, and the exact proof-of-concept flow later reused by RoguePotato."],
    ["The Impersonation Game: DCOM Security QOS", "https://decoder.cloud/2020/05/30/the-impersonation-game/", "Antonio Cocomazzi", "2020", 5, "DCOM RPC security QOS impersonation level CoInitializeSecurity svchost CLSID token", "Investigates why forged DCOM and OXID chains usually obtain only identification tokens by tracing the NTLM Identify flag back to RPC_SECURITY_QOS and COM initialization policy. Registry and runtime experiments across more than seven thousand CLSIDs identify services and interactive-user objects that negotiate SecurityImpersonation, distinguish svchost group configuration from component-specific behavior, and show how target selection determines whether a captured callback token can actually be used."],
    ["Using Kerberos for Authentication Relay Attacks", "https://projectzero.google/2021/10/using-kerberos-for-authentication-relay.html", "James Forshaw / Google Project Zero", "2021", 5, "Kerberos relay DCOM OXID RPC SPN AuthIP SSPI Windows authentication", "Develops the protocol theory required to relay Kerberos rather than NTLM, separating service tickets, SPN selection, channel binding, integrity requirements, delegation, and the server's inability to prove the intended hostname. It then turns a malicious DCOM OXID resolver and attacker-controlled OBJREF security bindings into an arbitrary-SPN authentication source, compares the behavior with AuthIP, and carefully records which signing and local-loopback rules still prevent useful relay targets."],
    ["Click or Trick: Escaping the Sandbox with Windows URIs", "https://www.safebreach.com/blog/click-or-trick-cve-2025-59199-escaping-the-sandbox-with-windows-uris/", "Shmuel Cohen and Tomer Bar / SafeBreach Labs", "2025", 5, "CVE-2025-59199 Windows URI COM LocalServer RPC ALPC sandbox escape arbitrary write", "Traces a low-integrity Windows URI activation through shell infrastructure into an out-of-process COM LocalServer whose proxy and stub communicate over local RPC, then identifies trust mistakes that let a single user interaction cross the sandbox boundary. The research maps registration, marshaling, integrity levels, callback flow, and the resulting elevated file-write and execution primitives, providing both a modern COM attack-surface methodology and a version-bounded exploit case rather than only the CVE outcome."],
    ["The Key to COMpromise, Part 1: Hijacking Trusted Frontends", "https://cirosec.de/en/news/the-key-to-compromise/", "Alain Rödel and Kolja Grassmann / cirosec and Neodyme", "2025", 5, "COM hijacking EDR frontend backend named pipe replay CVE-2024-36302 SYSTEM", "Establishes a repeatable method for auditing AV and EDR products whose unprivileged frontends are trusted by privileged backend services. The researchers enumerate per-user-hijackable COM classes, force a malicious DLL into a trusted UI process, capture and replay its custom named-pipe messages, and exploit Trend Micro Apex One as CVE-2024-36302, while explaining why process identity alone is an invalid authorization decision across an IPC boundary."],
    ["The Key to COMpromise, Part 2: RPC and a TOCTOU Race", "https://cirosec.de/en/news/the-key-to-compromise-part-2/", "Alain Rödel and Kolja Grassmann / cirosec and Neodyme", "2025", 5, "COM hijacking AVG RPC CVE-2024-6510 OpLock junction TOCTOU PPL SYSTEM", "Extends the frontend-trust attack to AVG by bypassing a DLL-directory allowlist through a user-writable System32 subtree, reconstructing undocumented RPC clients, and reaching privileged update and self-defense operations. A controlled OpLock and junction sequence swaps a signed update DLL after validation, while an exposed RPC method disables the product's PPL-style protection, producing a full SYSTEM chain and documenting every IPC and filesystem assumption it composes."],
    ["The Key to COMpromise, Part 3: Privileged File Operations", "https://cirosec.de/en/news/the-key-to-compromise-part-3/", "Alain Rödel and Kolja Grassmann / cirosec and Neodyme", "2025", 5, "COM hijacking named pipe RPC Webroot Check Point CVE-2023-7241 CVE-2024-24912", "Applies the same methodology to two distinct backend protocols: an obfuscated fixed-size named-pipe command channel in Webroot and exported RPC client functions in Check Point Harmony. By recovering opcodes, buffer layouts, encryption, and file-operation arguments, the researchers turn unrestricted SYSTEM file deletion and download into privilege escalation, demonstrating how protocol reverse engineering—not the initial COM hijack—reveals the decisive authorization flaws."],
    ["ALPChecker: Detecting ALPC Spoofing and Blinding", "https://arxiv.org/abs/2401.01376", "Anastasiia Kropova and Igor Korkin", "2023", 5, "Windows ALPC kernel DKOM spoofing blinding port objects EDR detection ALPChecker", "Studies ALPC as a kernel-resident trust graph and demonstrates three DKOM attacks that alter connection and communication-port relationships to spoof endpoints or blind legitimate clients and servers without simply closing their handles. The paper reconstructs relevant port structures, implements the attacks in a driver, and introduces ALPChecker cross-view validation to recover inconsistencies, pairing an uncommon kernel IPC attack surface with a concrete defensive method."],
    ["Covert Kernel/User Communication Channels on Windows", "https://kernullist.github.io/kernullist-blog/posts/covert-kernel-user-communication-channels-on-windows/", "Kernullist", "2026", 5, "Windows kernel user communication ALPC shared memory inverted calls callbacks ETW detection", "Compares the implementation and detection properties of IOCTLs, inverted-call patterns, shared sections, named objects, ALPC and RPC, callbacks, registry or file channels, and other kernel-to-user control planes used by rootkits and game cheats. Rather than labeling one method stealthy, it maps object relationships, synchronization, handle and namespace evidence, message semantics, and cross-view opportunities so researchers can choose or detect a channel from its full lifecycle."],
    ["Building an Offensive RPC Interface", "https://sensepost.com/blog/2021/building-an-offensive-rpc-interface/", "SensePost", "2021", 5, "Windows MSRPC offensive C2 IDL MIDL named pipe endpoint authentication RPC server", "Builds a custom Windows RPC client and server from IDL through MIDL-generated stubs, interface registration, endpoint selection, binding, authentication, dispatch, and payload transport, with complete source. Implementing the protocol as an offensive control channel makes normally implicit runtime behavior visible and provides a controlled baseline for auditing endpoint exposure, security callbacks, impersonation, and telemetry in more complex proprietary RPC services."],
    ["Remote Wininit Shutdown Through MS-RPC", "https://www.akamai.com/blog/security-research/cant-wait-to-shut-you-down-msrpc-wininit", "Oryan De Paz and Ben Barnea / Akamai", "2022", 5, "WindowsShutdown RPC wininit remote denial service interface security callback ALPC TCP", "Reverse engineers the WindowsShutdown RPC interface exposed by wininit.exe and discovers that its security callback accepts remote TCP clients under conditions intended primarily for local ALPC callers. The researchers reconstruct bindings and NDR calls, trace authorization and shutdown paths, demonstrate a remote denial of service, and document Microsoft's fix, making the case a compact lesson in why transport checks, authentication, and interface permissions must be evaluated together."],
    ["SLYP: Agentic Vulnerability Reasoning on Windows COM Binaries", "https://arxiv.org/abs/2605.05000", "Hwiwon Lee, Jongseong Kim, and Lingming Zhang", "2026", 5, "Windows COM binary analysis race condition vulnerability discovery WinDbg PoC agent SLYP", "Presents an end-to-end research pipeline that gives an analysis agent explicit COM inspection, binary exploration, and interactive debugger tools rather than asking a generic model to infer privileged service behavior from decompiler text alone. Across production Windows COM servers it reports twenty-eight MSRC-confirmed flaws, sixteen assigned CVEs, and debugger-verified proof-of-concept generation, with benchmark methodology that exposes where activation metadata, marshaling context, race timing, and runtime feedback materially improve vulnerability reasoning."],
    ["Exploiting .NET Managed DCOM", "https://projectzero.google/2017/04/exploiting-net-managed-dcom.html", "James Forshaw / Google Project Zero", "2017", 5, "Windows .NET DCOM IManagedObject BinaryFormatter CCW RCW deserialization LPE RCE", "Defines a vulnerability class in the .NET-to-COM interoperability layer rather than a defect in one application. By reversing COM Callable Wrappers, Runtime Callable Wrappers, and IManagedObject, the article shows how a hostile marshaled object can make a privileged managed server deserialize attacker data, generalizes the primitive into a reusable SYSTEM exploit, and then reverses the direction to compromise managed DCOM clients such as remote WMI tooling."],
    ["Windows Sandbox Attack Surface Analysis", "https://projectzero.google/2015/11/windows-sandbox-attack-surface-analysis.html", "James Forshaw / Google Project Zero", "2015", 5, "Windows sandbox attack surface access token RPC named pipe object manager shared handle tooling", "Introduces an open-source suite for measuring what a real restricted or AppContainer token can reach instead of approximating its permissions from group membership. Alongside filesystem, registry, device, process, object-manager, network and shared-handle analysis, the toolkit inventories accessible named pipes and RPC endpoints, correlates resources shared across privilege boundaries, and turns repeatable access checks into a practical starting point for IPC-focused sandbox-escape research."],
    ["Dissecting DCOM, Part 1", "https://www.synacktiv.com/en/publications/dissecting-dcom-part-1", "Kevin Tellier / Synacktiv", "2025", 5, "Windows DCOM internals OXID resolver OBJREF ORPC activation RPC endpoint NDR network analysis", "Reconstructs DCOM from class registration and object activation down to the packets needed for a remote method call. The article maps CLSID, AppID and interface metadata to SCM and RPCSS behavior, follows activation and OXID resolution, decodes OBJREF, dual-string arrays, ORPCTHIS and marshaled interface data, and validates each stage in network traces, providing a protocol-level base for vulnerability research rather than a list of lateral-movement commands."],
    ["COM-pletely Unplanned: A Windows Bug Hunter's Journey to LPE", "https://www.enki.co.kr/en/media-center/blog/com-pletely-unplanned-a-windows-bug-hunter-s-journey-to-lpe", "Jongseong Kim and Dongjun Kim / ENKI WhiteHat", "2025", 5, "Windows COM vulnerability research AppContainer LPE proxy stub type library race condition privileged service", "Documents a systematic campaign against privileged Windows COM and WinRT services that produced more than ten Microsoft reports. The researchers explain how they select interfaces reachable from normal users and AppContainers, recover proxy/stub and type-library contracts, model launch versus access permissions, trace marshaling and server-side authority, and turn lifetime, path-handling, race, and trust-boundary mistakes into reproducible privilege-escalation cases."],
    ["Detection Strategies for COM, WMI, and ALPC-Based Multi-Process Malware", "https://www.mdpi.com/1424-8220/24/16/5118", "Radu Marian Portase, Andrei Marius Muntea, Andrei Mermeze, Adrian Colesa, and Gheorghe Sebestyen", "2024", 5, "Windows COM WMI ALPC malware detection RPC spoofing out of process telemetry ETW", "Studies the attribution gap created when malware asks legitimate COM or WMI servers to perform behavior out of process, then follows local RPC into ALPC to show why ordinary process-centric monitoring loses causality. The authors compare intrusive hooks with two lower-impact observation methods based on undocumented Windows behavior, implement a monitoring architecture, evaluate overhead and detection across a malware corpus, and identify the endpoint, call, and client context required to reconnect brokered actions to their origin."],
    ["Windows Named Pipes and Impersonation", "https://decoder.cloud/2019/03/06/windows-named-pipes-impersonation/", "Decoder", "2019", 4, "Windows named pipe NPFS impersonation token SeImpersonatePrivilege CreateProcessWithToken security descriptor", "Builds a named-pipe impersonation lab from the underlying NPFS server/client model through pipe ACL construction, connection handling, ImpersonateNamedPipeClient, thread-token capture and process creation. The worked PowerShell and native-API sequence also explains the often-missed privilege boundary: a server does not gain authority merely by receiving data, but can adopt a connecting client's context when its token and SeImpersonatePrivilege conditions permit it."],
    ["Changing Windows Passwords Through SAMR", "https://decoder.cloud/2025/02/11/changing-windows-passwords-in-the-most-complex-way/", "Decoder", "2025", 5, "Windows SAMR RPC password change AES PBKDF2 ncacn_np NDR SamrSetInformationUser2", "Reimplements a Windows password-change path at the SAMR protocol layer instead of delegating to NetUser or ordinary account-management APIs. The research reconstructs undocumented internal information classes, derives the AES-protected password structure and salt handling, builds the missing MIDL binding routine over the samr named-pipe endpoint, and validates server-side policy behavior, making the transport, cryptography and marshaling contract directly inspectable."],
    ["Microsoft Defender RPC Activity Monitoring", "https://techcommunity.microsoft.com/blog/microsoftdefenderatpblog/microsoft-defender-now-monitors-rpc-activity/4523368", "Edan Zwick / Microsoft", "2026", 5, "Microsoft Defender Windows RPC WFP interface UUID opnum remote call telemetry lateral movement hunting", "Documents Defender for Endpoint's new visibility into remote RPC calls at interface-UUID and operation-number granularity. Microsoft explains how it extends the existing Windows Filtering Platform RPC integration beneath transport encryption, relates specific interfaces and OpNums to service creation, scheduled tasks, remote registry and directory replication, and exposes hunting fields plus disruption behavior that let defenders reason about the invoked procedure rather than only port 135 or a hosting process."],
    ["ALPC Workings", "https://y3a.github.io/2023/07/25/alpc-workings/", "y3a", "2023", 5, "Windows ALPC internals port connection message attributes shared section handles NtAlpc security", "Reverse engineers the kernel-side shape of Windows ALPC around the shared ALPC_PORT object, connection and communication ports, message queues, attributes and section-backed bulk transfers. The article follows the native create, connect, accept and send/receive calls with WinDbg-visible state, relates port DACLs and client identity to the trust boundary, and supplies a concrete mental model for analyzing the RPC transport rather than treating ALPC as an opaque local socket."],
    ["SilverPotato: Relaying Interactive-User Authentication", "https://decoder.cloud/2024/04/24/hello-im-your-domain-admin-and-i-want-to-authenticate-against-you/", "Decoder", "2024", 5, "SilverPotato Windows DCOM OXID resolver Kerberos relay interactive user domain controller authentication coercion", "Starts from default DCOM activation permissions on domain controllers and discovers components that execute or authenticate as the interactive user while remaining remotely triggerable by broad local groups. The research combines OXID resolution, marshaled target information, Kerberos relay, COM launch identity and live-session enumeration into SilverPotato, carefully separating the caller that activates a class from the higher-value user whose credentials the server can be induced to present."],
    ["A Definitive Guide to the Windows RPC Filter", "https://www.akamai.com/blog/security/guide-rpc-filter", "Ophir Harpaz and Stiv Kupchik / Akamai", "2022", 5, "Windows RPC filter WFP netsh interface UUID endpoint authentication auditing internals", "Documents the only built-in Windows control that can authorize remote RPC traffic at interface and endpoint granularity, from netsh syntax and WinAPI structures through testing and Security-log auditing. The deep section follows rule creation through rpcnsh, WFP, BFE, WNF, rpcrt4 and RpcRtRemote, explains all five RPC filtering layers and their available conditions, and traces a request into the server-side classification callback, giving defenders implementation evidence for what a rule can and cannot constrain."],
    ["RemotePotato0: DCOM Session Authentication Relay", "https://www.safebreach.com/blog/remotepotato0-a-complex-active-directory-attack/", "Andrea Pierini and Antonio Cocomazzi / SafeBreach Labs", "2021", 5, "RemotePotato0 DCOM OXID resolver NTLM relay session hijack RPC SMB LDAP", "Builds a cross-session relay chain by activating a DCOM object in an interactive user's session, substituting a forged OXID resolver and forwarding the resulting RPC authentication rather than impersonating a local service token. The research decodes OBJREF and IRemUnknown2 exchanges, explains why identification-level tokens and the NTLM Message Integrity Check block simpler paths, evaluates SMB, HTTP and LDAP relay destinations, and publishes both the proof of concept and traffic-focused detection material."],
    ["Firefox Sandbox Escape via a Privileged RPC Service", "https://projectzero.google/2020/06/ff-sandbox-escape-cve-2020-12388.html", "Mark Brand / Google Project Zero", "2020", 5, "CVE-2020-12388 Firefox Windows sandbox escape RPC privileged service handle validation race", "Analyzes a Windows Firefox broker service whose RPC methods accept handles and identifiers from a content sandbox, then exposes the common privileged-service error of validating an object before later reusing attacker-influenced state. The writeup moves from interface recovery and call reachability through race construction and object substitution to a reliable sandbox escape, while showing how ordinary Windows RPC service patterns make cache and broker code a recurring cross-integrity attack surface."],
    ["Print Spooler TOCTOU: Bypassing the PrintDemon Patch", "https://www.safebreach.com/blog/how-we-bypassed-cve-2020-1048-patch-and-got-cve-2020-1337/", "Peleg Hadar and Tomer Bar / SafeBreach Labs", "2020", 5, "CVE-2020-1337 Print Spooler RPC XcvData TOCTOU junction arbitrary file write SYSTEM", "Shows how a reported Windows 7 and 8 workaround became a Windows 10 bypass after the first PrintDemon fix omitted the same path. An unprivileged client uses Spooler management calls to register a local port in a writable directory, then swaps that directory for a mount-point redirection before SYSTEM performs the print write, placing attacker-controlled SPL content in System32 for later execution; the stepwise PoC and disclosure history make the TOCTOU boundary and patch failure directly auditable."],
    ["Exploring Ancient RPC Ruins to Find New Bugs", "https://2022.hexacon.fr/slides/Exploring-Ancient-Ruins-to-Find-New-Bugs_Hexacon2022.pdf", "Oryan De Paz and Stiv Kupchik / Akamai", "2022", 5, "Windows MS-RPC attack surface PE scraping interface analyzer security callback fuzzing Hexacon", "Presents the research methodology behind Akamai's system-wide RPC work, beginning with offline PE scraping so interfaces hidden in dormant services are not missed and continuing through IDA-assisted recovery of registration flags, callback logic and opnum contracts. The deck connects the generated corpus to graph queries, targeted fuzzing, authentication-coercion cases and patch analysis, providing the architectural overview that links the individual srvsvc, WksSvc, Wininit and runtime findings into one repeatable vulnerability-discovery pipeline."],
    ["Exploring Impersonation through the Named Pipe Filesystem Driver", "https://specterops.io/blog/2023/05/03/exploring-impersonation-through-the-named-pipe-filesystem-driver/", "Jonathan Johnson / SpecterOps", "2023", 5, "Windows NPFS named pipe impersonation NtFsControlFile FSCTL_PIPE_IMPERSONATE tokens", "Follows ImpersonateNamedPipeClient below Win32 into NtFsControlFile and the NPFS filesystem driver, identifying FSCTL_PIPE_IMPERSONATE and the kernel dispatch path that installs the client's security context on the server thread. A direct native-API proof of concept, IRP and FSCTL discussion, and token observations make the actual impersonation boundary reproducible without treating a Potato tool as a black box."],
    ["Man-in-the-Machine: Exploiting Ill-Secured Communication", "https://www.usenix.org/system/files/conference/usenixsecurity18/sec18-bui.pdf", "Bui, Rao, Antikainen, and Aura / USENIX Security", "2018", 5, "Windows named pipes IPC squatting impersonation client server authentication privilege escalation", "Systematically studies local IPC endpoint squatting and peer-authentication failures across real desktop software, with Windows named pipes as a central case. The paper models both malicious-server and malicious-client positions, measures vulnerable applications, demonstrates privilege and data impact, and evaluates defenses around first-instance creation, pipe ACLs, server identity and client impersonation instead of assuming a locally named channel authenticates either endpoint."],
    ["Exploit Development for Windows MS-RPC Vulnerabilities", "https://www.incendium.rocks/posts/Exploit-Development-For-MSRPC/", "Remco van der Meer", "2025", 5, "Windows MS-RPC exploit development CVE-2025-26651 IDL NDR stubless proxy PoC", "Builds a working RPC vulnerability proof of concept from reverse-engineered Windows binaries, filling the gap between identifying an interface and exercising a vulnerable operation. Using CVE-2025-26651, the guide recovers UUIDs, opnums and NDR types, reconstructs IDL and client stubs, configures bindings and authentication, and iterates malformed parameters into a crash, providing a concrete path from static service analysis to local and remote exploit validation."],
    ["Exploring Three RCE Vulnerabilities in the RPC Runtime", "https://www.akamai.com/blog/security-research/rpc-runtime-exploring-three-vulnerabilities", "Ben Barnea / Akamai Security Research", "2023", 5, "Windows RPC runtime integer overflow SIMPLE_DICT queue CVE-2023-24869 CVE-2023-24908 CVE-2023-23405", "Reverse engineers three integer overflows in the shared Windows RPC runtime rather than in an individual service, tracing dynamic growth of SIMPLE_DICT, SIMPLE_DICT2 and call-queue arrays into undersized allocations and wild copies. The research works through reachable call flows, OSF connection scheduling, authentication-coercion delays, packet leftovers and practical trigger constraints, demonstrating how one runtime flaw can propagate across the system's RPC server population."],
    ["Disturbing a Host's Rest: Local Session Manager RPC", "https://www.akamai.com/blog/security-research/msrpc-lsm-cve-disturbing-hosts-rest", "Ben Barnea / Akamai Security Research", "2022", 5, "Windows LSM RPC CVE-2022-37998 CVE-2022-37973 sessions containers use after free", "Audits the Local Session Manager's little-documented RPC interface used for container and terminal-session state and develops proofs of concept for two patched vulnerabilities. Interface discovery, client and server reversing, object lifetime and session bookkeeping show how malformed call sequences disrupt Defender Application Guard, Sandbox, Docker and Terminal Services, while the supplied repository makes the unusual LSM attack surface independently testable."],
  ]},
  { id: "execution", kicker: "Follow execution into memory", title: "APC, Loaders & Injection", items: [
    ["Delegated NT DLL Callback Table", "https://modexp.wordpress.com/2024/02/13/delegated-nt-dll/", "modexp", "2024", 5, "DelegatedNtdll LdrpDelegatedNtdllExports callback table WoW64 hooks", "Documents the delegated NTDLL export table introduced in modern Windows and shows how its function pointers provide callback interception in 32-bit compatibility paths without inline code modification. The post identifies architecture-specific DLL locations, symbol names, table layout, protection assumptions, and a discovery proof of concept useful for both implant and hook-integrity research."],
    ["Windows ARM64 Shellcode", "https://modexp.wordpress.com/2024/09/16/windows_arm64/", "modexp", "2024", 5, "Windows 11 ARM64 shellcode AArch64 PEB API hashing COM IStream", "Builds Windows ARM64 shellcode from the calling convention and toolchain upward, covering TEB/PEB traversal, export parsing, API hashing, COM interface invocation, HTTP streaming, allocation, and payload execution. Complete AArch64 assembly and structure definitions make this a rare primary reference for payload engineering beyond the dominant x64 architecture."],
    ["Process Injection via Command Line and Environment", "https://modexp.wordpress.com/2020/07/31/wpi-cmdline-envar/", "modexp", "2020", 5, "Windows process injection command line environment PEB window title shellcode", "Explores process creation fields as covert shellcode carriers by placing payloads in command-line, environment, and window-title storage, locating them through the remote PEB, changing protection, and redirecting an existing callback to execute. The comparative implementations expose both the native data layout and the operational artifacts each variant leaves."],
    ["Process Injection by Breaking BaDDEr", "https://modexp.wordpress.com/2019/08/09/windows-process-injection-breaking-badder/", "modexp", "2019", 5, "Windows DDE DDEML explorer process injection callbacks shellcode", "Reverse engineers Dynamic Data Exchange servers hosted by Explorer and repurposes DDEML transaction and callback behavior as a process-injection route. The post covers server enumeration, internal structures, memory placement, callable function-pointer selection, and the technique's narrow target constraints rather than marketing DDE as a universal injection primitive."],
    ["In-Memory Script Execution Shellcode", "https://modexp.wordpress.com/2019/07/21/inmem-exec-script/", "modexp", "2019", 5, "Windows shellcode JavaScript VBScript JScript XSL ActiveScript in memory", "Implements position-independent Windows shellcode that hosts Active Scripting engines and executes JavaScript, VBScript, JScript, or XSL content directly from memory. The article develops COM initialization, interface discovery, script-site callbacks, language selection, error handling, and compact assembly, providing unusually transparent coverage of script hosting without launching a script interpreter."],
    ["In-Memory DLL Execution Shellcode", "https://modexp.wordpress.com/2019/06/24/inmem-exec-dll/", "modexp", "2019", 5, "Windows reflective DLL loader shellcode PE relocations imports TLS memory", "Constructs a compact in-memory PE DLL loader in shellcode, handling headers, section mapping, relocations, import resolution, memory protections, TLS callbacks, and entry-point invocation. Because each loader responsibility is shown in source and tied to PE structures, the post is a strong implementation reference rather than another wrapper around LoadLibrary."],
    ["Loading .NET Assemblies from Shellcode", "https://modexp.wordpress.com/2019/05/10/dotnet-loader-shellcode/", "modexp", "2019", 5, "Windows .NET CLR hosting shellcode ICLRRuntimeHost assembly memory", "Builds native shellcode that discovers and hosts the CLR, loads a managed assembly from memory, resolves its entry point, marshals arguments, and invokes it without powershell.exe. The article exposes the COM interfaces and runtime-version decisions behind managed execution, making it useful for auditing later loaders that inherit the same CLR-hosting pattern."],
    ["How .NET Executables Are Loaded", "https://repnz.github.io/posts/dotnet-executable-load/", "Ori Damari / repnz", "2019", 5, ".NET executable loader _CorExeMain PE CLR bootstrap Windows internals", "Traces Windows loading of a managed executable from the PE entry stub and mscoree import through _CorExeMain, CLR initialization, metadata inspection, and transfer to managed Main. Debugger experiments and patching demonstrations clarify the native-to-managed boundary that in-memory loaders and process-injection techniques deliberately reproduce or bypass."],
    ["A Beginner's Guide to Windows Shellcode Execution Techniques", "https://csandker.io/2019/07/24/ABeginnersGuideToWindowsShellcodeExecutionTechniques.html", "Christoph Sandker", "2019", 4, "Windows shellcode execution VirtualAlloc CreateThread callbacks APC fibers", "Compares multiple Windows shellcode execution paths through their allocation, memory-protection, and control-transfer APIs, giving newcomers concrete implementations to inspect side by side. Its value is the structured progression from a byte buffer to execution and the visibility of each native call, though readers should pair it with current telemetry research."],
    ["VBA RunPE, Part 1", "https://itm4n.github.io/vba-runpe-part1/", "itm4n", "2018", 5, "VBA RunPE process hollowing PE loader Windows API Office", "Builds a RunPE-style loader in VBA from first principles, covering PE parsing, target-process creation, remote memory layout, relocation-sensitive image placement, and thread-context manipulation. It is a useful execution reference because the restricted language forces every native boundary and structure to be made explicit."],
    ["VBA RunPE, Part 2", "https://itm4n.github.io/vba-runpe-part2/", "itm4n", "2018", 5, "VBA RunPE process hollowing relocations imports 64-bit Windows", "Completes the VBA loader by addressing the architectural and PE details left by the initial proof of concept, including robust structure handling and execution transfer. Together the two parts provide an unusually transparent process-hollowing implementation whose constraints are easier to audit than those of an opaque dropper."],
    ["Reinventing PowerShell in C/C++", "https://itm4n.github.io/reinventing-powershell/", "itm4n", "2025", 5, "PowerShell CLR hosting C++ automation assembly in memory execution", "Reconstructs PowerShell-like execution through native CLR hosting rather than launching powershell.exe, mapping runtime initialization, assembly loading, runspace or automation integration, and output handling. The article is strong execution research because it explains the managed-native boundary and operational tradeoffs instead of presenting only a detection-evasion wrapper."],
    ["Nighthawk 0.1: Memory and Thread Tradecraft", "https://www.mdsec.co.uk/2021/12/nighthawk-0-1-new-beginnings/", "MDSec", "2021", 5, "Windows process injection section mapping APC ETW-TI callbacks", "Documents the memory allocation, section mapping, thread selection, APC delivery, and cleanup design behind a modern Windows command-and-control implant. The value is in the explicit sequence of native APIs and telemetry considerations, which lets readers reason about both the implementation and the signals created at each stage."],
    ["Nighthawk 0.2: Catch Us If You Can", "https://www.mdsec.co.uk/2022/05/nighthawk-0-2-catch-us-if-you-can/", "MDSec", "2022", 5, "Windows in memory execution sleep obfuscation injection syscall", "Expands the earlier Nighthawk execution model with new in-memory and evasion research, discussing how payload state, sleep behavior, system calls, and execution transitions are managed. It is best read as an engineering update that records which operational assumptions changed when the implant met newer endpoint telemetry."],
    ["Detecting and Advancing In-Memory .NET Tradecraft", "https://www.mdsec.co.uk/2020/06/detecting-and-advancing-in-memory-net-tradecraft/", "MDSec", "2020", 5, ".NET CLR in memory execution assemblies detection Windows", "Analyzes how in-memory .NET execution appears inside a Windows process and develops techniques alongside the defensive observations that reveal them. By treating CLR loading, assemblies, memory artifacts, and telemetry together, it gives both operators and analysts a more durable model than a single reflective-loading proof of concept."],
    ["IIS Raid: Backdooring IIS with Native Modules", "https://www.mdsec.co.uk/2020/02/iis-raid-backdooring-iis-using-native-modules/", "MDSec", "2020", 5, "IIS native module backdoor request pipeline Windows execution", "Implements an IIS backdoor as a native module and explains registration, request-pipeline integration, command handling, and response behavior. The article is strong Windows execution research because it derives persistence and code execution from the server's supported extension architecture while exposing concrete configuration and forensic artifacts."],
    ["Payload Generation with CACTUSTORCH", "https://www.mdsec.co.uk/2017/07/payload-generation-with-cactustorch/", "MDSec", "2017", 4, "DotNetToJScript Windows script COM CLR payload execution", "Explains a payload-generation framework built on DotNetToJScript, connecting script hosts, COM activation, CLR bootstrap, and in-memory assembly execution. Although older, it remains useful for understanding the mechanics behind a major family of Windows script-based loaders and the trust transitions defenders monitor."],
    ["Thread and Process State Change", "https://windows-internals.com/thread-and-process-state-change/", "Yarden Shafir", "2021", 5, "NtChangeProcessState NtChangeThreadState process thread state objects", "Investigates the newer process and thread state-change objects and the native APIs that operate on them, tracing their kernel implementation and supported actions. The article provides rare documentation for mechanisms that influence suspension, resumption, and process lifecycle outside the familiar Win32 wrappers, which is useful for both tooling and telemetry research."],
    ["Deferred Procedure Waits in Windows", "https://windows-internals.com/dpws-are-the-new-dpcs-deferred-procedure-waits-in-windows-10-21h1/", "Yarden Shafir", "2020", 5, "deferred procedure waits DPW DPC Windows kernel scheduling", "Introduces Deferred Procedure Waits from their undocumented structures and scheduler paths, contrasting them with conventional DPC execution. The research is useful for understanding new kernel execution contexts, synchronization semantics, and the forensic or security implications of work that does not fit older DPC-centric mental models."],
    ["APC Series: User APC API", "https://repnz.github.io/posts/apc/user-apc/", "Ori Damari / repnz", "2020", 5, "APC QueueUserAPC NtQueueApcThread alertable waits", "The correct entry point to a three-part APC series, establishing delivery rules, alertable waits, queueing APIs, and observable behavior. It replaces the usual copy-paste injection explanation with a precise execution model that remains useful for both offensive code and detection."],
    ["APC Series: User APC Internals", "https://repnz.github.io/posts/apc/kernel-user-apc-api/", "Ori Damari / repnz", "2020", 5, "KAPC KiDeliverApc kernel user APC internals", "Reverse engineers the kernel path behind user APC objects, queueing, state transitions, and delivery to user mode. This is the piece to read when an APC PoC behaves differently across thread states and you need to reason from kernel implementation rather than API documentation."],
    ["APC Series: KiUserApcDispatcher and WoW64", "https://repnz.github.io/posts/apc/wow64-user-apc/", "Ori Damari / repnz", "2020", 5, "KiUserApcDispatcher WoW64 APC injection Heaven's Gate", "Explains the dispatcher calling convention, NtContinue loop, and the 32/64-bit compatibility machinery used to deliver APCs into WoW64 processes. The cross-architecture injection analysis is unusually detailed and exposes monitoring pitfalls around encoded APC routines."],
    ["WoW64 Internals", "https://wbenny.github.io/2018/11/04/wow64-internals.html", "wbenny", "2018", 5, "WoW64 syscall transition turbo thunk Heaven's Gate internals", "A rigorous map of WoW64 process architecture, system-call transitions, generated thunks, and CPU-mode changes. It is foundational for debugging cross-architecture loaders and understanding why injection code that works in native x64 can fail inside WoW64."],
    ["Reflective DLL Injection", "https://github.com/stephenfewer/ReflectiveDLLInjection", "Stephen Fewer", "Living", 5, "reflective DLL loader PE relocations imports injection", "The original implementation that popularized loading a DLL from memory without the normal LoadLibrary path. Study it as a historical baseline for relocation, import resolution, and self-location, then compare its memory artifacts with modern loader and EDR research."],
    ["PE-sieve", "https://github.com/hasherezade/pe-sieve", "Hasherezade", "Living", 5, "malware scanner hollowing implants PE reconstruction memory", "A mature scanner for injected, replaced, and manually mapped PE images, shellcode, hooks, and in-memory patches. Its code and companion tools are excellent references for learning what imperfect loaders leave behind and how defenders reconstruct those artifacts."],
    ["Overview of Windows Execution Aliases", "https://www.tiraniddo.dev/2019/09/overview-of-windows-execution-aliases.html", "James Forshaw", "2019", 5, "App Execution Alias IO_REPARSE_TAG_APPEXECLINK CreateProcess AppX token", "Reverse engineers the zero-byte executables in WindowsApps as IO_REPARSE_TAG_APPEXECLINK objects handled specially by CreateProcess. It reconstructs the serialized alias format, AppInfo RPC activation-token creation, packaged-app launch flow, trust labels, and a file-switching TOCTOU that bypasses one Desktop Bridge eligibility check."],
    ["DLL Import Redirection in Windows 10", "https://www.tiraniddo.dev/2020/02/dll-import-redirection-in-windows-10_8.html", "James Forshaw", "2020", 5, "import redirection NTDLL loader AppX NtCreateUserProcess signing level image section", "Uncovers Windows' undocumented import-redirection table for packaged applications and reconstructs its process-parameter, manifest, loader, and forwarding structures. The post then escapes the intended packaging boundary by combining NtCreateUserProcess with a cached image-section/signing-level mismatch, demonstrating why loader features must validate file identity across every open."],
    ["Bypassing CIG Through KnownDlls", "https://www.tiraniddo.dev/2019/08/windows-code-injection-bypassing-cig.html", "James Forshaw", "2019", 5, "Code Integrity Guard KnownDlls section object symbolic link process injection", "Develops a code-injection path against Code Integrity Guard by studying how KnownDll section objects are selected and mapped during process startup. The research connects object-manager namespaces, section creation, image-signing policy, process creation, and loader timing into a concrete bypass while clearly bounding the privileges and target configuration it requires."],
    ["Exploiting Arbitrary Object Directory Creation", "https://projectzero.google/2018/08/windows-exploitation-tricks-exploiting.html", "James Forshaw / Project Zero", "2018", 5, "Object Manager KnownDlls DefineDosDevice CSRSS section DLL loading LPE", "Turns an arbitrary Object Manager directory primitive into SYSTEM by chaining CSRSS's BaseSrvDefineDosDevice RPC behavior, permanent symbolic links, KnownDll section lookup, and a privileged service's DLL load. The article is a model of finding an execution sink for a namespace bug and carefully preserving raced objects with handles."],
    ["Process Hollowing on Windows 11 24H2", "https://hshrzd.wordpress.com/2025/01/27/process-hollowing-on-windows-11-24h2/", "Hasherezade", "2025", 5, "Windows 11 24H2 process hollowing hotpatch MEM_PRIVATE MEM_IMAGE HVCI", "Root-causes why classic RunPE fails during process initialization on Windows 11 24H2: the hotpatch loader queries MemoryImageExtensionInformation on a MEM_PRIVATE implant, and HVCI adds an NtManageHotPatch failure. The article supplies narrowly scoped NTDLL patches, explains instruction-cache timing, and compares section-backed alternatives that preserve MEM_IMAGE semantics."],
    ["Process Doppelgänging", "https://hshrzd.wordpress.com/2017/12/18/process-doppelganging-a-new-way-to-impersonate-a-process/", "Hasherezade", "2017", 5, "process doppelganging NTFS transactions NtCreateSection NtCreateProcessEx PE loader", "Explains and implements process impersonation by writing an executable inside an NTFS transaction, creating an image section from the modified view, rolling back the file, and constructing a process through native APIs. The comparison with hollowing makes clear which PE mapping work is delegated to the Windows loader, which PEB and thread steps remain, and which disk-memory mismatches support detection."],
    ["Process Ghosting: executable image tampering", "https://www.elastic.co/blog/process-ghosting-a-new-executable-image-tampering-attack", "Gabriel Landau / Elastic Security", "2021", 5, "process ghosting delete pending image section tampering Defender detection", "Introduces Process Ghosting by placing a payload into a delete-pending file, creating an executable image section, closing the file so its name disappears, and only then creating the process. The original disclosure compares exact API ordering with Hollowing, Doppelgänging, and Herpaderping, demonstrates interference with pre-execution scanning, and derives FILE_OBJECT-based detection signals."],
    ["EDR Parallel-asis through Analysis", "https://www.mdsec.co.uk/2022/01/edr-parallel-asis-through-analysis/", "MDSec", "2022", 5, "Windows parallel loader ntdll syscall copies unhooking process initialization", "Reverse engineers the Windows 10 parallel DLL loader after unexpected startup threads reveal temporary copies of native syscall stubs created before ordinary application execution. The research uses those clean stubs to recover syscall numbers and map an unhooked NTDLL, connecting loader concurrency and initialization timing to a concrete execution and instrumentation primitive."],
    ["PoolParty: Process Injection Using Windows Thread Pools", "https://www.safebreach.com/blog/process-injection-using-windows-thread-pools/", "Alon Leviev, SafeBreach Labs", "2023", 5, "PoolParty thread pool worker factory TP_WORK TP_TIMER IO completion injection", "Reverse engineers the Windows user-mode thread-pool architecture and converts its worker factory plus three queue families into eight distinct remote execution primitives. The research reconstructs undocumented structures, duplicates target handles, writes valid work objects into remote memory, and triggers callbacks through legitimate worker activity, with public implementations that let defenders reproduce every variant."],
    ["Early Cascade Injection", "https://www.outflank.nl/blog/2024/10/15/introducing-early-cascade-injection-from-windows-process-creation-to-stealthy-injection/", "Dima van de Wouw, Outflank", "2024", 5, "Early Cascade injection g_pfnSE_DllLoaded shim APC LdrInitializeThunk EDR", "Maps the user-mode process initialization sequence through LdrInitializeThunk and LdrLoadDll, then abuses the undocumented g_pfnSE_DllLoaded callback while ntdll's mutable data sections are still writable. A small first-stage stub queues its own APC for NtTestAlert, escaping loader-lock constraints without a cross-process execution primitive and running before several EDR user-mode modules initialize."],
    ["Process Preluding: Injection Before Process Notification", "https://www.originhq.com/blog/process-preluding", "John Uhlmann, Origin", "2026", 5, "Process Preluding NtCreateProcess legacy API callback timing ETW PostProcessInitRoutine", "Shows how the legacy NtCreateProcess path creates an addressable child before its first thread causes process and handle callbacks, leaving a deterministic pre-notification window. The proof of concept builds the image section and process manually, writes private executable memory, and redirects a data callback before endpoint products can enable per-process Threat Intelligence ETW logging, then derives concrete kernel-side detection options."],
    ["Hiding Malicious Code with Module Stomping", "https://blog.f-secure.com/hiding-malicious-code-with-module-stomping/", "Aliz Hammond, F-Secure Countercept", "2019", 5, "module stomping DLL hollowing PE entrypoint CFG memory injection", "Develops module stomping from a simple injector that loads a legitimate DLL and overwrites its entry point, while explaining PE selection, remote parsing, Control Flow Guard constraints, and why image-backed execution evades naive private-memory heuristics. Source-backed experiments establish the baseline technique and the artifacts later installments and scanners attempt to generalize or detect."],
    ["Get-InjectedThreadEx: Detecting Thread Creation Trampolines", "https://www.elastic.co/security-labs/get-injectedthreadex-detection-thread-creation-trampolines", "John Uhlmann, Elastic Security Labs", "2022", 5, "Get-InjectedThreadEx thread trampoline call stack CFG APC SetThreadContext", "Systematically breaks the assumption that an image-backed Win32 thread start address proves benign execution. The article tests overwritten prologues, context redirection, Early Bird APCs, CFG-authorized JMP gadgets, and CRT start-routine indirection, then upgrades the open hunting script to inspect full stacks, memory types, parameters, and known false-positive classes rather than checking only the recorded start address."],
    ["Hunting In-Memory Attacks", "https://www.elastic.co/security-labs/hunting-memory", "Joe Desimone, Endgame", "2017", 5, "in-memory hunting injected threads reflective DLL hollowing module overwrite Gargoyle", "Compares shellcode injection, reflective DLL loading, memory modules, process hollowing, module overwriting, and Gargoyle-style execution through the memory artifacts each leaves. It then introduces the open Get-InjectedThreads approach—querying thread start addresses and VirtualQueryEx region types—and carefully discusses JIT, DRM, and security-agent false positives, establishing a durable foundation for later stack-aware hunting research."],
    ["Analyzing the DOUBLEPULSAR Kernel DLL Injection Technique", "https://blog.f-secure.com/analyzing-the-doublepulsar-kernel-dll-injection-technique/", "F-Secure Countercept", "2017", 5, "DOUBLEPULSAR kernel DLL injection APC ZwAllocateVirtualMemory KeInsertQueueApc", "Reverse engineers DOUBLEPULSAR's kernel payload from target-process selection through ZwAllocateVirtualMemory and the construction of a user-mode APC delivered with KeInsertQueueApc. WinDbg experiments connect the ring-zero implant, its injected loader, and persistent memory artifacts, making this a foundational explanation of kernel-assisted process injection rather than a high-level EternalBlue retrospective."],
    ["DOUBLEPULSAR Usermode Analysis: Generic Reflective DLL Loader", "https://blog.f-secure.com/doublepulsar-usermode-analysis-generic-reflective-dll-loader/", "Noora Hyvärinen, F-Secure Countercept", "2017", 5, "DOUBLEPULSAR reflective DLL loader APC CreateRemoteThread API hashing manual mapping", "Extracts and documents DOUBLEPULSAR's position-independent user-mode loader, including self-location, hashed API resolution, PE section mapping, relocations, imports, and entry-point transfer for arbitrary unmodified DLLs. The accompanying standalone injector can dispatch the same shellcode through an APC or CreateRemoteThread, giving researchers a reproducible way to inspect memory artifacts without the kernel implant."],
    ["Defining the Cobalt Strike Reflective Loader", "https://www.ibm.com/think/x-force/defining-cobalt-strike-reflective-loader", "Bobby Cooke, IBM X-Force Red", "2023", 5, "Cobalt Strike UDRL reflective loader Beacon PE mapping Malleable PE", "Builds a precise model of Cobalt Strike's User-Defined Reflective Loader, contrasting Windows image loading with original, prepended, and Beacon-specific reflective designs. It follows the patched call stub and raw-to-virtual transition, then decomposes a practical loader into header discovery, allocation, section copying, dependency and import resolution, relocations, and final execution."],
    ["Reflective Call Stack Detections and Evasions", "https://www.ibm.com/think/x-force/reflective-call-stack-detections-evasions", "Bobby Cooke and Dylan Tran, IBM X-Force Red", "2023", 5, "BokuLoader call stack spoofing synthetic frames return address ROP indirect syscall", "Pairs four concrete stack-trace hunting ideas with the evasions implemented in BokuLoader, including nonvolatile-register return gadgets, truncated stacks, synthetic thread-start frames, and spoofed indirect syscalls. The article compares AceLdr, SilentMoonwalk, and related public implementations while explicitly identifying false positives and the structural inconsistencies defenders can still test."],
    ["Secure Enclaves for Offensive Operations, Part I", "https://www.outflank.nl/blog/2025/02/03/secure-enclaves-for-offensive-operations-part-i/", "Matteo Malvica and Cedric Van Bockhaven, Outflank", "2025", 5, "Windows VBS enclave VTL1 secure kernel PE IMAGE_ENCLAVE_CONFIG debugging", "Maps Windows VBS enclave architecture from VTL boundaries and signing requirements to enclave PE metadata, development, loading, and secure-kernel debugging. The researchers publish tooling to inspect and modify IMAGE_ENCLAVE_CONFIG, enumerate production enclave DLLs, and reason about trusted APIs as hidden execution surface, establishing the internals required for the exploitation developed in Part II."],
    ["Process Herpaderping", "https://github.com/jxy-s/herpaderping", "Johnny Shaw", "2020", 5, "Process Herpaderping NtCreateSection PsSetCreateProcessNotifyRoutineEx image overwrite", "The original proof of concept and technical deep dive for exploiting the gap between creating a process object and inserting its first thread, when process-notify callbacks finally inspect the backing file. It writes and maps a payload image, overwrites the still-open file with benign or misleading content before notification, and manually completes process parameters and thread creation, exposing why file identity observed by a scanner can differ from the executable section already committed to memory."],
    ["Dirty Vanity: Windows Process Fork Injection", "https://www.deepinstinct.com/blog/dirty-vanity-a-new-approach-to-code-injection-edr-bypass", "Eliran Nissan / Deep Instinct", "2023", 5, "Dirty Vanity RtlCreateProcessReflection Windows process fork injection EDR bypass", "Reverse engineers Windows process reflection and repurposes RtlCreateProcessReflection as a code-injection primitive that avoids the familiar remote allocation, write, and thread-creation sequence. The research traces the undocumented fork path and its relationship to Windows Error Reporting, prepares the parent's address space before cloning, transfers execution in the reflected child, and publishes a companion implementation plus defensive guidance for distinguishing reflection from ordinary process creation."],
    ["AtomBombing: Windows Atom-Table Code Injection", "https://www.fortinet.com/blog/threat-research/atombombing-brand-new-code-injection-technique-for-windows", "Tal Liberman / enSilo", "2016", 5, "AtomBombing GlobalAddAtom GlobalGetAtomName APC NtQueueApcThread ZwContinue injection", "Presents the original AtomBombing technique, building a remote write primitive from the global atom table and GlobalGetAtomName rather than WriteProcessMemory. The full chain queues APCs to copy staged strings into a target, uses an alertable thread and a return-oriented call to NtProtectVirtualMemory for executable permissions, redirects context through ZwContinue, and restores the hijacked thread so researchers can study both execution and residual artifacts."],
    ["Process Mockingjay: RWX Sections for Code Execution", "https://blog.securityjoes.com/post/process-mockingjay-echoing-rwx-in-userland-to-achieve-code-execution", "Security Joes", "2023", 5, "Mockingjay RWX DLL section msys-2.0 ssh process injection EDR", "Develops a process-injection method around legitimate DLLs that ship with writable and executable sections, eliminating explicit allocation and protection changes that commonly anchor EDR detections. The researchers identify a sizeable RWX section in msys-2.0.dll, demonstrate both self-injection and remote use inside the trusted ssh.exe execution flow without creating a new thread, provide code and a proof-of-concept, and outline hunting opportunities based on anomalous module and network behavior."],
    ["When Process Hollowing Is Not Process Hollowing", "https://trainsec.net/library/windows-internals/when-process-hollowing-isnt-process-hollowing/", "Pavel Yosifovich", "2026", 5, "process hollowing NtCreateSection NtMapViewOfSection second image thread context Windows internals", "Constructs a loader variant that leaves the original executable image intact, maps a second SEC_IMAGE executable into the suspended target, and redirects its primary thread instead of unmapping and replacing the first image. The implementation walks native section creation, remote mapping, PEB and thread-context state, relocations, parameters, and loader constraints, providing a precise modern comparison between conventional hollowing, manual mapping, and a process that legitimately contains two image mappings but executes the unexpected one."],
    ["ThreadlessInject", "https://github.com/CCob/ThreadlessInject", "Ceri Coburn", "2023", 5, "threadless process injection remote function hook export trampoline shellcode Windows", "The original implementation accompanying Needles Without the Thread, replacing remote thread creation with a temporary hook on an exported function that the target is expected to call naturally. The source selects and patches the remote routine, saves displaced instructions, executes a position-independent loader, restores the original function, and resumes the legitimate call, while the presentation and improvement notes expose RWX, trigger-selection, allocation, and patchless-hooking tradeoffs."],
    ["DLL Notification Injection", "https://shorsec.io/blog/dll-notification-injection/", "ShorSec", "2023", 5, "Windows DLL notification callback LdrRegisterDllNotification PEB loader threadless injection", "Develops a threadless execution primitive from the Windows loader's DLL-notification callback machinery, first reconstructing registration and list structures and then inserting a crafted callback record into a local or remote process. The article follows PEB discovery, remote memory construction, loader-lock timing, triggering through a subsequent module load, cleanup, version assumptions, and EDR behavior, making the technique auditable beyond the final proof of concept."],
    ["Ruy Lopez: Avoiding Kernel-Triggered Memory Scans", "https://www.r-tec.net/r-tec-blog-process-injection-avoiding-kernel-triggered-memory-scans.html", "Fabian Mosch / r-tec", "2023", 5, "Ruy Lopez Windows process injection kernel callback memory scan SEC_IMAGE section mapping", "Investigates when endpoint products initiate memory scans from kernel process, thread, image-load, and handle telemetry, then redesigns an injection chain to separate suspicious memory preparation from the monitored trigger. The Ruy Lopez proof of concept and experiments show how section objects, remote mappings, protection state, execution timing, and process choice interact with scan heuristics, while clearly treating observed product behavior as version-specific rather than a universal invisibility claim."],
    ["Understanding and Measuring Inter-Process Code Injection", "https://research.utwente.nl/en/publications/understanding-and-measuring-inter-process-code-injection-in-windo/", "Jerre Starink, Marieke Huisman, Andreas Peter, and Andrea Continella", "2023", 5, "Windows malware code injection taxonomy dynamic analysis longitudinal measurement hollowing", "Provides a peer-reviewed taxonomy that groups Windows inter-process injection by common operational traits, implements behavioral models for the studied techniques, and applies them to a longitudinal malware corpus. The measurement finds injection in at least 9.1 percent of samples from 2017 through 2021, quantifies the dominance and changing share of process hollowing, and explains why sandboxes that fail to follow injected execution systematically under-observe later payload behavior."],
    ["Can You Run My Code? Measuring Windows Process Injection", "https://www.diag.uniroma1.it/~delia/papers/asiaccs25.pdf", "Giorgia Di Pietro, Daniele Cono D'Elia, and Leonardo Querzoni", "2025", 5, "Windows process injection address correlation malware dataset dynamic analysis ASIA CCS", "Introduces a technique-agnostic detector based on the minimal operational stages shared by process-injection families and correlates allocation, writes, control transfer, and execution through memory-address identity rather than fragile API sequences. Evaluation across 56,340 samples from 2,667 malware families spanning 2017–2023 compares dedicated tools and mainstream sandboxes, measures technique shifts, and releases implementation, dataset, and experimental logs for reproduction."],
    ["Injecting Code into Windows Protected Processes Using COM, Part 1", "https://projectzero.google/2018/10/injecting-code-into-windows-protected.html", "James Forshaw / Google Project Zero", "2018", 5, "Windows PPL COM injection NGEN type confusion KnownDlls cached signing level", "Builds a normal-user path into a PPL-WindowsTCB process by enumerating protected-capable binaries, attacking the NGEN COM service's marshaling type information, converting a controlled zero write into a KnownDll-directory handle substitution, and abusing cached signing levels. The writeup is unusually complete about PP and PPL signer hierarchy, Code Integrity's script-engine blocklist, native process creation, inherited handles, loader behavior, and the exact limits of Microsoft's defended boundary."],
    ["Injecting Code into Windows Protected Processes Using COM, Part 2", "https://projectzero.google/2018/11/injecting-code-into-windows-protected.html", "James Forshaw / Google Project Zero", "2018", 5, "Windows protected process COM injection DRM WER Fault secure marshaling code integrity", "Extends the first article from Protected Process Light to the stronger full Protected Process model, where KnownDll loading and several PPL assumptions no longer apply. Through COM activation, custom marshaling, protected media components, signing policy, and carefully selected trusted execution paths, it demonstrates how supported cross-process interfaces can become code-execution primitives even when ordinary process handles, DLL injection, and dynamic code are blocked."],
    ["Windows Instrumentation Callbacks, Part 4: Detection and Countermeasures", "https://cirosec.de/en/news/windows-instrumentation-callbacks-part-4/", "Lino Facco / cirosec", "2026", 5, "Windows instrumentation callbacks detection countermeasures NtSetInformationProcess EDR anti-cheat", "Completes the instrumentation-callback series by testing how a process can discover an installed callback, whether it can be cleared or replaced safely, and which controls can prevent an attacker from registering one in the first place. The analysis distinguishes documented access checks from build-specific behavior, explores races and ownership conflicts between security products and hostile code, and identifies why prevention remains incomplete even when callback state is continuously monitored."],
    ["Windows Instrumentation Callbacks, Part 2: Patchless Hooks", "https://cirosec.de/en/news/windows-instrumentation-callbacks-hooks/", "Lino Facco / cirosec", "2025", 5, "Windows instrumentation callbacks patchless hooking hardware breakpoints VEH syscall interception", "Turns the callback machinery established in Part 1 into patchless function interception without modifying target code or registering a visible vectored exception handler. The article reasons through hardware-breakpoint state, exception dispatch, callback recursion, stack and register integrity, pass-through calls, thread-local behavior, and collisions with debuggers or competing instrumentation, making both the hook's mechanics and its operational weaknesses auditable."],
    ["Windows Instrumentation Callbacks, Part 3: Process Injection", "https://cirosec.de/en/news/windows-instrumentation-callbacks-injections/", "Lino Facco / cirosec", "2026", 5, "Windows instrumentation callback process injection shellcode NtSetInformationProcess SeDebugPrivilege", "Uses a remote process's instrumentation callback as the execution half of an injection chain, so existing threads enter the payload naturally on their next kernel-to-user transition without CreateRemoteThread or an exception handler. The implementation covers SeDebugPrivilege requirements, remote callback and bridge placement, x64 stack alignment, register and TEB bookkeeping, one-shot restoration, triggering guarantees, and the artifacts defenders can inspect instead of treating the technique as generically threadless or invisible."],
    ["Inject-Me: Injection-less x64 Code Injection", "https://www.deepinstinct.com/blog/inject-me-x64-injection-less-code-injection", "Alon Weinberg / Deep Instinct", "2019", 5, "Inject-Me x64 Windows process injection NtReadVirtualMemory ROP thread context shared memory", "Reverses the usual remote-write model by manipulating a target thread into reading payload bytes from the injector's address space with NtReadVirtualMemory, then transferring control after the target copies the data itself. The article develops the x64 stack and context layout, ROP-assisted call sequence, cross-process buffer lifetime, restoration path, and architectural constraints, making the claimed injection-less distinction precise rather than semantic."],
    ["SharpParty: Thread-Pool Injection from C#", "https://www.levelblue.com/blogs/spiderlabs-blog/sharpparty-process-injection-in-c/", "Aidan Khoury / LevelBlue SpiderLabs", "2025", 5, "SharpParty C# PoolParty Windows thread pool injection worker factory TP_WORK marshalling", "Reimplements selected PoolParty primitives in managed C# and uses the porting effort to expose details hidden by the original C++ proof of concept: native structure marshalling, handle duplication, worker-factory information, remote callback and work-object layout, allocation, and queue insertion. The side-by-side design decisions provide a useful independent validation of the Windows thread-pool model and a concrete study of how managed runtimes affect low-level injection artifacts."],
    ["DCOM Upload and Execute Through MSI Custom Actions", "https://www.deepinstinct.com/blog/forget-psexec-dcom-upload-execute-backdoor", "Eliran Nissan / Deep Instinct", "2024", 5, "Windows DCOM IMsiCustomAction remote MSI execution upload lateral movement RPC", "Reverse engineers an undocumented DCOM interface exposed by the Windows Installer service and turns its IMsiCustomAction methods into a remote upload-and-execute channel. The research reconstructs COM activation and marshaling, remote file placement, custom-action invocation, authentication and firewall prerequisites, cleanup, and a working proof of concept, providing a technically distinct lateral-execution primitive rather than another wrapper around service creation."],
    ["ConsoleWindowClass User-Data Injection", "https://modexp.wordpress.com/2018/09/12/process-injection-user-data/", "modexp", "2018", 5, "Windows conhost ConsoleWindowClass GWLP_USERDATA desktop heap process injection callback", "Discovers that a console window's GWLP_USERDATA points into writable conhost.exe heap state containing a class object with callable methods, then converts that legitimate cross-process window metadata into placement and execution primitives. The writeup reconstructs the desktop-heap and console structures, locates the target object, replaces method pointers, triggers the callback through window behavior, and restores state, making the relationship to Extra Window Memory injection explicit."],
    ["Post-start Command-line Substitution", "https://www.originhq.com/blog/post-start-command-line-substitution", "John Uhlmann / Origin", "2026", 5, "Windows process creation command line tampering PEB process callbacks image load telemetry", "Maps exactly when Windows process, thread, image-load, and endpoint callbacks observe a new process's command line, then changes the PEB-backed process parameters after those early observations but before ordinary user code consumes them. Kernel traces and controlled experiments separate immutable creation provenance from mutable runtime state, demonstrating how one process can be admitted under a benign argument set yet execute application logic from substituted arguments and giving defenders correlation points across both views."],
    ["Transacted Hollowing and Ghostly Hollowing", "https://github.com/hasherezade/transacted_hollowing", "Karsten Hahn and Hasherezade", "2018", 5, "Windows PE injection Transacted Hollowing Ghostly Hollowing TxF SEC_IMAGE process doppelganging", "Provides the reference implementation for a PE-injection hybrid that creates a transacted file, writes the payload, maps it as a SEC_IMAGE section, and rolls the transaction back before constructing the target process. The maintained code also implements Ghostly Hollowing with a delete-pending file, making the repository especially useful for comparing Doppelgänging- and Ghosting-derived image semantics, loader preparation, relocations, process parameters, and observable filesystem state."],
    ["Masking Malicious Memory Artifacts, Part I: Phantom DLL Hollowing", "https://www.cyberark.com/resources/threat-research-blog/masking-malicious-memory-artifacts-part-i-phantom-dll-hollowing-2", "Forrest Orr / CyberArk", "2020", 5, "Phantom DLL Hollowing TxF Windows memory artifacts MEM_IMAGE Moneta injection detection", "Develops Phantom DLL Hollowing from the defender-visible differences between private executable memory and legitimate image mappings. The article uses NTFS transactions and a temporary DLL image to obtain realistic MEM_IMAGE metadata before replacing its contents, then examines virtual-address descriptors, permissions, module bookkeeping, and scanner assumptions; the companion proof of concept includes both the hollower and a memory-region scanner for reproducing the artifacts."],
    ["In NTDLL I Trust: Process Reimaging", "https://www.trellix.com/blogs/research/in-ntdll-i-trust-process-reimaging-and-endpoint-security-solution-bypass/", "Thomas Roccia / McAfee Advanced Threat Research", "2019", 5, "Windows Process Reimaging NTDLL section object file path cache endpoint bypass K32GetProcessImageFileName", "Introduces Process Reimaging by tracing how Windows records an executable section's file identity and how endpoint products later recover that path through user-mode and native APIs. By moving and replacing the backing file after section creation, the proof of concept creates disagreement between the running image, cached path, and on-disk object; the writeup reverses the relevant NTDLL and kernel behavior and discusses concrete validation and mitigation choices for security products."],
    ["ListPlanting: Yet Another Code Injection Trick", "https://www.hexacorn.com/blog/2019/04/25/listplanting-yet-another-code-injection-trick/", "Adam / Hexacorn", "2019", 5, "Windows ListPlanting SysListView32 LVM_SORTITEMS callback process injection desktop heap", "Presents the original ListPlanting primitive, abusing a cross-process SysListView32 control rather than conventional remote-thread creation. The technique places payload material through list-view messages and redirects the comparison callback supplied to LVM_SORTITEMS so the victim's GUI thread invokes attacker-selected code; the concise research note connects the window-message surface to desktop-process injection and records the exact control behavior later standardized as ATT&CK T1055.015."],
    ["Process Injection Techniques: Gotta Catch Them All", "https://i.blackhat.com/USA-19/Thursday/us-19-Kotler-Process-Injection-Techniques-Gotta-Catch-Them-All.pdf", "Itzik Kotler and Amit Klein / SafeBreach Labs", "2019", 5, "Windows process injection taxonomy Pinjectra APC atom table desktop heap CFG CIG detection", "Systematically decomposes Windows injection into separate write and execution primitives, then recombines them in a test framework instead of treating each published sequence as an indivisible technique. The Black Hat research evaluates atom tables, desktop heap, APCs, window callbacks, section mappings, and return-oriented dispatch against mitigations such as CFG and CIG, and introduces Pinjectra so researchers can reproduce unusual pairings and reason about telemetry coverage by primitive."],
    ["Uncovering Cross-Process Injection with Windows Defender ATP", "https://www.microsoft.com/en-us/security/blog/2017/03/08/uncovering-cross-process-injection-with-windows-defender-atp/", "Microsoft Defender Security Research Team", "2017", 5, "Windows cross process injection VirtualAllocEx section mapping CreateRemoteThread APC Defender ATP telemetry", "Models cross-process injection as two independent phases—placing code into executable memory and redirecting execution—then maps the Win32 and native mechanisms commonly used for each phase. Microsoft validates the telemetry against real Fynloski and Wingbird samples using remote allocation, mapped sections, thread creation, context changes and queued APCs, showing why behavior correlation across processes is more durable than detecting a single suspicious API."],
    ["FinFisher: Defeating Traps, Tricks, and Virtual Machines", "https://www.microsoft.com/en-us/security/blog/2018/03/01/finfisher-exposed-a-researchers-tale-of-defeating-traps-tricks-and-complex-virtual-machines/", "Mohamed Fahmy / Microsoft", "2018", 5, "FinFisher Windows loader virtual machine KernelCallbackTable APC injection anti analysis", "Reconstructs a heavily protected FinFisher infection chain by peeling anti-disassembly, staged custom virtual machines and environment checks until the researchers recover its injection path. The final mechanism replaces an internal user32 KernelCallbackTable entry, uses an APC to enter the callback stub and restores state afterward, providing both a real-world execution primitive and a detailed methodology for progressing through deliberately hostile loader layers."],
    ["Detecting Parent PID Spoofing", "https://blog.f-secure.com/detecting-parent-pid-spoofing/", "Noora Hyvärinen / F-Secure Countercept", "2018", 5, "Windows parent PID spoofing PROC_THREAD_ATTRIBUTE_PARENT_PROCESS ETW process creation DLL injection", "Demonstrates how PROC_THREAD_ATTRIBUTE_PARENT_PROCESS can give a newly created process a plausible but false parent relationship and pair that deception with DLL injection. More importantly, the researchers compare user-visible process metadata with Microsoft-Windows-Kernel-Process ETW events, publish offensive and defensive proofs of concept, and derive a detection from the creator-versus-declared-parent discrepancy instead of trusting the process tree at face value."],
    ["WOW64 Callback Table: FinFisher", "https://modexp.wordpress.com/2023/04/19/finding-the-wow64-callback-table/", "odzhan / modexp", "2023", 5, "Windows WOW64 callback table ntdll Wow64PrepareForException APC anti debugging FinFisher", "Reverse engineers the undocumented callback array populated when 64-bit NTDLL initializes a WOW64 process, including entries for exception, APC, debugger-attach and suspension transitions. The post develops a version-tolerant heuristic that locates the table through read-only STRING descriptors rather than fixed offsets, supplies working source, and explains why interception occurs on the 64-bit side before ordinary 32-bit VEH or SEH handling."],
    ["Detecting Malicious Use of .NET: Part 2", "https://blog.f-secure.com/detecting-malicious-use-of-net-part-2/", "Noora Hyvärinen / F-Secure Countercept", "2018", 5, "Windows CLR ETW dynamic assembly PInvoke VirtualAlloc CreateThread in memory .NET execution detection", "Uses CLR ETW providers to expose execution details that disappear when managed assemblies are loaded directly from byte arrays rather than through normal files. The analysis correlates dynamic assembly creation, module and method activity, Base64 transformations and managed-to-native P/Invoke transitions such as VirtualAlloc and CreateThread, producing a behavior chain that distinguishes in-memory .NET tradecraft from benign runtime activity without relying on an assembly name."],
    ["The CONTEXT-Only Process-Injection Attack Surface", "https://blog.fndsec.net/2025/05/16/the-context-only-attack-surface/", "Yehuda Smirnov, Hoshea Yarden, Hai Vaknin, and Noam Pomerantz", "2025", 5, "Windows process injection thread context LoadLibrary NtCreateThread APC ETW RedirectThread", "Asks how far injection can proceed when defenders reliably observe remote allocation and writes, then develops execution-only primitives around data and code already mapped in the victim. The researchers build pointer-only LoadLibrary calls, redirect newly created threads with x64 register state, investigate NtCreateThread behavior and extend the model to APCs, while comparing ETW traces and publishing RedirectThread so the boundary between memory placement and control transfer can be reproduced rather than inferred."],
    ["QueueUserAPC Code Injection and the Security Boundary", "https://devblogs.microsoft.com/oldnewthing/20150519-00/?p=45571", "Raymond Chen / Microsoft", "2015", 5, "Windows QueueUserAPC SetThreadContext LoadLibrary integrity level access control injection boundary", "Dissects a reported QueueUserAPC elevation technique by reconstructing its exact prerequisites: locating reusable strings and code in shared modules, arranging LoadLibrary arguments through registers or gadgets, and obtaining THREAD_SET_CONTEXT access to the victim. The key lesson is architectural rather than dismissive—the injection works, but Windows integrity-level access checks normally grant the required thread control only across an already-equivalent security boundary, providing a precise method for separating code execution from privilege escalation."],
    ["Extending Extra Window Memory Injection", "https://www.hexacorn.com/blog/2018/08/18/a-possible-extension-of-extra-window-memory-injection-ewmi-via-setwindowlong/", "Adam / Hexacorn", "2018", 5, "Windows Extra Window Memory Injection SetWindowLong desktop heap callback explorer process injection", "Extends the malware-observed Extra Window Memory Injection pattern beyond its conventional explorer tray target by reasoning about how window classes expose process-owned extra bytes through cross-process USER APIs. The note identifies a broader population of candidate windows and a temporarily stealthier way to redirect stored callback state, making it valuable as original research into the desktop-heap execution surface and as a reminder that the small SetWindowLong write is only the trigger for a larger shared-memory injection chain."],
    ["The State of Advanced Code Injections", "https://adalogics.com/blog/the-state-of-advanced-code-injections", "David Korczynski / Ada Logics", "2019", 5, "Windows advanced code injection PROPagate AtomBombing Early Bird doppelganging module stomping", "Compares the mechanics and prerequisites of several post-classic Windows injection families instead of presenting another VirtualAllocEx recipe. The survey follows AtomBombing, process doppelgänging, module stomping, PROPagate and Early Bird through their distinct memory-placement and execution triggers, relates them to contemporary mitigations and monitoring assumptions, and provides a compact technical map for deciding which underlying primitive a new loader actually changes."],
    ["Understanding and Measuring Inter-Process Code Injection", "https://ris.utwente.nl/ws/portalfiles/portal/351183631/starink-codeinjection-2023.pdf", "Sven Starink and collaborators / University of Twente", "2023", 5, "Windows inter process code injection measurement taxonomy detection memory permissions threads", "Builds a systematic Windows 10 injection model from the attacker’s required cross-process operations, then implements and measures representative techniques instead of comparing them only by API names. The research examines memory provenance and permissions, thread and callback activation, observable artifacts and detector coverage across classic DLL loading, shellcode, hollowing and less direct variants, providing an empirical bridge between offensive taxonomies and defensible behavioral signals."],
    ["Vectored Exception Handlers for Evasion and Process Injection", "https://www.ibm.com/think/x-force/using-veh-for-defense-evasion-process-injection/jcr%3Acontent", "Tom Brice / IBM X-Force", "2024", 5, "Windows VEH vectored exception handler list process injection exception dispatch", "Reconstructs the undocumented user-mode vectored-exception-handler list and shows how an attacker with remote memory access can insert or redirect an encoded handler without creating a conventional remote thread. The research follows handler registration, pointer encoding, list discovery and exception dispatch, then separates local control-flow evasion from cross-process activation and proposes memory and behavioral signals defenders can use to validate the primitive."],
    ["Thread Local Storage Callback Injection", "https://attack.mitre.org/techniques/T1055/005/", "MITRE ATT&CK", "Living", 4, "Windows TLS callback injection PE loader hollowing pre entry point execution", "Defines TLS callback injection as manipulation of a PE image's TLS directory so the Windows loader invokes attacker-controlled code before the ordinary entry point or during thread initialization. The maintained technique record connects the primitive to hollowing and operational malware, distinguishes code placement from loader-triggered execution, and supplies detection guidance around PE-header mutation, callback-table changes and anomalous pre-entry-point thread behavior."],
    ["Immoral Fiber: Remote Fiber and FLS Callback Injection", "https://meterpreter.org/immoral-fiber-two-new-offensive-techniques-using-windows-fibers/", "Daniel Jary", "2024", 5, "Windows fibers PoisonFiber FLS callback remote injection dormant fiber PhantomThread", "Introduces PoisonFiber by recovering remote fiber state and turning two rarely monitored scheduler structures into execution triggers. The proof of concept can overwrite or redirect a dormant fiber's saved instruction state and can replace default or application-defined Fiber Local Storage cleanup callbacks; accompanying test programs and returning shellcode make the four variants reproducible while showing how execution inherits an existing thread and call stack."],
    ["AddressOfEntryPoint Code Injection", "https://www.ired.team/offensive-security/code-injection-process-injection/addressofentrypoint-code-injection-without-virtualallocex-rwx", "Red Team Notes", "2019", 4, "Windows PE AddressOfEntryPoint suspended process injection PEB image base WriteProcessMemory", "Demonstrates a compact suspended-process injection path that reuses the target image's already committed entry-point pages instead of allocating a conspicuous remote RWX region. The walkthrough reads the image base through the new process's PEB, parses the remote PE headers to recover AddressOfEntryPoint, overwrites that location, and resumes the original primary thread, making both the activation mechanism and its memory-forensic tradeoffs easy to reproduce."],
    ["Early Bird APC Injection", "https://www.bleepingcomputer.com/news/security/early-bird-code-injection-technique-helps-malware-stay-undetected/", "Cyberbit research, reported by BleepingComputer", "2018", 4, "Windows Early Bird APC injection suspended process NtTestAlert APT33 anti malware hooks", "Documents the original Early Bird pattern observed in TurnedUp, DorkBot and Carberp: create a legitimate process suspended, place code in it, queue an APC to the primary thread, and resume before the normal application entry path and many user-mode security hooks initialize. Although presented through real malware rather than a standalone loader, the sequence clearly identifies the timing property that distinguishes this primitive from ordinary APC injection."],
  ]},
  { id: "malware", kicker: "Reverse real tradecraft", title: "Windows Malware & Loader Analysis", items: [
    ["Signed Driver Malware Moves Up the Trust Chain", "https://www.sophos.com/en-us/blog/signed-driver-malware-moves-up-the-software-trust-chain", "Sophos X-Ops", "2022", 5, "BURNTCIGAR signed malicious driver WHCP EDR killer Cuba ransomware", "Reverse engineers BURNTCIGAR's loader and kernel driver after an attempted security-product shutdown, mapping the KApcHelper device, process-kill IOCTLs, VMProtect packing, signer evolution, and target list. The report is essential for understanding the shift from merely vulnerable signed drivers to attacker-built malware carrying legitimate WHCP signatures."],
    ["AuKill Abuses the Process Explorer Driver", "https://www.sophos.com/en-us/blog/aukill-edr-killer-malware-abuses-process-explorer-driver", "Sophos X-Ops", "2023", 5, "AuKill Process Explorer driver BYOVD EDR killer ransomware", "Analyzes AuKill's use of a legitimate Process Explorer driver to acquire privileged process handles and terminate endpoint products before ransomware deployment. The report follows the loader, service setup, driver-client protocol, protected target handling, observed incidents, and detection opportunities, making the operational chain directly useful to both reversers and defenders."],
    ["BURNTCIGAR 2: Driver-Based Attack Tool Update", "https://www.sophos.com/en-us/blog/burnt-cigar-2", "Sophos X-Ops", "2024", 5, "BURNTCIGAR 2 Poortry malicious driver EDR killer Windows crash", "Revisits the BURNTCIGAR/Poortry driver family as its developers expand process and file manipulation while changing signatures and deployment behavior. Static and incident analysis explain how newer variants impair protected endpoints and sometimes destabilize Windows, providing a version-aware continuation of the original signed-driver investigation."],
    ["DeadLock Ransomware's New BYOVD Loader", "https://blog.talosintelligence.com/byovd-loader-deadlock-ransomware/", "Cisco Talos", "2025", 5, "DeadLock ransomware BYOVD loader vulnerable driver EDR disable", "Dissects a newly observed loader used before DeadLock ransomware, including its vulnerable-driver deployment, privileged device interactions, security-product disruption, and handoff to the Windows encryptor. The report preserves samples, execution stages, behavioral indicators, and campaign context instead of treating the driver as an isolated IOC."],
    ["RedDriver: Undocumented Driver-Based Browser Hijacker", "https://blog.talosintelligence.com/undocumented-reddriver/", "Cisco Talos", "2023", 5, "RedDriver malicious Windows driver browser hijacker packet filtering China", "Reverse engineers an undocumented, signed Windows driver used to hijack browser traffic against Chinese-speaking users and internet cafés. The analysis follows installation, device communication, filtering and redirection behavior, certificates, supporting components, and network indicators, making it a rare study of kernel-assisted traffic manipulation outside ransomware."],
    ["ThrottleStop Driver AV Killer", "https://securelist.com/av-killer-exploiting-throttlestop-sys/117026/", "Kaspersky GReAT", "2025", 5, "ThrottleStop.sys AV killer physical memory shellcode kernel BYOVD", "Analyzes an AV-killer that abuses the legitimate ThrottleStop driver for physical-memory access, translates kernel targets, and installs shellcode to terminate security processes. The report includes the user-mode loader, vulnerable IOCTL path, kernel function modifications, PatchGuard considerations, YARA detection, and exact artifacts needed for defensive reproduction."],
    ["Hunting Attestation-Signed Malware", "https://cloud.google.com/blog/topics/threat-intelligence/hunting-attestation-signed-malware/", "Mandiant", "2022", 5, "Windows attestation signed malicious drivers hunting certificates rootkits", "Develops a hunting methodology for malicious Windows drivers that passed Microsoft's attestation-signing process, joining certificate metadata, code similarity, submission patterns, and driver behavior. Multiple clusters and real investigations show how trust infrastructure can become a discovery pivot while avoiding the assumption that every signed kernel module is benign."],
    ["Targeted Attacks Leverage Microsoft-Signed Malicious Drivers", "https://www.sentinelone.com/labs/driving-through-defenses-targeted-attacks-leverage-signed-malicious-microsoft-drivers/", "SentinelLabs", "2022", 5, "Microsoft signed malicious driver EDR evasion SIM swapping Hive ransomware", "Documents multiple intrusions where Microsoft-signed malicious drivers and companion user-mode clients attempted to control or kill endpoint processes, including SIM-swapping operations and Hive ransomware deployment. Driver analysis, victimology, signer details, disclosure to MSRC, and ADV220005 context connect the samples to a wider failure mode in the signing pipeline."],
    ["BlackByte Removes EDR Kernel Callbacks", "https://www.sophos.com/en-us/blog/blackbyte-ransomware-returns", "Sophos X-Ops", "2022", 5, "BlackByte ransomware RTCore64 BYOVD kernel callbacks ETW TI", "Reverse engineers BlackByte's abuse of RTCore64.sys arbitrary kernel read/write to locate and erase process, thread, and image-load callbacks belonging to more than a thousand security drivers. It also covers ETW Threat Intelligence tampering, build-specific offsets, service installation, and code copied from EDRSandblast, creating a detailed bridge from public tooling to ransomware tradecraft."],
    ["AcidBox Repurposes a Turla Driver Exploit", "https://unit42.paloaltonetworks.com/acidbox-rare-malware/", "Unit 42", "2020", 5, "AcidBox Turla VirtualBox driver exploit Russian targets malware", "Reconstructs a rare malware family that repurposed a Turla-linked vulnerable-driver exploit against Russian organizations, tracing the delivery components, driver abuse, privilege transition, persistence, and encrypted communications. The analysis is valuable for comparing a public or previously attributed kernel technique with its implementation by a separate operational cluster."],
    ["WINTAPIX: Kernel Driver Backdoor", "https://www.fortinet.com/blog/threat-research/wintapix-kernal-driver-middle-east-countries", "FortiGuard Labs", "2023", 5, "WINTAPIX malicious kernel driver Donut shellcode Middle East backdoor", "Analyzes a signed Windows kernel driver targeting Middle Eastern organizations that embeds Donut-generated shellcode and acts as a loader, backdoor, and proxy. The report maps driver initialization, payload extraction, injection and communication behavior, certificate pivots, victim telemetry, and related variants while preserving concrete hunting indicators."],
    ["Shamoon the Wiper: Driver and Disk Destruction", "https://securelist.com/shamoon-the-wiper-further-details-part-ii/57784/", "Kaspersky GReAT", "2012", 5, "Shamoon wiper RawDisk driver MBR disk destruction Windows malware", "Provides a technical decomposition of Shamoon's destructive Windows components, including use of a signed RawDisk driver to bypass filesystem controls and overwrite disks. The report separates dropper, wiper, reporting, and driver interactions, records timestamps and artifacts, and remains foundational for studying how legitimate low-level storage software is repurposed for destructive malware."],
    ["CopperStealer: Password and Cookie Theft at Scale", "https://www.proofpoint.com/us/blog/threat-insight/now-you-see-it-now-you-dont-copperstealer-performs-widespread-theft", "Proofpoint", "2021", 4, "CopperStealer Windows malware browser credentials cookies Facebook Google accounts", "Profiles a rapidly evolving Windows credential stealer across more than eighty versions, covering browser database access, cookie and password theft, account targeting, persistence, distribution, C2 protocols, DGA changes, and sinkholing results. The longitudinal sample comparison makes it useful loader-and-malware analysis beyond a single campaign snapshot."],
    ["PARALLAX Loader and REF2731", "https://www.elastic.co/security-labs/exploring-the-ref2731-intrusion-set", "Elastic Security Labs", "2022", 5, "PARALLAX NETWIRE DLL sideloading Heaven's Gate direct syscalls injection", "Reconstructs a multi-stage Windows campaign from malicious document through MsiDb DLL side-loading, encrypted WAV shellcode, direct syscall recovery, Heaven's Gate, suspended-process injection, and NETWIRE delivery. The report connects each loader transition to concrete files, APIs, memory behavior, and public detections rather than treating the campaign as a list of indicators."],
    ["SHADOWPAD Loader in REF2924", "https://www.elastic.co/security-labs/update-to-the-REF2924-intrusion-set-and-related-campaigns", "Elastic Security Labs", "2023", 5, "SHADOWPAD Bitdefender DLL sideloading registry shellcode injection", "Analyzes a SHADOWPAD loader side-loaded by an old Bitdefender crash handler, including its encrypted companion data, registry storage, service persistence, process creation, and injection into Windows Media Player and dllhost. The article also follows shared code and campaign relationships, linking loader internals with operational deployment."],
    ["Elastic Analysis of the r77 Rootkit", "https://www.elastic.co/security-labs/elastic-security-labs-steps-through-the-r77-rootkit", "Elastic Security Labs", "2023", 5, "r77 rootkit API hooks process hollowing registry PowerShell named pipe", "Walks through r77's installer, .NET stager, service, and injected core modules, covering registry-hosted payloads, scheduled tasks, AMSI patching, process hollowing, DLL unhooking, named-pipe coordination, and Native API filtering. Detection rules and YARA are published alongside the code analysis, supporting both reproduction and hunting."],
    ["LOBSHOT hVNC Malware", "https://www.elastic.co/security-labs/elastic-security-labs-discovers-lobshot-malware", "Elastic Security Labs", "2023", 5, "LOBSHOT hVNC malvertising dynamic imports explorer parent evasion", "A full analysis of a previously undocumented hVNC family distributed through convincing Google Ads and installers. It covers dynamic API resolution, Defender emulation checks, process ancestry breaking, persistence, desktop interaction, configuration extraction, infrastructure pivots, and detections, providing a complete view from delivery to interactive fraud capability."],
    ["XWORM and AGENTTESLA Loader Chain", "https://www.elastic.co/security-labs/attack-chain-leads-to-xworm-and-agenttesla", "Elastic Security Labs", "2023", 4, "XWORM AGENTTESLA RTF PowerShell .NET process hollowing AMSI", "Traces a weaponized document through a remotely fetched RTF, Excel macro, obfuscated PowerShell, and custom .NET loader into XWORM or AGENTTESLA. The loader analysis documents AMSI patching, suspended trusted processes, ZwUnmapViewOfSection, image replacement, and payload-specific configuration with published YARA rules."],
    ["SUDDENICON in the 3CX Supply-Chain Attack", "https://www.elastic.co/security-labs/elastic-users-protected-from-suddenicon-supply-chain-attack", "Elastic Security Labs", "2023", 5, "3CX SUDDENICON supply chain ffmpeg DLL shellcode GitHub C2", "A rapid but technically grounded triage of the compromised 3CX Windows client, showing how backdoored libraries locate and decrypt SUDDENICON, map it through shellcode, delay execution, recover C2 data from icon files, and fetch another payload. It includes behavioral queries and YARA while carefully distinguishing confirmed behavior from early assessment."],
    ["BLISTER Loader Evolution", "https://www.elastic.co/security-labs/blister-loader", "Elastic Security Labs", "2023", 5, "BLISTER loader manual mapping Heaven's Gate process hollowing unhooking", "Revisits BLISTER after the original campaign report and dissects its evolving x86 and x64 loader: custom API hashing, manual mapping, clean ntdll replacement, Heaven's Gate wrappers, Rabbit decryption, LZNT1 decompression, persistence, reflective execution, and process hollowing. A configuration extractor and detection artifacts make the analysis directly reproducible."],
    ["RONINGLOADER: DragonBreath's Path to PPL Abuse", "https://www.elastic.co/security-labs/roningloader", "Elastic Security Labs", "2025", 5, "RONINGLOADER PPL abuse signed driver WDAC thread pool injection", "Dissects a multi-stage Windows loader that combines a signed kernel driver, custom WDAC policy, PPL abuse, phantom DLLs, and thread-pool injection to suppress multiple security products before launching a gh0st RAT variant. The report connects installer stages, certificate pivots, kernel abuse, user-mode injection, and final payload behavior with public detections."],
    ["BRUSHWORM and BRUSHLOGGER", "https://www.elastic.co/security-labs/brushworm-targets-financial-services", "Elastic Security Labs", "2026", 4, "BRUSHWORM BRUSHLOGGER DLL sideloading keylogger USB propagation", "Analyzes a modular Windows backdoor and companion keylogger recovered from a financial-sector intrusion, including AES-encrypted configuration, scheduled-task persistence, removable-media propagation, extension-based theft, DLL side-loading, keyboard hooks, and iterative development samples. The straightforward code makes the article a useful study in reconstructing capability even when malware is not heavily obfuscated."],
    ["Defeating BazarLoader Anti-Analysis Techniques", "https://unit42.paloaltonetworks.com/bazarloader-anti-analysis-techniques/", "Unit 42", "2022", 5, "BazarLoader anti analysis API hashing control flow obfuscation debugger", "Turns BazarLoader's anti-analysis layers into a repeatable reversing workflow, with scripts and methods for recovering APIs, untangling execution, and neutralizing checks that impede static and dynamic analysis. The focus on reusable analyst techniques rather than campaign indicators makes it valuable beyond the specific malware family."],
    ["CL-UNK-1068 Windows Loader Operations", "https://unit42.paloaltonetworks.com/cl-unk-1068-targets-critical-sectors/", "Unit 42", "2026", 4, "Windows DLL side loading Python loader critical infrastructure malware", "Documents a long-running intrusion set's Windows tooling with detailed attention to Python-based DLL side-loading, malicious loaders, persistence, credential access, and operator utilities. The article provides enough sample and execution context to connect individual loader mechanics to a broader operational chain without reducing the analysis to indicators."],
    ["OXLOADER technical analysis", "https://www.elastic.co/security-labs/oxloader-malware-loader-infostealer", "Elastic Security Labs", "2026", 5, "loader reloc section self modifying MBA anti VM Donut", "A full analysis of a modern loader using CRT-initializer hijacking, self-modifying decryption stubs, control-flow obfuscation, sandbox checks, and .reloc section abuse. It follows execution into Donut-based in-memory delivery and includes detection artifacts, so the article supports both reversing and defensive validation."],
    ["Deep dive on the BLISTER loader", "https://www.elastic.co/blog/deep-dive-on-the-blister-loader", "Elastic Security Labs", "2021", 5, "BLISTER loader signed certificate embedded payload injection", "Analyzes a signed Windows loader that blends malicious logic into legitimate libraries, delays execution, decrypts embedded payloads, and injects them into trusted processes. The combination of loader mechanics, campaign context, and a public configuration extractor makes it a durable case study."],
    ["DarkGate Internals", "https://blog.sekoia.io/darkgate-internals/", "Sekoia.io", "2023", 5, "DarkGate loader APC injection NtTestAlert crypter malware", "Dissects DarkGate's multi-stage execution, configuration, crypter behavior, process injection, and use of NtTestAlert for APC delivery. It is a useful real-world counterpart to the APC internals series because the same mechanism is visible inside an operational malware family."],
    ["BITS and Bytes: analyzing BITSLOTH", "https://www.elastic.co/security-labs/bits-and-bytes-analyzing-bitsloth", "Elastic Security Labs", "2024", 5, "BITSLOTH Windows backdoor BITS C2 handlers reversing", "A careful reverse engineering of a Windows backdoor that uses BITS as its command-and-control channel and exposes dozens of task handlers. It demonstrates how native Windows services shape malware architecture and includes implementation-level details and detections."],
    ["P8LOADER and SPECTRALVIPER", "https://www.elastic.co/security-labs/elastic-charms-spectralviper", "Elastic Security Labs", "2023", 4, "P8LOADER manual PE mapping RuntimeBroker unbacked memory", "Documents an x64 loader that manually maps PE files from disk or memory and a modular backdoor deployed through it. The analysis is concise but valuable for connecting classic section mapping, relocations, and import resolution to the memory telemetry produced by a real intrusion."],
    ["Qilin ransomware and the hidden dangers of BYOVD", "https://blackpointcyber.com/blog/qilin-ransomware-and-the-hidden-dangers-of-byovd/", "Blackpoint Cyber", "2025", 5, "Qilin ransomware EDRSandblast Toshiba physical memory BYOVD", "Reconstructs a Qilin intrusion in which a sideloaded DLL deploys a customized EDRSandblast and an abused Toshiba driver. It follows byte-wise physical-memory IOCTLs through virtual-to-physical translation, a Beep.sys control-path overwrite, callback removal, and ETW tampering, tying kernel primitives to the surrounding ransomware operation."],
    ["Scattered Spider attempts BYOVD to avoid detection", "https://www.crowdstrike.com/en-us/blog/scattered-spider-attempts-to-avoid-detection-with-bring-your-own-vulnerable-driver-tactic/", "CrowdStrike Intelligence", "2023", 5, "Scattered Spider CVE-2015-2291 Intel driver EDR tampering", "Documents Scattered Spider using Intel's vulnerable iqvw64.sys driver to load attacker-controlled kernel code and patch security-product routines with trampoline hooks. The report connects product-specific offsets, stolen or test signing certificates, and concrete csagent.sys modifications to an observed intrusion campaign."],
    ["W-2: from malvertising to kernel-mode EDR kill", "https://www.huntress.com/blog/w2-malvertising-to-kernel-mode-edr-kill", "Anna Pham, Huntress", "2026", 5, "malvertising Havoc HwAudKiller Huawei driver IOCTL EDR", "Traces a Google Ads and rogue ScreenConnect intrusion into an in-memory EDR killer backed by a previously undocumented signed Huawei driver. The analysis identifies the Havoc service, device path, PID-taking IOCTL, unchecked ZwOpenProcess and ZwTerminateProcess flow, kill loop, target list, and host-level detection artifacts."],
    ["Killing me gently: inside Gentlemen's EDR killer framework", "https://www.welivesecurity.com/en/eset-research/killing-me-gently-inside-gentlemens-edr-killer-framework/", "Jakub Souček, ESET Research", "2026", 5, "Gentlemen ransomware EDR killer vulnerable drivers rootkits BYOVD", "Maps eight variants of the GentleKiller framework across abused NSecKrnl, Safetica, Zemana, Qihoo, IObit, and other drivers. By comparing shared masquerading and evasion layers with rapidly incorporated public PoCs, it shows how a ransomware affiliate maintains and evolves a modular kernel-tampering capability."],
    ["Embargo ransomware: Rock'n'Rust", "https://www.welivesecurity.com/en/eset-research/embargo-ransomware-rocknrust/", "Jan Holman and Tomáš Zvara, ESET Research", "2024", 5, "Embargo ransomware MS4Killer probmon minifilter Rust EDR", "Reverse engineers Embargo's Rust-based MDeployer, MS4Killer, and ransomware chain. It explains how a victim-tailored s4killer derivative decrypts and registers probmon.sys as a minifilter, communicates through FilterConnectCommunicationPort and FilterSendMessage, and repeatedly terminates selected security processes."],
    ["FINALDRAFT and PATHLOADER Technical Analysis", "https://www.elastic.co/security-labs/finaldraft", "Elastic Security Labs", "2025", 5, "FINALDRAFT PATHLOADER Microsoft Graph Outlook drafts C2 reflective loading", "Reverse engineers a Windows downloader and a previously undocumented espionage implant that turns Outlook draft messages into a command channel through Microsoft Graph. The report recovers PATHLOADER's embedded configuration and encrypted shellcode, then maps FINALDRAFT's reflective loading, API hashing, command handlers, token impersonation, network pivoting, and protocol structure with public configuration extractors and detections."],
    ["GHOSTPULSE's Pixel-Level Payload Storage", "https://www.elastic.co/security-labs/tricks-and-treats", "Elastic Security Labs", "2024", 5, "GHOSTPULSE HIJACKLOADER PNG pixels GDIPlus encrypted configuration payload", "Explains how a Windows loader evolved from hiding encrypted data in PNG IDAT chunks to reconstructing its configuration and payload from individual RGB pixel values through GDI+. The analysis documents the CRC32-scanned metadata structure, XOR decryption path, single-file resource packaging, and an updated extractor, making the steganographic implementation reproducible rather than merely describing the delivery campaign."],
    ["BUGHATCH Malware Analysis", "https://www.elastic.co/security-labs/bughatch-malware-analysis", "Elastic Security Labs", "2022", 5, "BUGHATCH reflective loader SeDebugPrivilege custom C2 protocol shellcode", "Walks from an obfuscated PowerShell and shellcode loader into the native BUGHATCH implant used in CUBA ransomware operations. It reconstructs reflective PE loading, privilege adjustment, host fingerprinting, thread synchronization, per-session XOR key generation, HTTP message framing, command dispatch, and several payload execution modes, with pseudocode and YARA that support hands-on reversing."],
    ["Thawing the Permafrost of ICEDID", "https://www.elastic.co/pdf/elastic-security-labs-thawing-the-permafrost-of-icedid.pdf", "Elastic Security Labs", "2023", 5, "ICEDID GZip loader bot payload configuration hooks browser proxy C2", "Provides an end-to-end reverse engineering report for a GZip-era ICEDID loader and bot instead of stopping at campaign telemetry. It follows staged decryption and persistence into the core implant, recovers configuration and command handling, and explains browser-proxy behavior, Windows API use, communications, and the tooling needed to extract actionable structure from samples."],
    ["BlackLotus UEFI Bootkit: Myth Confirmed", "https://www.welivesecurity.com/2023/03/01/blacklotus-uefi-bootkit-myth-confirmed/", "Martin Smolár, ESET Research", "2023", 5, "BlackLotus UEFI bootkit Secure Boot CVE-2022-21894 HVCI winlogon", "Presents the first public end-to-end analysis of BlackLotus, from its installer and Baton Drop exploitation of CVE-2022-21894 through Machine Owner Key enrollment and persistent UEFI execution. It traces hooks across Windows Boot Manager, winload, the kernel, and security drivers, then explains the protected kernel component and winlogon-hosted HTTP downloader that survive on fully updated Windows 11 systems."],
    ["ESPecter: UEFI Threats Moving to the ESP", "https://www.welivesecurity.com/2021/10/05/uefi-threats-moving-esp-introducing-especter-bootkit/", "Martin Smolár and Anton Cherepanov, ESET Research", "2021", 5, "ESPecter UEFI bootkit bootmgfw winload DSE kernel driver espionage", "Reverse engineers a real Windows bootkit that evolved from legacy MBR infection into a patched bootmgfw.efi implant on the EFI System Partition. The report follows integrity-check bypasses and detours through Boot Manager, winload, and ntoskrnl, shows how SepInitializeCodeIntegrity is patched to disable DSE, and continues into the unsigned driver, process injection, encrypted configuration, and user-mode espionage payloads."],
    ["NSPX30: An AitM-Enabled Implant Evolving Since 2005", "https://www.welivesecurity.com/en/eset-research/nspx30-sophisticated-aitm-enabled-implant-evolving-since-2005/", "Facundo Muñoz, ESET Research", "2024", 5, "NSPX30 Blackwood AitM loader orchestrator backdoor plugin evolution", "Reconstructs almost two decades of a Windows espionage platform from Project Wood and DCM to NSPX30 by comparing code, build artifacts, loaders, orchestrators, backdoors, and plugins across generations. The analysis explains its unusual on-path traffic interception delivery, multistage persistence, allowlisting against security products, encrypted configurations, C2 protocol, and modular collection capabilities with unusually rich historical sample evidence."],
    ["SprySOCKS for Windows and Its RawWNPF Rootkit", "https://www.welivesecurity.com/en/eset-research/fishmongers-arsenal-upgraded-sprysocks-windows/", "ESET Research", "2026", 5, "SprySOCKS Windows DriverLoader RawWNPF rootkit IOCTL network process hiding", "Dissects the Windows port of SprySOCKS together with a signed DriverLoader that decrypts and manually maps a second kernel component. The RawWNPF analysis enumerates its private IOCTL interface and follows InfinityHook-style NtQuerySystemInformation filtering, nsiproxy completion-routine hooks, process and connection hiding, file protection, encrypted configuration, and the differences between user-mode and driver-backed variants."],
    ["EDR Killers Explained: Beyond the Drivers", "https://www.welivesecurity.com/en/eset-research/edr-killers-explained-beyond-the-drivers/", "Jakub Souček / ESET Research", "2026", 5, "EDR killers BYOVD vulnerable drivers packers EDRSilencer EDR-Freeze attribution", "Builds a taxonomy from nearly ninety EDR killers rather than treating each abused driver as an isolated sample. The research compares fifty-four BYOVD tools, driver-switching and code-reuse patterns, private implementations without public PoCs, script and driverless techniques such as EDRSilencer and EDR-Freeze, commercial killer products, packer overlap, and the attribution traps created when ransomware crews rapidly reuse public projects."],
    ["EnCase BYOVD EDR Killer", "https://www.huntress.com/blog/encase-byovd-edr-killer", "Huntress", "2026", 5, "EnCase forensic driver BYOVD EDR killer expired certificate wordlist encoding", "Reconstructs an incident in which an attacker transformed an old EnCase forensic driver into an EDR killer after obtaining SonicWall credentials. The user-mode component hides the driver behind a 256-word encoding scheme, decodes and drops OemHwUpd.sys, applies hidden and system attributes, copies timestamps from ntdll, and repeatedly targets fifty-nine security processes while exploiting Windows' legacy acceptance of pre-2015 cross-signed drivers."],
    ["Fake Tech Support Delivers Modified Havoc", "https://www.huntress.com/blog/fake-tech-support-havoc-command-control", "Huntress", "2026", 5, "Havoc Demon fake tech support indirect syscalls registry C2 lateral movement", "Follows a social-engineering intrusion across five organizations from spam and a fake support call into a customized Havoc Demon deployment. Sample analysis distinguishes the implant from stock Havoc through indirect syscalls and a registry-backed fallback command channel, while incident telemetry connects those implementation changes to RMM installation, credential use, custom payload generation, and lateral movement across nine endpoints in eleven hours."],
    ["BlackCat Deploys a Signed Kernel Driver", "https://www.trendmicro.com/en_us/research/23/e/blackcat-ransomware-deploys-new-signed-kernel-driver.html", "Trend Micro Research", "2023", 5, "BlackCat ransomware ktgn.sys signed kernel driver IOCTL process kill file delete", "Reverse engineers BlackCat's obfuscated user-mode agent and the Safengine-protected ktgn.sys driver it drops under certificates later revoked by Microsoft. The analysis recovers the device interface and ten-command IOCTL protocol, including activation, kernel-thread process termination through ZwTerminateProcess, file copy and forced deletion, callback-management stubs, and reboot, then compares certificate and driver variants observed across the campaign."],
    ["Water Orthrus Rootkit and Phishing Modules", "https://www.trendmicro.com/en_us/research/23/e/water-orthrus-new-campaigns-deliver-rootkit-and-phishing-modules.html", "Trend Micro Research", "2023", 5, "Water Orthrus CopperStealth rootkit winio driver process protection phishing module", "Tracks a financially motivated Windows malware operation as it expands CopperStealth with a kernel-rootkit branch and a separate phishing module. The report connects signed-driver abuse and low-level process protection or concealment to the loaders, configuration, command infrastructure, credential theft, persistence, and campaign telemetry, making the kernel component understandable as one stage in an evolving modular toolchain rather than an isolated driver sample."],
    ["Donut-Generated Shellcode: End-to-End Malware Analysis", "https://unit42.paloaltonetworks.com/donut-malware-analysis-tutorial/", "Lauren Che and Zong-Yu Wu / Unit 42", "2025", 5, "Donut shellcode .NET Remcos dnSpy IDA x64dbg process injection AMSI patch", "Builds a complete Windows malware-analysis workflow around a staged Donut-generated sample, recording the analyst's reasoning from initial triage through dynamic API recovery, .NET inspection, shellcode debugging, process injection, AMSI memory patching, and final Remcos identification. The linked full tutorial and sample-oriented tool choices make it particularly useful for moving from isolated reversing techniques to an end-to-end investigation."],
    ["HeartCrypt Packer-as-a-Service", "https://unit42.paloaltonetworks.com/packer-as-a-service-heartcrypt-malware/", "Jerome Tujague and Daniel Bunce / Unit 42", "2024", 5, "HeartCrypt packer PIC PE resources BMP shellcode process injection payload extraction", "Reverse engineers a Windows packer used across thousands of samples and dozens of malware families, showing how it modifies legitimate PE entry paths, inserts position-independent code, executes BMP-disguised resource stages, performs sandbox checks and process injection, and establishes persistence. The article then derives a repeatable payload extractor from stable offsets, XOR properties, and PE invariants rather than stopping at a family overview."],
    ["Kazuar's Upgraded Windows Backdoor", "https://unit42.paloaltonetworks.com/pensive-ursa-uses-upgraded-kazuar-backdoor/", "Daniel Frank and Tom Fakterman / Unit 42", "2023", 5, "Kazuar Turla .NET backdoor string decryption injection named pipes WMI C2", "Provides a deep source-level reconstruction of a Windows-only Kazuar revision after exporting and renaming its deobfuscated .NET code. It covers custom string encryption, multiple browser and svchost injection modes, asynchronous task handling, forty-five commands, named-pipe and WMI behaviors, credential collection, configuration storage, anti-dumping, and layered C2 cryptography, with a public artifact appendix for verification."],
    ["ScatterBrain: Deobfuscating POISONPLUG.SHADOW", "https://cloud.google.com/blog/topics/threat-intelligence/scatterbrain-unmasking-poisonplug-obfuscator", "Nino Isakovic / Mandiant FLARE", "2025", 5, "ScatterBrain POISONPLUG ShadowPad compiler obfuscation CFG mutation import protection deobfuscator", "An exhaustive reverse engineering of the custom compiler protecting POISONPLUG.SHADOW, inferred entirely from recovered Windows binaries. It decomposes selective and full control-flow transformation, instruction mutation, import protection, mixed-mode changes, and version evolution, then explains how each layer is removed by a published framework-independent static library that emits functioning deobfuscated executables."],
    ["Bypassing MassLogger's Runtime MSIL Replacement", "https://cloud.google.com/blog/topics/threat-intelligence/bypassing-masslogger-anti-analysis-man-in-the-middle-approach/", "Nhan Huynh / Mandiant FLARE", "2020", 5, "MassLogger .NET CLR MSIL runtime replacement profiler API ReJIT deobfuscation", "Investigates a .NET credential stealer that defeats ordinary static analysis by replacing method bodies with new Microsoft Intermediate Language at runtime. The article follows its staged loader, CLR execution boundary, and anti-analysis design, then develops a profiler-based man-in-the-middle technique and companion tooling to capture the real MSIL as the runtime requests it, a method reusable against similarly protected malware."],
    ["PHANTOMPULSE: Hijackable Blockchain-C2 RAT", "https://www.elastic.co/security-labs/blockchain-c2-phantompulse-rat-sinkhole", "Salim Bitam / Elastic Security Labs", "2026", 5, "PHANTOMPULSE Windows RAT blockchain C2 hardware breakpoint AMSI WLDP ETW injection", "Reverse engineers a large Windows implant that resolves command infrastructure from Ethereum-family transaction inputs, implements three payload-specific injection engines, and shares a hardware-breakpoint primitive across AMSI, WLDP, and ETW bypasses. The report also derives a chain-wide encrypted-input signature and proves that missing sender authentication lets responders override the resolver and sinkhole deployed implants."],
    ["NANOREMOTE and WMLOADER", "https://www.elastic.co/security-labs/nanoremote", "Daniel Stepanic / Elastic Security Labs", "2025", 5, "NANOREMOTE WMLOADER Google Drive C2 manual PE loader Detours AES backdoor", "Follows WMLOADER from rolling-XOR shellcode and AES-CBC payload recovery into a C++ backdoor with twenty-two command handlers, direct file and memory PE execution, and resumable Google Drive transfer queues. Configuration formats, HTTP encryption, OAuth behavior, libPeConv and Detours reuse, crash-dump support, and published detections make the relationship to FINALDRAFT independently testable."],
    ["LoJax: First UEFI Rootkit Found in the Wild", "https://www.welivesecurity.com/2018/09/27/lojax-first-uefi-rootkit-found-wild-courtesy-sednit-group/", "ESET Research", "2018", 5, "LoJax Sednit UEFI rootkit SPI flash ReWriter driver firmware persistence Windows", "Documents the first UEFI rootkit observed in an active campaign, including platform reconnaissance, SPI-flash acquisition, firmware patching, and use of the legitimate RWEverything driver to cross the hardware boundary. The analysis reconstructs the malicious DXE module's dropper role, write-protection bypass choices, user-mode agent recovery, and why reflashing—not reinstalling Windows—is required to remove this persistence layer."],
    ["MosaicRegressor: Lurking in UEFI", "https://securelist.com/mosaicregressor/98849/", "Kaspersky GReAT", "2020", 5, "MosaicRegressor UEFI firmware rootkit Hacking Team VectorEDK MosaicRegressor loaders", "Connects a malicious UEFI module derived from leaked Hacking Team VectorEDK code to a wider Windows espionage framework rather than analyzing firmware in isolation. The research traces SPI-resident persistence into IntelUpdate.exe and a modular chain of downloaders and intermediate loaders, compares execution and configuration traits across victims, and preserves the forensic evidence used for attribution and detection."],
    ["MoonBounce: The Dark Side of UEFI Firmware", "https://securelist.com/moonbounce-the-dark-side-of-uefi-firmware/105468/", "Mark Lechtik, Vasily Berdnikov, Denis Legezo and Ilya Borisov / Kaspersky GReAT", "2022", 5, "MoonBounce APT41 UEFI CORE_DXE SPI flash ExitBootServices Windows loader memory only", "Reconstructs an APT41-linked firmware implant embedded by modifying CORE_DXE itself, where hooks on Boot Services hand execution through the Windows loader and into a fileless user-mode stager. Its comparison with LoJax and MosaicRegressor, precise AllocatePool, CreateEventEx, and ExitBootServices interception chain, in-memory delivery path, network pivots, and acknowledged infection unknowns make it a model firmware-malware investigation."],
    ["PIKABOT: Patched-Binary Loader Internals", "https://www.elastic.co/security-labs/pikabot-i-choose-you", "Salim Bitam and Daniel Stepanic / Elastic Security Labs", "2024", 5, "PIKABOT Windows loader patched PE direct syscalls process injection ctfmon anti analysis", "Locates PIKABOT code patched into a legitimate grepWin binary by comparing clean and malicious executables, then traces the first-stage loader into syscall-driven creation and injection of a suspended ctfmon.exe. The analysis covers API hashing, anti-debug checks, WOW64 hook evasion, string and configuration recovery, payload decryption, and call-stack evidence, giving reversers a concrete method for separating implanted logic from its benign host."],
    ["Blitz Malware: Game Cheats, Repositories, and a Modular Stealer", "https://unit42.paloaltonetworks.com/blitz-malware-2025/", "Dominik Reichel and Unit 42", "2025", 4, "Blitz Windows malware game cheats GitHub loader stealer browser credentials injection", "Reverse engineers successive Blitz samples distributed through game-cheat lures and public code repositories, following their delivery scripts, staged executables, persistence, credential and browser-data collection, and evolving command infrastructure. The version comparison and repository pivots connect implementation changes to an active development process, while sample hashes and behavioral detail make the conclusions independently useful for triage and detection."],
    ["TinyRCT: A Compact .NET Backdoor", "https://unit42.paloaltonetworks.com/cl-sta-1062-tinyrct-backdoor/", "Unit 42", "2026", 4, "TinyRCT .NET Windows RAT backdoor environment validation persistence C2 command handlers", "Dissects TinyRCT, a lightweight C# remote-access Trojan used against Southeast Asian targets, from its explicit host-validation checks through persistence, encrypted configuration, command dispatch, file transfer, and interactive execution. The sample-level .NET analysis distinguishes custom implant logic from supporting campaign infrastructure and provides enough protocol, artifact, and execution detail to reproduce defensive hunting without treating the RAT as a generic indicator list."],
    ["Webworm: EchoCreep and GraphWorm Cloud C2 Backdoors", "https://www.welivesecurity.com/en/eset-research/webworm-new-burrowing-techniques/", "Eric Howard / ESET Research", "2026", 5, "Webworm EchoCreep GraphWorm Windows backdoor Discord Microsoft Graph OneDrive C2 proxy", "Reconstructs Webworm's newer Windows arsenal around the EchoCreep and GraphWorm implants, showing how custom HTTP requests turn Discord into command-and-control and how Microsoft Graph and OneDrive provide per-victim job queues and large-file exfiltration. Recovered operator messages, sample hashes, command evolution, persistence experiments, staged repositories, and several custom proxy formats tie code behavior to live development and deployment evidence."],
    ["PipeMagic in 2025: Backdoor and Loader Evolution", "https://securelist.com/pipemagic/117270/", "Kaspersky GReAT", "2025", 5, "PipeMagic Windows backdoor MSBuild encrypted shellcode named pipes in memory ransomware", "Tracks PipeMagic's revised Windows delivery and execution chain across malicious MSBuild projects, encrypted shellcode, callback-based execution, and the final in-memory backdoor. The researchers compare current samples with earlier campaigns, recover loader and payload relationships, document named-pipe and command behavior, and connect the implant to multiple exploit-led intrusions, making the post useful for both family reversing and longitudinal change analysis."],
    ["Off the Beaten Path: Three Unusual Windows Implants", "https://unit42.paloaltonetworks.com/unusual-malware/", "Unit 42", "2025", 5, "Windows IIS backdoor C++ CLI GRUB bootkit vulnerable driver Sliver implant", "Performs sample-level analysis of three uncommon Windows payloads instead of grouping them only by campaign: a passive IIS backdoor written in C++/CLI, a bootkit that uses an unsecured kernel driver to install a modified GRUB 2 chain, and a native Windows port of a cross-platform post-exploitation implant. The report reconstructs loading, persistence, communications, anti-analysis choices, and build artifacts for each, making the contrast between user-mode, boot-time, and framework-derived tradecraft especially useful."],
    ["Airstalk: AirWatch as a Covert Command Channel", "https://unit42.paloaltonetworks.com/new-windows-based-malware-family-airstalk/", "Kristopher Russo and Chema Garcia / Unit 42", "2025", 5, "Airstalk Windows PowerShell .NET AirWatch Workspace ONE API C2 browser theft", "Reverse engineers both PowerShell and .NET generations of Airstalk, a Windows implant that repurposes Workspace ONE AirWatch device attributes and file uploads as an authenticated command channel. The analysis compares protocol and browser-target differences, reconstructs multithreaded task handling, configuration, persistence, certificate use, screenshot and browser-data collection, and unfinished commands, preserving evidence of development rather than reducing the family to its supply-chain attribution."],
    ["Katz and Mouse: Infostealers Bypass Chrome App-Bound Encryption", "https://www.elastic.co/security-labs/katz-and-mouse-game", "Elastic Security Labs", "2024", 5, "Chrome App-Bound Encryption STEALC VIDAR METASTEALER ChromeKatz COM elevation IElevator", "Tracks the infostealer ecosystem's rapid response to Chrome 127 App-Bound Encryption by comparing implementations recovered from STEALC, VIDAR, METASTEALER, PHEMEDRONE, and related samples. The researchers pivot from binary signatures to ChromeKatz source lineage, explain how malware obtains the elevation service and decrypts protected browser keys in the correct security context, distinguish copied and independently adapted code, and publish detection logic that follows behavior rather than a single family hash."],
    ["Dissecting GootLoader with the Node.js Debugger", "https://unit42.paloaltonetworks.com/javascript-malware-gootloader/", "Unit 42", "2024", 5, "GootLoader JavaScript Node.js VS Code anti analysis environment key payload deobfuscation", "Turns GootLoader's deeply obfuscated JavaScript and environment-sensitive execution into a reproducible debugging workflow using Node.js and Visual Studio Code. The article identifies browser-versus-host assumptions, neutralizes anti-analysis and timing behavior, traces generated functions and staged data transformations at runtime, and recovers the executable payload without relying on fragile beautification alone, providing a method that transfers to other script-based Windows loaders."],
    ["Extracting GuLoader and RedLine Configurations from Memory", "https://unit42.paloaltonetworks.com/malware-configuration-extraction-techniques-guloader-redline-stealer/", "Unit 42", "2024", 5, "GuLoader RedLine Stealer memory dump configuration extractor anti analysis Python Volatility", "Explains a production-oriented approach to malware configuration recovery that searches process-memory dumps for stable decoded structures instead of fully defeating every packing and anti-analysis layer. Using GuLoader and RedLine as worked cases, the researchers derive invariant byte and string relationships, validate candidate layouts across sample variants, handle false positives and encoding differences, and publish Python extraction logic, bridging manual reverse engineering with repeatable high-volume triage."],
    ["RegPhantom Kernel Backdoor Threat Analysis", "https://www.nextron-systems.com/2026/03/20/regphantom-backdoor-threat-analysis/", "Pierre-Henri Pezier / Nextron Systems", "2026", 5, "RegPhantom Windows kernel rootkit registry callback reflective PE loader CFG obfuscation signed driver", "Reverse engineers a Microsoft-trusted kernel driver that turns ordinary registry writes into an encrypted user-to-kernel command channel. The analysis removes control-flow obfuscation, reconstructs the CmRegisterCallback filter and command format, follows reflective PE mapping into unlisted pool memory, callback hijacking, payload wiping and pointer encoding, then clusters related signed samples and provides code-pattern and certificate pivots suited to finding the maintained family rather than one hash."],
    ["Anatomy of a WHQL-Signed WFP Kernel Backdoor", "https://www.nextron-systems.com/2026/06/26/anatomy-of-a-whql-signed-windows-filtering-platform-wfp-kernel-resident-network-backdoor/", "Pierre-Henri Pezier / Nextron Systems", "2026", 5, "Windows wskmon WHQL signed kernel backdoor WFP stream callout HMAC SHA256 network protocol", "Dissects wskmon.sys, a self-contained WHQL-signed backdoor that receives commands directly inside a Windows Filtering Platform stream callout without an IOCTL device or user-mode agent. The report reconstructs packet framing, HMAC-SHA256 authentication, encryption, connection state and kernel command handlers, maps its execution and memory-management architecture, validates behavior dynamically, and extracts network, certificate and binary detections for an implant designed to blend with the trusted driver ecosystem."],
    ["HoneyMyte Kernel Rootkit and ToneShell Backdoor", "https://securelist.com/honeymyte-kernel-mode-rootkit/118590/", "Noushin Shabab / Kaspersky GReAT", "2025", 5, "HoneyMyte ToneShell Windows minifilter rootkit stolen certificate WdFilter altitude process protection injection", "Analyzes a signed HoneyMyte minifilter driver that protects its file, service registry state and injected user-mode payload while actively interfering with Microsoft Defender. The writeup traces API resolution, callback and minifilter registration, object and process protection, WdFilter altitude tampering, payload decryption and injection, then reverses the resulting ToneShell command channel and correlates certificates, samples and victims across the campaign."],
    ["GhostEmperor: From ProxyLogon to Kernel Mode", "https://securelist.com/ghostemperor-from-proxylogon-to-kernel-mode/104407/", "David Kirari and Mark Lechtik / Kaspersky GReAT", "2021", 5, "GhostEmperor Demodex rootkit ProxyLogon Cheat Engine dbk64 manual map encrypted C2", "Reconstructs an intrusion chain from Exchange ProxyLogon exploitation to Demodex, a custom Windows kernel rootkit loaded through Cheat Engine's signed dbk64.sys driver. The analysis follows the service and injected unloader, bespoke IOCTL protocol, manual import resolution and kernel image mapping, user-mode loader, encrypted network communication and forensic countermeasures, while connecting infrastructure and tooling across a long-running threat cluster."],
    ["DynoWiper: Technical Analysis and Attribution", "https://www.welivesecurity.com/en/eset-research/dynowiper-update-technical-analysis-attribution/", "Anton Cherepanov and Robert Lipovský / ESET Research", "2026", 5, "DynoWiper Sandworm Windows wiper scheduled task file destruction domain deployment attribution", "Provides sample-level reconstruction of DynoWiper variants deployed inside a compromised organization, including their recursive traversal, exclusion mistakes, overwrite and deletion differences, privilege assumptions, forced reboot, build artifacts and repeated operator attempts. The incident timeline correlates scheduled-task deployment, adjacent credential and proxy tooling, infrastructure and code relationships with earlier Sandworm operations, carefully separating confirmed destructive behavior from attribution assessment."],
    ["MIMICRAT: ClickFix to a Custom Native RAT", "https://www.elastic.co/security-labs/mimicrat-custom-rat-mimics-c2-frameworks", "Salim Bitam / Elastic Security Labs", "2026", 5, "MIMICRAT ClickFix Lua shellcode loader native Windows RAT token theft SOCKS5 malleable C2", "Reconstructs a five-stage Windows infection beginning with compromised websites and obfuscated PowerShell, then follows ETW and AMSI patching, a statically linked Lua loader, in-memory shellcode, and the previously undocumented native MIMICRAT implant. Configuration recovery, RSA and AES session handling, token impersonation, the 22-command dispatcher, SOCKS5 tunneling, sample hashes, and YARA make the final family independently triageable."],
    ["TCLBANKER: Banking Trojan and Self-Propagating Worm", "https://www.elastic.co/security-labs/tclbanker-brazilian-banking-trojan", "Jia Yu Chan et al. / Elastic Security Labs", "2026", 5, "TCLBANKER Windows banking trojan DLL sideloading WPF overlay WhatsApp Outlook worm .NET Reactor", "Analyzes a Brazilian banking-malware chain that side-loads a malicious Flutter plugin through a signed Logitech executable and releases two .NET Reactor-protected payloads. The researchers recover environment and locale gates, browser UI-Automation targeting, screen-capture-resistant WPF fraud overlays, operator commands, and separate WhatsApp and Outlook propagation modules, connecting delivery artifacts to the complete banker and worm implementation."],
    ["SILENTCONNECT: Native Loader Delivering ScreenConnect", "https://www.elastic.co/security-labs/silentconnect-delivers-screenconnect", "Daniel Stepanic and Salim Bitam / Elastic Security Labs", "2026", 5, "SILENTCONNECT Windows loader VBScript PowerShell NTAPI PEB masquerading UAC bypass ScreenConnect", "Follows a digital-invitation lure through VBScript and in-memory C# compilation into a compact Windows loader that deploys ScreenConnect for interactive access. Code-level analysis explains its direct Native API delegates, executable-memory PEB stub, process masquerading, Defender exclusions, elevation behavior, COM usage, persistence, and silent RMM installation, with detection logic and indicators tied to each stage rather than only the landing infrastructure."],
    ["De-obfuscating ALCATRAZ-Protected DOUBLELOADER", "https://www.elastic.co/security-labs/deobfuscating-alcatraz", "Daniel Stepanic / Elastic Security Labs", "2025", 5, "ALCATRAZ DOUBLELOADER Windows malware deobfuscation control flow flattening instruction mutation anti disassembly IDAPython", "Uses a DOUBLELOADER sample deployed with RHADAMANTHYS to turn five ALCATRAZ protections into reproducible analyst exercises. The article recovers the true PE entry point, repairs anti-disassembly jumps and mutated instructions, unfolds hidden constants and RIP-relative LEA targets, and removes flattened control flow with D810, while releasing IDAPython helpers that expose both the patterns and their limitations."],
    ["WARMCOOKIE One Year Later", "https://www.elastic.co/security-labs/revisiting-warmcookie", "Daniel Stepanic and Seth Goodwin / Elastic Security Labs", "2025", 5, "WARMCOOKIE Windows backdoor configuration extraction RC4 command handlers scheduled task infrastructure clustering", "Compares a year of WARMCOOKIE builds to isolate new PE, DLL, and PowerShell execution handlers, revised scheduled-task behavior, randomized company-name paths, dual mutexes, and code-quality changes. Extracted configurations reveal campaign identifiers, operator-specific RC4-key clusters, feature differences, and a reused expired TLS certificate, demonstrating how longitudinal binary comparison can turn small implementation changes into infrastructure and actor pivots."],
    ["Emulating Windows Kernel-Mode Rootkits with Speakeasy", "https://cloud.google.com/blog/topics/threat-intelligence/emulation-of-kernel-mode-rootkits-with-speakeasy", "Andrew Davis / Mandiant FLARE", "2021", 5, "Windows kernel rootkit malware emulation driver IRP IOCTL injected DLL memory extraction Speakeasy", "Shows how high-resolution emulation can replace fragile two-machine kernel debugging for first-pass analysis of malicious Windows drivers. Speakeasy executes DriverEntry, discovers and invokes IRP dispatch routines with synthetic requests, follows worker threads and kernel APIs, records stealth and injection behavior, and exports tagged memory containing the user-mode implant; the worked rootkit case demonstrates how to recover coverage and payloads at scale without granting an unknown driver ring-0 execution."],
    ["Emulating Malicious Windows Shellcode with Speakeasy", "https://cloud.google.com/blog/topics/threat-intelligence/emulation-of-malicious-shellcode-with-speakeasy", "Andrew Davis / Mandiant FLARE", "2020", 5, "Windows shellcode malware emulation API environment profiling Cobalt Strike IOC extraction Speakeasy", "Introduces Speakeasy's Windows-focused execution model through a Cobalt Strike Beacon whose API hashing, environment discovery and network setup would otherwise require manual single stepping. The article explains configurable OS artifacts, dynamic API handling, memory and string tracing, automatic report generation and custom hooks, then demonstrates extraction of network indicators while retaining support for PE files, DLLs and kernel drivers as a single reproducible analysis workflow."],
    ["What Deep Neural Networks Learn from Windows Malware", "https://cloud.google.com/blog/topics/threat-intelligence/what-are-deep-neural-networks-learning-about-malware/", "Scott Coull and Christopher Gardner / Mandiant", "2018", 5, "Windows PE malware machine learning CNN byte features imports attribution explainability WannaCry NotPetya", "Opens a raw-byte malware classifier rather than treating its verdict as magic, using millions of Windows PE samples and layer-by-layer activation analysis to identify the structures that drive decisions. The researchers map learned features back to text sections, imports, padding and compiler artifacts, compare activations across WannaCry, NotPetya and Bad Rabbit, and expose both useful family signals and dataset shortcuts, providing a rigorous model for validating automated triage systems before analysts trust them."],
    ["Annotating Malware Disassembly Functions with Neural Translation", "https://cloud.google.com/blog/topics/threat-intelligence/annotating-malware-disassembly-functions", "Philip Tully, Sunil Vasisht, Omar Sardar and Jay Gibble / Mandiant FLARE", "2022", 5, "malware reverse engineering Windows disassembly function naming neural translation capa FLOSS FLARE", "Treats function naming as a measurable reverse-engineering task and trains a sequence model on analyst-authored labels paired with normalized disassembly. The post details tokenization, architecture, confidence scoring and failure modes, then integrates predicted names with FLARE workflows so an analyst can prioritize cryptography, networking and persistence code without accepting guesses blindly; evaluation against held-out binaries makes it a practical study in augmenting rather than replacing manual Windows malware analysis."],
    ["SUNBURST: Additional Technical Details", "https://cloud.google.com/blog/topics/threat-intelligence/sunburst-additional-technical-details/", "Mandiant", "2020", 5, "SUNBURST SolarWinds Windows malware DGA process service blocklist registry configuration C2 protocol", "Deepens the initial SolarWinds compromise reporting with binary-level behavior needed to reproduce detection and analysis. The researchers recover SUNBURST's hashed process, service and driver blocklists, registry-backed state machine, delayed execution, victim-domain generation and C2 response decoding, and show how network and host configuration influence each branch; the mapping from constants and structures to observable artifacts remains a strong example of turning a complex signed DLL into testable behavioral hypotheses."],
    ["QBOT Malware Analysis", "https://www.elastic.co/security-labs/qbot-malware-analysis", "Elastic Security Labs", "2023", 5, "QBOT QakBot Windows malware process injection configuration extractor persistence string bank C2", "Reconstructs QBOT's multistage Windows execution from regsvr32 launch through process injection, per-user installation, dynamic persistence, and command-and-control message verification. The report explains its fingerprint-seeded naming, XOR string banks, hashed imports, encrypted resources, antivirus-specific branches, injected-module bookkeeping, and update flow, then publishes YARA, a configuration extractor, and indicators that let analysts validate the recovered internals."],
    ["Doing Time with the YIPPHB Dropper", "https://www.elastic.co/security-labs/doing-time-with-the-yipphb-dropper", "Elastic Security Labs", "2022", 4, "YIPPHB REF4526 Windows dropper PowerShell Unicode icons Base64 loader RAT", "Follows REF4526 from malicious documents into PowerShell commands that hide Base64 fragments among Unicode icons, delaying automated extraction before installing the YIPPHB dropper and multiple RAT stages. By comparing twelve related activity clusters, the researchers separate a repeatable delivery technique from individual payload families and provide execution artifacts, infrastructure pivots, detections, and YARA suitable for reproducing the chain in a controlled lab."],
    ["NAPLISTENER: An HTTP Listener Hidden in Plain Sight", "https://www.elastic.co/security-labs/naplistener-more-bad-dreams-from-the-developers-of-siestagraph", "Remco Sprooten / Elastic Security Labs", "2023", 4, "NAPLISTENER SIESTAGRAPH Windows C sharp HTTP listener service web server persistence", "Analyzes a compact C# backdoor installed as the deliberately misspelled Wmdtc Windows service, placing its encrypted command traffic inside requests that resemble legitimate web activity. The report reconstructs NAPLISTENER's HTTP request handling, in-memory payload execution, serialization and cryptographic routines, relates its development choices to SIESTAGRAPH and SOMNIRECORD, and supplies behavioral detections and YARA that distinguish the listener from the Microsoft Distributed Transaction Coordinator it impersonates."],
    ["TOLLBOOTH: What's Yours, IIS Mine", "https://www.elastic.co/security-labs/tollbooth", "Elastic Security Labs and Texas A&M System Cybersecurity", "2025", 5, "TOLLBOOTH IIS module ASP.NET machine key Godzilla webshell Hidden rootkit SEO cloaking", "Traces exploitation of IIS servers that reused publicly disclosed ASP.NET machine keys into a Godzilla-derived webshell, remote-management tooling, a modified Hidden kernel driver, and the TOLLBOOTH native IIS module. The report recovers the module's SEO-cloaking and backdoor behavior, correlates active scanning with 571 infected servers, and publishes endpoint detections plus YARA for the module, command-line component, and driver, making the post useful beyond its incident narrative."],
    ["Debugging Heap-Resident POISONPLUG Modules", "https://cloud.google.com/blog/topics/threat-intelligence/debugging-complex-malware-that-executes-code-on-the-heap", "Michael Bailey / Mandiant", "2018", 5, "POISONPLUG Windows malware heap shellcode IDA WinDbg remote debugging anti reverse engineering", "Develops a reusable IDA Pro and WinDbg workflow around a POISONPLUG sample whose shellcode unpacks seven interdependent modules with custom PE headers into nondeterministic heap addresses. The case study shows how to snapshot live loader segments, identify executable mappings with flare-qdb or injectfind, suspend every thread before detaching, and preserve a stable remote-debugging save point so annotations survive repeated experiments despite anti-analysis threads and cross-module control flow."],
  ]},
  { id: "cves", kicker: "Study complete cases", title: "CVE & Case Studies", items: [
    ["Exploiting Enterprise Backup Software: Part One", "https://northwave-cybersecurity.com/exploiting-enterprise-backup-software-for-privilege-escalation-part-one", "Alex Oudenaarden / Northwave", "2024", 5, "Macrium Reflect psmounterex kernel heap overflow OOB read driver", "Reverse engineers Macrium Reflect's psmounterex.sys after an automated crash and develops two complementary kernel-heap vulnerabilities: a state-corruption out-of-bounds read and a mount-manager-assisted out-of-bounds write. Part one carefully establishes the device exposure, request paths, allocation behavior, and constraints later used for exploitation."],
    ["Exploiting Enterprise Backup Software: Part Two", "https://northwave-cybersecurity.com/exploiting-enterprise-backup-software-for-privilege-escalation-part-two?hsLang=en", "Alex Oudenaarden / Northwave", "2024", 5, "Macrium Reflect segment heap token spray OOB read write LPE", "Turns the paired Macrium Reflect heap primitives into a reliable local privilege-escalation exploit on the modern segment heap. The authors use duplicated-token grooming, process-token placement, read-assisted heap reconnaissance, constrained allocation retries, and a precise SEP_TOKEN_PRIVILEGES overwrite while documenting why simpler sprays fail."],
    ["Ivanti/Pulse VPN Privilege Escalation Exploit", "https://northwave-cybersecurity.com/ivanti-pulse-vpn-privilege-escalation", "Alex Oudenaarden and Tijme Gommers", "2023", 5, "CVE-2023-38043 CVE-2023-35080 CVE-2023-38543 Ivanti kernel function call", "Develops three Ivanti Secure Access Client driver flaws into a constrained kernel-function-call chain through an exposed IOCTL and attacker-controlled IoCsqRemoveIrp state. The analysis handles CFG restrictions, post-call cleanup crashes, spin-lock behavior, and function selection instead of treating the primitive as an automatic path to SYSTEM."],
    ["VIVE VR Driver Out-of-Bounds Read", "https://northwave-cybersecurity.com/vive-vr-headset-kernel-driver-vulnerable-for-out-of-bounds-memory-read", "Tijme Gommers / Northwave", "2024", 4, "HTC VIVE ViveRRaudio IOCTL OOB kernel memory disclosure", "Audits HTC VIVE Business Streaming's world-accessible ViveRRaudio.sys device and identifies IOCTL 0x9C40240F copying a fixed test string with an attacker-controlled output length. The post reconstructs the dispatch path, MDL mapping, information-disclosure primitive, proof of concept, affected version, coordinated disclosure, and vendor patch."],
    ["CVE-2024-31757: TeraByte Kernel Handle Leak", "https://northwave-cybersecurity.com/vulnerability-notice-terabyte-image-for-windows", "Northwave Research", "2024", 4, "CVE-2024-31757 TBOFLHelper64 kernel handle leak privilege escalation", "Documents two low-privilege kernel-handle leaks in TeraByte Image for Windows' TBOFLHelper64.sys, caused by a device interface accessible to every local user. The original notice identifies affected hashes and versions, explains how leaked System-process handles can support elevation, and records the coordinated fix in version 4.0.0.0."],
    ["ADLINK PXI Physical-Memory Disclosure", "https://northwave-cybersecurity.com/vulnerability-notice-adlink-pxi-platform-services", "Northwave Research", "2024", 4, "ADLINK ADRMDRVSYS IOCTL physical memory LSASS disclosure", "Describes a world-accessible ADRMDRVSYS.sys interface in ADLINK PXI Platform Services whose IOCTL 0x2234D4 maps caller-selected physical memory into user space. The original advisory connects the primitive to sensitive-memory and LSASS disclosure, supplies affected versions and hashes, and preserves the vendor-coordination timeline."],
    ["CVE-2024-28519: eScan Kernel Handle Leak", "https://northwave-cybersecurity.com/vulnerability-notice-escan-antivirus", "Northwave Research", "2024", 4, "CVE-2024-28519 eScan ProcObsrvesx kernel handle leak LPE", "The original disclosure of a low-privilege kernel-handle leak in eScan Antivirus' ProcObsrvesx.sys, whose device is accessible to every local user. It identifies the affected driver version, relates the flaw to the component's process-handle operations and local elevation, and records coordinated remediation by Microworld Technologies."],
    ["CVE-2024-31756: MarvinTest Hw64 Handle Leak", "https://northwave-cybersecurity.com/vulnerability-notice-hardware-access-driver-marvintest-solutions", "Northwave Research", "2024", 4, "CVE-2024-31756 MarvinTest Hw64 kernel handle leak Candiru driver", "Documents a low-privilege kernel-handle leak in MarvinTest's Hw64.sys hardware-access driver and explains how handles held by communicating processes can be repurposed for elevation. The notice preserves hashes, affected and fixed versions, disclosure dates, and the important lineage to a different Hw64.sys flaw previously exploited by Candiru."],
    ["CVE-2023-52271: Topaz Antifraud PPL Termination", "https://northwave-cybersecurity.com/vulnerability-notice-topaz-antifraud", "Northwave Research", "2024", 4, "CVE-2023-52271 Topaz wsftprm arbitrary kernel calls PPL Defender", "Analyzes Topaz Antifraud's world-accessible wsftprm.sys interface, whose IOCTL path lets an unprivileged caller invoke kernel functions useful for arbitrary process termination. Northwave built a working exploit that kills PPL-protected Microsoft Defender processes and records the affected version, patch, and coordinated disclosure timeline."],
    ["CVE-2025-8061: Lenovo LnvMSRIO Exploit", "https://github.com/spawn451/CVE-2025-8061-Exploit", "spawn451", "2025", 5, "CVE-2025-8061 Lenovo LnvMSRIO physical memory Superfetch VA PA LPE", "Implements the LnvMSRIO.sys physical-memory read and write IOCTLs and builds a Superfetch PFN-based virtual-to-physical translation layer around them. The Delphi proof of concept exposes request structures, driver lifecycle, kernel-memory verification, and the assumptions required to turn a hardware-facing primitive into useful Windows kernel access."],
    ["CVE-2024-30085: exploiting the Cloud Files minifilter", "https://starlabs.sg/blog/2024/12-all-i-want-for-christmas-is-a-cve-2024-30085-exploit/", "Cherie-Anne Lee / STAR Labs", "2024", 5, "CVE-2024-30085 cldflt reparse point paged pool WNF ALPC PipeAttribute", "Builds a complete Windows kernel LPE from a cldflt.sys reparse-data heap overflow. Two controlled triggers corrupt WNF state data for disclosure and writes, while ALPC handle tables and PipeAttribute objects convert the pool damage into arbitrary read/write before token privileges are modified and a SYSTEM process is opened."],
    ["CVE-2023-41444: irec.sys Driver Exploitation", "https://blog.dru1d.ninja/windows-driver-exploit-development-irec-sys-a5eb45093945", "Tyler Booth (dru1d)", "2023", 5, "CVE-2023-41444 irec.sys driver LSASS process handle IOCTL exploit", "Starts from a sparse LOLDrivers record, identifies the Binalyze forensic driver, recovers its device and twenty-two IOCTL paths in Ghidra, and exploits a ZwOpenProcess wrapper to obtain an LSASS-readable handle. The article exemplifies the discovery graph used by this catalog and includes a public proof of concept."],
    ["CVE-2023-38817: Echo Anti-Cheat Driver", "https://ioctl.fail/echo-ac-writeup/", "Whanos and kite03", "2023", 5, "CVE-2023-38817 echo anti cheat arbitrary kernel read write token theft", "Audits a commercial anti-cheat scanner whose unrestricted driver interface exposes kernel memory read and write operations, then turns those IOCTLs into EPROCESS token theft and SYSTEM execution. The writeup includes request formats, reverse-engineering evidence, exploit source, disclosure history, and the later certificate and blocklist response."],
    ["CVE-2022-3699: Lenovo Diagnostics Arbitrary R/W", "https://nephosec.com/cve-2022-3699-lenovo-diagnostics-driver-eop-arbitrary-r-w/", "NephoSec", "2022", 5, "CVE-2022-3699 Lenovo diagnostics driver arbitrary kernel read write", "Provides the long-form analysis behind the Lenovo Diagnostics driver flaw, recovering its accessible device, IOCTL contract, and arbitrary kernel read/write capability before demonstrating elevation. It complements the compact exploit repository with the reasoning needed to understand why the primitive exists and how its constraints are handled."],
    ["CVE-2020-17382: Weaponizing MSI Ambient Link", "https://www.matteomalvica.com/blog/2020/09/24/weaponizing-cve-2020-17382/", "Matteo Malvica (uf0)", "2020", 5, "CVE-2020-17382 MSI Ambient Link driver kernel exploitation token stealing", "Develops MSI Ambient Link's vulnerable driver from interface and IOCTL reversing through a working local privilege-escalation exploit. The article exposes the buffer contracts, kernel memory primitive, address and structure requirements, and final token manipulation, making it substantially more useful than the short advisory or a precompiled proof of concept."],
    ["Tower of Flaws: Anti-Cheat Driver Audit", "https://vespalec.com/blog/tower-of-flaws/", "Vespalec", "2025", 5, "Tower of Fantasy anti cheat driver vulnerabilities IOCTL CVE exploit", "Performs a broad audit of Tower of Fantasy's anti-cheat driver, mapping its exposed interface and multiple unsafe operations before building concrete demonstrations of impact. The long-form analysis, coordinated disclosure context, and accompanying source make it a strong example of systematically reviewing a large privileged attack surface rather than stopping at one dangerous import."],
    ["CVE-2021-21551: Dell dbutil Driver Flaws", "https://www.sentinelone.com/labs/cve-2021-21551-hundreds-of-millions-of-dell-computers-at-risk-due-to-multiple-bios-driver-privilege-escalation-flaws/", "Kasif Dekel / SentinelLabs", "2021", 5, "CVE-2021-21551 Dell dbutil driver arbitrary read write port IOCTL LPE", "The discoverer's analysis of five flaws in Dell's long-shipped firmware-update driver, including unrestricted device access, attacker-controlled memmove arguments, kernel arbitrary read/write, and privileged port I/O. It connects root cause to token-privilege modification, direct storage access, remediation, and the residual BYOVD risk of signed copies."],
    ["CVE-2018-7502: TwinCAT3 Kernel Drivers", "https://srcincite.io/advisories/src-2018-0007/", "Steven Seeley / Source Incite", "2018", 5, "CVE-2018-7502 Beckhoff TwinCAT3 untrusted pointer IOCTL kernel LPE", "The original advisory for an untrusted-pointer dereference shared by nineteen Beckhoff TwinCAT3 kernel drivers through IOCTL 0x222206. It identifies every affected module, states the low-privilege boundary, links the coordinated vendor fix, and preserves a public proof of concept that can be audited against the concise root-cause description."],
    ["CVE-2019-18845: Viper RGB Driver LPE", "https://www.activecyber.us/activelabs/viper-rgb-driver-local-privilege-escalation-cve-2019-18845", "Active Cyber", "2019", 4, "CVE-2019-18845 Viper RGB Patriot driver local privilege escalation", "Presents the original vulnerability research into the privileged Viper RGB software driver, following its exposed device interface and unsafe request handling to local elevation. The post is retained as a focused vendor-driver case study with disclosure context and technical reproduction rather than merely a CVE database record."],
    ["Gigabyte Driver Elevation-of-Privilege Vulnerabilities", "https://www.secureauth.com/labs/advisories/gigabyte-drivers-elevation-privilege-vulnerabilities", "SecureAuth Labs", "2018", 5, "Gigabyte gdrv driver IOCTL physical memory privilege escalation advisory", "The original coordinated research into Gigabyte utility drivers that exposed privileged kernel and hardware operations to local callers. It documents the affected components, vulnerable interface, security impact, and vendor response, providing the provenance needed to understand why gdrv-family binaries later became recurring BYOVD providers."],
    ["From Admin to Kernel: One Driver, Zero Attention", "https://dor00tkit.github.io/Dor00tkit/posts/from-admin-to-kernel-one-year-one-driver-zero-attention/", "Dor00tkit", "2026", 5, "vulnerable Windows driver reverse engineering kernel primitive BYOVD exploit", "Takes a neglected signed driver from identification through static and dynamic reverse engineering, IOCTL reconstruction, capability validation, and kernel-impact demonstration. The article earns inclusion by documenting the entire research process and practical constraints, not just publishing a hash or claiming that a dangerous function is reachable."],
    ["CVE-2020-0981: One Line Broke the Chrome Sandbox", "https://projectzero.google/2020/04/you-wont-believe-what-this-one-line.html", "James Forshaw / Project Zero", "2020", 5, "CVE-2020-0981 Windows restricted token Chrome sandbox escape job object", "Traces a one-line Windows kernel change that copied the wrong token parent identifier and broke Chromium's restricted-token assumptions, then constructs the remaining chain around accessible tokens, job limits, child-process policy, and console behavior. It is an exceptional case study in how individually modest platform behaviors compose into a complete browser sandbox escape."],
    ["CVE-2020-0668: Windows Service Tracing EoP", "https://itm4n.github.io/cve-2020-0668-windows-service-tracing-eop/", "itm4n", "2020", 5, "CVE-2020-0668 service tracing arbitrary file move oplock LPE", "Dissects a Windows Service Tracing bug that lets an unprivileged user influence privileged file operations, then develops the constraints needed to weaponize it for elevation. The article covers trace configuration, path behavior, reparse points and timing, target selection, and the gap between a vulnerability trigger and a practical SYSTEM chain."],
    ["CVE-2020-0787: BITS Undocumented RPC EoP", "https://itm4n.github.io/cve-2020-0787-windows-bits-eop/", "itm4n", "2020", 5, "CVE-2020-0787 BITS RPC arbitrary file move privilege escalation", "Recovers an undocumented BITS RPC function and shows how its privileged file operation can be controlled for local elevation. The analysis combines RPC interface reconstruction, parameter semantics, filesystem experimentation, and exploit design, providing a rare end-to-end example of finding and weaponizing a service RPC bug."],
    ["CVE-2020-0863: DiagTrack Arbitrary File Read", "https://itm4n.github.io/cve-2020-0863-windows-diagtrack-info-disclo/", "itm4n", "2020", 5, "CVE-2020-0863 DiagTrack service arbitrary file read RPC disclosure", "Analyzes an arbitrary file-read vulnerability in the Diagnostic Tracking service, mapping the privileged service interface and the data path that returns protected content to a low-privilege caller. It is a valuable confidentiality case study because it explains access context, RPC invocation, and how to demonstrate impact without overstating it as code execution."],
    ["CVE-2020-1170: Windows Defender EoP", "https://itm4n.github.io/cve-2020-1170-windows-defender-eop/", "itm4n", "2020", 5, "CVE-2020-1170 Windows Defender quarantine file operation LPE", "Reverse engineers a Windows Defender elevation flaw involving privileged handling of attacker-influenced files and develops a reproducible exploit chain. The post connects Defender's service workflow, filesystem permissions, timing, and payload placement, making the remediation and residual attack surface easier to evaluate."],
    ["CVE-2022-41099: BitLocker Bypass Analysis", "https://itm4n.github.io/cve-2022-41099-analysis-bitlocker-drive-encryption-bypass/", "itm4n", "2023", 5, "CVE-2022-41099 BitLocker bypass WinRE patch analysis", "Provides a patch-driven analysis of a BitLocker security-feature bypass affecting the Windows Recovery Environment. It reconstructs the vulnerable boot and recovery behavior, explains the trust assumption that failed, and evaluates Microsoft's fix, offering a strong example of analyzing a platform-security CVE outside the kernel memory-corruption model."],
    ["CVE-2025-59201: NCSI Elevation of Privilege", "https://itm4n.github.io/cve-2025-59201-ncsi-eop/", "itm4n", "2026", 5, "CVE-2025-59201 NCSI service network connectivity SYSTEM EoP", "A current Windows elevation case study centered on Network Connectivity Status Indicator behavior, developed from patch and component analysis into an explanation of the privileged action an attacker can influence. It documents the service boundary, trigger, exploitation constraints, and fix rather than repeating the MSRC summary."],
    ["CVE-2026-20817: Windows Error Reporting EoP", "https://itm4n.github.io/cve-2026-20817-wersvc-eop/", "itm4n", "2026", 5, "CVE-2026-20817 WerSvc ALPC command execution SYSTEM patch analysis", "Reverse engineers a removed Windows Error Reporting feature that accepted attacker-controlled state through ALPC and could lead to privileged command execution. The article tests the tempting initial explanation against implementation details, reconstructs the real permission failure, and uses the patch to bound affected behavior."],
    ["PrintNightmare Exploitation in 2024", "https://itm4n.github.io/printnightmare-exploitation/", "itm4n", "2024", 5, "PrintNightmare CVE-2021-1675 CVE-2021-34527 spooler exploitation patches", "A practical, build-aware guide to the PrintNightmare family that separates the related CVEs, explains Point and Print policy, driver installation paths, authentication and protocol choices, and demonstrates what remains exploitable after successive fixes. It is a much stronger reference than one-shot scripts written against the original vulnerable builds."],
    ["The PrintNightmare Is Not Over Yet", "https://itm4n.github.io/printnightmare-not-over/", "itm4n", "2024", 5, "PrintNightmare spooler driver installation bypass Windows patch", "Revisits Print Spooler exploitation after the major PrintNightmare mitigations and identifies remaining behavior that preserves security impact under specific configurations. The research is valuable for its precise version and policy reasoning, showing why a named vulnerability family cannot be considered closed solely from the first patch."],
    ["CVE-2020-17087: cng.sys Pool Overflow", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2020/CVE-2020-17087.html", "Mateusz Jurczyk / Project Zero", "2021", 5, "CVE-2020-17087 cng.sys integer truncation pool overflow named pipe", "A concise root-cause analysis of a 16-bit allocation-size truncation in a user-reachable cng.sys IOCTL that produced a large kernel pool overflow. It records the trigger boundary, Chrome sandbox-escape context, named-pipe arbitrary read/write strategy, patch information, variant ideas, structural hardening, and the unusual direct-driver interaction defenders can monitor."],
    ["CVE-2020-1027: CSRSS Heap Buffer Overflow", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2020/CVE-2020-1027.html", "Sergei Glazunov / Project Zero", "2021", 5, "CVE-2020-1027 CSRSS ALPC activation context heap overflow CFG ROP", "Documents a CSRSS side-by-side activation-context bug reachable through ALPC, including a complete trigger, the unchecked UNICODE_STRING capacity, controlled heap overflow, object corruption, write-what-where construction, fake loader-list code reuse, CFG transition, and ROP. The analysis also identifies the IPC audit and sandbox attack-surface reductions that could prevent variants."],
    ["CVE-2020-0986: splwow64 Pointer Dereference", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2020/CVE-2020-0986.html", "Maddie Stone / Project Zero", "2020", 5, "CVE-2020-0986 splwow64 LPC untrusted pointer arbitrary memcpy sandbox", "Analyzes an in-the-wild splwow64 flaw where attacker-controlled LPC message fields provide the arguments for a privileged memcpy. The RCA includes a minimized trigger, shared-buffer layout, relation to CVE-2019-0880, exploit-chain context, the incomplete pointer-to-offset patch, follow-on CVEs, and concrete variant and detection directions."],
    ["CVE-2020-0938: Windows Type 1 Font Corruption", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2020/CVE-2020-0938.html", "Mateusz Jurczyk / Project Zero", "2021", 5, "CVE-2020-0938 ATMFD Type1 font stack corruption BlendDesignPositions", "A detailed analysis of non-contiguous stack writes in the legacy Type 1 Multiple Masters BlendDesignPositions parser, complete with a minimal malicious font and cross-version context. It explains how the bug was chained on older Windows, why fontdrvhost and win32k lockdown reduced value on Windows 10, and where parser-differential and variant research should focus."],
    ["CVE-2020-1020: VToHOrigin Font Write", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2020/CVE-2020-1020.html", "Mateusz Jurczyk / Project Zero", "2021", 5, "CVE-2020-1020 Windows font driver Type1 VToHOrigin write primitive", "Covers the companion Windows Type 1 font vulnerability used with CVE-2020-0938 in an in-the-wild chain, separating its controlled write role from the stack-control bug. The RCA preserves trigger and exploit context while evaluating how legacy parser design, duplicated font engines, sandbox policy, and moving font parsing out of the kernel affect the attack surface."],
    ["CVE-2026-29923: pstrip64.sys LPE", "https://github.com/athenasec16/CVE-2026-29923", "AthenaSec", "2026", 5, "CVE-2026-29923 pstrip64 physical memory EPROCESS token LPE", "A full driver-to-SYSTEM case study for PowerStrip's pstrip64.sys: it reverses the IOCTL dispatcher, recovers physical-memory mapping, handles a 64-to-32-bit pointer truncation constraint, scans pool allocations with validation heuristics, accounts for different EPROCESS header layouts, replaces the token, and publishes the tested source and defensive guidance."],
    ["CVE-2025-61155: GameDriverX64 Process Termination", "https://github.com/pollotherunner/CVE-2025-61155", "pollotherunner", "2025", 5, "CVE-2025-61155 GameDriverX64 anticheat IOCTL process termination", "The discoverer's official advisory and C++ proof of concept for an anti-cheat driver that lets any local user terminate arbitrary processes through an exposed IOCTL. The repository includes disclosure material, target details, a demonstration, related threat research, and a direct bridge into the deeper Tower of Flaws analysis."],
    ["CVE-2023-20564: AMD Ryzen Master Physical Memory", "https://github.com/NtGabrielGomes/CVE-2023-20564", "NtGabrielGomes", "2023", 4, "CVE-2023-20564 AMD Ryzen Master physical memory read write", "A source proof of concept for AMD Ryzen Master's insufficiently validated physical-memory read and write IOCTLs. It records request structures, control codes, driver service lifecycle, read-write verification, expected output, affected component, and vendor references, providing a concrete starting point for studying how physical access becomes kernel compromise."],
    ["CVE-2022-42046: wfshbr64 DKOM LPE", "https://github.com/kkent030315/CVE-2022-42046", "kkent030315 and DoranekoSystems", "2022", 5, "CVE-2022-42046 wfshbr64 DKOM EPROCESS protection flags bypass", "A well-documented proof of concept for a signed driver that performs caller-controlled bitwise operations at arbitrary EPROCESS offsets. The repository shows manipulation of Protection and SignatureLevel, analyzes unsafe IRP handling, records the vendor's attempted validation, and demonstrates how byte-shifted operations bypassed that mitigation."],
    ["CVE-2022-3699: Lenovo Diagnostics Driver", "https://github.com/alfarom256/CVE-2022-3699", "Alvaro Munoz", "2022", 4, "CVE-2022-3699 Lenovo diagnostics driver arbitrary read write LPE", "A focused exploit repository for the Lenovo Diagnostics driver elevation-of-privilege vulnerability, exposing the arbitrary kernel read/write path and the code used to turn it into elevation. It is useful as a compact companion to vendor and CVE records because the actual request structures and exploit implementation are preserved."],
    ["CVE-2018-19320: Gigabyte gdrv.sys LPE", "https://github.com/hmnthabit/CVE-2018-19320-LPE", "hmnthabit", "2021", 4, "CVE-2018-19320 Gigabyte gdrv kernel memory write SYSTEM", "A working local privilege-escalation exploit for Gigabyte's gdrv.sys, which exposes low-level memory allocation and write capabilities to insufficiently privileged callers. The repository records affected vendor utilities, the tested Windows build, source, demonstration, and original SecureAuth advisory for cross-checking the vulnerability."],
    ["CVE-2026-36425: OPSWAT ardrv.sys", "https://github.com/redteamfortress/CVE-2026-36425", "Jehad Abudagga / Red Team Fortress", "2026", 5, "CVE-2026-36425 OPSWAT ardrv process termination registry file IO", "The coordinated advisory for an AppRemover driver whose world-accessible device exposes unauthenticated process termination through memory corruption, job objects, and ZwTerminateProcess. It also documents adjacent registry-write, port-I/O, and forced-file-deletion handlers, affected versions, disclosure timeline, and concrete blocklisting and monitoring recommendations."],
    ["PrintDemon: CVE-2020-1048 and More", "https://windows-internals.com/printdemon-cve-2020-1048/", "Alex Ionescu and Yarden Shafir", "2020", 5, "PrintDemon CVE-2020-1048 spooler LPE persistence arbitrary file write", "A comprehensive investigation of Print Spooler file-writing behavior that produced privilege escalation, persistence, and stealth techniques as well as follow-on fixes. It combines service internals, printer configuration, impersonation, filesystem effects, disclosure timeline, and patch analysis, making it a model multi-impact Windows case study."],
    ["Faxing Your Way to SYSTEM", "https://windows-internals.com/faxing-your-way-to-system/", "Alex Ionescu and Yarden Shafir", "2020", 5, "Windows Fax service SYSTEM privilege escalation DLL loading", "Analyzes a Windows Fax service attack path from service configuration and RPC-accessible behavior through controlled file placement and privileged code loading. The post's strength is its complete treatment of prerequisites, service lifecycle, and remediation, showing how a legacy Windows component can expose a modern local escalation chain without kernel memory corruption."],
    ["CVE-2019-1458: Win32k uninitialized variable", "https://googleprojectzero.blogspot.com/p/rca-cve-2019-1458.html", "Maddie Stone / Project Zero", "2020", 5, "CVE-2019-1458 win32k uninitialized variable bitmap KASLR arbitrary write", "A structured root-cause analysis of an in-the-wild Win32k flaw that records the vulnerable state transition, limited write primitive, public proof of concept, exploit strategy, applicable mitigations, and promising variant-analysis directions. Its explicit separation of root cause, exploitation, structural improvements, and detection makes it an excellent template for studying any Windows zero-day."],
    ["The Windows Registry Adventure: an attack surface review", "https://googleprojectzero.blogspot.com/2024/04/the-windows-registry-adventure-1-registry.html", "Mateusz Jurczyk / Project Zero", "2024", 5, "Windows kernel registry hive fuzzing memory corruption attack surface CVE", "The opening installment of a deep audit of the Windows registry implementation, built from public symbols, reverse engineering, coverage-guided kernel fuzzing, and more than twenty reported issues. It maps the duplicated parser and hive code across boot, kernel, offline, and user-mode components before later exploitation work, giving researchers a rigorous way to bound a complex attack surface."],
    ["CVE-2025-8061: exploiting a Lenovo driver", "https://blog.quarkslab.com/exploiting-lenovo-driver-cve-2025-8061.html", "Quarkslab", "2025", 5, "Lenovo driver LPE reverse engineering CVE-2025-8061", "Follows a vulnerable Lenovo driver from interface reverse engineering through primitive discovery to a working local privilege-escalation chain. The end-to-end methodology makes it useful well beyond this single CVE."],
    ["eneio64.sys physical-memory R/W", "https://xacone.github.io/eneio-driver.html", "xacone", "2025", 5, "CVE-2020-12446 BYOVD HVCI physical memory", "Starts from exposed physical-memory access in eneio64.sys and builds the translation machinery required for useful virtual kernel reads and writes. It also covers HVCI and driver-blocklist constraints that simplified BYOVD writeups often omit."],
    ["AOMEI amwrtdrv raw-disk LPE", "https://afflicted.sh/blog/posts/amwrtdrv-aomei-lpe.html", "afflicted.sh", "2026", 5, "raw disk GPT FAT12 UEFI pre-kernel LPE", "Turns ordinary-user raw-disk access into a pre-kernel execution chain by planting a FAT12 image and redirecting a GPT entry. The post is exceptional for showing how a seemingly narrow driver permission error crosses storage, firmware, and boot trust boundaries."],
    ["SignalRGB: standard user to SYSTEM", "https://afflicted.sh/blog/posts/signalrgb-service-lpe.html", "afflicted.sh", "2026", 4, "service ACL writable binary LocalSystem LPE", "Analyzes a LocalSystem auto-start service whose executable resides in a user-writable directory. It also explains practical replacement and restart constraints, turning a familiar service-permission bug into a complete operational case study."],
    ["SAS CTF Windows 7 challenge explained", "https://securelist.com/sas-ctf-windows-7-challenge-explained/114180/", "Kaspersky Securelist", "2024", 4, "kernel shellcode persistence APT Windows 7 CTF", "Connects a Windows 7 CTF challenge to a kernel-shellcode persistence technique observed in APT activity. The article is valuable for seeing how a real threat technique can be distilled into a reverse-engineering and exploitation exercise."],
    ["CVE-2026-21222: information disclosure", "https://windowsforum.com/threads/cve-2026-21222-windows-kernel-information-disclosure-risk-and-mitigation.400816/", "WindowsForum", "2026", 2, "Windows kernel information disclosure mitigation", "A secondary overview of the reported Windows kernel information-disclosure issue and basic mitigation guidance. Use it as a lead rather than an authoritative technical reference, then confirm details in Microsoft advisories and original research when available."],
    ["CVE-2024-26170: CimFS from crash discovery to SYSTEM", "https://starlabs.sg/blog/2025/03-cimfs-crashing-in-memory-finding-system-kernel-edition/", "Chen Le Qi / STAR Labs", "2025", 5, "CVE-2024-26170 cimfs filesystem fuzzing OOB read Windows kernel LPE", "Documents the complete research lifecycle for a previously unexplored Windows 11 filesystem driver: bypassing the control-device path check, reconstructing the CIM mount format, building a mutation fuzzer, grouping seven crash classes, and exploiting an out-of-bounds read reached through a hard-link alternate data stream. It is unusually strong because discovery engineering and final SYSTEM exploitation receive equal depth."],
    ["CVE-2023-36802 under modern exploitation constraints", "https://starlabs.sg/blog/2026/06-old-bug-harder-rules-exploiting-cve-2023-36802-without-the-usual-shortcuts/", "Nguyễn Đức Hiếu / STAR Labs", "2026", 5, "CVE-2023-36802 mskssrv type confusion kernel pool arbitrary decrement read write", "Rebuilds exploitation of the mskssrv.sys rendezvous-object type confusion without NtQuery-based kernel pointer disclosures or KTHREAD PreviousMode abuse. Patch diffing and trigger reconstruction lead into leak, DWORD write, and arbitrary-decrement primitives, followed by pool-list corruption, arbitrary read/write, EPROCESS discovery, and SYSTEM on the constrained target."],
    ["CVE-2022-24547: CastSrv cross-session elevation", "https://starlabs.sg/blog/2024/12-behind-the-scenes-understanding-cve-2022-24547/", "Đào Tuấn Linh / STAR Labs", "2024", 4, "CVE-2022-24547 CastSrv COM session moniker symbolic link DACL LPE", "Explains how the interactive-user CastServer COM class can be activated in another logged-on user's session and induced to create a permissive PlayToReceiver directory without defending against symbolic-link redirection. The reproduction maps CLSID, interface methods, session-moniker activation, folder creation, DACL behavior, exploit conditions, and detection guidance."],
    ["CVE-2024-26230: Windows Telephony Service UAF", "https://starlabs.sg/blog/2025/01-cve-2024-26230-windows-telephony-service-its-got-some-call-ing-issues-elevation-of-privilege/", "Đào Tuấn Linh / STAR Labs", "2025", 5, "CVE-2024-26230 TapiSrv RPC use after free GOLD object heap LPE", "Reverse engineers a TapiSrv RPC lifetime bug in which FreeDialogInstance releases a GOLD object while a context handle retains the dangling pointer, and TUISPIDLLCallBack later invokes its virtual function. The article develops same-process heap replacement primitives, service triggering, exploit reproduction, and the final Network Service-to-SYSTEM path while separating a related priority-list bug."],
    ["CVE-2025-54098: Hyper-V vhdmp.sys arbitrary file write", "https://starlabs.sg/advisories/25/25-54098/", "Chen Le Qi / STAR Labs", "2025", 5, "CVE-2025-54098 Hyper-V vhdmp arbitrary file write OBJ_FORCE_ACCESS_CHECK LPE", "Analyzes a Hyper-V virtual-disk kernel path that opens an attacker-selected file through a Zw routine without OBJ_FORCE_ACCESS_CHECK, so the operation bypasses the caller token's normal filesystem authorization. The advisory preserves the affected component, privileged write behavior, root access-check mistake, elevation impact, patch timeline, and enough kernel semantics to recognize the same bug pattern elsewhere."],
    ["CVE-2024-55414: Motorola SmSerl64 Driver", "https://github.com/heyheysky/vulnerable-driver/blob/master/CVE-2024-55414/CVE-2024-55414_SmSerl64.sys_README.md", "heyheysky", "2024", 5, "CVE-2024-55414 SmSerl64 Motorola modem physical memory IO port kernel LPE", "Provides an unusually extensive reverse engineering of Motorola's signed SM56 modem driver, reconstructing a large IOCTL dispatcher and the caller-access failures around physical-memory mapping and port operations. The 797-line disclosure preserves decompiled paths, request layouts, proof-of-concept clients, affected version data, and the routes from low privilege to information disclosure, arbitrary privileged operations, and SYSTEM."],
    ["CVE-2023-1453: WatchDog Antivirus Arbitrary File Delete", "https://github.com/zeze-zeze/WindowsKernelVuln/tree/master/CVE-2023-1453", "zeze-zeze", "2023", 4, "CVE-2023-1453 WatchDog Antivirus wsdk driver arbitrary file delete IOCTL", "Shows that WatchDog Antivirus 1.4.214.0 exposes wsdk-driver.sys IOCTL 0x80002008 to ordinary users without access control, allowing forced deletion of an attacker-selected file. The repository includes the C++ client, vulnerable package, reproducible setup, and expected cmd.exe deletion, making the privileged file-operation sink directly reviewable even though it stops short of a full SYSTEM chain."],
    ["CVE-2026-0828: Safetica ProcessMonitorDriver", "https://kb.cert.org/vuls/id/818729", "CERT/CC and KOSEC", "2026", 4, "CVE-2026-0828 Safetica ProcessMonitorDriver IOCTL unprivileged process termination EDR", "The coordinated CERT/CC note confirms that Safetica endpoint client versions 10.5.75.0 and 11.11.4.0 expose a kernel IOCTL path that lets an unprivileged caller terminate arbitrary protected system processes. It records the affected driver, disclosure status, unavailable vendor fix, and concrete monitoring plus WDAC/AppLocker mitigations, providing authoritative context for the associated KOSEC proof-of-concept family."],
    ["CVE-2015-2291: Intel Diagnostic Driver Kernel Overwrite", "https://github.com/Tare05/Intel-CVE-2015-2291", "Tare05", "2020", 4, "CVE-2015-2291 iqvw64e Intel diagnostic driver physical memory token SYSTEM", "Implements a data-only SYSTEM exploit against Intel's signed Ethernet diagnostic driver and exposes the lower-level helpers behind it: physical-memory mapping, physical-to-virtual translation, and composition into arbitrary kernel memory overwrite. The repository is concise, but the source makes a historically important iqvw64e primitive auditable and provides a useful comparison point for kdmapper and later ransomware abuse."],
    ["CVE-2022-37415: Uniwill SparkIO.sys Overflow", "https://gist.github.com/alfarom256/220cb75816ca2b5556e7fc8d8d2803a0", "alfarom256", "2022", 4, "CVE-2022-37415 SparkIO Uniwill stack overflow physical memory port IOCTL", "Maps three dangerous SparkIO.sys interfaces: physical-memory reads through 0x40002004, arbitrary port I/O through 0x40002000, and a handle-close plus stack-overflow path through 0x40002008. The C++ proof of concept reconstructs the overflow buffer, controls the saved return address, and triggers the vulnerable device directly, giving the short CVE record a concrete driver contract for further exploit work."],
    ["CVE-2024-38213: Copy2Pwn Mark-of-the-Web Bypass", "https://www.thezdi.com/blog/2024/8/14/cve-2024-38213-copy2pwn-exploit-evades-windows-web-protections", "Peter Girnus / Zero Day Initiative", "2024", 5, "CVE-2024-38213 Copy2Pwn WebDAV Mark of the Web SmartScreen DarkGate", "Connects threat hunting against DarkGate to discovery of a Windows trust-boundary failure: files copied from a WebDAV-backed Explorer view could land locally without a Zone.Identifier stream. The analysis reconstructs the browser-to-Explorer search flow, contrasts browser and UNC handling, demonstrates how crafted visible names and icons support execution, explains which SmartScreen and Office Protected View decisions depend on MotW, and records the June fix rather than treating the issue as a generic social-engineering trick."],
    ["CVE-2024-20697: Windows Libarchive RARVM Overflow", "https://www.thezdi.com/blog/2024/4/17/cve-2024-20697-windows-libarchive-remote-code-execution-vulnerability", "Trend Micro Research / Zero Day Initiative", "2024", 5, "CVE-2024-20697 Windows libarchive RAR RARVM E8 filter integer overflow heap RCE", "Performs a format-level root-cause analysis of the libarchive code shipped in Windows, where a crafted RARVM Intel E8 filter block length overflows the allocation arithmetic before decompression writes attacker-controlled data. The report documents the relevant RAR block and VM structures, follows parsing and size propagation to the vulnerable copy, states the application-context execution boundary, and provides detection-oriented packet and file constraints useful for reproducing the bug independently."],
    ["CVE-2022-26937: Windows NFS NLM Portmap Overflow", "https://www.thezdi.com/blog/2022/6/7/cve-2022-26937-microsoft-windows-network-file-system-nlm-portmap-stack-buffer-overflow", "Trend Micro Research / Zero Day Initiative", "2022", 5, "CVE-2022-26937 Windows NFS NLM ONC RPC Portmap stack overflow SYSTEM RCE", "Reconstructs a remotely reachable stack overflow in the Windows Network File System client's Network Lock Manager, beginning with ONC RPC and Portmap message formats and following a malicious response into fixed-size stack storage. The analysis identifies the vulnerable decoding path, attacker-controlled length relationship, service and SYSTEM execution context, affected network role, and protocol-level trigger, giving substantially more root-cause evidence than the terse Microsoft bulletin."],
    ["CVE-2021-1732: Win32k Window-State Desynchronization", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2021/CVE-2021-1732.html", "Quan Jin / Project Zero RCA", "2021", 5, "CVE-2021-1732 win32k xxxCreateWindowEx KernelCallbackTable tagWND spmenu token zero day", "Explains an in-the-wild Win32k exploit in which a user-mode callback changes a tagWND field from pointer semantics to offset semantics, after which the kernel overwrites the value without restoring the matching flag. The RCA follows HMValidateHandle disclosure, cbWndExtra out-of-bounds access, fake spmenu read, paired-window write, kernel-address recovery, EPROCESS traversal, and token replacement, then identifies callback-state auditing and behavioral detection opportunities for variants."],
    ["CVE-2022-41033: COM+ Event System Type Confusion", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2022/CVE-2022-41033.html", "James Forshaw / Project Zero", "2022", 5, "CVE-2022-41033 COM+ Event System service type confusion registry persistence SYSTEM exploit", "Dissects an in-the-wild Windows service elevation caused by COM+ Event System objects being reconstructed under an incompatible class assumption. The analysis maps the attacker-controlled persistent state, privileged service activation, object layout mismatch and resulting memory effects, then separates the observed exploit route from root cause, patch behavior, variant surfaces, and structural improvements, making it a rigorous service-side counterpart to kernel memory-corruption case studies."],
    ["CVE-2021-26892: EFI System Partition Authorization Bypass", "https://www.thezdi.com/blog/2021/6/30/cve-2021-26892-an-authorization-bypass-on-the-microsoft-windows-efi-system-partition", "Simon Zuckerbraun / Zero Day Initiative", "2021", 5, "CVE-2021-26892 Windows EFI system partition UEFI CreateFile authorization bypass boot denial", "Explains how a low-integrity caller could combine a zero-access CreateFile request with CREATE_ALWAYS to truncate protected files on the EFI System Partition despite lacking write permission. The original analysis separates handle access from create-disposition side effects, documents bare-metal and hypervisor reproduction differences, and shows how a deceptively small authorization mismatch can cross the operating-system boundary and destroy bootability."],
    ["CVE-2021-26900: DirectComposition Use-After-Free Patch Bypass", "https://www.thezdi.com/blog/2021/5/3/cve-2021-26900-privilege-escalation-via-a-use-after-free-vulnerability-in-win32k", "Zero Day Initiative", "2021", 5, "CVE-2021-26900 CVE-2020-1381 DirectComposition win32k use after free patch bypass DWM", "Reconstructs a DirectComposition lifetime error across interaction-tracker and binding-manager marshalers, where inconsistent ownership leaves a freed resource reachable during command serialization. The writeup first models the original CVE-2020-1381 object graph, then demonstrates how CVE-2021-26900 bypassed its narrow binding check, providing an unusually clear study of incomplete patches, dangling cross-references, and variant analysis in win32k."],
    ["CVE-2021-27077: Mismatched GDI Device Contexts", "https://www.thezdi.com/blog/2021/7/26/cve-2021-27077-selecting-bitmaps-into-mismatched-device-contexts", "Marcin Wiązowski / Zero Day Initiative", "2021", 5, "CVE-2021-27077 win32k GDI bitmap printer device context dhpdev arbitrary kernel write LPE", "Builds a Windows kernel elevation from a bitmap whose printer-controlled dhpdev state is later consumed by a display device context under incompatible assumptions. The researcher reconstructs undocumented GDI and user-mode printer-driver thunks, intercepts and modifies callback traffic, engineers a kernel overwrite and token-privilege target, analyzes reliability, and explains Microsoft's new surface-compatibility check plus its opt-out policy key."],
    ["CVE-2021-31969: Cloud Files Integer Underflow", "https://www.thezdi.com/blog/2021/7/19/cve-2021-31969-underflowing-in-the-clouds", "Hossein Lotfi / Zero Day Initiative", "2021", 5, "CVE-2021-31969 cldflt Cloud Files reparse point integer underflow kernel buffer overflow LPE", "Traces an attacker-modified Cloud Files placeholder reparse record through cldflt.sys until a small decompression length is reduced below zero and becomes an enormous unsigned destination size. The analysis supplies the sync-root and FSCTL trigger sequence, follows the vulnerable HsmFlt processing path, identifies the exact allocation-versus-offset mismatch, and patch-diffs Microsoft's minimum-length validation."],
    ["CVE-2019-1184: Core Shell COM Registrar Sandbox Escape", "https://www.thezdi.com/blog/2019/12/19/privilege-escalation-via-the-core-shell-com-registrar-object", "Simon Zuckerbraun / Zero Day Initiative", "2019", 5, "CVE-2019-1184 CoreShellCOMServerRegistrar COM low integrity sandbox escape privilege escalation", "Analyzes an elegant Windows 10 sandbox escape centered on the CoreShellCOMServerRegistrar class, whose COM activation and exposed registration behavior could be reached from a low-integrity process and abused to execute at medium integrity. The post maps the CLSID and AppID configuration, trust-boundary mistake and practical elevation path, making it a compact but valuable case study in auditing privileged COM brokers rather than memory corruption."],
    ["CVE-2021-1647: Windows Defender ASProtect Overflow", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2021/CVE-2021-1647.html", "Maddie Stone / Google Project Zero", "2021", 5, "CVE-2021-1647 Windows Defender mpengine ASProtect heap buffer overflow remote code execution in the wild", "Reconstructs an in-the-wild Windows Defender engine vulnerability reached while unpacking an ASProtect section table, where non-monotonic virtual addresses drive an under-sized allocation and heap overflow inside automatic scanning. The RCA compares engine versions, isolates the added ordering validation, studies the exploit sample and delivery conditions, and evaluates both variant-analysis opportunities and the unusually exposed no-click attack surface of antimalware parsers."],
    ["CVE-2022-21882: Win32k Window Type Confusion", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2022/CVE-2022-21882.html", "RyeLv / Google Project Zero", "2022", 5, "CVE-2022-21882 win32k tagWND type confusion KernelCallbackTable NtUserConsoleControl kernel LPE", "Analyzes a win32k type confusion that synchronizes a client callback with NtUserConsoleControl to change a tagWND object's interpretation while window creation is incomplete. The RCA records affected callback paths, flag and extra-byte state, the in-the-wild exploit sequence, memory-disclosure and corruption primitives, and its close relationship to CVE-2021-1732, making the incomplete earlier fix and variant lineage explicit."],
    ["CVE-2022-41073: Activation-Context Cache Poisoning", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2022/CVE-2022-41073.html", "Maddie Stone and James Forshaw / Google Project Zero", "2022", 5, "CVE-2022-41073 Windows activation context CSRSS device map impersonation DLL hijack in the wild LPE", "Explains how an attacker-controlled DOS device map can redirect the privileged activation-context generator toward a writable side-by-side manifest, after which CSRSS caches and reuses the poisoned result across a trust boundary. The analysis follows the observed exploit through impersonation, manifest generation and DLL loading, relates it to earlier device-map and activation-context bugs, and distinguishes the immediate patch from the deeper cross-process cache-identity problem."],
    ["CVE-2023-28252: CLFS Metadata Corruption Zero-Day", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2023/CVE-2023-28252.html", "Genwei Jiang / Google Project Zero", "2023", 5, "CVE-2023-28252 Windows CLFS BLF metadata corruption kernel LPE in the wild exploit RCA", "Studies the exploit sample for an actively used Common Log File System elevation and maps malformed BLF metadata through CClfsBaseFile parsing into controlled kernel corruption. Patch comparison identifies new validation in control-record and metadata-block handling, while exploitation notes cover heap shaping, kernel address recovery and privilege escalation; comparison with CVE-2023-23376 also shows why the case is strong evidence of operational variant analysis."],
    ["CVE-2023-36033: DWM Arbitrary Object Dereference", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2023/CVE-2023-36033.html", "Genwei Jiang / Google Project Zero", "2023", 5, "CVE-2023-36033 Windows DWM core CKeyframeAnimation arbitrary object dereference shellcode in the wild LPE", "Reverse engineers an in-the-wild DirectComposition exploit that reaches CKeyframeAnimation::SampleStartingValue with attacker-controlled object state inside dwm.exe. The RCA follows its heap disclosure, forged object and reflective payload stages, explains the Window Manager privilege gained and subsequent execution behavior, patch-diffs the corrected dereference, and identifies a nearby structurally identical variant rather than treating the serviced function as the entire bug class."],
    ["CVE-2022-24521: CLFS Container-Context Corruption", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2022/CVE-2022-24521.html", "Sergey Kornienko / PixiePoint Security", "2022", 5, "CVE-2022-24521 Windows CLFS logical error container context signature overlap indirect call RIP control", "Reconstructs an in-the-wild Common Log File System exploit without a public sample by following how sector signature encoding overlaps mutable container and client contexts. A crafted base log restores an attacker-selected pContainer after decoding, deliberately fails AcquireContainerContext, and feeds controlled state into an indirect call; the RCA patch-diffs LoadContainerQ's new overlap and node validation and explains why the multi-condition layout suggests targeted auditing rather than an ordinary random crash."],
    ["CVE-2023-36802: In-the-Wild mskssrv Exploit RCA", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2023/CVE-2023-36802.html", "Benoît Sevens / Google Project Zero", "2023", 5, "CVE-2023-36802 mskssrv type confusion in the wild PreviousMode CLFS pool exploit variant analysis", "Analyzes the actual in-the-wild exploitation of mskssrv's FsContextReg-versus-FsStreamReg confusion and compares two build-dependent chains. The newer path turns an out-of-bounds ObfDereferenceObject into a PreviousMode primitive while containing the later KeSetEvent; the older path corrupts CLFS state and supplies a fake vtable, with the RCA documenting grooming, cleanup, patch changes and differences from the independently developed I/O Ring exploit."],
    ["CVE-2024-43639: Windows KDC Proxy Remote Code Execution", "https://www.thezdi.com/blog/2025/3/3/cve-2024-43639", "Simon Humbert and Guy Lederfein / Trend Micro ZDI", "2025", 5, "CVE-2024-43639 Windows KDC Proxy Kerberos ASN.1 integer overflow heap buffer overflow unauthenticated RCE", "Reverse engineers the HTTPS-to-Kerberos KDC Proxy path from DER request parsing and domain-controller discovery through asynchronous TCP response handling. A malicious KDC supplies a near-4-GiB length that bypasses the shallow Kerberos tag check and overflows 32-bit size arithmetic in Microsoft's ASN.1 encoder, preventing reallocation before memcpy corrupts the heap; the report traces both overflow ranges, reachability requirements, patch placement and network detection conditions for the unauthenticated service-context RCE."],
    ["CVE-2025-50170: Cloud Files Arbitrary File Corruption", "https://www.starlabs.sg/advisories/25/25-50170/", "Chen Le Qi / STAR Labs", "2025", 5, "CVE-2025-50170 cldflt Cloud Files minifilter mapped view boundary arbitrary file write SYSTEM", "Finds a boundary-validation mismatch in cldflt where checks cover attacker-writable bytes immediately before a mapped victim view but a later kernel write lands inside the read-only file mapping. By placing a 64-KiB controlled region adjacent to the target and passing victimView minus 0x40, the PoC corrupts protected files and shared image pages, demonstrating both disk-backed SYSTEM escalation and memory-only impact while documenting affected builds and the exact pointer arithmetic behind the primitive."],
    ["CVE-2025-55336: Cloud Files EPROCESS Disclosure", "https://www.starlabs.sg/advisories/25/25-55336/", "Chen Le Qi / STAR Labs", "2025", 4, "CVE-2025-55336 cldflt Windows Cloud Files minifilter EPROCESS kernel address information disclosure side channel", "Documents a focused but valuable information-disclosure primitive in the Cloud Files minifilter across Windows 10, 11 and Server releases. An unprivileged caller reaches a side channel that reveals the current process's EPROCESS address, removing a kernel-randomization prerequisite that modern exploit chains otherwise must solve; the advisory supplies affected-build coverage, trigger conditions, proof-of-concept evidence and remediation data, making the leak useful to assess alongside cldflt's memory-corruption bugs."],
    ["CVE-2025-49660: ETW Reference-Count Overflow", "https://starlabs.sg/advisories/25/25-49660/", "Chen Le Qi / STAR Labs", "2025", 5, "CVE-2025-49660 Windows ETW provider traits reference count integer overflow use after free LPE", "Shows how unprivileged NtTraceControl operations can repeatedly attach a shared provider-traits entry until its 32-bit reference count wraps, after which closing registration handles removes and frees an object that remains referenced. The advisory quantifies the otherwise unusual exploitation cost—nearly sixteen million handles per process, roughly 256 processes, substantial memory, and under thirty minutes—then confirms the resulting double-free and use-after-free primitive in WinDbg and relates it to an earlier Project Zero report."],
    ["CVE-2025-47985: Mutable ETW Flag Extensions", "https://starlabs.sg/advisories/25/25-47985/", "Chen Le Qi / STAR Labs", "2025", 5, "CVE-2025-47985 Windows ETW WMI_LOGGER_INFORMATION flag extension offset out of bounds read LPE", "Reverse engineers how StartTraceW packages WMI_LOGGER_INFORMATION for NtTraceControl and why EtwpValidateFlagExtension's initial bounds check is insufficient: the extension offset may overlap output fields that ETW later mutates. Subsequent EtwpGetFlagExtension callers trust the stale validation and reinterpret changed logger state as extension headers and items, giving an attacker out-of-bounds kernel reads through paths such as EtwpUpdatePerProcessTracing; the writeup identifies the structures, offsets, cross-references, and update route needed to reproduce the flaw."],
    ["CVE-2024-43626: Telephony Service Heap Corruption", "https://starlabs.sg/advisories/24/24-43626/", "Chen Le Qi and Nguyễn Đăng Nguyễn / STAR Labs", "2024", 5, "CVE-2024-43626 Windows Telephony Service tapisrv heap out of bounds read write registry SYSTEM LPE", "Traces a user-controlled RequestMakeCall registry string into tapisrv.dll, where RegQueryValueExW does not guarantee termination before _wcsupr and lstrlenW scan beyond the allocated heap chunk. A non-ASCII prefix suppresses mutation during the disclosure phase so adjacent svchost heap pointers can be copied back into a readable registry value; controlled heap adjacency then turns uppercase conversion into corruption of a neighboring size or pointer field. The advisory maps the default RPC surface, SYSTEM boundary, affected releases, and RegGetValueW-based remediation."],
    ["CVE-2022-21877: Storage Spaces Tier-Index Disclosure", "https://starlabs.sg/advisories/22/22-21877/", "Lê Hữu Quang Linh / STAR Labs", "2022", 4, "CVE-2022-21877 Windows spaceport Storage Spaces tier GUID index kernel information disclosure IOCTL", "Reconstructs the Storage Spaces control plane from SpaceAgent.exe and management APIs down to spaceport.sys IOCTL dispatch, then identifies an attacker-selected tier GUID index used without adequate bounds checking inside pool-extension logic. The report supplies the object and transaction sequence—obtain a pool, create a space and tier, then issue SpIoctlSetTierInfo—along with crash stacks, reversed structures, access checks, proof-of-concept code, and the important constraint that a regular user must already have rights to a configured storage pool."],
    ["CVE-2022-41128: In-the-Wild JScript9 Type Confusion", "https://googleprojectzero.github.io/0days-in-the-wild/0day-RCAs/2022/CVE-2022-41128.html", "Benoît Sevens and Clément Lecigne / Google TAG", "2022", 5, "CVE-2022-41128 JScript9 JIT type confusion Office APT37 arbitrary read write CFG bypass", "Dissects an APT37-delivered Office exploit in which JScript9's GlobOpt phase assumes a value remains an Int32Array after control flow replaces it with an ordinary object. The resulting typed write corrupts a neighboring array length, expands into relative and then arbitrary memory access through a DataView, resolves VirtualProtect from module tables, and constructs a fake string object and vtable that remain valid CFG targets. The RCA includes a minimized trigger, complete exploit progression, delivery prerequisites, prior-bug lineage, and the feature-gated optimizer change used to force safe validation."],
  ]},
  { id: "tools", kicker: "Keep beside the debugger", title: "Tools & Technical References", items: [
    ["qiomem Physical-Memory PoC", "https://github.com/valium007/qiomem", "Valium", "2026", 5, "qiomem.sys physical memory read write PnP driver exploit source", "The source artifact accompanying the Toshiba qiomem.sys analysis, including driver-interface discovery, software-device creation for PnP loading, packed IOCTL requests, and physical-memory access code. It allows the article's unusual loading and HVCI claims to be reviewed directly rather than inferred from screenshots."],
    ["Echo Anti-Cheat Driver PoC", "https://github.com/kite03/echoac-poc", "kite03", "2023", 5, "CVE-2023-38817 echo_driver arbitrary kernel read write exploit", "The public implementation for CVE-2023-38817, preserving the Echo driver's request structures, initialization call, kernel read/write wrappers, EPROCESS traversal, and token-copy escalation. It is the executable companion to the long-form disclosure and a compact lab target for auditing driver exploit assumptions."],
    ["TowerOfFlaws", "https://github.com/svespalec/TowerOfFlaws", "Vespalec", "2025", 5, "Tower of Fantasy anti cheat vulnerable driver exploit PoC source", "The code and research artifacts behind the Tower of Flaws anti-cheat driver audit, organized so individual vulnerable operations and proof-of-concept paths can be inspected alongside the article. The repository preserves implementation detail that would otherwise be lost in screenshots and supports repeatable lab validation."],
    ["KslDump", "https://github.com/andreisss/KslDump", "andreisss", "Living", 4, "BYOVD Kaspersky driver LSASS dump process memory kernel tool", "A focused vulnerable-driver-assisted utility for obtaining protected process memory through a Kaspersky driver path, with source that exposes the user-mode orchestration and device interaction. It is useful for comparing an operational credential-access tool with the underlying driver primitive and its required system state."],
    ["KslKatz", "https://github.com/vergamota/KslKatz", "vergamota", "Living", 4, "Kaspersky driver BYOVD LSASS PPL credential dumping source", "A source-level implementation that combines a Kaspersky driver capability with LSASS access and credential-extraction workflow. The repository belongs in the technical-reference table because it shows how device loading, IOCTL use, protection bypass, and post-access tooling are assembled, while requiring isolated lab handling."],
    ["Debugging Protected Processes", "https://itm4n.github.io/debugging-protected-processes/", "itm4n", "2022", 5, "WinDbg protected process PPL debugging kernel debugger methodology", "Shows how to investigate protected and protected-light processes when ordinary user-mode debugging is blocked, using kernel debugging and carefully selected process state. The workflow is broadly reusable for validating PPL research because it explains debugger context, breakpoints, symbols, and the limitations that can otherwise produce misleading observations."],
    ["A Deep Dive into TPM-Based BitLocker", "https://itm4n.github.io/tpm-based-bitlocker/", "itm4n", "2023", 5, "BitLocker TPM PCR protectors measured boot Windows internals", "Explains TPM-backed BitLocker from the key hierarchy and protectors through PCR-bound sealing, measured boot, recovery behavior, and the Windows components that orchestrate unlock. It supplies the architectural context needed to assess BitLocker bypass claims and separates cryptographic guarantees from configuration and recovery-path weaknesses."],
    ["Extracting PEAP Credentials from Wired Connections", "https://itm4n.github.io/peap-credentials-wired-connections/", "itm4n", "2024", 5, "PEAP 802.1X Windows wired credentials DPAPI registry extraction", "Investigates how Windows stores and retrieves credentials for wired PEAP and 802.1X profiles, tracing configuration artifacts, protected data, relevant services, and decryption context. The post is a useful forensic and credential-storage reference because it identifies the exact scope and prerequisites instead of implying that every enterprise network secret is directly recoverable."],
    ["Auditing Symantec ACC with PrivescCheck", "https://itm4n.github.io/checking-symantec-application-control-config-with-privesccheck/", "itm4n", "2025", 4, "Symantec Application Control PrivescCheck policy audit Windows", "Adds Symantec Application Control configuration checks to PrivescCheck and explains how the relevant policy state affects local privilege-escalation opportunities. The article connects collection code to the control's security meaning, making it useful both for extending a native assessment tool and for interpreting the resulting findings responsibly."],
    ["Offline Extraction of Symantec ACC Configuration", "https://itm4n.github.io/offline-extraction-symantec-application-control-config/", "itm4n", "2025", 4, "Symantec Application Control offline registry policy extraction forensics", "Develops an offline method for extracting Symantec Application Control configuration from Windows artifacts when the protected endpoint cannot be queried normally. It documents storage locations, parsing and decoding steps, and validation, providing a reproducible forensic companion to the live PrivescCheck assessment workflow."],
    ["BitLocker's Little Secrets: the Undocumented FVE API", "https://itm4n.github.io/bitlocker-little-secrets-the-undocumented-fve-api/", "itm4n", "2026", 5, "BitLocker FVE API undocumented RPC reverse engineering volume encryption", "Reverse engineers the undocumented Full Volume Encryption API used by Windows to manage BitLocker, recovering interfaces, data structures, and operational semantics from native components. It is a high-value reference for researchers building precise BitLocker experiments because it replaces fragile command-line automation with an understanding of the underlying management boundary."],
    ["POPKORN Artifact", "https://github.com/ucsb-seclab/popkorn-artifact", "UCSB SecLab", "2022", 5, "Windows driver symbolic execution angr vulnerability discovery dataset", "The reproducibility package for POPKORN: Popping Windows Kernel Drivers at Scale, containing the evaluated driver corpus, angr-based analysis, Docker environment, expected results, and scripts for single-target or bulk runs. It is a strong research reference because findings can be reproduced and the analysis can be applied to a new driver dataset."],
    ["Elastic Protections Artifacts", "https://github.com/elastic/protections-artifacts", "Elastic Security", "Living", 5, "Windows endpoint detection EQL YARA ransomware behavior rules", "Elastic's published endpoint protection logic, including behavior rules, YARA signatures, and ransomware artifacts generated from the same research behind its public threat reports. It is a useful primary defensive reference for testing whether a driver, loader, or evasion technique creates observable behavior covered by production-oriented rules."],
    ["VoidSec Exploit Development Archive", "https://github.com/VoidSec/Exploit-Development", "VoidSec", "Living", 5, "Windows exploits proof of concept drivers CVE exploit development", "A maintained archive of weaponized exploits and proof-of-concept code tied to VoidSec's vulnerability research. The repository complements the author's long-form driver methodology and case studies by preserving buildable artifacts that can be reviewed against the narrative and vendor fixes."],
    ["WindowsKernelVuln", "https://github.com/zeze-zeze/WindowsKernelVuln", "zeze-zeze", "Living", 4, "Windows kernel vulnerability exploitation examples drivers training", "A Windows kernel vulnerability research collection with code and notes spanning driver bugs and exploitation techniques. It is most useful as a lab corpus for comparing implementation patterns and locating original references; individual samples should still be matched to their target build and advisory before use."],
    ["Secure Kernel Research with LiveCloudKd", "https://windows-internals.com/secure-kernel-research-with-livecloudkd/", "Yarden Shafir", "2024", 5, "LiveCloudKd secure kernel VTL1 debugging memory acquisition", "A practical workflow for using LiveCloudKd to inspect the Secure Kernel and VTL1 state that ordinary kernel debugging cannot directly expose. It explains the acquisition model, symbol use, and analysis boundaries, making the article and tool valuable for validating VBS, KDP, and HyperGuard research against a live system."],
    ["An Exercise in Dynamic Analysis", "https://windows-internals.com/an-exercise-in-dynamic-analysis/", "Yarden Shafir", "2022", 5, "WinDbg dynamic analysis Windows kernel reverse engineering methodology", "A methodology-focused exercise in answering Windows internals questions through live debugging and controlled experiments. Rather than presenting a static conclusion, it demonstrates breakpoint selection, state inspection, hypothesis refinement, and verification, which makes it a reusable guide for researching undocumented kernel behavior safely."],
    ["Troubleshooting a System Crash", "https://windows-internals.com/troubleshooting-a-system-crash/", "Yarden Shafir", "2024", 4, "Windows crash dump WinDbg bugcheck root cause driver debugging", "Walks through a real Windows crash investigation using dump analysis, stack and object inspection, and progressive hypothesis testing. It belongs in the reference table because it teaches how to establish causality from debugger evidence instead of stopping at the blamed module name reported by automated crash tools."],
    ["I/O Rings: When One I/O Operation Is Not Enough", "https://windows-internals.com/i-o-rings-when-one-i-o-operation-is-not-enough/", "Yarden Shafir", "2021", 5, "Windows I/O rings internals asynchronous I/O API structures", "The original deep introduction to Windows I/O rings, reconstructing the user-mode API, submission and completion queues, registered resources, and kernel implementation. It is the conceptual reference needed before reading later exploitation primitives, because it explains the legitimate object lifecycle and invariants that corruption violates."],
    ["One Year to I/O Ring: What Changed?", "https://windows-internals.com/one-year-to-i-o-ring-what-changed/", "Yarden Shafir", "2022", 5, "Windows I/O rings version changes API kernel structures", "Compares the I/O ring implementation across a year of Windows releases, documenting API growth, structure changes, registration behavior, and security-relevant differences. The version-aware analysis prevents researchers from applying an early proof of concept blindly to newer builds and demonstrates how to maintain undocumented internals research over time."],
    ["IoRing vs io_uring", "https://windows-internals.com/ioring-vs-io_uring-a-comparison-of-windows-and-linux-implementations/", "Yarden Shafir", "2021", 4, "Windows IoRing Linux io_uring architecture comparison asynchronous I/O", "A careful architectural comparison of Windows I/O rings and Linux io_uring, covering queue ownership, registration, operation submission, completion, and kernel trust boundaries. The cross-platform framing clarifies which security assumptions are inherent to ring-based asynchronous I/O and which are specific implementation choices in Windows."],
    ["WinAFL", "https://github.com/googleprojectzero/winafl", "Google Project Zero", "Living", 5, "Windows coverage guided fuzzing DynamoRIO TinyInst persistent mode", "The established AFL-derived coverage-guided fuzzer for Windows binaries, with DynamoRIO and TinyInst instrumentation, persistent and in-app modes, crash minimization, and extensive real-world vulnerability credits. Its documentation and harness examples make it a primary starting point for reproducible user-mode fuzzing rather than a generic link collection."],
    ["Sandbox Attack Surface Analysis Tools", "https://github.com/googleprojectzero/sandbox-attacksurface-analysis-tools", "James Forshaw / Project Zero", "Living", 5, "Windows sandbox attack surface COM RPC named pipes object manager tokens", "A maintained suite for enumerating and analyzing Windows sandbox attack surface across object-manager namespaces, processes, tokens, services, RPC, COM, network endpoints, and accessible resources. The tools embody the methodology behind several Project Zero sandbox-escape investigations and are especially useful for comparing effective policy with the boundary a product claims to enforce."],
    ["TinyInst", "https://github.com/googleprojectzero/TinyInst", "Google Project Zero", "Living", 5, "dynamic instrumentation coverage Windows fuzzing debugger harness", "A lightweight dynamic instrumentation library used for coverage collection and fuzzing on Windows and other platforms, with debugger-based control and a deliberately smaller architecture than full binary-instrumentation frameworks. It is the relevant primary reference when WinAFL or Jackalope uses TinyInst-backed coverage and when a researcher needs to understand instrumentation behavior rather than treat it as a black box."],
    ["Jackalope", "https://github.com/googleprojectzero/Jackalope", "Ivan Fratric / Project Zero", "Living", 5, "binary coverage guided fuzzer Windows TinyInst mutators persistent", "A modern binary coverage-guided fuzzer designed around TinyInst, supporting Windows targets, custom mutators, persistent execution, corpus management, and distributed workflows. The repository includes the actual engine and operational documentation, making it a high-signal alternative for targets that do not fit source-based fuzzing or WinAFL's harness model."],
    ["PerfView and TraceEvent", "https://github.com/microsoft/perfview", "Microsoft", "Living", 5, "ETW TraceEvent ETL stacks kernel providers performance diagnostics", "Microsoft's open-source ETW collection and analysis stack, including the TraceEvent library used to create sessions, enable kernel and user providers, decode events, capture stacks, and process ETL data programmatically. It is a primary implementation reference for researchers who need to verify telemetry behavior rather than infer it from an EDR interface."],
    ["Awesome Windows CTF", "https://zaratec.io/awesome-windows-ctf/", "zaratec", "Living", 5, "Windows CTF pwn challenges writeups kernel heap usermode Hyper-V", "A Windows-specific CTF index that separates challenges by competition, target layer, and exploitation topic, with direct links to artifacts and writeups. It is now used as a discovery graph for this catalog; individual challenges are promoted only after their technical content is independently checked."],
    ["Windows Malware Analysis Training, Volume 1", "https://github.com/hasherezade/malware_training_vol1", "Hasherezade", "Living", 5, "malware analysis PE processes WoW64 shellcode loaders hooking exercises", "A freely licensed Windows malware-analysis curriculum with slides and hands-on exercises covering PE files, processes, WoW64, shellcode, loaders, injection, hooking, persistence, and evasion. It is unusually valuable because concepts are paired with code and analysis tasks rather than presented as a tool checklist."],
    ["Driver Buddy Reloaded", "https://github.com/VoidSec/DriverBuddyReloaded", "VoidSec", "Living", 5, "IDA plugin Windows driver IOCTL WDM WDF reverse engineering", "An IDA Pro plugin that labels WDM/WDF structures, finds dispatch routines and device names, decodes IOCTLs, identifies pool tags, and flags dangerous functions or opcodes. It accelerates triage without hiding the analysis steps, which makes it suitable for both learning and repeated driver audits."],
    ["vulnerable-drivers", "https://github.com/KeServiceDescriptorTable/vulnerable-drivers", "KeServiceDescriptorTable", "Living", 4, "vulnerable Windows drivers samples research corpus", "A broad driver corpus linked from many recent LOLDrivers records and intended for vulnerability research. Its value is coverage and sample availability; provenance and exploitability still need to be established from each driver's advisory, issue, or independent reversing work."],
    ["prefetch-tool", "https://github.com/exploits-forsale/prefetch-tool", "exploits.forsale", "2024", 5, "KASLR prefetch side channel assembly timing", "A focused proof of concept for resolving the Windows kernel base through prefetch timing. Read the assembly-level timing loop alongside the 24H2 exploit research to connect the side-channel theory with hardware-specific reliability limits."],
    ["Vergilius Project", "https://www.vergiliusproject.com/", "Vergilius", "Living", 5, "Windows kernel structures symbols offsets", "A searchable catalog of tens of thousands of undocumented Windows kernel structures across builds and architectures. It is invaluable for quickly comparing layouts, but build-specific offsets should still be validated against symbols and the target binary."],
    ["System Informer: ntexapi.h", "https://github.com/winsiderss/systeminformer/blob/master/phnt/include/ntexapi.h", "System Informer / phnt", "Living", 5, "NtQuerySystemInformation SYSTEM_INFORMATION_CLASS Native API", "The phnt declarations for Native system-information APIs and the SYSTEM_INFORMATION_CLASS family. Use it for accurate enum values and structure layouts missing from the public SDK, while remembering these interfaces can change between Windows builds."],
    ["System Informer: ntpsapi.h", "https://github.com/winsiderss/systeminformer/blob/master/phnt/include/ntpsapi.h", "System Informer / phnt", "Living", 5, "Native process thread APIs information classes", "The phnt process-and-thread header covering Native process, thread, job, and related information classes. It is the quickest source for checking structures expected by NtQueryInformationProcess and NtQueryInformationThread before confirming behavior in symbols or disassembly."],
    ["NtDoc: PROCESSINFOCLASS", "https://ntdoc.m417z.com/processinfoclass", "NtDoc", "Living", 5, "PROCESSINFOCLASS NtQueryInformationProcess documentation", "A browsable, cross-linked reference for process information classes used by NtQueryInformationProcess and NtSetInformationProcess. It summarizes buffer types, access requirements, and version notes, making it a convenient companion to phnt headers."],
    ["IoRingReadWritePrimitive", "https://github.com/yardenshafir/IoRingReadWritePrimitive", "Yarden Shafir", "2022", 5, "Windows 11 I/O rings kernel read write primitive", "Shows how a limited kernel write or increment can be transformed into a full read/write primitive through Windows I/O rings. The small implementation is an excellent post-exploitation reference for understanding the user/kernel objects and corruption required by the technique."],
    ["DrvEye", "https://github.com/0xDbgMan/DrvEye", "0xDbgMan", "2026", 4, "driver triage IOCTL symlink certificates BYOVD", "Automates static triage of Windows drivers by surfacing IOCTLs, symbolic links, certificates, imports, and other exploitation-relevant features. Its BYOVD-oriented workflow is useful for prioritization, but findings still require manual reverse engineering and validation."],
    ["Windows Kernel Exploits archive", "https://github.com/SecWiki/windows-kernel-exploits", "SecWiki", "Living", 4, "Windows kernel CVE privilege escalation exploit archive", "A large historical archive of public Windows kernel privilege-escalation exploits organized by vulnerability and platform. It is useful for comparative study and lab reproduction, though many samples target obsolete builds and should never be assumed safe or production-ready."],
    ["awesome-fuzzing", "https://github.com/secfigo/awesome-fuzzing", "secfigo", "Living", 4, "fuzzing root cause analysis exploit development resources", "A broad curated index covering fuzzers, papers, courses, root-cause analysis, and exploit development. Use it to choose a domain-specific starting point rather than reading linearly, and check linked projects for current maintenance status."],
    ["vss-fr2system", "https://github.com/sailay1996/vss-fr2system", "sailay1996", "2026", 3, "VSS file read SYSTEM Windows technique", "A compact research repository exploring a Windows VSS/file-read-to-SYSTEM path. The upstream description is intentionally sparse, so treat the code as a lab artifact to reverse engineer and validate rather than as documented guidance."],
    ["BokuLoader", "https://github.com/boku7/BokuLoader", "Bobby Cooke / boku7", "2021", 5, "Cobalt Strike UDRL reflective loader sleep mask direct syscall call stack spoofing", "A heavily documented Cobalt Strike User-Defined Reflective Loader that reconstructs Beacon mapping in C and assembly while integrating Malleable PE behavior, sleep masking, API hashing, syscall recovery, and later synthetic stack frames. Its versioned implementation and diagrams make it valuable for studying how loader responsibilities and evasion features interact rather than copying an isolated primitive."],
    ["AceLdr", "https://github.com/kyleavery/AceLdr", "Kyle Avery", "2022", 5, "Cobalt Strike UDRL return address spoofing sleep obfuscation memory scanner evasion", "An influential Cobalt Strike reflective loader that combines custom PE mapping with return-address spoofing, section permission control, header obfuscation, and sleep-time memory protection. The repository exposes the loader, Aggressor integration, and design constraints that later stack-spoofing projects build upon, making it a useful implementation benchmark for both operators and defenders."],
    ["SilentMoonwalk", "https://github.com/klezVirus/SilentMoonwalk", "Alessandro Magnosi, Arash Parsa, Athanasios Tserpelis", "2022", 5, "Windows x64 dynamic call stack spoofing unwind metadata ROP desynchronization", "Implements dynamic Windows x64 call-stack spoofing by parsing runtime-function and unwind metadata, selecting suitable frames and gadgets, and desynchronizing the visible unwind path from actual control flow. Read it with the authors' technical article: the code demonstrates both synthetic and desync approaches while documenting limitations that matter when adapting the proof of concept."],
    ["VulcanRaven CallStackSpoofer", "https://github.com/WithSecureLabs/CallStackSpoofer", "WithSecure Labs", "2022", 5, "VulcanRaven Windows syscall call stack spoofing synthetic frames Sysmon", "Creates an arbitrary plausible Windows call stack around sensitive calls by profiling legitimate frames, manipulating a worker thread's context, and issuing native operations through a controlled trampoline. The proof of concept includes Sysmon-oriented demonstrations and makes the difference between hiding a sleeping thread and spoofing the active origin of a security-relevant syscall concrete."],
    ["CallStackMasker", "https://github.com/Cobalt-Strike/CallStackMasker", "Cobalt Strike", "2022", 4, "Windows call stack masking timers sleep beacon thread context", "A focused proof of concept for masking a sleeping implant's call stack by coordinating timers, thread contexts, and stack restoration around a sleep interval. It is narrower than active stack spoofers, but its small codebase and explicit lifecycle make passive stack concealment easy to trace and provide defenders with a controlled sample for validating stack-capture analytics."],
    ["LoudSunRun", "https://github.com/susMdT/LoudSunRun", "Dylan Tran / susMdT", "2023", 5, "Windows synthetic call stack frames indirect syscalls stack spoofing multiple arguments", "Combines ideas from SilentMoonwalk and VulcanRaven into a compact active spoofer that builds synthetic frames and supports indirect system calls with relocated stack arguments. The implementation later feeds BokuLoader's stack evasion, so it is especially useful for following a research primitive from standalone assembly and C into a practical reflective-loader integration."],
    ["ThreadStackSpoofer", "https://github.com/mgeeky/ThreadStackSpoofer", "mgeeky", "2020", 4, "Windows thread stack spoofing sleep obfuscation RtlCaptureContext stack erase", "Demonstrates passive thread-stack concealment by locating the active stack range, overwriting it during a controlled sleep, and restoring execution state afterward. Although newer projects provide more convincing unwindable frames, this early public implementation remains a clear baseline for understanding stack erasure, restoration hazards, and the artifacts defenders can test."],
    ["WinObjEx64", "https://github.com/hfiref0x/WinObjEx64", "hfiref0x", "Living", 5, "Windows Object Manager namespace driver objects callbacks SSDT kernel inspection", "An advanced Windows Object Manager explorer that exposes namespaces, symbolic links, security descriptors, object types, loaded drivers, named pipes, processes, tokens, callbacks, and SSDT state. Its source and optional helper driver make it especially valuable for validating kernel-object relationships that simpler GUI viewers only summarize."],
    ["System Informer", "https://github.com/winsiderss/systeminformer", "System Informer", "Living", 5, "Windows process service network stack trace KSystemInformer phnt debugging malware analysis", "A production-grade process and system inspection suite with live views of threads, tokens, handles, modules, services, network activity, disk access, and kernel, WOW64, or .NET stack traces. The same repository includes KSystemInformer and phnt, so it serves both as an operational debugger and a substantial implementation reference for undocumented Windows behavior."],
    ["capa", "https://github.com/mandiant/capa", "Mandiant FLARE", "Living", 5, "FLARE capa PE dotnet shellcode capability detection rules ATT&CK malware triage", "Identifies executable capabilities by extracting low-level features and matching them against a transparent, community-reviewed rule corpus instead of relying on opaque signatures. Support for PE, .NET, shellcode, ELF, and sandbox reports, plus ATT&CK mappings and the web explorer, makes it a strong bridge from rapid triage to auditable behavioral analysis."],
    ["FLOSS", "https://github.com/mandiant/flare-floss", "Mandiant FLARE", "Living", 5, "FLARE FLOSS obfuscated strings stack strings decoded strings malware emulation", "Recovers static, stack, tight, and dynamically decoded strings that ordinary extraction tools miss by combining program analysis with targeted emulation. Its source, structured output, and explicit decoding categories help analysts verify why a string was recovered and quickly expose configuration, API names, and other behavior hidden by common malware obfuscators."],
    ["x64dbg", "https://github.com/x64dbg/x64dbg", "x64dbg", "Living", 5, "Windows x86 x64 user mode debugger reverse engineering malware analysis plugins scripting", "A mature open-source Windows debugger for x86 and x64 targets with breakpoints, tracing, control-flow graphs, memory maps, symbols, expressions, scripting, and an extensive plugin interface. The complete source and active ecosystem make it useful not only for live malware and exploit analysis, but also for understanding and extending the debugger machinery beneath the interface."],
    ["MemProcFS", "https://github.com/ufrisk/MemProcFS", "Ulf Frisk", "Living", 5, "Windows memory forensics virtual filesystem YARA VMM LeechCore PCILeech", "Presents live memory, raw dumps, Hyper-V saved state, and PCILeech acquisition as a virtual filesystem while also exposing C, C++, C#, Rust, Python, and Java APIs. Its Windows object reconstruction, forensic timeline, YARA scanning, remote agents, ARM64 support, and documented LeechCore device layer make it both an operational memory-analysis environment and an auditable research platform."],
    ["Hollows Hunter", "https://github.com/hasherezade/hollows_hunter", "Hasherezade", "Living", 5, "Windows memory scanner process hollowing shellcode hooks implants ETW PE-sieve", "Extends PE-sieve from single-process inspection into selective or system-wide scanning, continuous loops, and ETW-triggered analysis. It detects and dumps replaced or implanted PE images, shellcode, hooks, and memory patches while retaining structured reports and filtering controls, making it practical for comparing injection artifacts across an entire Windows host."],
    ["Moneta", "https://github.com/forrest-orr/moneta", "Forrest Orr", "2020", 5, "Windows live usermode memory scanner private executable pages PE implants shellcode IOC", "Inspects committed user-mode memory and reports suspicious region types, permissions, allocation relationships, unsigned images, modified code, and other artifacts produced by loaders and injection. Detailed and surface views, focused address traversal, dumping, statistics, and false-positive filters make the source a strong reference for both designing memory evasions and validating defensive heuristics."],
    ["Volatility 3", "https://github.com/volatilityfoundation/volatility3", "Volatility Foundation", "Living", 5, "Windows memory forensics framework symbols layers plugins processes kernel malware", "The modern, modular Volatility framework reconstructs Windows kernel and process state from memory images through translation layers, symbol tables, automagic configuration, and independently testable plugins. Its source and extensive Windows plugin set provide a canonical basis for examining processes, handles, modules, registry data, injected code, callbacks, and other evidence without trusting the live operating system."],
    ["ScyllaHide", "https://github.com/x64dbg/ScyllaHide", "x64dbg project", "Living", 5, "Windows anti anti debugging plugin hooks PEB NtQueryInformationProcess TitanHide IDA", "An advanced user-mode anti-anti-debugging layer available for x64dbg, IDA, and standalone workflows, with configurable hooks and profiles for common debugger checks across Win32 and Native APIs. The open implementation lets researchers trace exactly which PEB fields, timing paths, information classes, exception behaviors, and API results are virtualized instead of treating debugger hiding as unexplained magic."],
    ["HyperDbg", "https://github.com/HyperDbg/HyperDbg", "HyperDbg Project", "Living", 5, "Windows hypervisor debugger Intel VT-x EPT kernel user mode tracing fuzzing", "A hypervisor-assisted Windows debugger that uses Intel VT-x and Extended Page Tables to observe user- and kernel-mode execution below ordinary debugging APIs. Its source implements hidden EPT hooks, unrestricted memory watchpoints, syscall tracing, coverage collection, symbols, kernel-side scripting, and anti-timing measures, providing both a capable reversing environment and a detailed reference for building hardware-assisted instrumentation."],
    ["Windows Driver Samples", "https://github.com/microsoft/windows-driver-samples", "Microsoft", "Living", 5, "Windows WDK driver samples KMDF UMDF WDM file system network security IOCTL", "Microsoft's official WDK sample corpus covers KMDF, UMDF, WDM, file-system, network, storage, HID, security, setup, and many device-class drivers for current Windows releases. Researchers can use the buildable code to establish intended framework lifecycles, request handling, buffer methods, PnP and power behavior, and INF conventions before deciding whether a reversed third-party pattern is anomalous or merely standard driver machinery."],
    ["Blackbone", "https://github.com/DarthTon/Blackbone", "DarthTon", "Living", 5, "Windows process memory manual map PE loader injection WOW64 kernel driver", "A substantial Windows process-manipulation library implementing manual PE mapping, relocations and imports, remote execution, native loader interaction, WOW64 handling, memory management, and optional kernel-assisted access. Although maintenance and target-build assumptions must be checked, its source remains a valuable comparative implementation for studying what custom loaders reproduce, where injection artifacts arise, and how user- and kernel-mode components coordinate."],
    ["TitanHide", "https://github.com/mrexodia/TitanHide", "mrexodia", "Living", 4, "Windows kernel anti anti debugging driver NtQueryInformationProcess hooks debugger hiding", "A kernel driver and control utility that suppress common Windows anti-debugging signals for selected processes, exposing the exact information classes, system calls, flags, and exception paths it alters. Read beside ScyllaHide and modern PatchGuard constraints, the implementation helps analysts distinguish user-mode result virtualization from kernel intervention and provides a controlled target for testing whether defensive or anti-tamper checks observe the underlying state."],
    ["Ghidra", "https://github.com/NationalSecurityAgency/ghidra", "NSA Research", "Living", 5, "reverse engineering decompiler Windows PE PDB processor modules scripting extensions", "An open-source software reverse-engineering platform with disassembly, decompilation, data-flow analysis, collaborative projects, scripting, extension APIs, PE parsing, and PDB support relevant to Windows binaries and drivers. The complete analyzer and decompiler source makes it more than a GUI tool: researchers can inspect recovery assumptions, automate repetitive structure reconstruction, and implement domain-specific analysis when existing passes fail on unusual compiler or obfuscator output."],
    ["Speakeasy", "https://github.com/mandiant/speakeasy", "Mandiant FLARE", "Living", 5, "Windows malware emulation PE shellcode kernel driver API configuration extraction", "A Python-based Windows emulation framework that executes user-mode PE files, shellcode, and kernel drivers against modeled operating-system APIs without requiring the sample to run on a real host. Its extensible handlers, memory and API tracing, configuration output, command-line workflows, and programmatic interface make it useful for rapid malware triage while the open implementation lets analysts identify where emulated behavior diverges from genuine Windows semantics."],
    ["Microsoft Detours", "https://github.com/microsoft/Detours", "Microsoft Research", "Living", 5, "Windows API instrumentation function interception trampoline PE import table process injection", "Microsoft's production-grade library for intercepting arbitrary Win32 functions by rewriting entry instructions and routing execution through transactionally installed trampolines. The repository includes the x86, x64, ARM, and ARM64 implementation, import and payload helpers, process-creation support, samples, and technical documentation, providing a canonical reference for understanding hooks found in profilers, compatibility layers, security products, and malware rather than inferring their mechanics from disassembly alone."],
    ["winchecksec", "https://github.com/trailofbits/winchecksec", "Trail of Bits", "Living", 5, "Windows PE mitigations ASLR DEP CFG GS SafeSEH RFG CET checksec", "Parses Windows PE metadata to report exploit-relevant protections including ASLR, DEP, CFG, RFG, SafeSEH, stack cookies, isolation, integrity, and .NET characteristics in a scriptable format. The compact C++ implementation exposes how each conclusion is derived from headers, load configuration, relocations, and imports, making it valuable both for fast challenge or target triage and for auditing the limitations of mitigation scanners against malformed binaries."],
    ["Detect It Easy", "https://github.com/horsicq/Detect-It-Easy", "Hors", "Living", 5, "Detect It Easy DIE PE packer compiler linker signature script binary analysis", "A cross-platform file inspection suite whose scriptable signature engine recognizes compilers, linkers, packers, protectors, installers, and many executable formats, with deep PE-oriented metadata views and entropy, strings, hashing, and disassembly support. Because the signatures, database, engine, CLI, and GUI are all published, analysts can verify a detection, extend it for a malware lineage, and distinguish heuristic evidence from a definitive packer attribution."],
    ["LIEF", "https://github.com/lief-project/LIEF", "LIEF Project", "Living", 5, "PE parser builder Windows Authenticode load configuration PDB Python C++ Rust", "A library for parsing, inspecting, modifying, and rebuilding executable formats with extensive PE coverage exposed through C++, Python, Rust, and C APIs. Its implementation models imports, relocations, resources, TLS, exception and load-configuration data, signatures, debug records, and modern mitigation fields, allowing researchers to build reproducible binary transformations and analyzers while inspecting exactly how malformed or unusual Windows images are tolerated."],
    ["Rewind", "https://github.com/quarkslab/rewind", "Quarkslab", "2020", 5, "Windows kernel fuzzer snapshot WinDbg crash dump coverage guided Bochs VMware driver", "A snapshot-based coverage-guided fuzzer designed around the realities of Windows kernel targets. Rewind converts a WinDbg kernel crash dump into a restorable execution state, supports Bochs and VMware-backed replay, collects coverage through breakpoints or Intel PT-style mechanisms, mutates user-controlled inputs and resets without rebooting a full guest, turning an otherwise slow driver-crash workflow into a reproducible fuzzing loop whose state reconstruction and harness assumptions are available for audit."],
    ["WinKAFL", "https://github.com/Y3A/winkafl", "Y3A", "2023", 5, "Windows kernel driver fuzzing WinAFL static binary instrumentation Intel PT WinDbg IOCTL", "Extends WinAFL toward closed-source Windows kernel drivers by statically instrumenting a target binary and connecting its coverage to a user-mode IOCTL harness. The repository includes the instrumentation pass, runtime and VM workflow, documents driver replacement, signature and debugger setup, and accompanies a worked research series, making it useful for understanding where kernel coverage, persistent execution, crash collection and safe reset differ from ordinary application fuzzing."],
    ["msFuzz", "https://github.com/0dayResearchLab/msFuzz", "0Day Research Lab", "2024", 5, "Windows WDM driver fuzzer symbolic execution IOCTL dependency sequence static analysis CodeQL", "Automates WDM driver fuzzing around a problem simple random IOCTL generation misses: requests often require a valid sequence and data dependencies established by earlier calls. msFuzz statically recovers dispatch and handler relationships, applies symbolic execution to infer constraints and useful states, generates dependency-aware sequences and executes them against drivers, with source and evaluation artifacts supporting the reported multi-driver vulnerability discoveries rather than exposing only a front-end scanner."],
    ["PE-bear", "https://github.com/hasherezade/pe-bear", "Hasherezade", "Living", 5, "Windows PE parser viewer malware analysis packer imports relocations TLS load config Authenticode", "A focused, open-source Portable Executable inspection tool built for fast structural triage without hiding malformed details behind the Windows loader. PE-bear exposes raw and interpreted headers, sections, directories, imports, exports, relocations, resources, TLS, exceptions, load configuration and signatures, highlights suspicious layout and value relationships, and includes a maintained parsing core, making it a practical bridge between hex-level validation and the higher-level behavior seen in a debugger or decompiler."],
    ["CHIPSEC", "https://github.com/chipsec/chipsec", "CHIPSEC Project", "Living", 5, "Windows firmware platform security UEFI SPI flash PCI MSR ACPI SMM TPM hardware assessment", "An open-source platform-security framework for inspecting the firmware and hardware boundary beneath Windows and other operating systems. Its modules read chipset registers, PCI configuration, SPI flash, UEFI variables, ACPI tables, MSRs, memory and protection state, test known classes of firmware misconfiguration, and provide Python primitives for custom experiments; the code, platform definitions and result semantics let researchers verify whether a driver or boot-chain primitive reaches protections that ordinary kernel tooling cannot observe."],
    ["phnt Native API Headers", "https://github.com/winsiderss/phnt", "System Informer Project", "Living", 5, "Windows Native API headers NT kernel user mode ntdll structures syscalls SDK reverse engineering", "Maintains the broad Native API definition set used by System Informer, derived from Microsoft headers, public symbols, and sustained reverse engineering since the Process Hacker era. The repository supplies version-selectable declarations for process, memory, object, I/O, ALPC, registry, loader, security, win32k, WoW64, and many other undocumented interfaces, making it the compilable source behind individual header references rather than a static web mirror."],
    ["KrabsETW", "https://github.com/microsoft/krabsetw", "Microsoft", "Living", 5, "Windows ETW C++ .NET trace provider event schema TDH security telemetry", "Wraps low-level Event Tracing for Windows consumption in native C++ and a production-used .NET layer, supporting multiple concurrent traces, arbitrary providers, callbacks, and generic-event conversion into strongly typed values. Its primer, nontrivial examples, parser code, tests, and explicit lifecycle limitations provide a reliable foundation for building telemetry experiments and validating what an ETW-based detector actually receives."],
    ["WTF Snapshot Fuzzer", "https://github.com/0vercl0k/wtf", "Axel Souchet / 0vercl0k", "Living", 5, "Windows kernel usermode snapshot fuzzer coverage guided Intel PT Hyper-V backend distributed fuzzing", "A distributed snapshot-based fuzzer designed for Windows user-mode and kernel-mode targets, with coverage feedback, customizable mutation, crash reproduction, and backends that restore complex machine state far faster than reboot-driven harnesses. Its targets and debugger-oriented workflow demonstrate how to isolate one operation inside a real Windows environment while retaining enough operating-system context for drivers and closed-source applications."],
    ["NtApiDotNet", "https://github.com/googleprojectzero/sandbox-attacksurface-analysis-tools/tree/main/NtApiDotNet", "James Forshaw / Project Zero", "Living", 5, "Windows Native API .NET PowerShell NT objects tokens security descriptors ALPC RPC COM sandbox", "Provides the managed library and PowerShell surface underlying much of Project Zero's Windows sandbox tooling. It models NT handles, object namespaces, tokens, access checks, security descriptors, processes, sections, ALPC, RPC and COM with disposable typed wrappers, letting researchers script security-boundary experiments while inspecting the exact native calls and marshaling behavior instead of depending on opaque administrative cmdlets."],
    ["Win32 Metadata", "https://github.com/microsoft/win32metadata", "Microsoft", "Living", 5, "Win32 API metadata Windows SDK IDL headers CSharp Rust language projections ABI", "Generates machine-readable, strongly typed metadata for broad Win32 API coverage from Windows SDK headers and IDL, including handle lifetimes, enums, structures, constants, and calling details that hand-written bindings frequently get wrong. The emitted Windows.Win32.winmd drives official C# and Rust projections and is an auditable reference for producing research tooling in other languages without silently changing the underlying ABI."],
    ["Winbindex", "https://github.com/m417z/winbindex", "Michael Maltsev", "2020", 5, "Windows binaries index Microsoft symbol server historical exe dll sys versions patch diffing", "Indexes historical Windows EXE, DLL and SYS metadata and derives authenticated download links from Microsoft's public symbol server, making exact build recovery far less error-prone than searching unofficial mirrors. Its regularly generated database and open indexing scripts let vulnerability researchers acquire pre- and post-patch binaries, verify hashes and timestamps, automate version archaeology and reproduce binary-diff results against the same artifacts used by the original analysis."],
    ["PoolViewer", "https://github.com/yardenshafir/PoolViewer", "Yarden Shafir", "2021", 5, "Windows kernel pool dump allocation viewer tags filtering memory forensics crash dump", "Parses Windows 10 RS5-and-later crash dumps into a searchable view of live kernel pool allocations, exposing address, size, pool type and tag without requiring repetitive WinDbg commands. Researchers can filter and group allocations, correlate unfamiliar tags with drivers, compare grooming outcomes after a crash and export evidence for later analysis, which makes the tool particularly useful when validating pool-spray assumptions or locating the reclaimed object behind a kernel exploit."],
    ["Windows Driver Plugin for IDA", "https://github.com/FSecureLABS/win_driver_plugin", "WithSecure Labs", "2019", 5, "Windows kernel driver IDA plugin WDM WDF IOCTL dispatch device control reverse engineering", "Automates the repetitive structural work that precedes meaningful Windows driver review inside IDA. The plugin identifies WDM and WDF entry points, annotates dispatch tables and major-function handlers, decodes IOCTL control values, applies relevant kernel types and highlights user-facing paths, giving analysts a consistent map from DriverEntry to reachable attack surface while leaving data-flow and vulnerability judgments visible for manual verification."],
    ["OneFuzz", "https://github.com/microsoft/onefuzz", "Microsoft", "2020", 4, "OneFuzz archived fuzzing as a service Windows Linux crash triage deduplication CI Azure", "Preserves Microsoft's now-archived self-hosted fuzzing orchestration platform, which can scale jobs from a few virtual machines to thousands of cores while sharing interesting inputs across engines. The source documents reproducible crash handling, deduplication, notification, live debugging and CI integration on Windows and Linux, making it a useful architectural reference for building a research pipeline even though maintainers explicitly ended public development in 2023 and deployments should account for that status."],
    ["BinSkim", "https://github.com/microsoft/binskim", "Microsoft", "2016", 5, "BinSkim Windows PE binary security analyzer compiler mitigations PDB SARIF driver SDL", "Analyzes compiled Windows binaries and PDBs for security-relevant build properties that source review alone cannot prove, including stack protection, control-flow hardening, relocation support, executable permissions and toolchain provenance. Its rule engine emits SARIF suitable for CI and can scan drivers as well as user-mode PE files, giving exploit researchers a repeatable mitigation inventory and giving defenders an auditable way to catch insecure compiler or linker settings before release."],
    ["RPC Investigator", "https://github.com/trailofbits/RpcInvestigator", "Trail of Bits", "Living", 5, "Windows RPC reverse engineering interface enumeration NDR decompilation client fuzzing ETW", "Combines RPC endpoint discovery, procedure inspection and client generation in a Windows desktop research environment rather than requiring analysts to manually reconstruct every MIDL artifact. It enumerates registered interfaces and bindings, recovers NDR procedure and type information, renders call structure, invokes selected operations and integrates tracing-oriented workflows, making it a strong bridge from opaque service binaries to reproducible RPC attack-surface experiments."],
    ["PrivFu", "https://github.com/daem0nc0re/PrivFu", "daem0nc0re", "Living", 5, "Windows token privileges WinDbg extension kernel EPROCESS TOKEN PoC privilege research", "Pairs a kernel-mode WinDbg extension with user and kernel proofs of concept for investigating Windows token privileges at the data-structure level. Commands locate process tokens, decode SEP_TOKEN_PRIVILEGES state and enable or disable individual rights—including protected and secure-process research cases—so researchers can validate offsets, observe privilege checks and test data-only escalation ideas without rebuilding one-off debugger scripts for every Windows version."],
    ["tiny_tracer", "https://github.com/hasherezade/tiny_tracer", "Hasherezade", "Living", 5, "Windows malware tracing Intel Pin API calls arguments branches coverage unpacking", "Provides a configurable Intel Pin-based tracer optimized for Windows malware and protected binaries, logging API calls, resolved parameters, indirect branches and selected instruction ranges while controlling noise through tags and rule files. Its companion scripts translate traces into coverage and call relationships, allowing analysts to follow unpacked execution, compare paths and recover runtime-only behavior when ordinary debugger stepping is defeated by volume or anti-analysis checks."],
    ["Impel", "https://github.com/cbev0x/impel", "cbev", "2026", 5, "Windows RPC authentication coercion scanner Server 2025 Linux NDR named pipe TCP endpoints", "Automates mapping of Windows authentication-coercion behavior across RPC interfaces from a Linux research host instead of encoding only known PetitPotam-style calls. Impel discovers and binds candidate endpoints, generates or mutates NDR requests, observes outbound authentication and records the UUID, opnum, transport and trigger context, supporting systematic comparison on current Windows Server builds and follow-up review of the client-side code that accepted an attacker-controlled network target."],
    ["IRPT Windows Driver Fuzzer", "https://github.com/kirasys/irpt", "Kira Systems Research", "Living", 5, "Windows driver fuzzing IOCTL kAFL coverage kernel harness crash triage", "Documents and implements a driver-fuzzing system built around coverage-guided execution of Windows IOCTL paths, with explicit engineering for kernel resets, input delivery, device initialization and crash collection. The repository is valuable beyond its fuzzer binary because it records the tradeoffs between kAFL-style hardware tracing and Windows-aware harness control, helping researchers design campaigns that preserve required driver state instead of sending context-free random buffers."],
  ]},
] as const;
const total = groups.reduce((sum, group) => sum + group.items.length, 0);
const stars = (rating: number) => `${"★".repeat(rating)}${"☆".repeat(5 - rating)}`;
---

<div class="research-index" data-research-index>
  <div class="research-index__search">
    <label for="research-search">Search the index</label>
    <input id="research-search" type="search" placeholder="Try: KASLR, EDR, pool, CVE, I/O rings..." autocomplete="off" data-research-search />
    <p data-research-status aria-live="polite">{researchers.length} researchers and {total} resources</p>
  </div>
  <aside class="research-index__rubric" aria-label="Reading priority rubric">
    <strong>Reading priority</strong>
    <span><b>★★★★★</b> foundational / must-read</span><span><b>★★★★☆</b> strong practical depth</span><span><b>★★★☆☆</b> useful or specialized</span><span><b>★★☆☆☆</b> supplemental / secondary</span>
  </aside>
  <nav class="research-index__jump" aria-label="Jump to a research area">
    <a href="#researchers-heading">Researchers</a>
    {groups.map((group) => <a href={`#${group.id}-heading`}>{group.title}</a>)}
  </nav>
  <section data-index-group aria-labelledby="researchers-heading">
    <div class="research-index__heading"><div><p class="research-index__kicker">People to follow</p><h2 id="researchers-heading">Researchers &amp; Blogs</h2></div><span>{researchers.length} entries</span></div>
    <div class="research-index__table-wrap"><table><thead><tr><th>Researcher</th><th>Blog</th><th>Primary focus</th></tr></thead><tbody>
      {researchers.map(([name, site, url, profile, focus]) => <tr data-index-row data-kind="researcher" data-searchable={`${name} ${site} ${focus}`}><td><a href={profile} target="_blank" rel="noreferrer">{name}</a></td><td><a href={url} target="_blank" rel="noreferrer">{site}</a></td><td>{focus}</td></tr>)}
    </tbody></table></div><p class="research-index__none" data-group-empty hidden>No matching researchers.</p>
  </section>
  {groups.map((group) => <section id={`${group.id}-section`} data-index-group aria-labelledby={`${group.id}-heading`}>
    <div class="research-index__heading"><div><p class="research-index__kicker">{group.kicker}</p><h2 id={`${group.id}-heading`}>{group.title}</h2></div><span>{group.items.length} entries</span></div>
    <div class="research-index__table-wrap"><table class="resource-table"><thead><tr><th>Resource</th><th>Year</th><th>Priority</th><th>Why it matters</th></tr></thead><tbody>
      {group.items.map(([title, url, source, year, rating, tags, note]) => <tr data-index-row data-kind="resource" data-searchable={`${title} ${source} ${year} ${tags} ${note}`}><td><a href={url} target="_blank" rel="noreferrer">{title}</a><small>{source}</small></td><td><span class="research-index__year">{year}</span></td><td><span class="research-index__stars" title={`${rating} out of 5 reading priority`} aria-label={`${rating} out of 5 reading priority`}>{stars(rating)}</span></td><td>{note}</td></tr>)}
    </tbody></table></div><p class="research-index__none" data-group-empty hidden>No matching resources in this section.</p>
  </section>)}
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-research-index]").forEach((root) => {
    const input = root.querySelector<HTMLInputElement>("[data-research-search]");
    const status = root.querySelector<HTMLElement>("[data-research-status]");
    const sections = [...root.querySelectorAll<HTMLElement>("[data-index-group]")];
    input?.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase(); let researchers = 0; let resources = 0;
      sections.forEach((section) => { let visible = 0; section.querySelectorAll<HTMLElement>("[data-index-row]").forEach((row) => { const match = (row.dataset.searchable ?? "").toLowerCase().includes(query); row.hidden = !match; if (match) { visible++; row.dataset.kind === "researcher" ? researchers++ : resources++; } }); const empty = section.querySelector<HTMLElement>("[data-group-empty]"); if (empty) empty.hidden = visible !== 0; });
      if (status) status.textContent = `${researchers} researchers and ${resources} resources`;
    });
  });
</script>

<style>
