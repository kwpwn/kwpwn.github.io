const resources = [
  {
    title: "The KASLR graveyard: leaking ntoskrnl on Windows 11 25H2",
    url: "https://afflicted.sh/blog/posts/kaslr-graveyard.html",
    source: "afflicted.sh",
    category: "Technique / Evasion",
    tags: "windows kernel kaslr ntoskrnl infoleak ExIsRestrictedCaller WIL GDT IDT desktop heap prefetch",
    note: "A practical catalog of kernel-base leak paths tested on a specific Windows 11 25H2 target, including the exact reason each approach worked or failed. It is useful as a decision tree for modern KASLR work because it covers restricted NtQuery* outputs, descriptor tables, desktop heap ideas, physical-memory approaches, CPU differences, and the eventual working path.",
  },
  {
    title: "amwrtdrv: AOMEI Backupper hands every local user the disk",
    url: "https://afflicted.sh/blog/posts/amwrtdrv-aomei-lpe.html",
    source: "afflicted.sh",
    category: "Windows LPE",
    tags: "vulnerable driver raw disk gpt fat12 uefi boot pre-kernel secure boot",
    note: "Shows how an insecure kernel driver turns ordinary-user access into raw reads and writes against the live system disk. The post then develops that primitive into a pre-kernel execution chain by placing a FAT12 image in the pre-partition gap, redirecting the GPT entry, and letting UEFI load the planted binary before Windows protections start.",
  },
  {
    title: "SignalRGB: standard user to SYSTEM",
    url: "https://afflicted.sh/blog/posts/signalrgb-service-lpe.html",
    source: "afflicted.sh",
    category: "Windows LPE",
    tags: "service acl writable binary appdata local system cwe-732 cwe-276",
    note: "A clear Windows service-permission case study where an auto-start LocalSystem service executes a binary stored in a user-writable profile directory. It also documents the operational detail many writeups omit: replacing a running image, understanding SERVICE_START versus stop rights, and choosing between reboot and a chained restart trigger.",
  },
  {
    title: "KASLR Leaks Restriction",
    url: "https://windows-internals.com/kaslr-leaks-restriction/",
    source: "Windows Internals",
    category: "Mitigation",
    tags: "windows kernel kaslr ExIsRestrictedCaller NtQuerySystemInformation SeDebugPrivilege",
    note: "Yarden Shafir's internal analysis of the Windows mitigation that removes many kernel-address disclosures from unprivileged callers. Read this first to understand ExIsRestrictedCaller, the affected system-information paths, the role of caller privileges, and why exploit developers can no longer treat NtQuerySystemInformation as a universal KASLR bypass.",
  },
  {
    title: "An End to KASLR Bypasses?",
    url: "https://windows-internals.com/an-end-to-kaslr-bypasses/",
    source: "Windows Internals",
    category: "Mitigation",
    tags: "windows kernel kaslr pointers restricted caller mitigation",
    note: "Background on Microsoft's broader effort to restrict kernel pointer disclosure and its effect on established exploit-development workflows. The article is valuable for understanding the mitigation's original scope, how integrity levels and sandbox boundaries influenced the design, and which assumptions older Windows kernel exploits made about address disclosure.",
  },
  {
    title: "Bypassing Windows Kernel Mitigations: Part 0",
    url: "https://hackyboiz.github.io/2025/04/13/l0ch/bypassing-kernel-mitigation-part0/en/",
    source: "Hackyboiz / L0ch",
    category: "Technique / Evasion",
    tags: "windows 24h2 kernel kaslr prefetch side channel EntryBleed KVA shadow Intel AMD",
    note: "Explains the Windows 11 24H2 KASLR restriction from an exploit developer's perspective, then adapts an EntryBleed-style prefetch timing side channel to Windows. It connects page-table behavior, KVA shadowing, TLB state, CPU-specific timing differences, and the practical process of recovering the ntoskrnl base without the legacy query APIs.",
  },
  {
    title: "Breaking KASLR on Windows 11 24H2 with physical memory access",
    url: "https://xacone.github.io/kaslr_leak_24h2.html",
    source: "xacone / Yazid",
    category: "Technique / Evasion",
    tags: "windows 24h2 kernel kaslr hvci physical memory driver cr3 page table",
