const references = [
  {
    title: "System Informer: ntexapi.h",
    url: "https://github.com/winsiderss/systeminformer/blob/master/phnt/include/ntexapi.h",
    source: "System Informer / phnt",
    category: "Reference",
    tags: "windows native api NtQuerySystemInformation SYSTEM_INFORMATION_CLASS ntexapi",
    note: "The phnt header for Native system-information APIs, including NtQuerySystemInformation and the SYSTEM_INFORMATION_CLASS family. Use it when you need accurate declarations, enum values, or structure layouts that are absent or incomplete in the public Windows SDK.",
  },
  {
    title: "System Informer: ntpsapi.h",
    url: "https://github.com/winsiderss/systeminformer/blob/master/phnt/include/ntpsapi.h",
    source: "System Informer / phnt",
    category: "Reference",
    tags: "windows native api process thread information ntpsapi",
    note: "The phnt process-and-thread API header, covering Native process, thread, job, and related information classes. It is especially useful while building low-level tooling or checking the exact user-mode structures expected by NtQueryInformationProcess and NtQueryInformationThread.",
  },
  {
    title: "NtDoc: PROCESSINFOCLASS",
    url: "https://ntdoc.m417z.com/processinfoclass",
    source: "NtDoc",
    category: "Reference",
    tags: "windows native api process information class undocumented ntdll",
    note: "A browsable, cross-linked reference for PROCESSINFOCLASS values accepted by NtQueryInformationProcess and NtSetInformationProcess. It provides a faster way to understand what each class returns, expected buffer types, access requirements, and known version differences before moving to headers or disassembly.",
