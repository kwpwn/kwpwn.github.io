---
interface Lens {
  establishes: string;
  boundary: string;
  composition: string;
  evidence: string;
}

export interface Props {
  lens: Lens;
}

const { lens } = Astro.props as Props;

const items = [
  ["What it establishes", lens.establishes],
  ["What it does not establish", lens.boundary],
  ["How it composes", lens.composition],
  ["Evidence to collect", lens.evidence],
] as const;
---

<aside class="concept-lens" aria-label="Concept analysis lens">
  <p>Reasoning lens</p>
  <dl>
    {
      items.map(([term, description]) => (
        <div>
          <dt>{term}</dt>
          <dd>{description}</dd>
        </div>
      ))
    }
  </dl>
</aside>

<style>
  .concept-lens {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .concept-lens > p {
    margin: 0;
    color: var(--color-text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .concept-lens dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
    margin: 0;
  }

  .concept-lens dl > div {
    display: grid;
    align-content: start;
    gap: var(--space-xs);
    padding: 0;
    border: 0;
  }

  .concept-lens dt {
    color: var(--color-text-primary);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
  }

  .concept-lens dd {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 40rem) {
    .concept-lens dl {
      grid-template-columns: 1fr;
    }
  }
</style>
