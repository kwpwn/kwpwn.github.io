interface AtlasEntry {
  name: string;
  description: string;
  note?: string;
}

interface AtlasFamily {
  title: string;
  description: string;
  entries: AtlasEntry[];
}

interface Tool {
  name: string;
  url: string;
  use: string;
  status?: string;
}

interface ToolFamily {
  title: string;
  stage: string;
  description: string;
  tools: Tool[];
}

interface Technique {
  name: string;
  query: string;
}

interface TechniqueFamily {
  title: string;
  description: string;
  techniques: Technique[];
}

const pipeline = [
  {
    step: "01",
    title: "Component & exposure",
    description:
      "Identify what runs with privilege, who can reach it, through which transport, and under which token, session, integrity level, or device state.",
  },
  {
    step: "02",
    title: "Attack surface",
    description:
      "Map the concrete entry point: IOCTL, IRP, RPC method, COM activation, parser, callback, shared section, service control, or hardware-facing channel.",
  },
  {
    step: "03",
    title: "Root-cause class",
    description:
      "Describe the defect that violates an invariant: memory safety, lifetime, authorization, path identity, input validation, or protocol state.",
  },
  {
    step: "04",
    title: "Obtained primitive",
    description:
      "Record the capability the defect actually grants, including its limits: read, write, create, delete, redirect, impersonate, map, allocate, or invoke.",
  },
  {
    step: "05",
    title: "Composition & impact",
    description:
      "Show how building blocks, mitigations, and environmental assumptions turn that capability into SYSTEM, PPL bypass, persistence, disclosure, or code execution.",
  },
] as const;

