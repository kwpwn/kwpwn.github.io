const caseStudies = [
  {
    title: "Arbitrary object-directory creation to LPE",
    url: "https://projectzero.google/2018/08/windows-exploitation-tricks-exploiting.html",
    source: "James Forshaw / Project Zero",
    primitive:
      "Object directory create → namespace shadowing → privileged symbolic-link recreation",
    level: "Advanced",
    reason:
      "A model non-memory-corruption chain that makes Object Manager semantics, access checks, AppContainer namespaces, and each conversion step explicit.",
  },
  {
    title: "Abusing arbitrary file deletes to escalate privilege",
    url: "https://www.thezdi.com/blog/2022/3/16/abusing-arbitrary-file-deletes-to-escalate-privilege-and-other-great-tricks",
    source: "Abdelhamid Naceri / ZDI",
    primitive:
      "Privileged delete → Windows Installer rollback conversion → controlled privileged file",
    level: "Advanced",
    reason:
      "Explains why delete is usually insufficient, then provides source for a reusable delete-to-SYSTEM conversion through installer rollback state.",
  },
  {
    title: "Weaponizing privileged file writes with USO",
    url: "https://itm4n.github.io/usodllloader-part1/",
    source: "itm4n",
    primitive:
      "Privileged file write → controlled service load path → SYSTEM execution",
    level: "Intermediate",
    reason:
      "Two-part, implementation-backed study of identifying a reliable sink and trigger instead of treating arbitrary file write as equivalent to code execution.",
  },
  {
    title: "Winning race conditions with path lookups",
    url: "https://projectzero.google/2025/12/windows-exploitation-techniques.html",
    source: "James Forshaw / Project Zero",
    primitive:
      "Oplock / namespace loop → deterministic path race → identity substitution",
    level: "Advanced",
    reason:
      "A current, reusable methodology for expanding race windows and reasoning about NT path resolution rather than a one-off CVE walkthrough.",
  },
  {
    title: "Windows I/O Manager access-mode variant class",
    url: "https://www.microsoft.com/en-us/msrc/blog/2019/03/local-privilege-escalation-via-the-windows-i-o-manager-a-variant-finding-collaboration",
    source: "MSRC and Project Zero",
    primitive:
      "RequestorMode confusion → missing forced access check → privileged object access",
    level: "Intermediate",
    reason:
      "Connects one authorization mistake to systematic variant finding across drivers and explains why SL_FORCE_ACCESS_CHECK changes the security decision.",
  },
  {
    title: "Windows DLL hijacking clarified",
    url: "https://itm4n.github.io/windows-dll-hijacking-clarified/",
    source: "itm4n",
    primitive:
      "Writable path / missing module → privileged loader resolution → code execution",
    level: "Beginner → Intermediate",
    reason:
      "Establishes precise terminology for search-order, phantom, replacement, and proxying cases and supplies a repeatable validation workflow.",
  },
  {
    title: "PrintSpoofer",
    url: "https://itm4n.github.io/printspoofer-abusing-impersonate-privileges/",
    source: "itm4n",
    primitive:
      "Pipe server → privileged client coercion → impersonation token → SYSTEM process",
    level: "Intermediate",
    reason:
      "A compact, reproducible named-pipe identity chain with enough token and service detail to understand why it works on modern Windows.",
  },
  {
    title: "Exploiting a simple vulnerability in 35 steps",
    url: "https://windows-internals.com/exploiting-a-simple-vulnerability-in-35-easy-steps-or-less/",
    source: "Yarden Shafir / Windows Internals",
    primitive:
      "Constrained kernel corruption → information leak → data-only privilege escalation",
    level: "Advanced",
    reason:
      "Refuses to skip the engineering between a small primitive and reliable elevation, making it one of the strongest guided modern kernel labs.",
  },
] as const;

const totalEntries =
  techniqueFamilies.reduce((sum, family) => sum + family.techniques.length, 0) +
  primitiveFamilies.reduce((sum, family) => sum + family.entries.length, 0) +
  vulnerabilityFamilies.reduce(
    (sum, family) => sum + family.entries.length,
    0,
  ) +
  attackSurfaceFamilies.reduce(
    (sum, family) => sum + family.entries.length,
    0,
  ) +
  driverTypeFamilies.reduce((sum, family) => sum + family.entries.length, 0);
const totalTools = toolFamilies.reduce(
  (sum, family) => sum + family.tools.length,
  0,
);
---

<section class="atlas" aria-labelledby="atlas-heading">
  <header class="atlas__hero" id="atlas-overview">
    <p class="atlas__eyebrow">Windows Security Research Atlas</p>
    <h2 id="atlas-heading">A capability-first map from exposure to impact</h2>
    <p>
      Inspired by <a
        href="https://splintersfury.github.io/KernelSight/"
        target="_blank"
        rel="noreferrer">KernelSight</a
      >, this model expands beyond kernel drivers and fixes a useful but
      important taxonomy problem: a bug class, an obtained primitive, an
      exploitation building block, and a final objective are not the same thing.
      The atlas currently defines {totalEntries} concepts and {totalTools} workflow-selected
      tools.
    </p>
  </header>

  <nav class="atlas__nav" aria-label="Atlas sections">
    <a href="#atlas-overview">Overview</a>
    <a href="#technique-families">Technique families</a>
    <a href="#primitives">Primitives</a>
    <a href="#vulnerability-classes">Vulnerability classes</a>
    <a href="#attack-surfaces">Attack surfaces</a>
    <a href="#driver-types">Driver types</a>
    <a href="#case-studies">Case studies</a>
    <a href="#tooling">Tooling</a>
    <a href="#research-library">Research library</a>
    <a class="atlas__nav-ctf" href="#ctf-archive">CTF archive</a>
  </nav>

  <div class="atlas__pipeline" aria-label="Research pipeline">
    {
      pipeline.map((item) => (
        <article>
          <span>{item.step}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))
    }
  </div>

  <aside class="atlas__rule">
    <strong>The classification rule</strong>
    <p>
      Write the chain as <code
        >exposure → root cause → constrained capability → composition → impact</code
      >. For example, <code
        >World-writable device → missing caller check → physical-memory map →
        page-table edit → SYSTEM</code
      >. This makes missing evidence visible and prevents “arbitrary R/W” from
      hiding the actual defect.
    </p>
  </aside>

  <section
    class="atlas__section"
    id="technique-families"
    aria-labelledby="technique-families-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">Browse by research objective</p>
        <h2 id="technique-families-heading">Technique families</h2>
      </div>
      <p>
        These are saved views over the research library, not duplicate resource
        buckets. Select a technique such as COM hijacking or DLL hijacking to
        apply its editorial query to the main atlas tables.
      </p>
    </header>
    <div class="atlas__techniques">
      {
        techniqueFamilies.map((family) => (
          <article>
            <h3>{family.title}</h3>
            <p>{family.description}</p>
            <div>
              {family.techniques.map((technique) => (
                <button
                  type="button"
                  data-atlas-query={technique.query}
                  aria-label={`Search the research library for ${technique.name}`}
                >
                  {technique.name}
                </button>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section
    class="atlas__section"
    id="primitives"
    aria-labelledby="primitives-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">What the attacker gains</p><h2
          id="primitives-heading"
        >
          Primitives
        </h2>
      </div>
      <p>
        Capabilities are recorded with constraints, then separated from the
        techniques used to stabilize them and the impact produced at the end.
      </p>
    </header>
    <div class="atlas__families">
      {
        primitiveFamilies.map((family, index) => (
          <details class="atlas__family" open={index === 0}>
            <summary>
              <>
                <span>{family.title}</span>
                <small>{family.entries.length} capabilities</small>
              </>
            </summary>
            <p class="atlas__family-intro">{family.description}</p>
            <dl>
              {family.entries.map((entry) => (
                <div>
                  <dt>{entry.name}</dt>
                  <dd>
                    {entry.description}
                    {entry.note && <small>{entry.note}</small>}
                  </dd>
                </div>
              ))}
            </dl>
          </details>
        ))
      }
    </div>
  </section>

  <section
    class="atlas__section"
    id="vulnerability-classes"
    aria-labelledby="vulnerability-classes-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">Why the invariant breaks</p><h2
          id="vulnerability-classes-heading"
        >
          Vulnerability classes
        </h2>
      </div>
      <p>
        Root causes are causal defects. Arbitrary read/write belongs in the
        primitive layer; authorization and object security deserve first-class
        treatment instead of disappearing inside “logic bug.”
      </p>
    </header>
    <aside class="atlas__callout">
      <h3>ACL/DACL: exposure is not automatically a vulnerability</h3>
      <p>
        A low-privilege user being able to open a device, query a service, or
        connect to an RPC endpoint may be intentional. The security finding
        begins when the granted access mask reaches a privileged operation that
        lacks a correct per-request authorization check. For a service, <code
          >SERVICE_QUERY_STATUS</code
        > is normally benign; <code>SERVICE_CHANGE_CONFIG</code> can change the executable
        that SCM later launches, while <code>WRITE_DAC</code> can let the caller grant
        themselves stronger rights. For a driver, the device SDDL determines who can
        obtain a handle, but each IOCTL still needs validation appropriate to its
        effect. Always record the ACE, requested rights, reachable method, effective
        token, and boundary crossed.
      </p>
      <p>
        See Microsoft's <a
          href="https://learn.microsoft.com/en-us/windows/win32/services/service-security-and-access-rights"
          target="_blank"
          rel="noreferrer">service access-rights reference</a
        >
        and <a
          href="https://learn.microsoft.com/en-us/windows-hardware/drivers/ifs/applying-security-descriptors-on-the-device-object"
          target="_blank"
          rel="noreferrer">device-object security guidance</a
        >.
      </p>
    </aside>
    <div class="atlas__families">
      {
        vulnerabilityFamilies.map((family, index) => (
          <details class="atlas__family" open={index === 2}>
            <summary>
              <>
                <span>{family.title}</span>
                <small>{family.entries.length} classes</small>
              </>
            </summary>
            <p class="atlas__family-intro">{family.description}</p>
            <dl>
              {family.entries.map((entry) => (
                <div>
                  <dt>{entry.name}</dt>
                  <dd>
                    {entry.description}
                    {entry.note && <small>{entry.note}</small>}
                  </dd>
                </div>
              ))}
            </dl>
          </details>
        ))
      }
    </div>
  </section>

  <section
    class="atlas__section"
    id="attack-surfaces"
    aria-labelledby="attack-surfaces-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">Where input crosses trust</p><h2
          id="attack-surfaces-heading"
        >
          Attack surfaces
        </h2>
      </div>
      <p>
        Entry points are organized by transport and parsed input. Framework,
        component family, required privilege, and local/remote/guest/physical
        exposure remain separate dimensions.
      </p>
    </header>
    <div class="atlas__families">
      {
        attackSurfaceFamilies.map((family, index) => (
          <details class="atlas__family" open={index === 0}>
            <summary>
              <>
                <span>{family.title}</span>
                <small>{family.entries.length} surfaces</small>
              </>
            </summary>
            <p class="atlas__family-intro">{family.description}</p>
            <dl>
              {family.entries.map((entry) => (
                <div>
                  <dt>{entry.name}</dt>
                  <dd>{entry.description}</dd>
                </div>
              ))}
            </dl>
          </details>
        ))
      }
    </div>
  </section>

  <section
    class="atlas__section"
    id="driver-types"
    aria-labelledby="driver-types-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">What the component controls</p><h2
          id="driver-types-heading"
        >
          Driver &amp; component types
        </h2>
      </div>
      <p>
        A functional family is only the first axis. Framework, origin, exposure,
        load model, stack role, signing, blocklist status, and mitigation
        compatibility are required for meaningful comparison.
      </p>
    </header>
    <div class="atlas__families">
      {
        driverTypeFamilies.map((family, index) => (
          <details
            class="atlas__family"
            open={index === 0 || index === driverTypeFamilies.length - 1}
          >
            <summary>
              <>
                <span>{family.title}</span>
                <small>{family.entries.length} entries</small>
              </>
            </summary>
            <p class="atlas__family-intro">{family.description}</p>
            <dl>
              {family.entries.map((entry) => (
                <div>
                  <dt>{entry.name}</dt>
                  <dd>{entry.description}</dd>
                </div>
              ))}
            </dl>
          </details>
        ))
      }
    </div>
  </section>

  <section
    class="atlas__section"
    id="case-studies"
    aria-labelledby="case-studies-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">High-signal reproductions</p><h2
          id="case-studies-heading"
        >
          Lab-ready case studies
        </h2>
      </div>
      <p>
        Selected for primary evidence, a visible root cause and primitive chain,
        reproducible artifacts or sufficient implementation detail, and
        continuing value beyond one Windows build.
      </p>
    </header>
    <div class="atlas__cases">
      {
        caseStudies.map((study) => (
          <article>
            <div class="atlas__case-meta">
              <>
                <span>{study.level}</span>
                <span>Recommended lab</span>
              </>
            </div>
            <h3>
              <a href={study.url} target="_blank" rel="noreferrer">
                {study.title}
              </a>
            </h3>
            <p class="atlas__case-source">{study.source}</p>
            <p>
              <strong>Chain:</strong> {study.primitive}
            </p>
            <p>{study.reason}</p>
          </article>
        ))
      }
    </div>
    <aside class="atlas__rule">
      <strong>Case-study template</strong>
      <p>
        Context → reachable entry point → root cause → primitive with
        constraints → reliability work → mitigation interaction → fixed build
        and patch diff → detection/forensics → lab notes → primary references.
      </p>
    </aside>
  </section>

  <section
    class="atlas__section"
    id="tooling"
    aria-labelledby="tooling-heading"
  >
    <header class="atlas__section-head">
      <div>
        <p class="atlas__eyebrow">Tools chosen by workflow stage</p><h2
          id="tooling-heading"
        >
          Tooling
        </h2>
      </div>
      <p>
        This is broader than a static/fuzz/debug list. Each group states when it
        belongs in the workflow; status labels call out training-only, archived,
        or isolated-lab use where necessary.
      </p>
    </header>
    <div class="atlas__families atlas__families--tools">
      {
        toolFamilies.map((family, index) => (
          <details class="atlas__family" open={index === 0}>
            <summary>
              <>
                <span>{family.title}</span>
                <small>
                  {family.stage} · {family.tools.length} tools
                </small>
              </>
            </summary>
            <p class="atlas__family-intro">{family.description}</p>
            <ul class="atlas__tools">
              {family.tools.map((tool) => (
                <li>
                  <div>
                    <a href={tool.url} target="_blank" rel="noreferrer">
                      {tool.name}
                    </a>
                    {tool.status && <span>{tool.status}</span>}
                  </div>
                  <p>{tool.use}</p>
                </li>
              ))}
            </ul>
          </details>
        ))
      }
    </div>
  </section>
</section>

<script>
  document
    .querySelectorAll<HTMLButtonElement>("[data-atlas-query]")
    .forEach((button) => {
      button.addEventListener("click", () => {
        const input = document.querySelector<HTMLInputElement>(
          "[data-research-search]",
        );
        const library =
          document.querySelector<HTMLElement>("#research-library");
        if (!input || !library) return;

        input.value = button.dataset.atlasQuery ?? "";
        input.dispatchEvent(new Event("input", { bubbles: true }));
        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        library.scrollIntoView({
          behavior: reducedMotion ? "auto" : "smooth",
          block: "start",
        });
        input.focus({ preventScroll: true });
      });
    });
</script>

