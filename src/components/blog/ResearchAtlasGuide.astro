const primitiveFamilies: AtlasFamily[] = [
  {
    title: "Memory access capabilities",
    description:
      "Describe exactly what memory can be observed or changed. Width, alignment, address range, repetition, process context, and whether the operation is atomic are part of the primitive—not implementation trivia.",
    entries: [
      {
        name: "Arbitrary read",
        description:
          "Read attacker-selected virtual memory. Track kernel/user range, readable length, alignment, fault behavior, and whether repeated reads are stable.",
      },
      {
        name: "Relative or out-of-bounds read",
        description:
          "Read only near a legitimate object or buffer. It is often enough for a pointer, cookie, pool metadata, or secret disclosure, but it is not equivalent to unrestricted read.",
      },
      {
        name: "Information leak",
        description:
          "Disclose an address, handle, token field, uninitialized bytes, or object metadata. Model the exact leaked value and the mitigation it defeats, such as KASLR.",
      },
      {
        name: "Arbitrary write",
        description:
          "Write attacker-controlled data to an attacker-selected address. Record size, alignment, repeatability, address restrictions, and whether the old value is known.",
      },
      {
        name: "Write-what-where",
        description:
          "A strong arbitrary-write form with independent control of destination and value. Pointer provenance and copy length still determine whether it is reliable.",
      },
      {
        name: "Constrained write",
        description:
          "A zero write, NULL write, constant write, partial-pointer overwrite, increment/decrement, or bit flip. These deserve separate tags because their viable targets differ sharply.",
      },
      {
        name: "Read-modify-write",
        description:
          "Change selected bits while preserving surrounding state. This is especially useful for token flags, access masks, reference state, and mitigation fields.",
      },
      {
        name: "Controlled dereference",
        description:
          "Cause privileged code to read from or write through a chosen pointer without fully controlling the transferred value. Probe mode and exception handling often decide exploitability.",
      },
      {
        name: "Controlled call target",
        description:
          "Redirect an indirect call, callback, dispatch pointer, vtable entry, or return address. Modern control-flow and shadow-stack mitigations must be recorded beside it.",
      },
    ],
  },
  {
    title: "File, directory & namespace capabilities",
    description:
      "Filesystem and Object Manager bugs frequently grant narrow but powerful operations. The atlas keeps creation, deletion, replacement, redirection, and permission changes distinct so a case study can show the real conversion step.",
    entries: [
      {
        name: "Arbitrary file read",
        description:
          "Read a privileged, locked, or cross-user file. Capture whether the primitive bypasses the file DACL, sharing mode, EFS, backup semantics, or only a path restriction.",
      },
      {
        name: "Arbitrary file creation",
        description:
          "Create a new file at an attacker-selected privileged path. Content control, owner, inherited DACL, overwrite behavior, and chosen extension determine the usable sink.",
      },
      {
        name: "Arbitrary file write / overwrite",
        description:
          "Write controlled bytes into an existing privileged file. Append-only, offset-limited, truncating, and whole-file replacement variants are modeled separately.",
      },
      {
        name: "Arbitrary file delete",
        description:
          "Delete a chosen file as a privileged principal. Deletion alone rarely executes code; a strong case study must explain the fail-open target or the delete-to-create/rollback conversion.",
      },
      {
        name: "Arbitrary file move / rename",
        description:
          "Move a controlled or privileged file across directories or names. Replace-if-exists behavior, volume boundaries, and final ownership can make this stronger than write.",
      },
      {
        name: "Arbitrary directory creation",
        description:
          "Create a filesystem directory or Object Manager directory at a chosen path. This can enable namespace shadowing, later symbolic-link placement, or privileged child creation.",
      },
      {
        name: "Arbitrary directory delete",
        description:
          "Remove a directory tree or redirect a privileged cleanup operation. Whether traversal follows reparse points and whether non-empty targets are accepted are core constraints.",
      },
      {
        name: "Junction / mount-point creation",
        description:
          "Redirect a filesystem directory lookup through an NTFS reparse point. The chain must document who resolves each path component and when the attacker can swap it.",
      },
      {
        name: "Object Manager symbolic link",
        description:
          "Redirect an NT namespace lookup, commonly through an object directory such as RPC Control. This differs from an NTFS symbolic link and does not require the same privilege.",
      },
      {
        name: "Hard-link creation",
        description:
          "Give another name to an existing file and induce a privileged writer to modify it. Modern link restrictions, ownership, volume, and open-handle rules must be checked.",
      },
      {
        name: "Reparse-point substitution",
        description:
          "Swap, retarget, or race a reparse point between validation and use. Record the exact identity check that is absent or invalidated.",
      },
      {
        name: "ACL / owner manipulation",
        description:
          "Change a file, directory, registry key, service, device, pipe, or kernel object's DACL, owner, integrity label, or mandatory policy to unlock a later operation.",
      },
      {
        name: "Privileged file copy / restore",
        description:
          "Make a privileged component copy, quarantine, extract, repair, or restore attacker-influenced bytes. Destination validation and inherited security are the primary invariants.",
      },
      {
        name: "Oplock-assisted path race",
        description:
          "Hold a privileged file operation at a deterministic point, mutate the namespace, then release it. The oplock is a race-winning building block, not the vulnerability itself.",
      },
    ],
  },
  {
    title: "Identity, object & control capabilities",
    description:
      "These capabilities act on securable objects or privileged control planes. The requested access mask and the server-side authorization performed after opening the object both belong in the record.",
    entries: [
      {
        name: "Handle acquisition / duplication",
        description:
          "Obtain or duplicate a process, thread, token, section, device, service, job, or ALPC handle with rights the caller should not possess.",
      },
      {
        name: "Token impersonation",
        description:
          "Acquire and impersonate a more privileged token. Record impersonation level, token type, session, integrity level, privileges, and whether primary-token conversion is possible.",
      },
      {
        name: "Named-pipe creation / squatting",
        description:
          "Pre-create or control a pipe endpoint that a privileged client trusts by name. The security boundary is crossed only when peer identity is not authenticated correctly.",
      },
      {
        name: "Registry create / write / delete",
        description:
          "Modify privileged configuration, service parameters, COM registration, security policy, or a loader-controlled value. Value type, WOW64 view, and trigger are material.",
      },
      {
        name: "Service create / reconfigure / control",
        description:
          "Create a service, change its binary path or account, alter failure actions, start/stop it, or send a privileged custom control. Each right is tracked independently.",
      },
      {
        name: "Scheduled-task create / modify / trigger",
        description:
          "Influence task actions, principals, working directories, COM handlers, or triggers. A writable payload location and the task's effective token complete the chain.",
      },
      {
        name: "COM registration / activation redirection",
        description:
          "Control a CLSID, AppID, TreatAs, proxy/stub, in-process server, or activation path used by a more privileged client.",
      },
      {
        name: "Driver load / unload",
        description:
          "Register, load, map, replace, or unload kernel code. Signature enforcement, vulnerable-driver policy, HVCI, service rights, and cleanup method define the real capability.",
      },
      {
        name: "Object allocation / free",
        description:
          "Cause privileged allocation, release, or reference-count transitions for selected object types. This is a heap-shaping or lifetime primitive until paired with reuse or corruption.",
      },
      {
        name: "Process / thread control",
        description:
          "Open, suspend, terminate, create, inject into, or change the context of a target process or thread. The exact access rights prevent vague 'process control' claims.",
      },
    ],
  },
  {
    title: "Mapping, hardware & exploit composition",
    description:
      "This family separates low-level access mechanisms and exploitation building blocks from final security impact. Pool spray, I/O rings, WNF, token swap, and ROP should never be presented as though they were the original bug class.",
    entries: [
      {
        name: "Physical-memory mapping",
        description:
          "Map or translate physical pages into an accessible virtual range. Firmware reservations, RAM ranges, page attributes, VBS, and IOMMU state constrain the result.",
      },
      {
        name: "MDL mapping",
        description:
          "Build, reuse, or corrupt an MDL to lock and map pages. Track ownership, process context, access mode, cache type, and lifetime of the mapped view.",
      },
      {
        name: "PTE manipulation",
        description:
          "Change page-table entries to alter write, execute, user/supervisor, or mapping properties. HVCI, KDP, secure-kernel ownership, and TLB coherence matter.",
      },
      {
        name: "MMIO / port I/O / MSR access",
        description:
          "Reach device registers, I/O ports, or model-specific registers through an exposed driver. Classify each operation separately because their security consequences differ.",
      },
      {
        name: "DMA capability",
        description:
          "Program a device or exposed adapter path to access system memory. IOMMU policy, device isolation, address width, and physical presence determine scope.",
      },
      {
        name: "Pool spray / grooming",
        description:
          "Shape allocator state so a freed or overflowing object meets a useful neighbor or replacement. It stabilizes a primitive; it is not a vulnerability class.",
      },
      {
        name: "Fake-object construction",
        description:
          "Place a controlled object, vtable, pipe attribute, WNF state, I/O-ring buffer, palette, or bitmap where privileged code will interpret it as trusted state.",
      },
      {
        name: "Kernel ROP / data-only chain",
        description:
          "Compose gadgets or protected data changes when direct code execution is blocked. The atlas records which mitigations force the chosen strategy.",
      },
      {
        name: "PreviousMode manipulation",
        description:
          "Change the kernel's trust decision for a thread so system calls treat user pointers or handles as kernel-originated. This is an exploitation technique and end-state enabler.",
      },
      {
        name: "Token swap / privilege edit",
        description:
          "Replace a process token or modify token privilege/group state. The primitive used to perform the change and the restoration strategy remain separate fields.",
      },
      {
        name: "Security-control impact",
        description:
          "PPL bypass, DSE/CI disablement, callback removal, EDR termination, credential access, persistence, sandbox escape, and SYSTEM execution are outcomes—not primitives.",
      },
    ],
  },
];

const vulnerabilityFamilies: AtlasFamily[] = [
  {
    title: "Memory safety & numeric correctness",
    description:
      "Defects that violate object bounds, type, initialization, or size arithmetic before any exploitation capability is derived.",
    entries: [
      {
        name: "Out-of-bounds read / write",
        description:
          "Index, offset, count, or length permits access outside the intended object. Record direction, distance, controllability, and the adjacent allocation or mapping.",
      },
      {
        name: "Stack / heap / pool overflow",
        description:
          "A copy or write exceeds its destination. Keep stack, user heap, paged pool, nonpaged pool, session pool, and secure pool distinct because exploitation differs.",
      },
      {
        name: "Use-after-free",
        description:
          "Code retains or reacquires a pointer after object lifetime ended. Capture the freeing path, stale reference, replacement type, and synchronization assumptions.",
      },
      {
        name: "Double free / reference-count error",
        description:
          "An object is released twice or its reference count crosses the valid lifetime boundary. Underflow, premature zero, and mismatched ownership are separate patterns.",
      },
      {
        name: "Type confusion",
        description:
          "Code interprets an object, handle, message, or union as the wrong type without validating the discriminator or runtime type.",
      },
      {
        name: "Uninitialized memory",
        description:
          "Uninitialized stack, pool, structure padding, or output data influences control flow or crosses a trust boundary as disclosure.",
      },
      {
        name: "Integer overflow / truncation / signedness",
        description:
          "Arithmetic changes a size, offset, allocation, index, or comparison. Specify bit width and the later memory or policy decision it corrupts.",
      },
      {
        name: "Invalid / NULL pointer handling",
        description:
          "A pointer is trusted, probed incorrectly, or dereferenced after an incomplete check. A crash is not automatically exploitable; control and mapping constraints matter.",
      },
    ],
  },
  {
    title: "Lifetime, concurrency & execution context",
    description:
      "Defects where separately valid operations become unsafe because state changes between them or code runs in the wrong context.",
    entries: [
      {
        name: "Race condition",
        description:
          "Concurrent operations violate an invariant. A useful record identifies participants, shared state, winning condition, race window, and deterministic synchronization method.",
      },
      {
        name: "TOCTOU / double fetch",
        description:
          "Privileged code validates data or a path, then consumes a mutable version later. User memory, shared sections, files, registry, and object namespaces need separate tags.",
      },
      {
        name: "Reference / lifetime mismatch",
        description:
          "A pointer, handle, callback registration, work item, timer, IRP, or object outlives the owner that guaranteed its validity.",
      },
      {
        name: "Reentrancy / callback race",
        description:
          "A callback, APC, completion, message pump, or external component re-enters code while invariants are temporarily broken.",
      },
      {
        name: "Cancellation / teardown bug",
        description:
          "IRP cancellation, process exit, device removal, service stop, or error cleanup races active work and leaves stale state or repeated cleanup.",
      },
      {
        name: "IRQL / locking violation",
        description:
          "Code touches pageable memory, waits, frees, or calls an unsafe API at the wrong IRQL or under an incompatible lock, creating corruption or deadlock conditions.",
      },
      {
        name: "Process / session context confusion",
        description:
          "A driver or service assumes the current process, thread, desktop, session, silo, or impersonation state still represents the original requester.",
      },
    ],
  },
  {
    title: "Authorization, ACL & trust-boundary failures",
    description:
      "Low-privilege reachability is evidence of exposure, not automatically a vulnerability. The defect exists when the granted object rights or a missing per-operation check let that caller perform an action outside the intended security boundary.",
    entries: [
      {
        name: "Weak device-object DACL",
        description:
          "A named device grants World, Authenticated Users, or another low-trust SID enough access to open a dangerous path. The review must pair the SDDL/ACE with reachable IOCTLs and their per-request checks.",
        note: "World-readable telemetry can be intentional; World-write plus a privileged IOCTL with no authorization is the exploitable chain.",
      },
      {
        name: "Weak service DACL",
        description:
          "A service grants rights such as SERVICE_CHANGE_CONFIG, WRITE_DAC, WRITE_OWNER, START, STOP, or a dangerous user-defined control to an untrusted principal.",
        note: "SERVICE_CHANGE_CONFIG can replace the executable path; START/STOP alone is usually availability impact unless another writable configuration or load path exists.",
      },
      {
        name: "Weak file / directory / registry DACL",
        description:
          "A low-privilege user can modify a binary, DLL search directory, COM registration, service parameter, task action, policy value, or other object later trusted by privileged code.",
      },
      {
        name: "NULL / absent / inherited security descriptor",
        description:
          "An object is created with unintended defaults, a NULL DACL, unsafe inheritance, or inconsistent ACLs across a device stack or namespace.",
      },
      {
        name: "Missing access or privilege check",
        description:
          "The entry point is intentionally reachable, but a sensitive operation never verifies the caller's token, access mask, privilege, integrity level, capability, or trust label.",
      },
      {
        name: "Access-mode confusion",
        description:
          "KernelMode versus UserMode, RequestorMode, SL_FORCE_ACCESS_CHECK, previous mode, or a trusted-handle flag is used incorrectly and suppresses a required access check.",
      },
      {
        name: "Confused deputy",
        description:
          "A privileged service, broker, driver, or installer performs a valid operation on attacker-selected data or destinations without binding it to an authorized request.",
      },
      {
        name: "Impersonation failure",
        description:
          "A server forgets to impersonate, reverts too early, accepts Identification-level identity as authorization, or uses its own token for a client-controlled action.",
      },
      {
        name: "Endpoint ACL / peer-authentication failure",
        description:
          "RPC, ALPC, named pipe, COM, shared-memory, or object-namespace endpoints are open too broadly or trust a name/session instead of authenticating the peer.",
      },
      {
        name: "Token / handle context confusion",
