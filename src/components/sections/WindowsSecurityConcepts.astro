---
import ResearchAtlasGuide from "../blog/ResearchAtlasGuide.astro";
import Badge from "../ui/data-display/Badge/Badge.astro";
import Button from "../ui/form/Button/Button.astro";
import Container from "../ui/layout/Container/Container.astro";
import Section from "../ui/layout/Section/Section.astro";

const readingModel = [
  {
    step: "01",
    title: "Locate the boundary",
    description:
      "Identify the weaker principal, privileged component, transport, reachable method, and execution context.",
  },
  {
    step: "02",
    title: "Name the broken invariant",
    description:
      "Classify the root cause precisely: bounds, lifetime, authorization, path identity, parsing, or protocol state.",
  },
  {
    step: "03",
    title: "Measure the primitive",
    description:
      "Describe the capability and every constraint: target, width, value control, timing, identity, repetition, and failure behavior.",
  },
  {
    step: "04",
    title: "Build the composition",
    description:
      "Add the leak, race, target, privileged consumer, mapping, token, or loader that converts the primitive into a stronger one.",
  },
  {
    step: "05",
    title: "Test the boundaries",
    description:
      "Verify active mitigations, fixed versions, detection evidence, cleanup, and the exact final authority obtained.",
  },
] as const;
---

<Section spacing="xl" class="concepts-page">
  <Container size="xl">
    <nav class="concepts-page__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Blogs</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">Windows Security Concepts</span>
    </nav>

    <header class="concepts-page__hero">
      <div class="concepts-page__hero-copy">
        <Badge variant="outline" size="sm">One-page knowledge base</Badge>
        <p class="concepts-page__eyebrow">Windows security research handbook</p>
        <h1>Understand the chain, not only the bug name.</h1>
        <p class="concepts-page__lead">
          A practical theory map for Windows vulnerability research: techniques,
          primitives, vulnerability classes, attack surfaces, driver families,
          mitigations, case studies, and tooling—connected through one
          capability-first model.
        </p>
        <div class="concepts-page__actions">
          <Button href="#atlas-overview" size="lg">Start with the model</Button>
          <Button
            href="/blog/security-research-index/#research-library"
            variant="secondary"
            size="lg">Open the source library</Button
          >
        </div>
      </div>

      <aside class="concepts-page__scope" aria-label="Handbook scope">
        <p>Designed for</p>
        <ul>
          <li>Windows kernel and driver research</li>
          <li>Privileged services, RPC, COM, ALPC, and named pipes</li>
          <li>Filesystem, Object Manager, ACL, DACL, and identity chains</li>
          <li>Exploit composition under modern mitigations</li>
        </ul>
        <p>
          CTF writeups remain separate. This page is the durable theory layer;
          the research library supplies primary sources and lab material.
        </p>
      </aside>
    </header>

    <section
      class="concepts-page__reading-model"
      aria-labelledby="reading-model-heading"
    >
      <header>
        <p class="concepts-page__eyebrow">A repeatable reading method</p>
        <h2 id="reading-model-heading">How to read any finding</h2>
        <p>
          If a writeup skips one of these stages, treat that stage as an open
          research question rather than an implied fact.
        </p>
      </header>
      <ol>
        {
          readingModel.map((item) => (
            <li>
              <span>{item.step}</span>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <ResearchAtlasGuide standalone />
  </Container>
</Section>

<style>
  .concepts-page {
    overflow: clip;
  }

  .concepts-page__breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-xl);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .concepts-page__breadcrumb a {
    color: var(--color-text-primary);
    text-underline-offset: var(--spacing-1);
  }

  .concepts-page__breadcrumb a:focus-visible,
  .concepts-page__actions a:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .concepts-page__hero {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.65fr);
    align-items: end;
    gap: var(--space-2xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
  }

  .concepts-page__hero-copy {
    display: grid;
    justify-items: start;
    gap: var(--space-md);
  }

  .concepts-page__eyebrow {
    margin: 0;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .concepts-page__hero h1 {
    max-width: var(--container-wide);
    margin: 0;
    font-size: var(--text-5xl);
    letter-spacing: var(--tracking-tight);
  }

  .concepts-page__lead {
    max-width: var(--container-wide);
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .concepts-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
  }

  .concepts-page__scope {
    display: grid;
    gap: var(--space-md);
    padding: var(--space-xl);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    background: var(--color-bg-secondary);
    box-shadow: var(--shadow-sm);
  }

  .concepts-page__scope p,
  .concepts-page__scope ul {
    margin: 0;
  }

  .concepts-page__scope > p:first-child {
    color: var(--color-text-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }

  .concepts-page__scope ul {
    display: grid;
    gap: var(--space-sm);
    padding-left: var(--space-lg);
  }

  .concepts-page__scope li,
  .concepts-page__scope > p:last-child {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .concepts-page__scope > p:last-child {
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .concepts-page__reading-model {
    display: grid;
    gap: var(--space-xl);
    padding-block: var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
  }

  .concepts-page__reading-model > header {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
    align-items: end;
    gap: var(--space-xl);
  }

  .concepts-page__reading-model h2,
  .concepts-page__reading-model header > p:last-child {
    margin: 0;
  }

  .concepts-page__reading-model h2 {
    margin-top: var(--space-xs);
  }

  .concepts-page__reading-model header > p:last-child {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .concepts-page__reading-model ol {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .concepts-page__reading-model li {
    min-width: 0;
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: var(--card);
    box-shadow: var(--shadow-sm);
  }

  .concepts-page__reading-model li > span {
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .concepts-page__reading-model h3 {
    margin: var(--space-xs) 0;
    font-size: var(--text-base);
  }

  .concepts-page__reading-model li p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 64rem) {
    .concepts-page__hero,
    .concepts-page__reading-model > header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .concepts-page__reading-model ol {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 40rem) {
    .concepts-page__hero {
      gap: var(--space-xl);
      padding-bottom: var(--space-2xl);
    }

    .concepts-page__actions {
      display: grid;
      width: 100%;
    }

    .concepts-page__reading-model {
      padding-block: var(--space-2xl);
    }

    .concepts-page__reading-model ol {
      grid-template-columns: 1fr;
    }
  }
</style>
