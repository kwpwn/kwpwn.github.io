---
import catalog from "../../data/windows-service-vulnerabilities.generated.json";

export interface Props {
  datasetUrl?: string;
}

const { datasetUrl = "/data/windows-service-vulnerabilities.json" } =
  Astro.props;
const { meta, services, vulnerabilities } = catalog;
const orderedServices = [...services].sort(
  (left, right) =>
    left.category.localeCompare(right.category) ||
    left.name.localeCompare(right.name),
);
const categories = [...new Set(services.map((entry) => entry.category))].sort();
const featured = vulnerabilities.filter((entry) => entry.exploited).slice(0, 8);
const formatNumber = (value: number) =>
  new Intl.NumberFormat("en-US").format(value);
const formatDate = (value: string | null) =>
  value
    ? new Intl.DateTimeFormat("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
        timeZone: "UTC",
      }).format(new Date(`${value}T00:00:00Z`))
    : "Date not published";
const serviceBySlug = new Map(services.map((entry) => [entry.slug, entry]));
---

<section
  class="service-atlas"
  data-service-atlas
  data-dataset-url={datasetUrl}
  aria-labelledby="service-atlas-title"
>
  <header class="service-atlas__hero">
    <p class="service-atlas__eyebrow">Evidence-backed Windows research</p>
    <h1 id="service-atlas-title">Windows Service Vulnerability Atlas</h1>
    <p class="service-atlas__lede">
      A searchable historical catalog of vulnerabilities in built-in Windows
      services, server roles, service protocols, clients, and endpoint
      substrates. Every record keeps its bug class, impact, affected product
      matrix, fixed builds, exploitation evidence, and carefully qualified
      public-PoC status together.
    </p>
    <div class="service-atlas__hero-actions">
      <a href="#vulnerability-explorer">
        Explore {formatNumber(meta.vulnerabilityCount)} records
      </a>
      <a href={datasetUrl}>Open the JSON dataset</a>
    </div>
    <div class="service-atlas__metrics" aria-label="Catalog coverage">
      <article>
        <strong>{formatNumber(meta.serviceCount)}</strong><span
          >service families</span
        >
      </article>
      <article>
        <strong>{formatNumber(meta.uniqueCveCount)}</strong><span
          >unique CVEs</span
        >
      </article>
      <article>
        <strong>{formatNumber(meta.advisoryCount)}</strong><span
          >security advisories</span
        >
      </article>
      <article>
        <strong>{formatNumber(meta.knownExploitedCount)}</strong><span
          >known exploited</span
        >
      </article>
      <article>
        <strong>{formatNumber(meta.publicPocCount)}</strong><span
          >PoC leads</span
        >
      </article>
    </div>
  </header>

  <aside class="service-atlas__scope" aria-labelledby="scope-heading">
    <div>
      <p class="service-atlas__eyebrow">Coverage contract</p>
      <h2 id="scope-heading">What “complete” means here</h2>
    </div>
    <div>
      <p><strong>Included:</strong> {meta.definition}</p>
      <p><strong>Excluded:</strong> {meta.exclusions}</p>
      <p>
        The census inspected all {formatNumber(meta.msrcRecordCount)} records in the
        Microsoft Security Update Guide feed and classified the {
          formatNumber(meta.microsoftCnaRecordCount)
        }
        records issued by Microsoft as of <time datetime={meta.snapshotDate}
          >{formatDate(meta.snapshotDate)}</time
        >. A zero-day is modeled as disclosure or exploitation state—not as a
        root-cause class. Once a fix and public record exist, the same entry is
        an n-day research target; the history is preserved instead of copied
        into a second list.
      </p>
    </div>
  </aside>

  <section class="service-atlas__method" aria-labelledby="method-heading">
    <div class="service-atlas__section-heading">
      <div>
        <p class="service-atlas__eyebrow">How to read the evidence</p>
        <h2 id="method-heading">Source and confidence model</h2>
      </div>
      <p>
        Facts from vendors and government catalogs are separated from community
        discovery metadata. Missing evidence is reported as unknown, never
        silently converted into “safe” or “no exploit.”
      </p>
    </div>
    <ol class="service-atlas__method-grid">
      <li>
        <span>01</span><strong>Microsoft record</strong>
        <p>
          CVE, severity, CWE, impact, product versions, KBs, fixed builds,
          disclosure, and MSRC exploitation status.
        </p>
      </li>
      <li>
        <span>02</span><strong>Independent exploitation signal</strong>
        <p>
          CISA KEV is merged as a second authoritative signal for observed
          exploitation and remediation deadlines.
        </p>
      </li>
      <li>
        <span>03</span><strong>PoC confidence</strong>
        <p>
          “Credible reproducer” is curated. “Indexed candidate” is a lead from a
          public index and must be reviewed in an isolated lab.
        </p>
      </li>
      <li>
        <span>04</span><strong>No PoC located</strong>
        <p>
          No indexed public repository was found at snapshot time. This does not
          claim that private or unindexed exploit code does not exist.
        </p>
      </li>
    </ol>
    <div class="service-atlas__sources">
      <a href={meta.sourceGuideUrl} target="_blank" rel="noreferrer"
        >Microsoft Security Update Guide</a
      >
      <a
        href="https://www.cisa.gov/known-exploited-vulnerabilities-catalog"
        target="_blank"
        rel="noreferrer">CISA KEV</a
      >
      <a
        href="https://github.com/CVEProject/cvelistV5"
        target="_blank"
        rel="noreferrer">Official CVE List cache</a
      >
      <a
        href="https://github.com/nomi-sec/PoC-in-GitHub"
        target="_blank"
        rel="noreferrer">PoC discovery index</a
      >
      <a
        href="https://arxiv.org/abs/2210.08374"
        target="_blank"
        rel="noreferrer">PoC safety research</a
      >
    </div>
  </section>

  <section class="service-atlas__inventory" aria-labelledby="inventory-heading">
    <div class="service-atlas__section-heading">
      <div>
        <p class="service-atlas__eyebrow">Service taxonomy</p>
        <h2 id="inventory-heading">Mapped service families</h2>
      </div>
      <p>
        Select a family to move directly into its vulnerability history. SCM
        names are identifiers, not proof that every affected code path runs in a
        standalone service process.
      </p>
    </div>
    <details class="service-atlas__inventory-browser">
      <summary>
        Browse all {formatNumber(orderedServices.length)} mapped families
      </summary>
      <div class="service-atlas__service-grid">
        {
          orderedServices.map((entry) => (
            <button
              type="button"
              class="service-atlas__service"
              data-service-pick={entry.slug}
            >
              <span>{entry.category}</span>
              <strong>{entry.name}</strong>
              <small>
                {entry.kind.replaceAll("-", " ")} · {entry.exposure}
              </small>
              <b>{formatNumber(entry.vulnerabilityCount)} records</b>
            </button>
          ))
        }
      </div>
    </details>
  </section>

  <section
    class="service-atlas__explorer"
    id="vulnerability-explorer"
    aria-labelledby="explorer-heading"
  >
    <div class="service-atlas__section-heading">
      <div>
        <p class="service-atlas__eyebrow">Filterable evidence ledger</p>
        <h2 id="explorer-heading">Vulnerability explorer</h2>
      </div>
      <p>
        Search a CVE, service, bug class, Windows release, fixed build, or KB.
        Filters combine, and results are newest first.
      </p>
    </div>

    <form class="service-atlas__filters" data-service-filters>
      <label class="service-atlas__search">
        <span>Search the catalog</span>
        <input
          type="search"
          name="query"
          placeholder="CVE-2021-34527, Spooler, use-after-free, Server 2022…"
          autocomplete="off"
          data-service-search
        />
      </label>
      <label>
        <span>Service family</span>
        <select name="service" data-service-select>
          <option value="">All service families</option>
          {
            orderedServices.map((entry) => (
              <option value={entry.slug}>{entry.name}</option>
            ))
          }
        </select>
      </label>
      <label>
        <span>Category</span>
        <select name="category">
          <option value="">All categories</option>
          {
            categories.map((category) => (
              <option value={category}>{category}</option>
            ))
          }
        </select>
      </label>
      <label>
        <span>Impact</span>
        <select name="impact">
          <option value="">All impacts</option>
          <option value="Remote Code Execution">Remote code execution</option>
          <option value="Elevation of Privilege">Elevation of privilege</option>
          <option value="Information Disclosure">Information disclosure</option>
          <option value="Denial of Service">Denial of service</option>
          <option value="Security Feature Bypass"
            >Security feature bypass</option
          >
          <option value="Spoofing">Spoofing</option>
        </select>
      </label>
      <label>
        <span>Evidence state</span>
        <select name="evidence">
          <option value="">All evidence states</option>
          <option value="exploited">Known exploited</option>
          <option value="public">Publicly disclosed</option>
          <option value="not-known">Neither known</option>
        </select>
      </label>
      <label>
        <span>Public PoC</span>
        <select name="poc">
          <option value="">Any PoC status</option>
          <option value="credible-reproducer">Credible reproducer</option>
          <option value="indexed-unverified">Indexed candidate</option>
          <option value="none-located">None located</option>
        </select>
      </label>
      <label>
        <span>Severity</span>
        <select name="severity">
          <option value="">All severities</option>
          <option value="Critical">Critical</option>
          <option value="Important">Important</option>
          <option value="Moderate">Moderate</option>
          <option value="Low">Low</option>
        </select>
      </label>
      <button type="reset" data-service-reset>Reset filters</button>
    </form>

    <div class="service-atlas__result-bar">
      <p data-service-status aria-live="polite">
        Loading the complete dataset…
      </p>
      <label>
        <span>Results per page</span>
        <select data-page-size>
          <option value="25">25</option>
          <option value="50" selected>50</option>
          <option value="100">100</option>
        </select>
      </label>
    </div>

    <div class="service-atlas__results" data-service-results aria-busy="true">
      {
        featured.map((entry) => {
          const service = serviceBySlug.get(entry.serviceSlug);
          return (
            <article class="service-atlas__record service-atlas__record--preview">
              <div>
                <a href={entry.sources.msrc} target="_blank" rel="noreferrer">
                  {entry.id}
                </a>
                <span>{entry.severity}</span>
                <span>Known exploited</span>
              </div>
              <h3>{entry.title}</h3>
              <p>{service?.name}</p>
            </article>
          );
        })
      }
    </div>
    <nav
      class="service-atlas__pagination"
      aria-label="Vulnerability result pages"
    >
      <button type="button" data-page-prev disabled>Previous</button>
      <span data-page-label>Page 1</span>
      <button type="button" data-page-next disabled>Next</button>
    </nav>
    <noscript>
      <p class="service-atlas__noscript">
        JavaScript is required for local filtering. The complete evidence set is
        still available from the <a href={datasetUrl}
          >machine-readable JSON endpoint</a
        >.
      </p>
    </noscript>
  </section>
</section>

<script>
  interface ServiceEntry {
    slug: string;
    name: string;
    category: string;
    kind: string;
    exposure: string;
    description: string;
    scmNames: string[];
  }

  interface VulnerabilityEntry {
    id: string;
    recordType: "cve" | "security-advisory";
    serviceSlug: string;
    title: string;
    disclosed: string | null;
    severity: string;
    impact: string;
    cvss: number | null;
    vector: string | null;
    cwe: string[];
    bugClass: string;
    impactExplanation: string;
    publiclyDisclosed: boolean;
    exploited: boolean;
    zeroDayStatus: string;
    affectedProducts: string[];
    fixedBuilds: string[];
    kbArticles: Array<{ id: string; url: string; fixedBuild: string | null }>;
    poc: {
      status: string;
      url: string | null;
      repository: string | null;
      starsAtSnapshot?: number | null;
    };
    sources: {
      msrc: string;
      cve: string | null;
      kev: string | null;
      pocIndex: string | null;
    };
    kev: {
      dateAdded: string;
      requiredAction: string;
      dueDate: string;
      ransomwareUse: string;
    } | null;
  }

  interface CatalogPayload {
    services: ServiceEntry[];
    vulnerabilities: VulnerabilityEntry[];
  }

  const element = <K extends keyof HTMLElementTagNameMap>(
    tag: K,
    className?: string,
    text?: string,
  ) => {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text !== undefined) node.textContent = text;
    return node;
  };

  const appendLink = (
    parent: HTMLElement,
    text: string,
    href: string,
    className?: string,
  ) => {
    const link = element("a", className, text);
    link.href = href;
    link.target = "_blank";
    link.rel = "noreferrer";
    parent.append(link);
    return link;
  };

  const dateLabel = (value: string | null) =>
    value
      ? new Intl.DateTimeFormat("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric",
          timeZone: "UTC",
        }).format(new Date(`${value}T00:00:00Z`))
      : "Unknown date";

  const pocLabel = (status: string) =>
    ({
      "credible-reproducer": "Credible reproducer",
      "verified-primary": "Primary PoC",
      "indexed-unverified": "Indexed candidate — unverified",
      "none-located": "No public PoC located",
    })[status] ?? status;

  const disclosureLabel = (status: string) =>
    ({
      "exploited-and-publicly-disclosed":
        "Exploitation detected and public disclosure reported",
      "exploitation-detected-timing-unconfirmed":
        "Exploitation detected; pre-fix timing not established by this dataset",
      "known-exploited-timing-unconfirmed":
        "Known exploited; pre-fix timing not established by this dataset",
      "public-before-or-at-fix":
        "Publicly disclosed before or at the coordinated fix",
      "not-reported": "No zero-day or public-disclosure signal reported",
    })[status] ?? status;

  const makeList = (items: string[], empty: string) => {
    const wrapper = element("div", "service-atlas__compact-list");
    if (!items.length) {
      wrapper.append(element("p", undefined, empty));
      return wrapper;
    }
    const list = element("ul");
    items.forEach((item) => list.append(element("li", undefined, item)));
    wrapper.append(list);
    return wrapper;
  };

  document
    .querySelectorAll<HTMLElement>("[data-service-atlas]")
    .forEach((root) => {
      const form = root.querySelector<HTMLFormElement>(
        "[data-service-filters]",
      );
      const results = root.querySelector<HTMLElement>("[data-service-results]");
      const status = root.querySelector<HTMLElement>("[data-service-status]");
      const serviceSelect = root.querySelector<HTMLSelectElement>(
        "[data-service-select]",
      );
      const pageSizeSelect =
        root.querySelector<HTMLSelectElement>("[data-page-size]");
      const previous =
        root.querySelector<HTMLButtonElement>("[data-page-prev]");
      const next = root.querySelector<HTMLButtonElement>("[data-page-next]");
      const pageLabel = root.querySelector<HTMLElement>("[data-page-label]");
      if (
        !form ||
        !results ||
        !status ||
        !serviceSelect ||
        !pageSizeSelect ||
        !previous ||
        !next ||
        !pageLabel
      )
        return;

      let catalog: CatalogPayload | null = null;
      let filtered: VulnerabilityEntry[] = [];
      let page = 1;
      const serviceMap = new Map<string, ServiceEntry>();
      const searchIndex = new Map<string, string>();

      const renderRecord = (entry: VulnerabilityEntry) => {
        const service = serviceMap.get(entry.serviceSlug);
        const article = element("article", "service-atlas__record");
        article.id = entry.id.toLowerCase();

        const header = element("header");
        const identity = element("div", "service-atlas__identity");
        appendLink(
          identity,
          entry.id,
          entry.sources.msrc,
          "service-atlas__cve",
        );
        identity.append(
          element(
            "span",
            `service-atlas__badge service-atlas__badge--${entry.severity.toLowerCase()}`,
            entry.severity,
          ),
        );
        if (entry.exploited)
          identity.append(
            element(
              "span",
              "service-atlas__badge service-atlas__badge--danger",
              "Known exploited",
            ),
          );
        else if (entry.publiclyDisclosed)
          identity.append(
            element("span", "service-atlas__badge", "Publicly disclosed"),
          );
        header.append(identity);
        header.append(element("h3", undefined, entry.title));
        const metadata = element("p", "service-atlas__record-meta");
        metadata.textContent = `${service?.name ?? entry.serviceSlug} · ${dateLabel(entry.disclosed)} · ${entry.impact}${entry.cvss === null ? "" : ` · CVSS ${entry.cvss}`}`;
        header.append(metadata);
        article.append(header);

        const analysis = element("div", "service-atlas__analysis");
        const cause = element("section");
        cause.append(
          element("h4", undefined, "Bug / root-cause classification"),
        );
        cause.append(element("p", undefined, entry.bugClass));
        if (entry.cwe.length)
          cause.append(element("small", undefined, entry.cwe.join(" · ")));
        const impact = element("section");
        impact.append(element("h4", undefined, "Security impact"));
        impact.append(element("p", undefined, entry.impactExplanation));
        analysis.append(cause, impact);
        article.append(analysis);

        const details = element("details", "service-atlas__record-details");
        const summary = element(
          "summary",
          undefined,
          "Affected versions, fixed builds, PoC, and evidence",
        );
        details.append(summary);
        const grid = element("div", "service-atlas__detail-grid");

        const versions = element("section");
        versions.append(
          element(
            "h4",
            undefined,
            `Affected product matrix (${entry.affectedProducts.length})`,
          ),
        );
        versions.append(
          makeList(
            entry.affectedProducts,
            "MSRC did not publish a Windows product matrix for this record.",
          ),
        );
        grid.append(versions);

        const fixes = element("section");
        fixes.append(
          element(
            "h4",
            undefined,
            `Fixed builds & KBs (${entry.kbArticles.length})`,
          ),
        );
        if (entry.kbArticles.length) {
          const list = element("ul", "service-atlas__link-list");
          entry.kbArticles.forEach((kb) => {
            const item = element("li");
            appendLink(item, kb.id, kb.url);
            if (kb.fixedBuild)
              item.append(document.createTextNode(` — ${kb.fixedBuild}`));
            list.append(item);
          });
          fixes.append(list);
        } else {
          fixes.append(
            element(
              "p",
              undefined,
              "No fixed-build entry is present in the current MSRC product matrix.",
            ),
          );
        }
        grid.append(fixes);

        const poc = element("section", "service-atlas__poc");
        poc.append(element("h4", undefined, "Public PoC status"));
        const pocStatus = element("p");
        if (entry.poc.url)
          appendLink(pocStatus, pocLabel(entry.poc.status), entry.poc.url);
        else pocStatus.textContent = pocLabel(entry.poc.status);
        poc.append(pocStatus);
        if (entry.poc.status === "indexed-unverified") {
          poc.append(
            element(
              "small",
              undefined,
              "Unverified community lead. Inspect source and run only in a disposable, isolated lab; public PoC repositories can be incomplete or malicious.",
            ),
          );
        } else if (entry.poc.status === "none-located") {
          poc.append(
            element(
              "small",
              undefined,
              "This is a discovery result at snapshot time, not proof that exploit code does not exist.",
            ),
          );
        }
        grid.append(poc);

        const evidence = element("section");
        evidence.append(element("h4", undefined, "Evidence links"));
        evidence.append(
          element(
            "p",
            undefined,
            `Disclosure / zero-day state: ${disclosureLabel(entry.zeroDayStatus)}.`,
          ),
        );
        const links = element("div", "service-atlas__evidence-links");
        appendLink(links, "MSRC", entry.sources.msrc);
        if (entry.sources.cve)
          appendLink(links, "CVE record", entry.sources.cve);
        if (entry.sources.kev) appendLink(links, "CISA KEV", entry.sources.kev);
        if (entry.sources.pocIndex)
          appendLink(links, "PoC index record", entry.sources.pocIndex);
        evidence.append(links);
        if (entry.kev)
          evidence.append(
            element(
              "p",
              undefined,
              `CISA added ${entry.id} on ${entry.kev.dateAdded}; remediation due ${entry.kev.dueDate}. ${entry.kev.requiredAction}`,
            ),
          );
        grid.append(evidence);
        details.append(grid);
        article.append(details);
        return article;
      };

      const render = () => {
        const pageSize = Number(pageSizeSelect.value);
        const pageCount = Math.max(1, Math.ceil(filtered.length / pageSize));
        page = Math.min(Math.max(1, page), pageCount);
        const start = (page - 1) * pageSize;
        const pageItems = filtered.slice(start, start + pageSize);
        results.replaceChildren(...pageItems.map(renderRecord));
        results.setAttribute("aria-busy", "false");
        if (!pageItems.length)
          results.append(
            element(
              "p",
              "service-atlas__empty",
              "No records match every active filter.",
            ),
          );
        status.textContent = `${filtered.length.toLocaleString()} matching records${filtered.length ? ` · showing ${start + 1}–${Math.min(start + pageSize, filtered.length)}` : ""}`;
        pageLabel.textContent = `Page ${page} of ${pageCount}`;
        previous.disabled = page <= 1;
        next.disabled = page >= pageCount;
      };

      const applyFilters = () => {
        if (!catalog) return;
        const data = new FormData(form);
        const query = String(data.get("query") ?? "")
          .trim()
          .toLowerCase();
        const terms = query.split(/\s+/).filter(Boolean);
        const serviceSlug = String(data.get("service") ?? "");
        const category = String(data.get("category") ?? "");
        const impact = String(data.get("impact") ?? "");
        const evidence = String(data.get("evidence") ?? "");
        const poc = String(data.get("poc") ?? "");
        const severity = String(data.get("severity") ?? "");
        filtered = catalog.vulnerabilities.filter((entry) => {
          const service = serviceMap.get(entry.serviceSlug);
          const searchable = searchIndex.get(entry.id) ?? "";
          const evidenceMatch =
            !evidence ||
            (evidence === "exploited" && entry.exploited) ||
            (evidence === "public" && entry.publiclyDisclosed) ||
            (evidence === "not-known" &&
              !entry.exploited &&
              !entry.publiclyDisclosed);
          return (
            terms.every((term) => searchable.includes(term)) &&
            (!serviceSlug || entry.serviceSlug === serviceSlug) &&
            (!category || service?.category === category) &&
            (!impact || entry.impact === impact) &&
            evidenceMatch &&
            (!poc || entry.poc.status === poc) &&
            (!severity || entry.severity === severity)
          );
        });
        page = 1;
        render();
      };

      const load = async () => {
        try {
          const response = await fetch(
            root.dataset.datasetUrl ??
              "/data/windows-service-vulnerabilities.json",
          );
          if (!response.ok)
            throw new Error(`${response.status} ${response.statusText}`);
          catalog = (await response.json()) as CatalogPayload;
          catalog.services.forEach((entry) =>
            serviceMap.set(entry.slug, entry),
          );
          catalog.vulnerabilities.forEach((entry) => {
            const service = serviceMap.get(entry.serviceSlug);
            searchIndex.set(
              entry.id,
              [
                entry.id,
                entry.title,
                entry.disclosed,
                entry.bugClass,
                entry.impact,
                entry.zeroDayStatus,
                entry.cwe.join(" "),
                entry.affectedProducts.join(" "),
                entry.fixedBuilds.join(" "),
                entry.kbArticles
                  .map((kb) => `${kb.id} ${kb.fixedBuild ?? ""}`)
                  .join(" "),
                service?.name,
                service?.category,
                service?.scmNames.join(" "),
              ]
                .join(" ")
                .toLowerCase(),
            );
          });
          const requested = new URLSearchParams(window.location.search);
          const query = requested.get("q");
          const service = requested.get("service");
          if (query) {
            const input = form.elements.namedItem(
              "query",
            ) as HTMLInputElement | null;
            if (input) input.value = query;
          }
          if (service && serviceMap.has(service)) serviceSelect.value = service;
          applyFilters();
        } catch (error) {
          results.setAttribute("aria-busy", "false");
          results.replaceChildren(
            element(
              "p",
              "service-atlas__empty",
              "The catalog dataset could not be loaded. Use the JSON endpoint or try again.",
            ),
          );
          status.textContent = "Dataset unavailable";
          root.dataset.loadError =
            error instanceof Error ? error.message : "unknown";
        }
      };

      form.addEventListener("input", applyFilters);
      form.addEventListener("reset", () => window.setTimeout(applyFilters));
      pageSizeSelect.addEventListener("change", () => {
        page = 1;
        render();
      });
      previous.addEventListener("click", () => {
        page -= 1;
        render();
        root
          .querySelector("#explorer-heading")
          ?.scrollIntoView({ behavior: "smooth" });
      });
      next.addEventListener("click", () => {
        page += 1;
        render();
        root
          .querySelector("#explorer-heading")
          ?.scrollIntoView({ behavior: "smooth" });
      });
      root
        .querySelectorAll<HTMLButtonElement>("[data-service-pick]")
        .forEach((button) => {
          button.addEventListener("click", () => {
            serviceSelect.value = button.dataset.servicePick ?? "";
            applyFilters();
            root
              .querySelector("#vulnerability-explorer")
              ?.scrollIntoView({ behavior: "smooth", block: "start" });
          });
        });
      void load();
    });
</script>

