---
import { WindowsServiceAtlas } from "../components/sections";
import Container from "../components/ui/layout/Container/Container.astro";
import Section from "../components/ui/layout/Section/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = "en" as const;
const title = "Windows Service Vulnerability Atlas";
const description =
  "An evidence-backed catalog of Windows service CVEs, zero-day and exploitation state, bug classes, impact, affected versions, fixed builds, and qualified public PoCs.";
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path="/windows-service-vulnerabilities/"
>
  <Section spacing="xl">
    <Container size="xl">
      <WindowsServiceAtlas />
    </Container>
  </Section>
</BaseLayout>
