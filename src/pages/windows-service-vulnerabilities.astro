---
import { WindowsServiceHub } from "../components/sections";
import Container from "../components/ui/layout/Container/Container.astro";
import Section from "../components/ui/layout/Section/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = "en" as const;
const title = "Windows Service Vulnerability Research Portal";
const description =
  "Explore Windows service vulnerabilities through focused security topics and 103 target pages with theory, affected versions, fixed builds, exploitation evidence, and qualified public PoCs.";
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path="/windows-service-vulnerabilities/"
>
  <Section spacing="xl">
    <Container size="xl">
      <WindowsServiceHub locale={locale} />
    </Container>
  </Section>
</BaseLayout>
