---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { BlogCard } from "../components/blog/index";
import { siteConfig } from "../config/site.config";
import { slugify } from "../lib/utils";

const locale = "en" as const;
const currentTag = Astro.url.searchParams.get("tag") ?? "";
const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = allPosts
  .filter((post) => post.data.locale === locale && !post.data.draft)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const filteredPosts = currentTag
  ? posts.filter((post) =>
      post.data.tags.some((tag: string) => slugify(tag) === currentTag),
    )
  : posts;
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<BaseLayout
  title={siteConfig.name}
  description={siteConfig.description}
  locale={locale}
  path="/"
>
  <section class="posts container py-12">
    <header class="posts__header">
      <p class="posts__eyebrow">Latest articles</p>
      <h1>Blogs</h1>
      <p>Personal notes, articles, and things worth sharing.</p>
    </header>

    {tags.length > 0 && (
      <nav class="posts__filters" aria-label="Filter posts by category">
        <a href="/" aria-current={currentTag ? undefined : "page"}>All</a>
        {tags.map((tag) => {
          const value = slugify(tag);
          return <a href={`/?tag=${value}`} aria-current={currentTag === value ? "page" : undefined}>{tag}</a>;
        })}
      </nav>
    )}

    {filteredPosts.length > 0 ? (
      <div class="posts__grid">
        {filteredPosts.map((post) => <BlogCard post={post} locale={locale} headingLevel="h2" />)}
      </div>
    ) : (
      <p class="posts__empty">No posts yet.</p>
    )}
  </section>
</BaseLayout>

<style>
  .posts { display: grid; gap: var(--space-xl); }
  .posts__header { max-width: 48rem; }
  .posts__eyebrow { margin: 0 0 var(--space-xs); color: var(--color-text-secondary); font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; }
  .posts__header h1 { margin: 0; font-size: clamp(2.5rem, 6vw, 4.75rem); line-height: 1; letter-spacing: -0.04em; }
  .posts__header > p:last-child { max-width: 42rem; margin: var(--space-md) 0 0; color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; }
  .posts__filters { display: flex; flex-wrap: wrap; gap: var(--space-xs); padding-bottom: var(--space-lg); border-bottom: 1px solid var(--color-border); }
  .posts__filters a { padding: 0.375rem 0.875rem; border: 1px solid var(--color-border); border-radius: var(--radius-full); color: var(--color-text-secondary); font-size: 0.8125rem; text-decoration: none; }
  .posts__filters a[aria-current="page"] { border-color: var(--color-text-primary); background: var(--color-text-primary); color: var(--color-bg-primary); }
  .posts__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr)); gap: var(--space-lg); }
  .posts__empty { padding: var(--space-2xl); border: 1px dashed var(--color-border); border-radius: var(--radius-xl); color: var(--color-text-secondary); text-align: center; }
</style>
