---
import ApiFlagsCheatsheet from "../../components/handbook/ApiFlagsCheatsheet.astro";
import Container from "../../components/ui/layout/Container/Container.astro";
import Section from "../../components/ui/layout/Section/Section.astro";
import { i18nConfig } from "../../config/i18n.config";
import BaseLayout from "../../layouts/BaseLayout.astro";
import type { Locale } from "../../lib/site-config";

export function getStaticPaths() {
  return i18nConfig.locales
    .filter((locale) => locale !== i18nConfig.defaultLocale)
    .map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const title = "Windows API & Flags Cheatsheet";
const description =
  "A searchable Windows security research field guide for driver, service, filesystem, token, process, IPC, Native API, and mitigation interfaces and flags.";
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path={`/${locale}/windows-api-cheatsheet/`}
>
  <Section spacing="xl">
    <Container size="xl">
      <ApiFlagsCheatsheet />
    </Container>
  </Section>
</BaseLayout>
