---
import ConceptDocument from "../../../components/handbook/ConceptDocument.astro";
import Container from "../../../components/ui/layout/Container/Container.astro";
import Section from "../../../components/ui/layout/Section/Section.astro";
import { i18nConfig } from "../../../config/i18n.config";
import { handbookConcepts } from "../../../data/windows-security-handbook";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import type { Locale } from "../../../lib/site-config";

export function getStaticPaths() {
  return i18nConfig.locales
    .filter((locale) => locale !== i18nConfig.defaultLocale)
    .flatMap((locale) =>
      handbookConcepts.map((concept) => ({
        params: { locale, slug: concept.slug },
        props: { concept },
      })),
    );
}

const { concept } = Astro.props;
const locale = Astro.params.locale as Locale;
---

<BaseLayout
  title={`${concept.title} — Windows Security Handbook`}
  description={concept.summary}
  locale={locale}
  path={`/${locale}/windows-security-concepts/${concept.slug}/`}
>
  <Section spacing="xl">
    <Container size="xl">
      <ConceptDocument concept={concept} />
    </Container>
  </Section>
</BaseLayout>
