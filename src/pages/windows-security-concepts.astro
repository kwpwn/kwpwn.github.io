---
import { WindowsSecurityConcepts } from "../components/sections";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = "en" as const;
const title = "Windows Security Handbook";
const description =
  "A concept-first Windows security handbook with dedicated pages for primitives, vulnerability classes, attack surfaces, driver families, LPE, mitigations, APIs, flags, and research workflows.";
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path="/windows-security-concepts/"
>
  <WindowsSecurityConcepts />
</BaseLayout>
