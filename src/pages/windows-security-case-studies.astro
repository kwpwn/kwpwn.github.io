---
import CaseStudyLibrary from "../components/handbook/CaseStudyLibrary.astro";
import Container from "../components/ui/layout/Container/Container.astro";
import Section from "../components/ui/layout/Section/Section.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const locale = "en" as const;
const title = "Windows Security Case Studies";
const description =
  "Curated Windows security research chains plus a searchable coverage ledger for every KernelSight case study.";
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  path="/windows-security-case-studies/"
>
  <Section spacing="xl">
    <Container size="xl">
      <CaseStudyLibrary />
    </Container>
  </Section>
</BaseLayout>
